{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/withdraw/?$",
			"dest": "_render"
		},
		{
			"src": "^/chat/?$",
			"dest": "_render"
		},
		{
			"src": "^/data/?$",
			"dest": "_render"
		},
		{
			"src": "^/history/?$",
			"dest": "_render"
		},
		{
			"src": "^/lobby/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/music/?$",
			"dest": "_render"
		},
		{
			"src": "^/penarikan/?$",
			"dest": "_render"
		},
		{
			"src": "^/post/?$",
			"dest": "_render"
		},
		{
			"src": "^/saldo/?$",
			"dest": "_render"
		},
		{
			"src": "^/temp/?$",
			"dest": "_render"
		},
		{
			"src": "^/voice/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}