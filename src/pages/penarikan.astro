---
import Layout from '../layouts/Layout.astro';
import Header from '../components/withdraw/Headerwd.astro';
import InfoBox from '../components/withdraw/InfoBoxwd.astro';
import WithdrawForm from '../components/withdraw/WithdrawFormwd.astro';
---

<Layout title="Withdraw - HopeHype">
  <script is:inline src="/js/toast.js"></script>
  <link rel="stylesheet" href="/css/toast.css" />

  <div class="wd-container">
    <Header />

    <InfoBox />

    <WithdrawForm />
  </div>
</Layout>

<style is:global>
  /* Sesuai style lu sebelumnya, biarkan tetap begini */
  :root {
    --bg: #ffffff;
    --card-bg: #f9f9f9;
    --text-main: #000000;
    --text-muted: #8e8e93;
    --border: #f2f2f2;
    --accent-blue: #007bff;
  }
  .wd-container { 
    max-width: 480px; margin: 0 auto; padding: 40px 24px; height: 100vh;
    display: flex; flex-direction: column; font-family: 'Inter', sans-serif; 
    background: var(--bg); color: var(--text-main); 
  }
</style>
