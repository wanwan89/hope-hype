  box-shadow: 0 0 10px #00a2ff; 
}

.name {
    display: flex;
    align-items: center;
    gap: 6px; 
    white-space: nowrap; 
}

.verified {
    display: inline-flex;
    flex-shrink: 0; 
}

.overlay {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.actions {
    display: flex;
    align-items: center;
    justify-content: space-between; 
    margin-top: 12px;
    width: 100%;
}

.engagement-group {
    display: flex;
    gap: 15px;
    align-items: center;
}

/* =========================
   TIKTOK STYLE GIFT SHEET
========================= */
.gift-sheet {
  position: fixed;
  inset: 0;
  z-index: 99999;
  display: none;
}

.gift-sheet.active {
  display: block;
}

.gift-sheet-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(2px);
}

.gift-sheet-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72vh;
  background: var(--bg-modal);
  color: var(--text-main);
  border-radius: 22px 22px 0 0;
  transform: translateY(100%);
  transition: transform 0.32s ease;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  box-shadow: 0 -10px 40px rgba(0,0,0,0.4);
}

.gift-sheet.active .gift-sheet-panel {
  transform: translateY(0);
}

/* TOP BAR */
.gift-topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px 10px;
  font-size: 13px;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border-card);
}

.gift-pin-btn {
  background: transparent;
  border: none;
  color: #ff2d6f;
  font-weight: 700;
  font-size: 14px;
  cursor: pointer;
}

/* TARGET BAR */
.gift-target-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 16px;
}

.gift-target-left {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.gift-target-label {
  font-size: 13px;
  color: var(--text-muted);
}

.gift-target-name {
  font-size: 14px;
  font-weight: 700;
  color: var(--text-main);
}

.gift-balance-box {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-input);
  border-radius: 999px;
  padding: 8px 12px;
  font-size: 13px;
  font-weight: 700;
}

.coin-icon {
  font-size: 14px;
}

/* Container Utama */
.gift-sheet {
  position: fixed;
  inset: 0;
  z-index: 10000;
  display: none; 
  align-items: flex-end;
}

.gift-sheet.active {
  display: flex;
}

/* Konten Slide Up */
.gift-sheet-content {
  position: relative;
  width: 100%;
  background: var(--bg-modal);
  border-top: 1px solid var(--border-card);
  border-radius: 20px 20px 0 0;
  padding: 10px 15px 30px 15px;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  z-index: 10001;
}

.gift-sheet.active .gift-sheet-content {
  transform: translateY(0);
}

.sheet-handle {
  width: 40px;
  height: 4px;
  background: var(--border-card);
  border-radius: 2px;
  margin: 0 auto 15px auto;
}

.gift-header {
  display: flex;
  justify-content: space-between;
  color: var(--text-muted);
  font-size: 13px;
  margin-bottom: 20px;
}

.gift-close-x {
  font-size: 20px;
  cursor: pointer;
}

/* Grid & Item */
.gift-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.gift-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px;
  border-radius: 12px;
  border: 2px solid transparent;
  background: var(--bg-input);
  transition: 0.2s;
}

.gift-item.active {
  background: rgba(255, 45, 85, 0.1);
  border-color: #ff2d55;
}

.gift-img-container {
  width: 55px;
  height: 55px;
  margin-bottom: 5px;
}

.img-gift {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.gift-name { font-size: 11px; color: var(--text-main); }
.gift-price { font-size: 12px; color: #ffd700; display: flex; align-items: center; gap: 3px; }
.img-coin-inline { width: 12px; }

/* Footer */
.gift-footer {
  margin-top: 25px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 15px;
  border-top: 1px solid var(--border-card);
}

.user-coins-info {
  display: flex;
  align-items: center;
  gap: 5px;
  color: var(--text-main);
  font-weight: 600;
}

.img-coin-footer { width: 20px; }

.btn-send-gift {
  background: #ff2d55;
  color: white;
  border: none;
  padding: 10px 30px;
  border-radius: 25px;
  font-weight: bold;
  cursor: pointer;
}

.btn-send-gift:disabled { background: #333; color: #666; }
 
/* Efek Cahaya Meledak di Latar */
.glow-bg {
    position: absolute;
    width: 100px; height: 100px;
    background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,215,0,0) 70%);
    border-radius: 50%;
    animation: explodeGlow 2.5s ease-out forwards;
}

.meriah-text {
    font-family: 'Inter', sans-serif;
    font-size: 5rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -5px; 
    text-transform: uppercase;
    text-align: center;
    line-height: 1;
    filter: drop-shadow(0 0 20px rgba(255,255,255,0.5));
    animation: cinematicText 2.5s cubic-bezier(0.15, 0.85, 0.35, 1) forwards;
}

/* Animasi Cahaya Latar */
@keyframes explodeGlow {
    0% { transform: scale(0); opacity: 1; filter: blur(0px); }
    30% { transform: scale(30); opacity: 0.5; filter: blur(50px); }
    100% { transform: scale(50); opacity: 0; filter: blur(100px); }
}

/* Animasi Teks Utama */
@keyframes cinematicText {
    0% { transform: scale(0.5); letter-spacing: -20px; opacity: 0; filter: blur(20px) brightness(5); }
    15% { opacity: 1; filter: blur(0px) brightness(1.5); }
    25% { letter-spacing: 15px; }
    80% { opacity: 1; transform: scale(1.1); letter-spacing: 20px; filter: blur(0px) brightness(1); }
    100% { transform: scale(1.5); opacity: 0; filter: blur(15px) brightness(2); letter-spacing: 30px; }
}

@media (max-width: 768px) {
    .meriah-text { font-size: 1.5rem; letter-spacing: -2px; }
}

/* =========================================
   ANIMASI SMOOTH GAYA TIKTOK
   ========================================= */

#giftAnimationContainer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none; 
  z-index: 999999; 
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden; 
}

.gift-main-img {
  width: 320px; 
  height: auto;
  filter: drop-shadow(0 0 30px rgba(255, 215, 0, 0.7));
  opacity: 0;
  transform: scale(0.5) rotate(-15deg); 
  animation: tiktokPopIn 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes tiktokPopIn {
  0% { opacity: 0; transform: scale(0.5) rotate(-15deg); }
  40% { opacity: 1; transform: scale(1.1) rotate(5deg); }
  100% { opacity: 1; transform: scale(1) rotate(0deg); }
}

.gift-mini-icon {
  position: absolute;
  width: 60px; 
  height: auto;
  opacity: 0;
  animation: tiktokFloatUp 2.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes tiktokFloatUp {
  0% { opacity: 0; transform: translateY(100vh) rotate(0deg) scale(0.8); }
  15% { opacity: 1; transform: translateY(80vh) rotate(10deg) scale(1); }
  80% { opacity: 1; }
  100% { opacity: 0; transform: translateY(-20vh) rotate(360deg) scale(1.1); }
}

.gift-item.selected-gift {
  border: 2px solid #ff4757 !important; 
  background: rgba(255, 71, 87, 0.1) !important;
  transform: scale(1.05); 
  box-shadow: 0 0 15px rgba(255, 71, 87, 0.3);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.gift-item.selected-gift img {
  animation: bounceMini 0.4s ease;
}

@keyframes bounceMini {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.gift-item:hover {
  background: var(--border-card);
  transform: translateY(-3px);
}

.sidebar-post-btn {
  width: 100%;
  border: none;
  outline: none;
  cursor: pointer;
  margin-top: 10px;
  padding: 14px 16px;
  border-radius: 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 600;
  text-align: left;
  background: #2d79f3;
  color: white;
  box-shadow: 0 8px 20px rgba(45, 121, 243, 0.25);
  transition: all 0.25s ease;
}

.sidebar-post-btn:hover {
  background: #256de0;
  transform: translateY(-2px);
  box-shadow: 0 12px 24px rgba(45, 121, 243, 0.35);
}

.sidebar-post-btn:active {
  transform: scale(0.98);
  background: #1f63cf;
}

/* =======================
   POST MODAL
======================= */
.post-modal {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 999999;
  padding: 20px;
}

.post-modal.active {
  display: flex;
}

.post-modal-content {
  width: 100%;
  max-width: 460px;
  background: var(--bg-modal);
  border-radius: 18px;
  padding: 22px;
  position: relative;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
  animation: postFadeUp 0.18s ease;
}

@keyframes postFadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.post-close-btn {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 34px;
  height: 34px;
  border: none;
  border-radius: 50%;
  background: var(--bg-input);
  color: var(--text-main);
  font-size: 20px;
  cursor: pointer;
  transition: 0.2s ease;
}

.post-close-btn:hover {
  background: var(--border-card);
}

.post-modal-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 4px;
}

.post-modal-subtitle {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 18px;
  line-height: 1.5;
}

.post-form {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.post-upload-area {
  border: 1.5px dashed var(--border-card);
  border-radius: 14px;
  background: var(--bg-input);
  min-height: 190px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  overflow: hidden;
  position: relative;
  transition: 0.2s ease;
}

.post-upload-area:hover {
  border-color: #2d79f3;
}

.post-upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-align: center;
  padding: 20px;
}

.post-upload-text {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
}

.post-upload-placeholder small {
  font-size: 12px;
  color: var(--text-muted);
}

.post-preview-image {
  width: 100%;
  height: 100%;
  max-height: 300px;
  object-fit: cover;
  display: block;
}

.post-textarea {
  width: 100%;
  min-height: 100px;
  resize: none;
  border: 1px solid var(--border-card);
  border-radius: 12px;
  padding: 13px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  outline: none;
  color: var(--text-main);
  background: var(--bg-input);
  transition: 0.2s ease;
}

.post-textarea::placeholder {
  color: var(--text-muted);
}

.post-textarea:focus {
  border-color: #2d79f3;
  box-shadow: 0 0 0 3px rgba(45, 121, 243, 0.12);
}

.post-select {
  width: 100%;
  border: 1px solid var(--border-card);
  border-radius: 12px;
  padding: 13px 14px;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  outline: none;
  background: var(--bg-input);
  color: var(--text-main);
  transition: 0.2s ease;
}

.post-select:focus {
  border-color: #2d79f3;
  box-shadow: 0 0 0 3px rgba(45, 121, 243, 0.12);
}

.post-submit-btn {
  border: none;
  background: #2d79f3;
  color: #fff;
  font-family: 'Poppins', sans-serif;
  font-size: 14px;
  font-weight: 600;
  padding: 14px;
  border-radius: 12px;
  cursor: pointer;
  transition: 0.2s ease;
}

.post-submit-btn:hover {
  background: #256de0;
}

.post-submit-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

@media (max-width: 600px) {
  .post-modal {
    align-items: flex-end;
    padding: 0;
  }

  .post-modal-content {
    max-width: 100%;
    width: 100%;
    border-radius: 18px 18px 0 0;
    padding: 20px 16px;
  }

  .post-upload-area {
    min-height: 170px;
  }
}

/* =========================================
   CUSTOM DROPUP CATEGORY
   ========================================= */

.custom-select-container {
  position: relative;
  width: 100%;
  margin: 15px 0;
  font-family: 'Poppins', sans-serif;
}

.select-trigger {
  width: 100%;
  background: var(--bg-input); 
  color: var(--text-main);
  padding: 14px 18px;
  border: 1px solid var(--border-card);
  border-radius: 12px;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 14px;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.select-trigger:hover {
  border-color: #2d79f3; 
}

.arrow-icon {
  font-size: 12px;
  color: var(--text-muted);
  transition: transform 0.3s ease;
}

.custom-select-container.active .select-trigger {
  border-color: #2d79f3;
  box-shadow: 0 0 0 3px rgba(45, 121, 243, 0.15);
}

.custom-select-container.active .arrow-icon {
  transform: rotate(180deg); 
}

.select-options-list {
  display: none; 
  position: absolute;
  bottom: calc(100% + 10px); 
  left: 0;
  right: 0;
  background: var(--bg-modal);
  border: 1px solid var(--border-card);
  border-radius: 14px;
  z-index: 999999; 
  max-height: 220px;
  overflow-y: auto;
  box-shadow: 0 -12px 30px rgba(0,0,0,0.6); 
  padding: 6px;
  box-sizing: border-box;
}

.custom-select-container.active .select-options-list {
  display: block !important;
  animation: dropUpAnim 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  color: var(--text-main);
  cursor: pointer;
  border-radius: 10px;
  font-size: 14px;
  transition: all 0.2s ease;
  margin-bottom: 2px;
}

.option-item:last-child {
  margin-bottom: 0;
}

.option-item:hover {
  background: #2d79f3;
  color: #fff;
}

.option-item.selected {
  background: rgba(45, 121, 243, 0.15);
  color: #2d79f3;
  font-weight: 600;
}

.option-item.selected::after {
  content: '✓';
  font-size: 12px;
}

@keyframes dropUpAnim {
  from { opacity: 0; transform: translateY(15px); }
  to { opacity: 1; transform: translateY(0); }
}

.select-options-list::-webkit-scrollbar {
  width: 5px;
}

.select-options-list::-webkit-scrollbar-track {
  background: transparent;
}

.select-options-list::-webkit-scrollbar-thumb {
  background: var(--border-card);
  border-radius: 10px;
}

* {
    -webkit-tap-highlight-color: transparent;
    outline: none;
}

.menu-item-tiktok, .btn, .tab, button {
    -webkit-tap-highlight-color: rgba(0,0,0,0);
    user-select: none; 
}

/* Container Skeleton */
.skeleton-wrapper {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
  width: 100%;
}

.skeleton-card {
  background: var(--bg-card);
  border-radius: 20px;
  height: 400px; 
  position: relative;
  overflow: hidden;
  border: 1px solid var(--border-card);
}

.skeleton-card::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  transform: translateX(-100%);
  background-image: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0) 0,
    rgba(255, 255, 255, 0.05) 20%,
    rgba(255, 255, 255, 0.1) 60%,
    rgba(255, 255, 255, 0)
  );
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  100% { transform: translateX(100%); }
}

.skeleton-info {
