      <a href="#" class="nav-item" data-category="karya">Karya</a>
      <a href="#" class="nav-item" data-category="prestasi">Prestasi</a>
      <a href="#" class="nav-item" data-category="photography">Photography</a>
      <a href="#" class="nav-item" data-category="mountain">Mountain</a>

