@keyframes popupFade {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* BUTTON */ 
.Btn {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 45px;
  height: 45px;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition-duration: 0.3s;
  box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.199);
  background-color: white;
}

.sign {
  width: 100%;
  transition-duration: 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sign svg {
  width: 17px;
}

.sign svg path {
  fill: black;
}

.text {
  position: absolute;
  right: 0%;
  width: 0%;
  opacity: 0;
  color: white;
  font-size: 1.2em;
  font-weight: 600;
  transition-duration: 0.3s;
}

.Btn:hover {
  background-color: blue;
  width: 125px;
  border-radius: 40px;
  transition-duration: 0.3s;
}

.Btn:hover .sign {
  width: 30%;
  transition-duration: 0.3s;
  padding-left: 20px;
}

.Btn:hover .sign svg path {
  fill: white;
}

.Btn:hover .text {
  opacity: 1;
  width: 70%;
  transition-duration: 0.3s;
  padding-right: 10px;
}

.Btn:active {
  transform: translate(2px, 2px);
}

/* ========NOTIF SIMPEL ============ */
#notif {
  position: fixed;
  top: 20px;
  right: -300px; 
  background-color: #4facfe;
  color: white;
  padding: 12px 20px;
  border-radius: 10px;
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  font-weight: 500;
  opacity: 0;
  transition: all 0.4s ease;
  z-index: 9999;
}

#notif.show {
  right: 20px;
  opacity: 1;
}

#notif.hide {
  right: -300px;
  opacity: 0;
}

.admin-badge{
  font-size:9px;
  color:white;
  padding:1px 4px;
  border-radius:4px;
  margin-left:4px;
  font-weight:600;
  animation: rgbGlow 3s linear infinite;
}

@keyframes rgbGlow{
  0%{ background: rgb(255,0,0); }
  33%{ background: rgb(0,255,0); }
  66%{ background: rgb(0,0,255); }
  100%{ background: rgb(255,0,0); }
}

.toast-notification {
  position: fixed;
  top: 20px;      
  left: 20px;      
  background: #4facfe; 
  color: white;
  padding: 10px 15px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  opacity: 0;
  transform: translateY(-20px); 
  transition: all 0.3s ease;
  z-index: 9999;
}

.toast-notification.show {
  opacity: 1;
  transform: translateY(0);
}

.toast-notification.success {
  background: #4facfe;
}

.toast-notification.error {
  background: #ff4757;
}

/* --- Sidebar Premium --- */
.sidebar {
  position: fixed;
  top: 0;
  left: 0;
  width: 280px;
  height: 100vh;
  background: var(--bg-card); /* Supaya sidebar menyesuaikan mode */
  border-right: 1px solid var(--border-card);
  z-index: 2000;
  transform: translateX(-100%);
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  padding: 60px 30px;
  box-sizing: border-box;
}

.sidebar.active {
  transform: translateX(0);
}

.sidebar-logo {
  color: var(--text-main);
  font-size: 1rem;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 5px; 
  margin-bottom: 60px;
  opacity: 0.8;
}

/* --- Nav Item --- */
.nav-item {
  display: block;
  padding: 12px 0;
  color: var(--text-main);
  text-decoration: none;
  font-size: 1.1rem;
  font-weight: 300; 
  margin-bottom: 20px;
  transition: 0.4s;
  opacity: 0.6; 
}

.nav-item:hover {
  opacity: 1;
  color: #00a2ff;
  letter-spacing: 2px; 
}

.nav-item.active {
  opacity: 1;
