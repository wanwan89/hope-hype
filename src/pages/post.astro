---
// 1. IMPORT COMPONENTS
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/layout/Sidebarpost.astro';
import SearchWrapper from '../components/layout/SearchWrapperpost.astro';
import Gallery from '../components/post/Gallerypost.astro';
import CommentModal from '../components/post/CommentModalpost.astro';
import LoginPopup from '../components/auth/LoginPopuppost.astro';
import PostModal from '../components/post/PostModal.astro';
import GiftSheet from '../components/post/GiftSheetpost.astro';
import Overlays from '../components/ui/Overlayspost.astro';
---

<Layout title="Creator Gallery - Hope POST">
  
  <script is:inline>
    (function() {
      try {
        const theme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (theme === 'dark' || (!theme && prefersDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        window.addEventListener('storage', (e) => {
          if (e.key === 'theme') {
            if (e.newValue === 'dark') {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
          }
        });
      } catch (e) {}
    })();
  </script>

  <Sidebar />
  <SearchWrapper />
  <Gallery />
  <CommentModal />
  <LoginPopup />
  <PostModal />
  <GiftSheet />
  <Overlays />

</Layout>

<style is:global>
/* === CSS VARIABLES LIGHT & DARK MODE === */
:root {
  --bg-main: #f0f2f5;
  --text-main: #1c1e21;
  --bg-card: #ffffff;
  --border-card: #dddfe2;
  --text-muted: #606770;
  --bg-modal: #ffffff;
  --bg-input: #f0f2f5;
  --icon-fill: #1c1e21;
  --bg-secondary: #e4e6eb; 
  --accent-story: linear-gradient(45deg, #00ffa3, #03e1ff); /* Warna ciri khas Hype */
  --bg-story-seen: #dddfe2;
}

html.dark {
  --bg-main: #121212;
  --text-main: #e0e0e0;
  --bg-card: #1e1e1e;
  --border-card: #2c2c2c;
  --text-muted: #888888;
  --bg-modal: #111111;
  --bg-input: #1d1d1d;
  --icon-fill: #e0e0e0;
  --bg-secondary: #242526;
  --bg-story-seen: #2c2c2c;
}

/* === RESET GLOBAL === */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  -webkit-tap-highlight-color: transparent;
  outline: none;
}

body { 
  font-family: 'Poppins', sans-serif; 
  background: var(--bg-main); 
  color: var(--text-main); 
  transition: background 0.3s ease, color 0.3s ease;
}

.menu-item-tiktok, .btn, .tab, button {
  -webkit-tap-highlight-color: rgba(0,0,0,0);
  user-select: none; 
}
</style>
