/* Efek Cahaya Meledak di Latar */
.glow-bg {
    position: absolute;
    width: 100px; height: 100px;
    background: radial-gradient(circle, rgba(255,255,255,0.8) 0%, rgba(255,215,0,0) 70%);
    border-radius: 50%;
    animation: explodeGlow 2.5s ease-out forwards;
}

.meriah-text {
    font-family: 'Inter', sans-serif;
    font-size: 5rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -5px; /* Awalnya rapet banget */
    text-transform: uppercase;
    text-align: center;
    line-height: 1;
    
    /* Efek Bayangan Cinematic */
    filter: drop-shadow(0 0 20px rgba(255,255,255,0.5));
    
    /* Animasi Teks Meledak */
    animation: cinematicText 2.5s cubic-bezier(0.15, 0.85, 0.35, 1) forwards;
}

/* Animasi Cahaya Latar */
@keyframes explodeGlow {
    0% { transform: scale(0); opacity: 1; filter: blur(0px); }
    30% { transform: scale(30); opacity: 0.5; filter: blur(50px); }
    100% { transform: scale(50); opacity: 0; filter: blur(100px); }
}

/* Animasi Teks Utama */
@keyframes cinematicText {
    0% { 
        transform: scale(0.5); 
        letter-spacing: -20px; 
        opacity: 0; 
        filter: blur(20px) brightness(5);
    }
    15% { 
        opacity: 1; 
        filter: blur(0px) brightness(1.5);
    }
    25% {
        letter-spacing: 15px; /* Hurufnya merenggang drastis */
    }
    80% { 
        opacity: 1; 
        transform: scale(1.1);
        letter-spacing: 20px;
        filter: blur(0px) brightness(1);
    }
    100% { 
        transform: scale(1.5); 
        opacity: 0; 
        filter: blur(15px) brightness(2);
        letter-spacing: 30px;
    }
}

/* Biar gak aneh di HP */
@media (max-width: 768px) {
    .meriah-text { font-size: 1.5rem; letter-spacing: -2px; }
}
/* =========================================
   ANIMASI SMOOTH GAYA TIKTOK
   ========================================= */

/* 1. Wrapper Utama (Memastikan di Tengah & Di Atas Semuanya) */
#giftAnimationContainer {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none; /* Penting! Supaya nggak menghalangi klik setelah animasi */
  z-index: 999999; /* Sangat tinggi */
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden; /* Sembunyikan elemen yang keluar layar */
}

/* 2. Gambar Utama (Gede di Tengah) */
.gift-main-img {
  width: 320px; /* Sedikit lebih gede biar bombastis */
  height: auto;
  filter: drop-shadow(0 0 30px rgba(255, 215, 0, 0.7));
  opacity: 0;
  transform: scale(0.5) rotate(-15deg); /* Start: Kecil, miring, transparan */
  
  /* Animasi Masuk: Halus & Sedikit Membal */
  animation: tiktokPopIn 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes tiktokPopIn {
  0% { 
    opacity: 0; 
    transform: scale(0.5) rotate(-15deg); 
  }
  40% { 
    opacity: 1; 
    transform: scale(1.1) rotate(5deg); /* Sedikit membesar */
  }
  100% { 
    opacity: 1; 
    transform: scale(1) rotate(0deg); /* Kembali normal */
  }
}

/* 3. Floating Icons (Hujan Gift) */
.gift-mini-icon {
  position: absolute;
  width: 60px; /* Ukuran ikon mini */
  height: auto;
  opacity: 0;
  
  /* Animasi Meluncur: Halus & Cepat */
  animation: tiktokFloatUp 2.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes tiktokFloatUp {
  0% { 
    opacity: 0; 
    transform: translateY(100vh) rotate(0deg) scale(0.8); /* Start: Di bawah layar */
  }
  15% { 
    opacity: 1; 
    transform: translateY(80vh) rotate(10deg) scale(1); /* Mulai muncul */
  }
  80% { 
    opacity: 1; /* Tetap muncul saat di tengah */
  }
  100% { 
    opacity: 0; 
    transform: translateY(-20vh) rotate(360deg) scale(1.1); /* End: Di atas layar, muter, hilang */
  }
