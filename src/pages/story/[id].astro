---
// src/pages/story/[id].astro
import Layout from '../../layouts/Layout.astro';
const { id } = Astro.params;
---

<Layout title="Hype Story">
  <div class="story-full-viewer" id="viewerContainer">
    <div class="story-progress-container">
      <div class="story-progress-bar" id="progressBar"></div>
    </div>

    <div class="story-top-info">
      <div class="story-user">
        <img id="storyAvatar" src="https://ui-avatars.com/api/?name=..." class="s-avatar" />
        <span id="storyUser">Memuat...</span>
      </div>
      <button class="close-story" onclick="history.back()">×</button>
    </div>

    <div class="story-display">
      <div id="loader" class="loader"></div>
      
      <img id="storyImage" src="" class="s-img" style="display:none;" />
      <div id="storyTextOnly" class="s-text" style="display:none;"></div>
    </div>

    <div class="story-bottom-info">
      <p id="storyCaption"></p>
    </div>
  </div>

  <script>
    import { supabase } from '../../lib/supabase.js';

    // Ambil ID dari URL secara manual karena is:inline dihapus
    const storyId = window.location.pathname.split('/').pop();

    async function loadDetailStory() {
      const { data, error } = await supabase
        .from('stories')
        .select('*, profiles(username, avatar_url)')
        .eq('id', storyId)
        .single();

      if (error) {
        console.error("Error:", error);
        alert("Cerita tidak ditemukan atau sudah dihapus.");
        history.back();
        return;
      }

      if (data) {
        // Sembunyikan loader
        document.getElementById('loader').style.display = 'none';

        // Set Data User
        document.getElementById('storyUser').innerText = data.profiles.username;
        if(data.profiles.avatar_url) {
          document.getElementById('storyAvatar').src = data.profiles.avatar_url;
        }
        
        // Cek Foto atau Teks
        if (data.image_url) {
          const img = document.getElementById('storyImage');
          img.src = data.image_url;
          img.style.display = 'block';
        } else {
          const txt = document.getElementById('storyTextOnly');
          txt.innerText = data.content;
          txt.style.display = 'flex';
          // Kalau teks doang, kasih background warna dikit biar keren
          document.getElementById('viewerContainer').style.background = 'linear-gradient(45deg, #121212, #333)';
        }
        
        document.getElementById('storyCaption').innerText = data.content || "";
        
        // Timer otomatis balik setelah 5 detik
        setTimeout(() => {
          // Cek kalau masih di halaman story, baru balik
          if(window.location.pathname.includes('/story/')) {
            history.back();
          }
        }, 5000);
      }
    }

    loadDetailStory();
  </script>
</Layout>

<style>
  .story-full-viewer {
    position: fixed;
    inset: 0;
    background: #000;
    display: flex;
    flex-direction: column;
    z-index: 10000;
    color: white;
    font-family: 'Poppins', sans-serif;
  }

  .story-progress-container {
    padding: 15px 10px 5px;
    display: flex;
  }

  .story-progress-bar {
    height: 3px;
    background: #fff;
    flex: 1;
    border-radius: 10px;
    animation: progressLinear 5s linear forwards;
    transform-origin: left;
    box-shadow: 0 0 10px rgba(255,255,255,0.5);
  }

  @keyframes progressLinear {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .story-top-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 15px;
  }

  .story-user {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .s-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 2px solid #fff;
    object-fit: cover;
  }

  #storyUser {
    font-weight: 700;
    font-size: 15px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .close-story {
    background: none;
    border: none;
    color: white;
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
    opacity: 0.8;
  }

  .story-display {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .loader {
    border: 3px solid rgba(255,255,255,0.1);
    border-top: 3px solid #fff;
    border-radius: 50%;
    width: 30px;
    height: 30px;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .s-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .s-text {
    padding: 40px;
    text-align: center;
    font-size: 26px;
    font-weight: 700;
    line-height: 1.4;
  }

  .story-bottom-info {
    padding: 40px 20px;
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    text-align: center;
  }

  #storyCaption {
    font-size: 14px;
    opacity: 0.9;
    max-width: 80%;
    margin: 0 auto;
  }
</style>
