---
// src/pages/story/[id].astro
import Layout from '../../layouts/Layout.astro';
const { id } = Astro.params;
---

<Layout title="Hype Story">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

  <div class="story-full-viewer" id="viewerContainer">
    
    <div class="tap-area">
      <div class="tap-left" id="btnBack"></div>
      <div class="tap-right" id="btnSkip"></div>
    </div>

    <div class="story-progress-container" id="progContainer">
      </div>

    <div class="story-top-info">
      <div class="story-user">
        <img id="storyAvatar" src="https://ui-avatars.com/api/?name=..." class="s-avatar" />
        <div class="user-meta">
          <span id="storyUser">Memuat...</span>
          <span id="storyTime" class="story-time"></span>
        </div>
      </div>
      <button class="close-story" onclick="history.back()">×</button>
    </div>

    <div class="story-display">
      <div id="loader" class="loader"></div>
      
      <div id="musicTag" class="music-tag" style="display:none;">
        <span class="material-icons" style="font-size:14px; color: white;">music_note</span>
        <marquee id="musicTitle" scrollamount="3" class="marquee-text"></marquee>
      </div>

      <img id="storyImage" src="" class="s-img" style="display:none;" draggable="false" />
      <div id="storyTextOnly" class="s-text" style="display:none;"></div>
    </div>

    <div class="story-bottom-info">
      <div class="footer-layout">
        <div class="story-actions-left">
          <button id="likeStoryBtn" class="story-like-btn">
            <svg viewBox="0 0 24 24" id="heartIcon" class="heart-svg">
              <path d="M12.1 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3 9.24 3 10.91 3.81 12 5.09 13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5 22 12.28 18.6 15.36 13.55 20.04z"/>
            </svg>
          </button>
        </div>

        <div class="caption-container">
          <p id="storyCaption" class="story-caption"></p>
        </div>
      </div>
    </div>

    <audio id="storyAudio" preload="auto"></audio>
  </div>

  <script>
    import { supabase } from '../../lib/supabase.js';

    const pathParts = window.location.pathname.split('/');
    const storyId = pathParts[pathParts.length - 1];
    
    let allUserStories = [];
    let currentIndex = 0;
    let timer = null;
    let currentUserId = null;
    const STORY_DURATION = 7000; // 7 Detik

    async function initMultiStory() {
      const { data: { session } } = await supabase.auth.getSession();
      currentUserId = session?.user?.id;

      // Ambil creator dari ID story awal
      const { data: initStory } = await supabase.from('stories').select('creator_id').eq('id', storyId).single();
      if (!initStory) return history.back();

      // Ambil semua story user tersebut (24 jam terakhir)
      const timeLimit = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
      const { data: stories } = await supabase
        .from('stories')
        .select('*, profiles(username, avatar_url)')
        .eq('creator_id', initStory.creator_id)
        .gte('created_at', timeLimit)
        .order('created_at', { ascending: true });

      if (stories && stories.length > 0) {
        allUserStories = stories;
        currentIndex = allUserStories.findIndex(s => s.id == storyId);
        if (currentIndex === -1) currentIndex = 0;
        
        createProgressBars();
        renderCurrentStory();
      }
    }

    function createProgressBars() {
      const container = document.getElementById('progContainer');
      container.innerHTML = '';
      allUserStories.forEach((_, index) => {
        const wrap = document.createElement('div');
        wrap.className = 'bar-wrap';
        wrap.innerHTML = `<div class="bar-inner" id="bar-${index}"></div>`;
        container.appendChild(wrap);
      });
    }

    function updateProgressBars() {
      allUserStories.forEach((_, index) => {
        const bar = document.getElementById(`bar-${index}`);
        if (!bar) return;

        // Reset total
        bar.style.animation = 'none';
        bar.style.transform = 'scaleX(0)';
        
        if (index < currentIndex) {
          // Sudah lewat: penuh
          bar.style.transform = 'scaleX(1)';
        } else if (index === currentIndex) {
          // Sedang jalan: animasikan
          void bar.offsetWidth; // Force Reflow (PENTING BIAR ANIMASI JALAN)
          bar.style.animation = `progressLinear ${STORY_DURATION/1000}s linear forwards`;
        }
      });
    }

    function renderCurrentStory() {
      const story = allUserStories[currentIndex];
      const audio = document.getElementById('storyAudio');
      const musicTag = document.getElementById('musicTag');
      const loader = document.getElementById('loader');
      const imgEl = document.getElementById('storyImage');
      const txtEl = document.getElementById('storyTextOnly');
      
      loader.style.display = 'block';
      imgEl.style.display = 'none';
      txtEl.style.display = 'none';

      document.getElementById('storyUser').innerText = story.profiles.username;
      document.getElementById('storyAvatar').src = story.profiles.avatar_url || `https://ui-avatars.com/api/?name=${story.profiles.username}`;
      
      const createdDate = new Date(story.created_at);
      document.getElementById('storyTime').innerText = createdDate.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
      document.getElementById('storyCaption').innerText = story.content || "";

      if (story.image_url) {
        imgEl.src = story.image_url;
        imgEl.style.display = 'block';
        imgEl.onload = () => loader.style.display = 'none';
      } else {
        loader.style.display = 'none';
        txtEl.innerText = story.content;
        txtEl.style.display = 'flex';
      }

      // Logic Audio & Music Tag
      if (story.audio_src) {
        audio.src = story.audio_src;
        audio.load();
        audio.play()
          .then(() => {
            musicTag.style.display = 'flex';
            document.getElementById('musicTitle').innerText = `${story.title || 'Untitled'} - ${story.artist || 'Unknown'}`;
          })
          .catch(() => {
            // Jika autoplay diblokir browser, tampilkan tag tapi minta klik
            musicTag.style.display = 'flex';
            document.getElementById('musicTitle').innerText = "Ketuk untuk suara...";
          });
      } else {
        audio.pause();
        audio.src = "";
        musicTag.style.display = 'none';
      }

      checkIfLiked(story.id);
      updateProgressBars();
      resetTimer();
    }

    function resetTimer() {
      clearTimeout(timer);
      timer = setTimeout(nextStory, STORY_DURATION);
    }

    function nextStory() {
      if (currentIndex < allUserStories.length - 1) {
        currentIndex++;
        renderCurrentStory();
      } else {
        history.back();
      }
    }

    function prevStory() {
      if (currentIndex > 0) {
        currentIndex--;
        renderCurrentStory();
      } else {
        currentIndex = 0;
        renderCurrentStory();
      }
    }

    async function checkIfLiked(sId) {
      const heart = document.getElementById('heartIcon');
      heart.classList.remove('liked');
      if (!currentUserId) return;
      const { data } = await supabase.from('story_likes').select('id').match({ story_id: sId, user_id: currentUserId }).single();
      if (data) heart.classList.add('liked');
    }

    // Listener Ketuk Layar
    document.getElementById('btnSkip').onclick = () => nextStory();
    document.getElementById('btnBack').onclick = () => prevStory();

    // Listener Like
    document.getElementById('likeStoryBtn').onclick = async (e) => {
      e.stopPropagation();
      if (!currentUserId) return alert("Login dulu bro!");
      const sId = allUserStories[currentIndex].id;
      const heart = document.getElementById('heartIcon');
      
      if (heart.classList.contains('liked')) {
        heart.classList.remove('liked');
        await supabase.from('story_likes').delete().match({ story_id: sId, user_id: currentUserId });
      } else {
        heart.classList.add('liked');
        if (navigator.vibrate) navigator.vibrate(50);
        await supabase.from('story_likes').insert({ story_id: sId, user_id: currentUserId });
      }
    };

    initMultiStory();
  </script>
</Layout>

<style>
  .story-full-viewer {
    position: fixed; inset: 0; background: #000;
    display: flex; flex-direction: column; z-index: 10000;
    color: white; font-family: 'Poppins', sans-serif; overflow: hidden;
    /* FIX BUG 2: Ilangin warna biru pas klik area di HP */
    -webkit-tap-highlight-color: transparent;
  }

  .tap-area { position: absolute; inset: 0; display: flex; z-index: 10001; }
  .tap-left { width: 35%; height: 100%; }
  .tap-right { width: 65%; height: 100%; }

  /* FIX BUG 4: Progress Bar Tersegmentasi (Kayak IG) */
  .story-progress-container { 
    padding: 15px 10px 5px; 
    display: flex; 
    gap: 4px; /* Jarak antar bar */
    z-index: 10005; 
  }
  .bar-wrap {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.3);
    border-radius: 10px;
    overflow: hidden;
  }
  .bar-inner {
    height: 100%;
    width: 100%;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
  }
  @keyframes progressLinear { 
    from { transform: scaleX(0); } 
    to { transform: scaleX(1); } 
  }

  /* TOP INFO */
  .story-top-info { display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; z-index: 10005; }
  .story-user { display: flex; align-items: center; gap: 12px; }
  .s-avatar { width: 40px; height: 40px; border-radius: 50%; border: 2px solid #fff; object-fit: cover; }
  .user-meta { display: flex; flex-direction: column; }
  #storyUser { font-weight: 700; font-size: 14px; }
  .story-time { font-size: 11px; opacity: 0.6; }
  .close-story { background: none; border: none; color: white; font-size: 35px; cursor: pointer; z-index: 10008; }

  /* CONTENT DISPLAY */
  .story-display { 
    flex: 1; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    position: relative; 
    overflow: hidden; /* FIX BUG 5: Cegah gambar tinggi nembus layout */
  }
  .s-img { 
    max-width: 100%; 
    max-height: 100%; 
    object-fit: contain; /* Biar foto asli tetep utuh */
  }
  /* FIX BUG 1: Teks Center Vertikal & Horizontal */
  .s-text { 
    width: 100%; height: 100%;
    padding: 40px; 
    text-align: center; 
    font-size: 26px; 
    font-weight: 700; 
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .loader { border: 3px solid rgba(255,255,255,0.1); border-top: 3px solid #fff; border-radius: 50%; width: 35px; height: 35px; animation: spin 1s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* FIX BUG 3: Icon musik Material Design */
  .music-tag {
    position: absolute; bottom: 20px; left: 20px;
    background: rgba(0,0,0,0.6); padding: 6px 12px;
    border-radius: 20px; display: flex; align-items: center; gap: 8px;
    max-width: 220px; border: 1px solid rgba(255,255,255,0.2);
    z-index: 10006;
  }
  #musicTitle { font-size: 11px; font-weight: 600; width: 160px; color: white; }

  /* FOOTER */
  .story-bottom-info {
    padding: 30px 20px; 
    background: linear-gradient(to top, rgba(0,0,0,0.95), transparent);
    z-index: 10005;
  }
  .footer-layout { display: flex; align-items: center; gap: 15px; }
  .story-caption { font-size: 14px; text-align: left; opacity: 0.9; margin: 0; }

  .story-like-btn { background: none; border: none; cursor: pointer; padding: 5px; z-index: 10008; }
  .heart-svg {
    width: 32px; height: 32px; fill: none; stroke: #fff; stroke-width: 2;
    transition: all 0.2s ease;
  }
  .heart-svg.liked { fill: #ff2d55; stroke: #ff2d55; transform: scale(1.1); }
</style>
