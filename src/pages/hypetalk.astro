---
// src/pages/hypetalk.astro
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Hypetalk - Obrolan</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  
  <script>
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  </script>
</head>
<body>

  <div class="telegram-wrapper">
    
    <header class="tg-header">
      <div class="tg-header-top">
        <div class="tg-header-left">
          <button class="icon-btn menu-btn" onclick="window.location.href='/'">
            <span class="material-icons">arrow_back</span>
          </button>
          <h2>Hypetalk</h2>
        </div>
        <button class="icon-btn more-btn">
          <span class="material-icons">more_vert</span>
        </button>
      </div>

      <div class="tg-search-container">
        <div class="tg-search-box">
          <span class="material-icons">search</span>
          <input type="text" id="searchChat" placeholder="Cari teman atau obrolan..." autocomplete="off" />
        </div>
      </div>
    </header>

    <main class="tg-chat-list" id="chatList">
      <div class="loading-state">
        <span class="material-icons loading-spinner">sync</span>
        <p>Memuat obrolan...</p>
      </div>
    </main>

    <button class="tg-fab" onclick="window.location.href='/'">
      <span class="material-icons">edit</span>
    </button>

  </div>

  <style is:global>
    @keyframes spin { 100% { transform: rotate(360deg); } }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    
    body { background: #e5e7eb; display: flex; justify-content: center; height: 100dvh; overflow: hidden; transition: background 0.3s ease; }
    html.dark body { background: #000000; color: #fff; }

    /* WRAPPER UTAMA */
    .telegram-wrapper { 
      width: 100%; 
      max-width: 480px; 
      height: 100dvh; 
      display: flex; 
      flex-direction: column; 
      background: #ffffff; 
      position: relative; 
      box-shadow: 0 0 20px rgba(0,0,0,0.05); 
      transition: background 0.3s ease; 
    }
    html.dark .telegram-wrapper { background: #15171a; box-shadow: none; border-left: 1px solid #22252a; border-right: 1px solid #22252a; }

    /* HEADER KEKINIAN DENGAN BLUR */
    .tg-header { 
      background: rgba(255, 255, 255, 0.85); 
      backdrop-filter: blur(12px); 
      -webkit-backdrop-filter: blur(12px); 
      padding-top: 10px; 
      z-index: 10; 
      transition: background 0.3s ease, border-color 0.3s ease; 
      border-bottom: 1px solid rgba(0,0,0,0.05);
    }
    html.dark .tg-header { background: rgba(21, 23, 26, 0.85); border-bottom: 1px solid rgba(255,255,255,0.05); }

    .tg-header-top { display: flex; align-items: center; justify-content: space-between; padding: 10px 20px; }
    .tg-header-left { display: flex; align-items: center; gap: 16px; }
    .tg-header-left h2 { font-size: 22px; font-weight: 700; color: #111827; letter-spacing: -0.5px; transition: color 0.3s ease; }
    html.dark .tg-header-left h2 { color: #f9fafb; }

    .icon-btn { background: none; border: none; color: #4b5563; cursor: pointer; display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; transition: all 0.2s ease; }
    .icon-btn:active { background: rgba(0,0,0,0.05); transform: scale(0.95); }
    html.dark .icon-btn { color: #9ca3af; }
    html.dark .icon-btn:active { background: rgba(255,255,255,0.05); }

    /* SEARCH BAR PREMIUM */
    .tg-search-container { padding: 4px 20px 16px; }
    .tg-search-box { 
      display: flex; align-items: center; background: #f3f4f6; border-radius: 14px; padding: 10px 16px; gap: 12px; 
      transition: all 0.3s ease; border: 1px solid transparent;
    }
    .tg-search-box:focus-within { background: #ffffff; border-color: #1DA1F2; box-shadow: 0 4px 12px rgba(29, 161, 242, 0.1); }
    html.dark .tg-search-box { background: #1f2226; }
    html.dark .tg-search-box:focus-within { background: #15171a; border-color: #1DA1F2; }
    
    .tg-search-box .material-icons { color: #9ca3af; font-size: 20px; transition: color 0.3s; }
    .tg-search-box:focus-within .material-icons { color: #1DA1F2; }
    .tg-search-box input { flex: 1; border: none; background: transparent; outline: none; font-size: 15px; color: #111827; transition: color 0.3s ease; }
    html.dark .tg-search-box input { color: #f9fafb; }
    .tg-search-box input::placeholder { color: #9ca3af; font-weight: 500; }

    /* 🔥 FIX LIST CHAT (PADDING BAWAH LEBIH BESAR BIAR GAK KETUTUP FAB) 🔥 */
    .tg-chat-list { flex: 1; overflow-y: auto; padding-bottom: 120px; scroll-behavior: smooth; }
    .tg-chat-list::-webkit-scrollbar { width: 0; } 

    /* DESAIN KOTAK CHAT LEBIH NYAMAN */
    .tg-chat-item { 
      display: flex; align-items: center; gap: 16px; padding: 12px 20px; cursor: pointer; user-select: none; 
      transition: background 0.2s, transform 0.1s; position: relative;
    }
    /* Efek membal pas diklik */
    .tg-chat-item:active { background: #f3f4f6; transform: scale(0.98); }
    html.dark .tg-chat-item:active { background: #1f2226; }

    .tg-avatar { width: 56px; height: 56px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: none !important; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .global-avatar { background: linear-gradient(135deg, #1DA1F2 0%, #007bb5 100%); display: flex; align-items: center; justify-content: center; color: white; box-shadow: 0 4px 10px rgba(29, 161, 242, 0.3); }
    .group-avatar { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); display: flex; align-items: center; justify-content: center; color: white; box-shadow: 0 4px 10px rgba(245, 158, 11, 0.3); }

    .tg-chat-info { flex: 1; min-width: 0; border-bottom: 1px solid #f3f4f6; padding-bottom: 14px; padding-top: 4px; display: flex; flex-direction: column; justify-content: center; height: 100%; transition: border-color 0.3s ease; }
    .tg-chat-item:last-child .tg-chat-info { border-bottom: none; }
    html.dark .tg-chat-info { border-bottom-color: #1f2226; }

    .tg-chat-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .tg-name { font-size: 16px; font-weight: 700; color: #111827; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center; gap: 6px; transition: color 0.3s ease; }
    html.dark .tg-name { color: #f9fafb; }
    
    .verified-badge { color: #1DA1F2; display: flex; align-items: center; }
    .verified-badge .material-icons { font-size: 15px; }

    .tg-time { font-size: 12px; font-weight: 500; color: #9ca3af; flex-shrink: 0; }
    .tg-chat-item.unread .tg-time { color: #1DA1F2; font-weight: 700; }

    .tg-chat-bottom { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
    .tg-preview { font-size: 14px; font-weight: 500; color: #6b7280; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; display: flex; align-items: center; gap: 4px; transition: color 0.3s ease; }
    html.dark .tg-preview { color: #9ca3af; }
    .tg-chat-item.unread .tg-preview { color: #374151; font-weight: 600; }
    html.dark .tg-chat-item.unread .tg-preview { color: #e5e7eb; }

    .check-icon { font-size: 16px; color: #10b981; }

    /* Badge Merah Unread */
    .tg-unread-badge { background: #ef4444; color: white; font-size: 11px; font-weight: 800; min-width: 22px; height: 22px; border-radius: 99px; display: flex; align-items: center; justify-content: center; padding: 0 6px; flex-shrink: 0; box-shadow: 0 2px 6px rgba(239, 68, 68, 0.4); }

    /* 🔥 FIX TOMBOL FAB (DINAIKKAN & DIBIKIN MAKIN CAKEP) 🔥 */
    .tg-fab { 
      position: absolute; 
      /* Naikin posisi tombol 40px dari bawah + margin safe area HP */
      bottom: max(40px, env(safe-area-inset-bottom) + 20px); 
      right: 24px; 
      width: 60px; 
      height: 60px; 
      border-radius: 50%; 
      background: linear-gradient(135deg, #1DA1F2, #007bb5); 
      border: none; 
      color: white; 
      box-shadow: 0 8px 20px rgba(29, 161, 242, 0.4); 
      cursor: pointer; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); 
      z-index: 50; 
    }
    .tg-fab:hover { transform: translateY(-4px) scale(1.05); box-shadow: 0 12px 25px rgba(29, 161, 242, 0.5); }
    .tg-fab:active { transform: scale(0.9); box-shadow: 0 4px 10px rgba(29, 161, 242, 0.4); }
    .tg-fab .material-icons { font-size: 26px; }

    /* LOADING STATE */
    .loading-state { text-align: center; padding: 60px 20px; color: #9ca3af; display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .loading-spinner { font-size: 40px; animation: spin 1s linear infinite; color: #1DA1F2; }
    .loading-state p { font-size: 14px; font-weight: 600; }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const chatList = document.getElementById("chatList");
      const searchInput = document.getElementById("searchChat");
      let currentUser = null;

      function formatTimeTelegram(dateString) {
        const dateObj = new Date(dateString);
        const today = new Date();
        const isToday = dateObj.toDateString() === today.toDateString();
        
        if (isToday) {
            return dateObj.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
        } else {
            const diffTime = Math.abs(today - dateObj);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
            if (diffDays === 1) return "Kemarin";
            if (diffDays < 7) return dateObj.toLocaleDateString("id-ID", { weekday: "short" });
            return dateObj.toLocaleDateString("id-ID", { day: "numeric", month: "short" });
        }
      }

      async function loadAllChats() {
        try {
          const { supabase } = await import('../lib/supabase.js');
          
          const { data: { user }, error: authError } = await supabase.auth.getUser();
          if (authError || !user) {
            chatList.innerHTML = '<div class="loading-state"><span class="material-icons" style="color:#ef4444; animation:none;">error_outline</span><p>Silakan login dulu bro.</p></div>';
            return;
          }
          currentUser = user;

          const waktu24JamLalu = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
          
          const { data: pvMsgs } = await supabase
            .from("messages")
            .select("room_id, message, created_at, sticker_url, audio_url, user_id, status, is_system")
            .ilike("room_id", "pv_%").ilike("room_id", `%${currentUser.id}%`)
            .gte("created_at", waktu24JamLalu).order("created_at", { ascending: false });

          const { data: groups } = await supabase
            .from('group_members')
            .select(`group_id, groups(id, name, photo_url)`)
            .eq('user_id', currentUser.id);

          const finalChatList = [];

          let unreadGlobal = parseInt(localStorage.getItem('unread_room-1') || '0');
          finalChatList.push({
            id: 'room-1',
            type: 'global',
            name: 'HopeTalk Globe',
            avatar: '',
            preview: 'Obrolan umum komunitas',
            time: 'Always',
            unread: unreadGlobal,
            sortTime: Date.now() + 10000 
          });

          const lastPvMessages = new Map();
          const unreadPvCounts = new Map();

          if (pvMsgs) {
            pvMsgs.forEach((msg) => {
              const partnerId = msg.room_id.replace("pv_", "").split("_").find((id) => id !== currentUser.id);
              if (!partnerId) return;
              if (!lastPvMessages.has(partnerId)) lastPvMessages.set(partnerId, msg);
              if (msg.user_id !== currentUser.id && msg.status !== "read" && !msg.is_system) {
                unreadPvCounts.set(partnerId, (unreadPvCounts.get(partnerId) || 0) + 1);
              }
            });

            const partnerIds = Array.from(lastPvMessages.keys());
            if (partnerIds.length > 0) {
              const { data: profiles } = await supabase.from("profiles").select("id, username, avatar_url, role").in("id", partnerIds);
              
              const profileMap = new Map();
              profiles?.forEach(p => profileMap.set(p.id, p));

              lastPvMessages.forEach((msg, pId) => {
                const profile = profileMap.get(pId);
                if (!profile) return;
                
                let previewText = msg.sticker_url ? "🖼 Mengirim Stiker" : (msg.audio_url ? "🎤 Mengirim Voice Note" : msg.message);
                if (msg.message === "Pesan ini telah dihapus") previewText = "🚫 Pesan dihapus";

                const isMe = msg.user_id === currentUser.id && !msg.is_system;
                const statusCheck = isMe ? (msg.status === "read" ? `<span class="material-icons check-icon" style="color:#10b981; font-size:16px; margin-right:4px;">done_all</span>` : `<span class="material-icons check-icon" style="color:#9ca3af; font-size:16px; margin-right:4px;">check</span>`) : '';

                finalChatList.push({
                  id: pId, 
                  type: 'private',
                  name: profile.username || "User",
                  avatar: profile.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(profile.username)}`,
                  role: profile.role,
                  preview: `${statusCheck}${previewText}`,
                  time: formatTimeTelegram(msg.created_at),
                  unread: unreadPvCounts.get(pId) || 0,
                  sortTime: new Date(msg.created_at).getTime()
                });
              });
            }
          }

          if (groups) {
            groups.forEach(g => {
              const group = g.groups;
              if (!group) return;
              let unreadGrp = parseInt(localStorage.getItem('unread_group_' + group.id) || '0');
              
              finalChatList.push({
                id: group.id,
                type: 'group',
                name: group.name,
                avatar: group.photo_url || '',
                preview: 'Klik untuk melihat obrolan grup',
                time: 'Aktif',
                unread: unreadGrp,
                sortTime: Date.now() - 1000 
              });
            });
          }

          finalChatList.sort((a, b) => b.sortTime - a.sortTime);

          chatList.innerHTML = '';
          
          if (finalChatList.length === 1 && finalChatList[0].type === 'global') {
            chatList.innerHTML = `<div class="loading-state" style="opacity:0.7;"><span class="material-icons" style="font-size:48px; color:#1DA1F2; animation:none;">forum</span><p>Mulai cari doi untuk melihat riwayat chat pribadi di sini.</p></div>`;
          }

          finalChatList.forEach(chat => {
            const div = document.createElement("div");
            div.className = `tg-chat-item ${chat.unread > 0 ? 'unread' : ''}`;
            
            div.onclick = () => {
              if (chat.type === 'global') {
                window.location.href = `/chat`; 
              } else {
                window.location.href = `/chat?from=${chat.id}`; 
              }
            };

            let avatarHtml = '';
            if (chat.type === 'global') {
              avatarHtml = `<div class="tg-avatar global-avatar"><span class="material-icons">public</span></div>`;
            } else if (chat.type === 'group') {
              avatarHtml = chat.avatar 
                ? `<img src="${chat.avatar}" class="tg-avatar">` 
                : `<div class="tg-avatar group-avatar"><span class="material-icons">groups</span></div>`;
            } else {
              avatarHtml = `<img src="${chat.avatar}" class="tg-avatar" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(chat.name)}'">`;
            }

            let roleBadge = '';
            if (chat.role === 'admin') roleBadge = `<span class="badge" style="background:#ef4444; color:white; font-size:9px; padding:2px 6px; border-radius:4px; margin-left:6px; font-weight:800;">ADMIN</span>`;
            if (chat.role === 'verified') roleBadge = `<span class="verified-badge"><span class="material-icons">verified</span></span>`;

            div.innerHTML = `
              ${avatarHtml}
              <div class="tg-chat-info">
                <div class="tg-chat-top">
                  <h4 class="tg-name">${escapeHtml(chat.name)} ${roleBadge}</h4>
                  <span class="tg-time">${chat.time}</span>
                </div>
                <div class="tg-chat-bottom">
                  <p class="tg-preview">${chat.preview}</p>
                  ${chat.unread > 0 ? `<span class="tg-unread-badge">${chat.unread > 99 ? '99+' : chat.unread}</span>` : ''}
                </div>
              </div>
            `;
            chatList.appendChild(div);
          });

          initSearch();

        } catch (err) {
          console.error(err);
          chatList.innerHTML = '<div class="loading-state"><span class="material-icons" style="color:#ef4444; animation:none;">error_outline</span><p>Gagal memuat history chat.</p></div>';
        }
      }

      function escapeHtml(str = "") {
        return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
      }

      function initSearch() {
        if (searchInput) {
          searchInput.addEventListener("input", (e) => {
            const query = e.target.value.toLowerCase();
            const items = document.querySelectorAll(".tg-chat-item");
            
            items.forEach(item => {
              const name = item.querySelector(".tg-name").textContent.toLowerCase();
              if (name.includes(query)) {
                item.style.display = "flex";
              } else {
                item.style.display = "none";
              }
            });
          });
        }
      }

      loadAllChats();
    });
  </script>
</body>
</html>
