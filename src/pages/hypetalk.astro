---
// src/pages/hypetalk.astro
import * as uiUtils from '../lib/ui-utils.js';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Hypetalk - Obrolan</title>
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  
  <script>
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark") document.documentElement.classList.add("dark");
    else document.documentElement.classList.remove("dark");
  </script>
  
  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <style is:global>
    @keyframes spin { 100% { transform: rotate(360deg); } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @keyframes badgeBounce { 0% { transform: scale(1); } 50% { transform: scale(1.3); } 100% { transform: scale(1); } }

    :root {
      --tg-bg: #ffffff;
      --tg-bg-secondary: #f4f5f7;
      --tg-text: #111827;
      --tg-text-muted: #6b7280;
      --tg-border: #e5e7eb;
      --tg-primary: #1DA1F2;
      --tg-hover: #f9fafb;
    }

    html.dark {
      --tg-bg: #15171a;
      --tg-bg-secondary: #1f2226;
      --tg-text: #f9fafb;
      --tg-text-muted: #9ca3af;
      --tg-border: #2a2d31;
      --tg-hover: #1b1e22;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    
    html, body, button, a, div { 
      -webkit-tap-highlight-color: transparent !important; 
      outline: none !important;
    }

    html, body { height: 100%; width: 100%; overflow: hidden; }
    body { background: #e5e7eb; display: flex; justify-content: center; transition: background 0.3s ease; }
    html.dark body { background: #000000; }

    .telegram-wrapper { 
      position: fixed; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 480px; 
      display: flex; flex-direction: column; background: var(--tg-bg); box-shadow: 0 0 20px rgba(0,0,0,0.05); 
      transition: background 0.3s ease; padding-bottom: env(safe-area-inset-bottom); z-index: 1;
    }
    html.dark .telegram-wrapper { box-shadow: none; border-left: 1px solid var(--tg-border); border-right: 1px solid var(--tg-border); }

    .tg-header { background: var(--tg-bg); z-index: 10; transition: background 0.3s ease; padding-top: env(safe-area-inset-top); }
    .tg-header-top { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; }
    .tg-header-left { display: flex; align-items: center; gap: 16px; }
    .tg-header-left h2 { font-size: 20px; font-weight: 700; color: var(--tg-text); transition: color 0.3s ease; }
    .icon-btn { background: none; border: none; color: var(--tg-text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; transition: all 0.2s ease; }
    .icon-btn:active { background: transparent; transform: scale(0.95); }

    .tg-search-container { padding: 4px 16px 12px; }
    .tg-search-box { display: flex; align-items: center; background: var(--tg-bg-secondary); border-radius: 12px; padding: 10px 16px; gap: 12px; transition: all 0.2s ease; border: 1px solid transparent; }
    .tg-search-box:focus-within { background: var(--tg-bg); border-color: var(--tg-primary); box-shadow: 0 4px 12px rgba(29, 161, 242, 0.08); }
    .tg-search-box .material-icons { color: var(--tg-text-muted); font-size: 20px; }
    .tg-search-box:focus-within .material-icons { color: var(--tg-primary); }
    .tg-search-box input { flex: 1; border: none; background: transparent; outline: none; font-size: 15px; color: var(--tg-text); }
    .tg-search-box input::placeholder { color: var(--tg-text-muted); }

    .tg-chat-list { flex: 1; overflow-y: auto; padding-bottom: 100px; }
    .tg-chat-list::-webkit-scrollbar { width: 0; } 
    .tg-chat-item { display: flex; align-items: center; gap: 14px; padding: 10px 16px; cursor: pointer; user-select: none; transition: background 0.2s; position: relative; animation: fadeIn 0.3s ease forwards; }
    .tg-chat-item:active { background: var(--tg-hover); }
    .tg-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: none !important; }
    .global-avatar { background: linear-gradient(135deg, #1DA1F2, #007bb5); display: flex; align-items: center; justify-content: center; color: white; }
    .group-avatar { background: linear-gradient(135deg, #f59e0b, #d97706); display: flex; align-items: center; justify-content: center; color: white; }
    .tg-chat-info { flex: 1; min-width: 0; border-bottom: 1px solid var(--tg-border); padding-bottom: 12px; padding-top: 2px; display: flex; flex-direction: column; justify-content: center; height: 100%; transition: border-color 0.3s ease; }
    .tg-chat-item:last-child .tg-chat-info { border-bottom: none; }
    .tg-chat-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .tg-name { font-size: 16px; font-weight: 600; color: var(--tg-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center; gap: 4px; }
    .tg-time { font-size: 12px; font-weight: 500; color: var(--tg-text-muted); flex-shrink: 0; }
    .tg-chat-item.unread .tg-time { color: var(--tg-primary); font-weight: 600; }
    .tg-chat-bottom { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
    .tg-preview { font-size: 14px; color: var(--tg-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; display: flex; align-items: center; gap: 4px; }
    .tg-chat-item.unread .tg-preview { color: var(--tg-text); font-weight: 500; }
    .tg-unread-badge { background: var(--tg-primary); color: white; font-size: 11px; font-weight: 700; min-width: 22px; height: 22px; border-radius: 99px; display: flex; align-items: center; justify-content: center; padding: 0 6px; flex-shrink: 0; transition: all 0.3s ease; }
    .tg-unread-badge.bump { animation: badgeBounce 0.4s ease; }

    .tg-fab { 
      position: absolute; bottom: max(30px, env(safe-area-inset-bottom) + 30px); right: 20px; 
      width: 56px; height: 56px; border-radius: 50%; background: var(--tg-primary); border: none; color: white; 
      box-shadow: 0 4px 14px rgba(29, 161, 242, 0.4); cursor: pointer; display: flex; align-items: center; justify-content: center; 
      transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); z-index: 50; 
    }
    .tg-fab:active { transform: scale(0.9); }
    .tg-fab.hidden { display: none !important; }

    .sidebar-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(2px); z-index: 100; display: none; animation: fadeIn 0.2s ease; }
    .tg-sidebar { 
      position: fixed; top: 0; bottom: 0; left: 50%; width: 100%; max-width: 320px; background: var(--tg-bg); 
      transform: translateX(calc(-50% - 100vw)); z-index: 105; display: flex; flex-direction: column; 
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.1); box-shadow: 5px 0 25px rgba(0,0,0,0.1);
    }
    .tg-sidebar.open { transform: translateX(-50%); } 
    @media (max-width: 480px) {
      .tg-sidebar { left: 0; transform: translateX(-100%); }
      .tg-sidebar.open { transform: translateX(0); }
    }
    .sidebar-header { padding: 40px 20px 20px; background: var(--tg-bg-secondary); border-bottom: 1px solid var(--tg-border); display: flex; flex-direction: column; align-items: flex-start; gap: 10px; }
    #side-avatar { width: 70px; height: 70px; border-radius: 50%; object-fit: cover; border: 2px solid var(--tg-primary); }
    .sidebar-user-info { display: flex; flex-direction: column; gap: 2px; }
    #side-username { font-size: 18px; font-weight: 700; color: var(--tg-text); }
    #side-id { font-size: 13px; color: var(--tg-text-muted); cursor: pointer; transition: color 0.2s; }
    #side-id:active { color: var(--tg-primary); }
    .btn-edit-bio { background: var(--tg-primary); color: white; border: none; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; margin-top: 5px; }
    
    .sidebar-menu { display: flex; flex-direction: column; padding: 10px 0; overflow-y: auto; }
    .menu-item { display: flex; align-items: center; gap: 16px; padding: 16px 20px; background: transparent; border: none; font-size: 15px; font-weight: 600; color: var(--tg-text); cursor: pointer; text-align: left; outline: none; }
    .menu-item:active { background: transparent; transform: scale(0.98); }
    .menu-item .material-icons { color: var(--tg-text-muted); }
    .menu-divider { height: 1px; background: var(--tg-border); margin: 8px 0; }
    
    /* GANTI WARNA ICON SIDEBAR JADI BIRU */
    .btn-cari-doi { color: var(--tg-primary) !important; justify-content: space-between; }
    .btn-cari-doi .material-icons { color: var(--tg-primary) !important; }
    
    .limit-badge { background: #fee2e2; color: #ef4444; font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 800; }
    html.dark .limit-badge { background: rgba(239,68,68,0.15); }

    .custom-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 200; align-items: flex-end; justify-content: center; animation: fadeIn 0.2s ease; }
    .custom-modal-content { background: var(--tg-bg); width: 100%; max-width: 480px; border-top-left-radius: 24px; border-top-right-radius: 24px; padding: 24px; padding-bottom: max(24px, env(safe-area-inset-bottom) + 24px); animation: slideUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); display: flex; flex-direction: column; }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .modal-header h3 { color: var(--tg-text); font-size: 18px; font-weight: 700; }
    .close-modal-btn { background: var(--tg-bg-secondary); border: none; color: var(--tg-text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; }
    .modal-desc { font-size: 13px; color: var(--tg-text-muted); margin-bottom: 16px; }
    
    .input-group { display: flex; align-items: center; background: var(--tg-bg-secondary); border-radius: 12px; padding: 12px 16px; gap: 12px; border: 1px solid var(--tg-border); width: 100%; }
    .input-group input, .input-group select { flex: 1; border: none; background: transparent; outline: none; font-size: 14px; color: var(--tg-text); width: 100%; }
    .input-group .material-icons { color: var(--tg-text-muted); font-size: 18px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 16px; }
    
    .action-btn { width: 100%; background: var(--tg-primary); color: white; border: none; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.2s; text-align: center; }
    .action-btn:active { transform: scale(0.98); }
    .action-btn.outline { background: transparent; border: 2px solid var(--tg-border); color: var(--tg-text); }
    
    /* GANTI TOMBOL DOI JADI GRADASI BIRU */
    .love-btn { background: linear-gradient(135deg, #1DA1F2, #007bb5); }

    .group-photo-upload { display: flex; justify-content: center; margin-bottom: 20px; }
    .group-photo-upload label { position: relative; cursor: pointer; display: inline-block; }
    .group-photo-upload img { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--tg-border); }
    .upload-badge { position: absolute; bottom: 0; right: 0; background: var(--tg-primary); color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid var(--tg-bg); }
    .upload-badge .material-icons { font-size: 14px; }

    .doi-result-card { align-items: center; text-align: center; }
    .doi-profile-box { margin-bottom: 20px; width: 100%; }
    .doi-profile-box img { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 4px solid var(--tg-bg-secondary); margin-bottom: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
    .doi-profile-box h2 { font-size: 20px; color: var(--tg-text); margin-bottom: 16px; }
    .doi-tags { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
    .d-tag { background: var(--tg-bg-secondary); color: var(--tg-text); font-size: 12px; font-weight: 600; padding: 6px 12px; border-radius: 20px; display: flex; align-items: center; gap: 4px; }
    .d-tag .material-icons { font-size: 14px; color: var(--tg-text-muted); }

    .doi-search-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 300; flex-direction: column; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
    
    /* ==== CSS ANIMASI PESAWAT KERTAS ==== */
    .paper-plane-container {
      position: relative;
      width: 250px;
      height: 250px;
      margin-bottom: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .paper-plane-icon {
      font-size: 50px !important;
      color: var(--tg-primary); /* Warna Biru */
      position: absolute;
      z-index: 10;
      filter: drop-shadow(0 5px 15px rgba(29, 161, 242, 0.8)); /* Glow Biru */
      animation: fly-plane 3s linear infinite;
    }

    @keyframes fly-plane {
      0%   { transform: translate(-100px, 0px) rotate(0deg) scale(1); }
      25%  { transform: translate(0px, -50px) rotate(90deg) scale(1.3); }
      50%  { transform: translate(100px, 0px) rotate(180deg) scale(1); }
      75%  { transform: translate(0px, 50px) rotate(270deg) scale(0.7); }
      100% { transform: translate(-100px, 0px) rotate(360deg) scale(1); }
    }

    /* GANTI WARNA BORDER AVATAR JADI BIRU */
    .floating-avatar { 
      position: absolute; 
      width: 40px; height: 40px; 
      border-radius: 50%; object-fit: cover; 
      border: 2px solid rgba(29, 161, 242, 0.8); 
      box-shadow: 0 0 10px rgba(29, 161, 242, 0.5); 
      animation: popInAndOut 1.5s ease-in-out forwards; 
      opacity: 0; z-index: 3; 
    }
    
    /* GANTI TEKS BERSINAR JADI BIRU */
    .search-title-glow { color: white; font-size: 20px; margin-bottom: 8px; text-shadow: 0 0 10px var(--tg-primary); }
    .search-subtitle-glow { color: #aaa; font-size: 14px; }
    
    @keyframes popInAndOut { 
      0% { transform: scale(0.5) translateY(10px); opacity: 0; } 
      20% { transform: scale(1) translateY(0); opacity: 1; } 
      80% { transform: scale(1) translateY(0); opacity: 1; } 
      100% { transform: scale(1.2) translateY(-10px); opacity: 0; } 
    }
    /* =================================== */

    #toast-container { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 99999; display: flex; flex-direction: column; gap: 10px; align-items: center; pointer-events: none; }
    .toast-msg { background: rgba(0,0,0,0.8); color: white; padding: 10px 20px; border-radius: 24px; font-size: 13px; font-weight: 500; backdrop-filter: blur(5px); animation: slideUp 0.3s ease; }
    .loading-state { text-align: center; padding: 60px 20px; color: var(--tg-text-muted); display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .loading-spinner { font-size: 32px; animation: spin 1s linear infinite; color: var(--tg-primary); }
    .loading-state p { font-size: 14px; font-weight: 500; }
    .text-center { text-align: center; }

    /* Modal Call Animasi & Styling */
    .anim-calling-avatar { animation: radar-pulse-call 1.5s infinite cubic-bezier(0.66, 0, 0, 1); border: 3px solid #10b981; border-radius: 50%; }
    .anim-calling-text { animation: text-blink 1.5s infinite ease-in-out; color: #10b981 !important; font-weight: bold; letter-spacing: 2px; }
    
    @keyframes radar-pulse-call { 
      0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7), 0 0 0 0 rgba(16, 185, 129, 0.4); transform: scale(0.95); } 
      50% { box-shadow: 0 0 0 15px rgba(16, 185, 129, 0), 0 0 0 30px rgba(16, 185, 129, 0.2); transform: scale(1); } 
      100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0), 0 0 0 45px rgba(16, 185, 129, 0); transform: scale(0.95); } 
    }
    @keyframes text-blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

  </style>
</head>
<body>

  <div id="modals-container">
    <div id="sidebar-overlay" class="sidebar-overlay" style="display: none;"></div>
    
    <div id="search-modal" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-content">
        <div class="modal-header">
          <h3>Mulai Chat Baru</h3>
          <button class="close-modal-btn"><span class="material-icons">close</span></button>
        </div>
        <p class="modal-desc">Masukkan ID unik temanmu (contoh: 0E870)</p>
        <div class="input-group">
          <span class="material-icons">tag</span>
          <input type="text" id="input-new-id" placeholder="Ketik ID teman..." autocomplete="off" />
        </div>
        <button class="action-btn" id="btn-find-user">Cari & Chat</button>
      </div>
    </div>

    <div id="bio-modal" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-content">
        <div class="modal-header">
          <h3>Edit Biodata</h3>
          <button class="close-modal-btn"><span class="material-icons">close</span></button>
        </div>
        <p class="modal-desc">Isi data agar bisa ditemukan di radar Cari Doi</p>
        <div class="form-grid">
          <div class="input-group"><input type="number" id="in-umur" placeholder="Umur (contoh: 20)"></div>
          <div class="input-group">
            <select id="in-gender">
              <option value="Pria">Pria</option>
              <option value="Wanita">Wanita</option>
            </select>
          </div>
          <div class="input-group"><input type="text" id="in-zodiak" placeholder="Zodiak (contoh: Aries)"></div>
          <div class="input-group"><input type="text" id="in-kerja" placeholder="Pekerjaan (contoh: Mahasiswa)"></div>
          <div class="input-group" style="grid-column: span 2;"><input type="text" id="in-hobi" placeholder="Hobi (contoh: Musik, Coding)"></div>
        </div>
        <button class="action-btn" id="btn-save-bio">Simpan Profil</button>
      </div>
    </div>

    <div id="group-modal" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-content">
        <div class="modal-header">
          <h3>Buat Grup Baru</h3>
          <button class="close-modal-btn"><span class="material-icons">close</span></button>
        </div>
        <div class="group-photo-upload">
          <label for="group-photo-input">
            <img id="group-photo-preview" src="/asets/png/profile.webp" alt="Grup">
            <div class="upload-badge"><span class="material-icons">camera_alt</span></div>
          </label>
          <input type="file" id="group-photo-input" accept="image/*" style="display:none;">
        </div>
        <div class="input-group" style="margin-bottom: 16px;">
          <span class="material-icons">groups</span>
          <input type="text" id="in-group-name" placeholder="Nama Grup..." autocomplete="off" />
        </div>
        <button class="action-btn" id="btn-create-group">Buat Sekarang</button>
      </div>
    </div>

    <div id="doi-card-modal" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-content doi-result-card">
        <div class="modal-header">
          <h3>Kecocokan Ditemukan! </h3>
          <button class="close-modal-btn"><span class="material-icons">close</span></button>
        </div>
        <div class="doi-profile-box">
          <img id="doi-photo" src="" alt="Doi">
          <h2 id="doi-name-age">Nama, Umur</h2>
          <div class="doi-tags">
            <span class="d-tag"><span class="material-icons">work</span> <span id="doi-job">-</span></span>
            <span class="d-tag"><span class="material-icons">auto_awesome</span> <span id="doi-zodiac">-</span></span>
            <span class="d-tag" style="width: 100%;"><span class="material-icons">favorite</span> <span id="doi-hobby">-</span></span>
          </div>
        </div>
        <button class="action-btn love-btn" id="btn-gas-chat">Gas Chat Sekarang</button>
      </div>
    </div>

    <div id="modal-limit-doi" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-content text-center">
        <span class="material-icons" style="font-size: 50px; color: #ef4444; margin-bottom: 10px;">hourglass_empty</span>
        <h3 style="margin-bottom: 10px; color: var(--tg-text);">Kuota Habis Bro!</h3>
        <p style="font-size: 14px; color: var(--tg-text-muted); margin-bottom: 20px;">Tonton iklan pendek buat dapetin 10 kuota pencarian lagi.</p>
        <div style="display: flex; gap: 10px;">
          <button class="action-btn outline close-modal-btn" style="flex:1;">Nanti Aja</button>
          <button class="action-btn" style="flex:1;" onclick="window.jalankanIklanIsiUlangDoi()">Tonton Iklan</button>
        </div>
      </div>
    </div>

    <div id="incoming-call-overlay" class="custom-modal-overlay" style="display: none; flex-direction: column; justify-content: center; align-items: center; background: rgba(0,0,0,0.9); z-index: 999999;">
      <div class="anim-calling-avatar" style="padding: 10px; border-radius: 50%; margin-bottom: 20px;">
        <img id="incoming-avatar" src="/asets/png/profile.webp" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover;">
      </div>
      <h2 id="incoming-name" style="color: white; margin-bottom: 10px;">Nama Teman</h2>
      <p style="color: #10b981; font-weight: bold; margin-bottom: 40px; letter-spacing: 2px;">MEMANGGIL...</p>
      <div style="display: flex; gap: 30px;">
        <button onclick="window.rejectCall()" style="background: #ef4444; border: none; width: 60px; height: 60px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);">
          <span class="material-icons" style="font-size: 30px;">call_end</span>
        </button>
        <button onclick="window.answerCall()" style="background: #10b981; border: none; width: 60px; height: 60px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4); animation: badgeBounce 1s infinite;">
          <span class="material-icons" style="font-size: 30px;">call</span>
        </button>
      </div>
    </div>

    <div id="call-overlay" class="custom-modal-overlay" style="display: none; flex-direction: column; justify-content: center; align-items: center; background: rgba(0,0,0,0.95); z-index: 999999;">
      <img id="call-avatar" src="/asets/png/profile.webp" class="anim-calling-avatar" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; margin-bottom: 20px;">
      <h2 id="call-name" style="color: white; margin-bottom: 10px;">Nama Teman</h2>
      <p id="call-status" style="color: #10b981; font-weight: bold; margin-bottom: 40px; font-size: 18px;">MENYAMBUNGKAN...</p>
      <button onclick="window.endCall()" style="background: #ef4444; border: none; width: 65px; height: 65px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4);">
        <span class="material-icons" style="font-size: 35px;">call_end</span>
      </button>
    </div>
  </div>
  
  <aside id="tg-sidebar" class="tg-sidebar">
    <div class="sidebar-header">
      <img id="side-avatar" src="/asets/png/profile.webp" alt="Avatar" onerror="this.src='/asets/png/profile.webp'">
      <div class="sidebar-user-info">
        <h3 id="side-username">Memuat...</h3>
        <p id="side-id" title="Klik untuk salin ID">#0000</p>
      </div>
      <button class="btn-edit-bio" id="btn-open-bio">Edit Biodata</button>
    </div>
    
    <div class="sidebar-menu">
      <button class="menu-item" id="btn-open-group-modal">
        <span class="material-icons">group_add</span> Buat Grup Baru
      </button>
      <button class="menu-item btn-cari-doi" id="btn-sidebar-search">
        <span class="material-icons">favorite</span> Cari Doi Sekarang
        <span class="limit-badge"><span id="limit-doi-text">10</span>/10</span>
      </button>
    </div>
  </aside>

  <div class="telegram-wrapper">
    <header class="tg-header">
      <div class="tg-header-top">
        <div class="tg-header-left">
          <button class="icon-btn menu-btn" id="open-sidebar-btn" aria-label="Menu">
            <span class="material-icons">menu</span>
          </button>
          <h2>Hypetalk</h2>
        </div>
      </div>

      <div class="tg-search-container">
        <div class="tg-search-box">
          <span class="material-icons">search</span>
          <input type="text" id="searchChat" placeholder="Cari teman atau obrolan..." autocomplete="off" />
        </div>
      </div>
    </header>

    <main class="tg-chat-list" id="chatList">
      <div class="loading-state">
        <span class="material-icons loading-spinner">sync</span>
        <p>Memuat obrolan...</p>
      </div>
    </main>

    <button class="tg-fab" id="btn-new-chat" aria-label="Chat Baru">
      <span class="material-icons">chat</span>
    </button>
  </div>

  <div id="toast-container"></div>

  <script>
    import { supabase } from '../lib/supabase.js';
    
    document.addEventListener("DOMContentLoaded", async () => {
      let getBadgeFunc = null;
      try {
        const utils = await import('../lib/ui-utils.js');
        getBadgeFunc = utils.getRoleBadge || utils.getBadge || utils.default?.getRoleBadge || utils.default?.getBadge;
      } catch (err) {
        console.warn("Gagal import ui-utils, menggunakan fallback lokal.");
      }

      if (!getBadgeFunc || typeof getBadgeFunc !== 'function') {
        getBadgeFunc = function(role) {
          if (!role) return "";
          role = String(role).toLowerCase().trim();
          if (role === "admin") return `<span class="badge" style="background:#ef4444; color:white; font-size:9px; padding:2px 6px; border-radius:4px; margin-left:6px; font-weight:800;">ADMIN</span>`;
          if (role === "verified") return `<span class="verified-icon" style="margin-left:4px; display:inline-flex; align-items:center;"><svg width="14" height="14" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#1DA1F2"/><path d="M7 12.5l3 3 7-7" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>`;
          const crownBadges = { crown1: "/asets/png/crown1.png", crown2: "/asets/png/crown2.png", crown3: "/asets/png/crown3.png" };
          if (crownBadges[role]) return `<img src="${crownBadges[role]}" alt="${role}" style="width:16px;height:16px;margin-left:4px;vertical-align:middle;object-fit:contain;display:inline-block;" onerror="this.style.display='none';">`;
          return "";
        };
      }

      const chatList = document.getElementById("chatList");
      let currentUser = null;
      let sisaLimitDoi = parseInt(localStorage.getItem('doi_limit') || '10');
      let inboxRealtimeChannel = null;
      const typingChannels = new Map(); 
      const lastMessageMap = new Map(); 

      const ringtoneSound = new Audio("/asets/sound/call.wav");
      ringtoneSound.loop = true;
      let callRoom = null;
      let callSignalData = null;
      let callRingingTimeout = null; 
      let callTalkTimer = null;      
      let callSeconds = 0;

      window.myUsernameLocal = "User"; 

      function stopRingtone() {
          ringtoneSound.pause();
          ringtoneSound.currentTime = 0;
      }

      function startCallTimer() {
          const statusEl = document.getElementById('call-status');
          callSeconds = 0;
          if (callTalkTimer) clearInterval(callTalkTimer);
          callTalkTimer = setInterval(() => {
              callSeconds++;
              const m = String(Math.floor(callSeconds / 60)).padStart(2, '0');
              const s = String(callSeconds % 60).padStart(2, '0');
              if (statusEl) statusEl.innerText = `${m}:${s}`;
          }, 1000);
      }

      function stopCallTimer() {
          if (callTalkTimer) {
              clearInterval(callTalkTimer);
              callTalkTimer = null;
          }
      }

      window.endCall = (isSilent = false) => {
          stopRingtone(); 
          clearTimeout(callRingingTimeout);
          stopCallTimer();

          const avatarEl = document.getElementById('call-avatar');
          const statusEl = document.getElementById('call-status');
          if (avatarEl) avatarEl.classList.remove('anim-calling-avatar');
          if (statusEl) {
              statusEl.classList.remove('anim-calling-text');
              statusEl.style.color = ""; 
          }

          const callOverlay = document.getElementById('call-overlay');
          const incomingOverlay = document.getElementById('incoming-call-overlay');
          let isOverlayOpen = (callOverlay && callOverlay.style.display !== 'none') || 
                              (incomingOverlay && incomingOverlay.style.display !== 'none');

          if (callRoom) {
              callRoom.disconnect();
              callRoom = null;
          }
          
          if (callOverlay) callOverlay.style.display = 'none';
          if (incomingOverlay) incomingOverlay.style.display = 'none';
          
          if (isOverlayOpen && !isSilent) {
              if (callSeconds > 0) {
                  const m = String(Math.floor(callSeconds / 60)).padStart(2, '0');
                  const s = String(callSeconds % 60).padStart(2, '0');
                  window.showToast(`Panggilan berakhir (${m}:${s})`);
              } else {
                  window.showToast("Panggilan berakhir");
              }
          }
      };

      window.showIncomingCall = async function(msgData) {
          callSignalData = msgData; 
          const overlay = document.getElementById('incoming-call-overlay');
          const nameEl = document.getElementById('incoming-name');
          const avatarEl = document.getElementById('incoming-avatar'); 
          
          if (overlay) overlay.style.display = 'flex';
          if (nameEl) nameEl.innerText = "Memuat..."; 

          if (msgData.user_id) {
              const { data: profile } = await supabase.from('profiles').select('username, avatar_url').eq('id', msgData.user_id).single();
              if (profile) {
                  if (avatarEl) avatarEl.src = profile.avatar_url || '/asets/png/profile.webp';
                  if (nameEl) nameEl.innerText = profile.username || "Teman"; 
              }
          }
          ringtoneSound.play().catch(e => console.log("Browser blokir autoplay:", e));
      };

      window.answerCall = async () => {
          stopRingtone(); 
          const incomingOverlay = document.getElementById('incoming-call-overlay');
          if (incomingOverlay) incomingOverlay.style.display = 'none';

          const callOverlay = document.getElementById('call-overlay');
          if (callOverlay) callOverlay.style.display = 'flex';

          const callStatus = document.getElementById('call-status');
          if (callStatus) callStatus.innerText = "CONNECTING...";

          const callAvatar = document.getElementById('call-avatar');
          if (callAvatar && callSignalData?.user_id) {
              const { data: profile } = await supabase.from('profiles').select('avatar_url').eq('id', callSignalData.user_id).single();
              if (profile) callAvatar.src = profile.avatar_url || '/asets/png/profile.webp';
          }

          if (callSignalData) {
              await connectToCall(callSignalData.room_id);
              if (callStatus) callStatus.innerText = "ON CALL";
          }
      };

      window.rejectCall = async () => {
          stopRingtone(); 
          const incomingOverlay = document.getElementById('incoming-call-overlay');
          if (incomingOverlay) incomingOverlay.style.display = 'none';
          
          if (callSignalData) {
              await supabase.from('messages').insert([{
                  room_id: callSignalData.room_id,
                  message: `🚫 Panggilan Ditolak`,
                  user_id: currentUser.id,
                  is_system: true
              }]);
              callSignalData = null;
          }
      };

      async function connectToCall(roomName) {
          try {
              const apiUrl = supabase.supabaseUrl;
              const anonKey = supabase.supabaseKey;

              const response = await fetch(`${apiUrl}/functions/v1/get-livekit-token`, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'apikey': anonKey, 'Authorization': `Bearer ${anonKey}` },
                  body: JSON.stringify({ username: window.myUsernameLocal, identity: currentUser.id, roomName: roomName })
              });
              
              const data = await response.json();

              callRoom = new LivekitClient.Room({ adaptiveStream: true, dynacast: true });

              callRoom.on(LivekitClient.RoomEvent.TrackSubscribed, (track) => {
                  if (track.kind === "audio") {
                      const element = track.attach();
                      document.body.appendChild(element);
                      element.play().catch(() => {});
                  }
              });
              callRoom.on(LivekitClient.RoomEvent.ParticipantDisconnected, () => {
                  window.showToast("Panggilan diakhiri oleh lawan bicara.");
                  window.endCall();
              });
              callRoom.on(LivekitClient.RoomEvent.Disconnected, () => window.endCall());

              callRoom.on(LivekitClient.RoomEvent.ParticipantConnected, () => {
                  clearTimeout(callRingingTimeout); 
                  const avatarEl = document.getElementById('call-avatar');
                  const statusEl = document.getElementById('call-status');
                  if (avatarEl) avatarEl.classList.remove('anim-calling-avatar');
                  if (statusEl) { statusEl.classList.remove('anim-calling-text'); statusEl.style.color = "#2ecc71"; }
                  startCallTimer(); 
              });

              const LIVEKIT_URL = "wss://voicegrup-zxmeibkn.livekit.cloud"; 
              await callRoom.connect(LIVEKIT_URL, data.token);
              await callRoom.localParticipant.setMicrophoneEnabled(true);

              if (callRoom.remoteParticipants.size > 0) {
                  clearTimeout(callRingingTimeout);
                  const avatarEl = document.getElementById('call-avatar');
                  const statusEl = document.getElementById('call-status');
                  if (avatarEl) avatarEl.classList.remove('anim-calling-avatar');
                  if (statusEl) { statusEl.classList.remove('anim-calling-text'); statusEl.style.color = "#2ecc71"; }
                  startCallTimer();
              }
          } catch (e) {
              console.error("Gagal koneksi LiveKit:", e);
              window.showToast("Gagal terhubung ke server panggilan.");
              window.endCall();
          }
      }

      window.showToast = (msg) => {
        const container = document.getElementById("toast-container");
        const toast = document.createElement("div");
        toast.className = "toast-msg";
        toast.innerText = msg;
        container.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; setTimeout(() => toast.remove(), 300); }, 3000);
      };

      const sideIdEl = document.getElementById("side-id");
      if (sideIdEl) {
        sideIdEl.addEventListener("click", () => {
          const textToCopy = sideIdEl.innerText.replace('#', '');
          navigator.clipboard.writeText(textToCopy).then(() => {
            window.showToast("ID berhasil disalin!");
          }).catch(err => {
            console.error('Gagal copy: ', err);
            window.showToast("Gagal menyalin ID");
          });
        });
      }

      async function initUser() {
        try {
            const { data: { user }, error } = await supabase.auth.getUser();
            if (error || !user) {
              window.location.href = '/login'; return;
            }
            currentUser = user;

            const { data: profile } = await supabase.from('profiles').select('*').eq('id', user.id).single();
            if (profile) {
              document.getElementById("side-username").innerText = profile.username || "User";
              document.getElementById("side-avatar").src = profile.avatar_url || "/asets/png/profile.webp";
              document.getElementById("side-id").innerText = "#" + (profile.short_id || "N/A");
              
              window.myUsernameLocal = profile.username || "User";

              if (document.getElementById("in-umur")) document.getElementById("in-umur").value = profile.umur || "";
              if (document.getElementById("in-gender")) document.getElementById("in-gender").value = profile.gender || "Pria";
              if (document.getElementById("in-zodiak")) document.getElementById("in-zodiak").value = profile.zodiak || "";
              if (document.getElementById("in-kerja")) document.getElementById("in-kerja").value = profile.pekerjaan || "";
              if (document.getElementById("in-hobi")) document.getElementById("in-hobi").value = profile.hobi || "";
            }
            updateLimitUI();
            await loadAllChats();
            initInboxRealtime(); 
        } catch(e) {
            console.error("Gagal init user:", e);
        }
      }

      function subscribeToTyping(id, type, originalPreview) {
        const roomId = type === 'private' ? (currentUser.id < id ? `pv_${currentUser.id}_${id}` : `pv_${id}_${currentUser.id}`) : (type === 'group' ? `group_${id}` : 'room-1');
        lastMessageMap.set(id, originalPreview);
        if (typingChannels.has(id)) supabase.removeChannel(typingChannels.get(id));
        const chan = supabase.channel(`typing-${roomId}`)
          .on("broadcast", { event: "typing" }, (payload) => {
            const chatItem = document.querySelector(`.tg-chat-item[data-room-id="${id}"]`);
            if (!chatItem || payload.payload.userId === currentUser.id) return;
            const previewEl = chatItem.querySelector('.tg-preview');
            previewEl.innerHTML = `<span style="color:var(--tg-primary); font-style:italic; font-weight:500;">sedang mengetik...</span>`;
            clearTimeout(chatItem.typingTimeout);
            chatItem.typingTimeout = setTimeout(() => {
              previewEl.innerText = lastMessageMap.get(id) || "";
            }, 3000);
          }).subscribe();
        typingChannels.set(id, chan);
      }

      function initInboxRealtime() {
        if (!currentUser) return;
        if (inboxRealtimeChannel) supabase.removeChannel(inboxRealtimeChannel);

        inboxRealtimeChannel = supabase.channel('inbox-monitor')
          .on("postgres_changes", { event: "INSERT", schema: "public", table: "messages" }, (payload) => {
             const newMsg = payload.new;
             const isGlobal = newMsg.room_id === "room-1";
             const isPrivateForMe = newMsg.room_id.startsWith("pv_") && newMsg.room_id.includes(currentUser.id);
             const isGroup = newMsg.room_id.startsWith("group_"); 
             
             if (isGlobal || isPrivateForMe || isGroup) {
                 if (newMsg.is_system && newMsg.message.includes("📞 Memanggil") && newMsg.user_id !== currentUser.id) {
                     if (typeof window.showIncomingCall === "function") window.showIncomingCall(newMsg);
                 }
                 const stopKeywords = ["🚫 Panggilan Ditolak", "☎️ Panggilan tak terjawab", "Panggilan berakhir"];
                 if (newMsg.is_system && stopKeywords.some(k => newMsg.message.includes(k))) {
                     if (typeof window.endCall === "function") window.endCall(false);
                 }
                 if (newMsg.user_id !== currentUser.id) updateChatItemRealtime(newMsg);
             }
          }).subscribe();
      }

      async function updateChatItemRealtime(msg) {
         let targetId = msg.room_id;
         if (msg.room_id.startsWith("pv_")) {
             targetId = msg.room_id.replace("pv_", "").split("_").find(id => id !== currentUser.id);
         } else if (msg.room_id.startsWith("group_")) {
             targetId = msg.room_id.replace("group_", "");
         }

         const chatItemEl = document.querySelector(`.tg-chat-item[data-room-id="${targetId}"]`);
         let previewText = msg.sticker_url ? "🖼 Stiker" : (msg.audio_url ? "🎤 Voice Note" : msg.message);
         if (msg.is_system) previewText = msg.message;

         if (chatItemEl) {
             lastMessageMap.set(targetId, previewText);
             chatItemEl.querySelector('.tg-preview').innerText = previewText;
             chatItemEl.classList.add('unread');
             chatItemEl.querySelector('.tg-time').innerText = formatTimeTelegram(msg.created_at);
             let badgeEl = chatItemEl.querySelector('.tg-unread-badge');
             if (!badgeEl) {
                 const bottomContainer = chatItemEl.querySelector('.tg-chat-bottom');
                 badgeEl = document.createElement('span');
                 badgeEl.className = 'tg-unread-badge bump';
                 badgeEl.innerText = '1';
                 bottomContainer.appendChild(badgeEl);
             } else {
                 let currentCount = parseInt(badgeEl.innerText) || 0;
                 badgeEl.innerText = currentCount > 98 ? '99+' : (currentCount + 1).toString();
                 badgeEl.classList.remove('bump');
                 void badgeEl.offsetWidth; 
                 badgeEl.classList.add('bump');
             }
             chatList.insertBefore(chatItemEl, chatList.firstChild);
         } else {
             loadAllChats();
         }
      }

      const modals = document.querySelectorAll('.custom-modal-overlay');
      const closeBtns = document.querySelectorAll('.close-modal-btn');

      function openModal(id) {
        document.getElementById(id).style.display = "flex";
        if (id === 'search-modal') document.getElementById('btn-new-chat').classList.add('hidden');
      }
      function closeModal(id) {
        document.getElementById(id).style.display = "none";
        document.getElementById('btn-new-chat').classList.remove('hidden');
      }

      closeBtns.forEach(btn => {
        btn.onclick = (e) => closeModal(e.target.closest('.custom-modal-overlay').id);
      });
      modals.forEach(m => {
        m.onclick = (e) => { if (e.target === m) closeModal(m.id); }
      });

      const sidebarOverlay = document.getElementById("sidebar-overlay");
      const sidebar = document.getElementById("tg-sidebar");
      document.getElementById("open-sidebar-btn").onclick = () => {
        sidebarOverlay.style.display = "block";
        setTimeout(() => sidebar.classList.add("open"), 10);
      };
      sidebarOverlay.onclick = () => {
        sidebar.classList.remove("open");
        setTimeout(() => sidebarOverlay.style.display = "none", 300);
      };
      document.querySelectorAll('.menu-item, .btn-edit-bio').forEach(btn => {
        btn.addEventListener('click', () => sidebarOverlay.onclick());
      });

      document.getElementById("btn-new-chat").onclick = () => openModal("search-modal");
      document.getElementById("btn-find-user").onclick = async () => {
        const input = document.getElementById("input-new-id").value.trim().toUpperCase().replace("#", "");
        if (!input) return window.showToast("Masukkan ID dulu!");
        document.getElementById("btn-find-user").innerText = "Mencari...";
        try {
          const { data: friend, error } = await supabase.from("profiles").select("id, username").eq("short_id", input).single();
          if (error || !friend) throw new Error("ID tidak ditemukan!");
          if (friend.id === currentUser.id) throw new Error("Tidak bisa chat dengan diri sendiri.");
          window.location.href = `/chat?from=${friend.id}`;
        } catch (err) { window.showToast(err.message); } 
        finally { document.getElementById("btn-find-user").innerText = "Cari & Chat"; }
      };

      document.getElementById("btn-open-bio").onclick = () => openModal("bio-modal");
      document.getElementById("btn-save-bio").onclick = async () => {
        const btn = document.getElementById("btn-save-bio");
        btn.innerText = "Menyimpan..."; btn.disabled = true;
        try {
          const updateData = {
            umur: Number(document.getElementById("in-umur").value) || null,
            gender: document.getElementById("in-gender").value,
            zodiak: document.getElementById("in-zodiak").value,
            pekerjaan: document.getElementById("in-kerja").value,
            hobi: document.getElementById("in-hobi").value
          };
          const { error } = await supabase.from("profiles").update(updateData).eq("id", currentUser.id);
          if (error) throw error;
          window.showToast("Profil tersimpan!");
          closeModal("bio-modal");
        } catch (err) { window.showToast("Gagal menyimpan profil."); }
        finally { btn.innerText = "Simpan Profil"; btn.disabled = false; }
      };

      document.getElementById("btn-open-group-modal").onclick = () => openModal("group-modal");
      let selectedGroupFile = null;
      document.getElementById("group-photo-input").onchange = (e) => {
        if (e.target.files[0]) {
          selectedGroupFile = e.target.files[0];
          document.getElementById("group-photo-preview").src = URL.createObjectURL(selectedGroupFile);
        }
      };
      document.getElementById("btn-create-group").onclick = async () => {
        const name = document.getElementById("in-group-name").value.trim();
        if (!name) return window.showToast("Isi nama grup!");
        const btn = document.getElementById("btn-create-group");
        btn.innerText = "Mengunggah..."; btn.disabled = true;
        try {
          let photoUrl = "";
          if (selectedGroupFile) {
            const fd = new FormData(); fd.append("file", selectedGroupFile); fd.append("upload_preset", "post_hope");
            const res = await fetch("https://api.cloudinary.com/v1_1/dhhmkb8kl/image/upload", { method: "POST", body: fd });
            const cData = await res.json();
            if (cData.secure_url) photoUrl = cData.secure_url;
          }
          const { data: group, error } = await supabase.from('groups').insert([{ name, created_by: currentUser.id, photo_url: photoUrl }]).select().single();
          if (error) throw error;
          await supabase.from('group_members').insert([{ group_id: group.id, user_id: currentUser.id }]);
          window.showToast("Grup berhasil dibuat!");
          closeModal("group-modal");
          loadAllChats(); 
        } catch (err) { window.showToast("Gagal membuat grup."); }
        finally { btn.innerText = "Buat Sekarang"; btn.disabled = false; }
      };

      function updateLimitUI() {
        document.getElementById("limit-doi-text").innerText = sisaLimitDoi;
      }
      
      let radarInterval;

      document.getElementById("btn-sidebar-search").onclick = async () => {
        if (sisaLimitDoi <= 0) return openModal("modal-limit-doi");
        const { data: profile } = await supabase.from('profiles').select('gender').eq('id', currentUser.id).single();
        if (!profile || !profile.gender) {
          window.showToast("Setel Gender kamu dulu di Edit Biodata!"); return openModal("bio-modal");
        }
        sisaLimitDoi--; localStorage.setItem('doi_limit', sisaLimitDoi.toString()); updateLimitUI();
        const overlay = document.createElement("div"); 
        overlay.className = "doi-search-overlay"; 
        overlay.id = "active-search-overlay";
        overlay.style.display = "flex"; 
        overlay.innerHTML = `<div class="paper-plane-container" id="paper-plane-container-box"><span class="material-icons paper-plane-icon">send</span></div><div style="text-align: center; z-index: 10;"><h3 class="search-title-glow">Menerbangkan Pesawat...</h3><p class="search-subtitle-glow">Menjelajah mencari doi buat kamu</p></div>`; 
        document.body.appendChild(overlay);
        const container = document.getElementById("paper-plane-container-box");
        const dummyPhotos = ["https://ui-avatars.com/api/?name=Alex&background=random","https://ui-avatars.com/api/?name=Budi&background=random","https://ui-avatars.com/api/?name=Caca&background=random","https://ui-avatars.com/api/?name=Deni&background=random","https://ui-avatars.com/api/?name=Eka&background=random"];
        radarInterval = setInterval(() => {
            const img = document.createElement("img");
            img.className = "floating-avatar";
            img.src = dummyPhotos[Math.floor(Math.random() * dummyPhotos.length)];
            const angle = Math.random() * Math.PI * 2;
            const radius = 60 + Math.random() * 50; 
            img.style.left = `calc(50% + ${Math.cos(angle) * radius}px)`;
            img.style.top = `calc(50% + ${Math.sin(angle) * radius}px)`;
            container.appendChild(img);
            setTimeout(() => { if (img && img.parentNode) img.remove(); }, 1500);
        }, 800);
        const lawanJenis = profile.gender === "Pria" ? "Wanita" : "Pria";
        setTimeout(async () => {
          clearInterval(radarInterval); 
          try {
            const { data: users, error } = await supabase.from("profiles").select("*").neq("id", currentUser.id).eq("gender", lawanJenis);
            document.getElementById("active-search-overlay")?.remove();
            if (error || !users || users.length === 0) return window.showToast(`Belum ada ${lawanJenis} yang tersedia.`);
            const doi = users[Math.floor(Math.random() * users.length)];
            document.getElementById("doi-photo").src = doi.avatar_url || `https://ui-avatars.com/api/?name=${doi.username}`;
            document.getElementById("doi-name-age").innerText = `${doi.username}, ${doi.umur || "?"}`;
            document.getElementById("doi-zodiac").innerText = doi.zodiac || "Rahasia";
            document.getElementById("doi-job").innerText = doi.pekerjaan || "Sibuk";
            document.getElementById("doi-hobby").innerText = doi.hobi || "Rebahan";
            document.getElementById("btn-gas-chat").onclick = () => window.location.href = `/chat?from=${doi.id}`;
            openModal("doi-card-modal");
            if (navigator.vibrate) navigator.vibrate([100, 50, 100]); 
          } catch (err) {
            document.getElementById("active-search-overlay")?.remove(); window.showToast("Gangguan koneksi.");
          }
        }, 4000); 
      };

      window.jalankanIklanIsiUlangDoi = function() {
        window.open("https://omg10.com/4/10901295", "_blank");
        closeModal("modal-limit-doi");
        window.showToast("Menunggu konfirmasi iklan...");
        setTimeout(() => {
          sisaLimitDoi = 10; localStorage.setItem('doi_limit', '10'); updateLimitUI();
          window.showToast("Kuota berhasil diisi ulang!");
        }, 15000); 
      };

      function formatTimeTelegram(dateString) {
        const dateObj = new Date(dateString);
        const isToday = dateObj.toDateString() === new Date().toDateString();
        return isToday ? dateObj.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" }) : dateObj.toLocaleDateString("id-ID", { day: "2-digit", month: "short" });
      }

      async function loadAllChats() {
        try {
          const waktu24JamLalu = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
          const [pvMsgsRes, groupsRes, globalUnreadRes] = await Promise.all([
            supabase.from("messages").select("room_id, message, created_at, sticker_url, audio_url, user_id, status, is_system").ilike("room_id", "pv_%").ilike("room_id", `%${currentUser.id}%`).gte("created_at", waktu24JamLalu).order("created_at", { ascending: false }),
            supabase.from('group_members').select(`group_id, groups(id, name, photo_url)`).eq('user_id', currentUser.id),
            supabase.from('messages').select('*', { count: 'exact', head: true }).eq('room_id', 'room-1').neq('user_id', currentUser.id).eq('status', 'sent')
          ]);
          const pvMsgs = pvMsgsRes.data;
          const groups = groupsRes.data;
          const globalUnread = globalUnreadRes.count || 0;
          const finalChatList = [{ id: 'room-1', type: 'global', name: 'HopeTalk Globe', avatar: '', preview: 'Obrolan umum komunitas', time: 'Always', unread: globalUnread, sortTime: Date.now() + 10000 }];
          const countPromises = [];
          if (pvMsgs) {
            const lastPvMessages = new Map();
            pvMsgs.forEach((msg) => {
              const pId = msg.room_id.replace("pv_", "").split("_").find(id => id !== currentUser.id);
              if (pId && !lastPvMessages.has(pId)) lastPvMessages.set(pId, msg);
            });
            const partnerIds = Array.from(lastPvMessages.keys());
            if (partnerIds.length > 0) {
              const { data: profiles } = await supabase.from("profiles").select("id, username, avatar_url, role").in("id", partnerIds);
              const profileMap = new Map(); profiles?.forEach(p => profileMap.set(p.id, p));
              partnerIds.forEach(pId => {
                const msg = lastPvMessages.get(pId);
                const profile = profileMap.get(pId); 
                if (!profile) return;
                countPromises.push((async () => {
                    let preview = msg.sticker_url ? "🖼 Stiker" : (msg.audio_url ? "🎤 Voice Note" : msg.message);
                    if (msg.message === "Pesan ini telah dihapus") preview = "🚫 Dihapus";
                    const isMe = msg.user_id === currentUser.id && !msg.is_system;
                    const statusHtml = isMe ? (msg.status === "read" ? `<span class="material-icons check-icon" style="color:#10b981;font-size:16px;">done_all</span> ` : `<span class="material-icons check-icon" style="color:var(--tg-text-muted);font-size:16px;">check</span> `) : '';
                    const { count: pvUnread } = await supabase.from('messages').select('*', { count: 'exact', head: true }).eq('room_id', msg.room_id).eq('user_id', pId).eq('status', 'sent');
                    finalChatList.push({ id: pId, type: 'private', name: profile.username, avatar: profile.avatar_url || `https://ui-avatars.com/api/?name=${profile.username}`, role: profile.role, preview: statusHtml+preview, time: formatTimeTelegram(msg.created_at), unread: pvUnread || 0, sortTime: new Date(msg.created_at).getTime() });
                })());
              });
            }
          }
          if (groups) {
            groups.forEach(g => {
              if (!g.groups) return;
              countPromises.push((async () => {
                  const { count: gUnread } = await supabase.from('messages').select('*', { count: 'exact', head: true }).eq('room_id', `group_${g.group_id}`).neq('user_id', currentUser.id).eq('status', 'sent');
                  finalChatList.push({ id: g.groups.id, type: 'group', name: g.groups.name, avatar: g.groups.photo_url || '', preview: 'Obrolan grup aktif', time: 'Aktif', unread: gUnread || 0, sortTime: Date.now() - 1000 });
              })());
            });
          }
          await Promise.all(countPromises);
          finalChatList.sort((a, b) => b.sortTime - a.sortTime);
          chatList.innerHTML = '';
          if (finalChatList.length === 1) chatList.innerHTML = `<div class="loading-state"><span class="material-icons" style="font-size:48px;color:var(--tg-primary);animation:none;">forum</span><p>Mulai cari teman untuk chat!</p></div>`;
          finalChatList.forEach(chat => {
            const div = document.createElement("div"); 
            div.className = `tg-chat-item ${chat.unread > 0 ? 'unread' : ''}`;
            div.dataset.roomId = chat.id; 
            div.onclick = () => {
              if (chat.type === 'global') window.location.href = `/chat`;
              else if (chat.type === 'group') window.location.href = `/chat?group=${chat.id}&gname=${encodeURIComponent(chat.name)}`;
              else window.location.href = `/chat?from=${chat.id}`;
            };
            let avatarHtml = chat.type === 'global' ? `<div class="tg-avatar global-avatar"><span class="material-icons">public</span></div>` : (chat.type === 'group' ? (chat.avatar ? `<img src="${chat.avatar}" class="tg-avatar">` : `<div class="tg-avatar group-avatar"><span class="material-icons">groups</span></div>`) : `<img src="${chat.avatar}" class="tg-avatar" onerror="this.src='/asets/png/profile.webp'">`);
            div.innerHTML = `${avatarHtml}<div class="tg-chat-info"><div class="tg-chat-top"><h4 class="tg-name">${chat.name.replace(/</g, "&lt;")} ${getBadgeFunc(chat.role)}</h4><span class="tg-time">${chat.time}</span></div><div class="tg-chat-bottom"><p class="tg-preview">${chat.preview}</p>${chat.unread > 0 ? `<span class="tg-unread-badge">${chat.unread>99?'99+':chat.unread}</span>` : ''}</div></div>`;
            chatList.appendChild(div);
            subscribeToTyping(chat.id, chat.type, chat.preview);
          });
          document.getElementById("searchChat").addEventListener("input", (e) => {
            const query = e.target.value.toLowerCase();
            document.querySelectorAll(".tg-chat-item").forEach(item => {
              item.style.display = item.querySelector(".tg-name").textContent.toLowerCase().includes(query) ? "flex" : "none";
            });
          });
        } catch (err) { chatList.innerHTML = '<div class="loading-state"><span class="material-icons" style="color:#ef4444;animation:none;">error_outline</span><p>Gagal memuat obrolan.</p></div>'; }
      }

      initUser();
    });
  </script>
</body>
</html>
