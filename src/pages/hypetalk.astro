---
// src/pages/hypetalk.astro
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Hypetalk - Obrolan</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  
  <script>
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark") {
      document.documentElement.classList.add("dark");
    } else {
      document.documentElement.classList.remove("dark");
    }
  </script>
</head>
<body>

  <div class="telegram-wrapper">
    
    <header class="tg-header">
      <div class="tg-header-top">
        <div class="tg-header-left">
          <button class="icon-btn menu-btn" onclick="window.location.href='/'" aria-label="Kembali">
            <span class="material-icons">arrow_back</span>
          </button>
          <h2>Hypetalk</h2>
        </div>
      </div>

      <div class="tg-search-container">
        <div class="tg-search-box">
          <span class="material-icons">search</span>
          <input type="text" id="searchChat" placeholder="Cari obrolan..." autocomplete="off" />
        </div>
      </div>
    </header>

    <main class="tg-chat-list" id="chatList">
      <div class="loading-state">
        <span class="material-icons loading-spinner">sync</span>
        <p>Memuat obrolan...</p>
      </div>
    </main>

    <button class="tg-fab" id="btn-new-chat" aria-label="Chat Baru">
      <span class="material-icons">chat</span>
    </button>

    <div id="search-modal" class="search-modal-overlay" style="display: none;">
      <div class="search-modal-content">
        <div class="search-modal-header">
          <h3>Mulai Chat Baru</h3>
          <button class="close-modal-btn" id="close-search-modal" aria-label="Tutup popup"><span class="material-icons">close</span></button>
        </div>
        <p style="font-size: 13px; color: var(--tg-text-muted); margin-bottom: 12px;">Masukkan ID unik temanmu (contoh: 0E870)</p>
        <div class="search-input-group">
          <span class="material-icons">tag</span>
          <input type="text" id="input-new-id" placeholder="Ketik ID teman..." autocomplete="off" />
        </div>
        <button class="search-action-btn" id="btn-find-user">Cari & Chat</button>
      </div>
    </div>

  </div>

  <style is:global>
    @keyframes spin { 100% { transform: rotate(360deg); } }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    :root {
      --tg-bg: #ffffff;
      --tg-bg-secondary: #f4f5f7;
      --tg-text: #111827;
      --tg-text-muted: #6b7280;
      --tg-border: #e5e7eb;
      --tg-primary: #1DA1F2;
      --tg-hover: #f9fafb;
    }

    html.dark {
      --tg-bg: #15171a;
      --tg-bg-secondary: #1f2226;
      --tg-text: #f9fafb;
      --tg-text-muted: #9ca3af;
      --tg-border: #2a2d31;
      --tg-hover: #1b1e22;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
    
    body { background: #e5e7eb; display: flex; justify-content: center; height: 100dvh; overflow: hidden; transition: background 0.3s ease; }
    html.dark body { background: #000000; }

    .telegram-wrapper { 
      width: 100%; max-width: 480px; height: 100dvh; display: flex; flex-direction: column; 
      background: var(--tg-bg); position: relative; box-shadow: 0 0 20px rgba(0,0,0,0.05); 
      transition: background 0.3s ease; 
    }
    html.dark .telegram-wrapper { box-shadow: none; border-left: 1px solid var(--tg-border); border-right: 1px solid var(--tg-border); }

    /* HEADER */
    .tg-header { 
      background: var(--tg-bg); z-index: 10; transition: background 0.3s ease; 
    }

    .tg-header-top { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; }
    .tg-header-left { display: flex; align-items: center; gap: 16px; }
    .tg-header-left h2 { font-size: 20px; font-weight: 700; color: var(--tg-text); letter-spacing: -0.3px; transition: color 0.3s ease; }

    .icon-btn { background: none; border: none; color: var(--tg-text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; transition: all 0.2s ease; }
    .icon-btn:active { background: var(--tg-border); transform: scale(0.95); }

    /* SEARCH BAR */
    .tg-search-container { padding: 4px 16px 12px; }
    .tg-search-box { 
      display: flex; align-items: center; background: var(--tg-bg-secondary); border-radius: 12px; padding: 10px 16px; gap: 12px; 
      transition: all 0.2s ease; border: 1px solid transparent;
    }
    .tg-search-box:focus-within { background: var(--tg-bg); border-color: var(--tg-primary); box-shadow: 0 4px 12px rgba(29, 161, 242, 0.08); }
    .tg-search-box .material-icons { color: var(--tg-text-muted); font-size: 20px; transition: color 0.2s; }
    .tg-search-box:focus-within .material-icons { color: var(--tg-primary); }
    .tg-search-box input { flex: 1; border: none; background: transparent; outline: none; font-size: 15px; color: var(--tg-text); transition: color 0.2s ease; }
    .tg-search-box input::placeholder { color: var(--tg-text-muted); }

    /* LIST CHAT */
    .tg-chat-list { flex: 1; overflow-y: auto; padding-bottom: 100px; }
    .tg-chat-list::-webkit-scrollbar { width: 0; } 

    .tg-chat-item { 
      display: flex; align-items: center; gap: 14px; padding: 10px 16px; cursor: pointer; user-select: none; 
      transition: background 0.2s; position: relative; animation: fadeIn 0.3s ease forwards;
    }
    .tg-chat-item:active { background: var(--tg-hover); }

    .tg-avatar { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: none !important; }
    .global-avatar { background: linear-gradient(135deg, #1DA1F2, #007bb5); display: flex; align-items: center; justify-content: center; color: white; }
    .group-avatar { background: linear-gradient(135deg, #f59e0b, #d97706); display: flex; align-items: center; justify-content: center; color: white; }

    .tg-chat-info { flex: 1; min-width: 0; border-bottom: 1px solid var(--tg-border); padding-bottom: 12px; padding-top: 2px; display: flex; flex-direction: column; justify-content: center; height: 100%; transition: border-color 0.3s ease; }
    .tg-chat-item:last-child .tg-chat-info { border-bottom: none; }

    .tg-chat-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .tg-name { font-size: 16px; font-weight: 600; color: var(--tg-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: flex; align-items: center; gap: 4px; transition: color 0.3s ease; }
    
    .verified-badge { color: var(--tg-primary); display: flex; align-items: center; }
    .verified-badge .material-icons { font-size: 15px; }

    .tg-time { font-size: 12px; font-weight: 500; color: var(--tg-text-muted); flex-shrink: 0; }
    .tg-chat-item.unread .tg-time { color: var(--tg-primary); font-weight: 600; }

    .tg-chat-bottom { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
    .tg-preview { font-size: 14px; color: var(--tg-text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; display: flex; align-items: center; gap: 4px; transition: color 0.3s ease; }
    .tg-chat-item.unread .tg-preview { color: var(--tg-text); font-weight: 500; }

    .check-icon { font-size: 16px; color: #10b981; }

    .tg-unread-badge { background: var(--tg-primary); color: white; font-size: 11px; font-weight: 700; min-width: 22px; height: 22px; border-radius: 99px; display: flex; align-items: center; justify-content: center; padding: 0 6px; flex-shrink: 0; }

    /* FAB */
    .tg-fab { 
      position: absolute; bottom: max(30px, env(safe-area-inset-bottom) + 20px); right: 20px; 
      width: 56px; height: 56px; border-radius: 50%; background: var(--tg-primary); border: none; color: white; 
      box-shadow: 0 4px 14px rgba(29, 161, 242, 0.4); cursor: pointer; display: flex; align-items: center; justify-content: center; 
      transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275); z-index: 50; 
    }
    .tg-fab:active { transform: scale(0.9); }
    .tg-fab .material-icons { font-size: 24px; }
    
    /* 🔥 CSS UNTUK MENYEMBUNYIKAN FAB AGAR TIDAK KETUTUP/MENUTUPI 🔥 */
    .tg-fab.hidden {
      display: none !important;
    }

    /* MODAL CARI TEMAN (POPUP FULL LOGIC) */
    .search-modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 100; display: flex; align-items: flex-end; justify-content: center; animation: fadeIn 0.2s ease; }
    .search-modal-content { background: var(--tg-bg); width: 100%; border-top-left-radius: 20px; border-top-right-radius: 20px; padding: 24px; animation: slideUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .search-modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .search-modal-header h3 { color: var(--tg-text); font-size: 18px; font-weight: 700; }
    .close-modal-btn { background: none; border: none; color: var(--tg-text-muted); cursor: pointer; display: flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 50%; background: var(--tg-bg-secondary); }
    .search-input-group { display: flex; align-items: center; background: var(--tg-bg-secondary); border-radius: 12px; padding: 12px 16px; gap: 12px; border: 1px solid var(--tg-border); margin-bottom: 16px; }
    .search-input-group input { flex: 1; border: none; background: transparent; outline: none; font-size: 15px; color: var(--tg-text); }
    .search-input-group .material-icons { color: var(--tg-text-muted); font-size: 18px; }
    .search-action-btn { width: 100%; background: var(--tg-primary); color: white; border: none; padding: 14px; border-radius: 12px; font-size: 15px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .search-action-btn:active { background: #007bb5; }

    .loading-state { text-align: center; padding: 60px 20px; color: var(--tg-text-muted); display: flex; flex-direction: column; align-items: center; gap: 12px; }
    .loading-spinner { font-size: 32px; animation: spin 1s linear infinite; color: var(--tg-primary); }
    .loading-state p { font-size: 14px; font-weight: 500; }
  </style>

  <script>
    document.addEventListener("DOMContentLoaded", async () => {
      const chatList = document.getElementById("chatList");
      const searchInput = document.getElementById("searchChat");
      let currentUser = null;

      // =====================================
      // 🔥 LOGIKA FAB (TOMBOL CHAT BARU) 🔥
      // =====================================
      const fabBtn = document.getElementById("btn-new-chat");
      const searchModal = document.getElementById("search-modal");
      const closeModalBtn = document.getElementById("close-search-modal");
      const inputNewId = document.getElementById("input-new-id");
      const btnFindUser = document.getElementById("btn-find-user");

      if (fabBtn && searchModal) {
        fabBtn.addEventListener("click", () => {
          searchModal.style.display = "flex";
          // 🔥 SEMBUNYIKAN FAB SECARA INSTAN DI LAYAR PRIBADI 🔥
          fabBtn.classList.add("hidden"); 
          setTimeout(() => inputNewId?.focus(), 100);
        });

        // 🔥 FUNGSI REUSABLE UNTUK TUTUP MODAL & MUNCULIN LAGI FAB 🔥
        const closeNewChatModal = () => {
          searchModal.style.display = "none";
          fabBtn.classList.remove("hidden"); // Munculkan FAB kembali secara instan
          if (inputNewId) inputNewId.value = ''; // Bersihkan input
        }

        closeModalBtn.addEventListener("click", closeNewChatModal);

        searchModal.addEventListener("click", (e) => {
          // Tutup kalau user klik area dimmed di luar modal content
          if (e.target === searchModal) closeNewChatModal();
        });

        btnFindUser.addEventListener("click", async () => {
          const searchValue = inputNewId?.value.trim().toUpperCase().replace("#", "");
          if (!searchValue) return alert("Masukkan ID teman dulu bro!");
          
          btnFindUser.innerText = "Mencari...";
          btnFindUser.disabled = true;

          try {
            const { supabase } = await import('../lib/supabase.js');
            const { data: friend, error } = await supabase
              .from("profiles")
              .select("id, username")
              .eq("short_id", searchValue)
              .single();

            if (error || !friend) throw new Error("ID tidak ditemukan!");
            if (friend.id === currentUser?.id) throw new Error("Masa chat ke diri sendiri bro?");

            // 🔥 TUTUP MODAL SEBELUM PINDAH HALAMAN 🔥
            closeNewChatModal();

            // Langsung arahkan ke halaman chat berdua
            window.location.href = `/chat?from=${friend.id}`;
          } catch (err) {
            alert(err.message);
          } finally {
            btnFindUser.innerText = "Cari & Chat";
            btnFindUser.disabled = false;
          }
        });
      }

      function formatTimeTelegram(dateString) {
        const dateObj = new Date(dateString);
        const today = new Date();
        const isToday = dateObj.toDateString() === today.toDateString();
        if (isToday) return dateObj.toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
        const diffTime = Math.abs(today - dateObj);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
        if (diffDays === 1) return "Kemarin";
        if (diffDays < 7) return dateObj.toLocaleDateString("id-ID", { weekday: "short" });
        return dateObj.toLocaleDateString("id-ID", { day: "2-digit", month: "short" });
      }

      async function loadAllChats() {
        try {
          const { supabase } = await import('../lib/supabase.js');
          const { data: { user }, error: authError } = await supabase.auth.getUser();
          if (authError || !user) {
            chatList.innerHTML = '<div class="loading-state"><span class="material-icons" style="color:#ef4444; animation:none;">error_outline</span><p>Silakan login dulu bro.</p></div>';
            return;
          }
          currentUser = user;

          const waktu24JamLalu = new Date(Date.now() - 24 * 60 * 60 * 1000).toISOString();
          
          const { data: pvMsgs } = await supabase
            .from("messages")
            .select("room_id, message, created_at, sticker_url, audio_url, user_id, status, is_system")
            .ilike("room_id", "pv_%").ilike("room_id", `%${currentUser.id}%`)
            .gte("created_at", waktu24JamLalu).order("created_at", { ascending: false });

          const { data: groups } = await supabase
            .from('group_members')
            .select(`group_id, groups(id, name, photo_url)`)
            .eq('user_id', currentUser.id);

          const finalChatList = [];

          let unreadGlobal = parseInt(localStorage.getItem('unread_room-1') || '0');
          finalChatList.push({
            id: 'room-1', type: 'global', name: 'HopeTalk Globe', avatar: '',
            preview: 'Obrolan umum komunitas', time: 'Always', unread: unreadGlobal, sortTime: Date.now() + 10000 
          });

          const lastPvMessages = new Map();
          const unreadPvCounts = new Map();

          if (pvMsgs) {
            pvMsgs.forEach((msg) => {
              const partnerId = msg.room_id.replace("pv_", "").split("_").find((id) => id !== currentUser.id);
              if (!partnerId) return;
              if (!lastPvMessages.has(partnerId)) lastPvMessages.set(partnerId, msg);
              if (msg.user_id !== currentUser.id && msg.status !== "read" && !msg.is_system) {
                unreadPvCounts.set(partnerId, (unreadPvCounts.get(partnerId) || 0) + 1);
              }
            });

            const partnerIds = Array.from(lastPvMessages.keys());
            if (partnerIds.length > 0) {
              const { data: profiles } = await supabase.from("profiles").select("id, username, avatar_url, role").in("id", partnerIds);
              const profileMap = new Map();
              profiles?.forEach(p => profileMap.set(p.id, p));

              lastPvMessages.forEach((msg, pId) => {
                const profile = profileMap.get(pId);
                if (!profile) return;
                
                let previewText = msg.sticker_url ? "🖼 Mengirim Stiker" : (msg.audio_url ? "🎤 Mengirim Voice Note" : msg.message);
                if (msg.message === "Pesan ini telah dihapus") previewText = "🚫 Pesan dihapus";

                const isMe = msg.user_id === currentUser.id && !msg.is_system;
                const statusCheck = isMe ? (msg.status === "read" ? `<span class="material-icons check-icon" style="color:#10b981; font-size:16px; margin-right:4px;">done_all</span>` : `<span class="material-icons check-icon" style="color:var(--tg-text-muted); font-size:16px; margin-right:4px;">check</span>`) : '';

                finalChatList.push({
                  id: pId, type: 'private', name: profile.username || "User",
                  avatar: profile.avatar_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(profile.username)}`,
                  role: profile.role, preview: `${statusCheck}${previewText}`,
                  time: formatTimeTelegram(msg.created_at), unread: unreadPvCounts.get(pId) || 0,
                  sortTime: new Date(msg.created_at).getTime()
                });
              });
            }
          }

          if (groups) {
            groups.forEach(g => {
              const group = g.groups;
              if (!group) return;
              let unreadGrp = parseInt(localStorage.getItem('unread_group_' + group.id) || '0');
              finalChatList.push({
                id: group.id, type: 'group', name: group.name, avatar: group.photo_url || '',
                preview: 'Klik untuk melihat obrolan grup', time: 'Aktif', unread: unreadGrp, sortTime: Date.now() - 1000 
              });
            });
          }

          finalChatList.sort((a, b) => b.sortTime - a.sortTime);

          chatList.innerHTML = '';
          
          if (finalChatList.length === 1 && finalChatList[0].type === 'global') {
            chatList.innerHTML = `<div class="loading-state" style="opacity:0.7;"><span class="material-icons" style="font-size:48px; color:var(--tg-primary); animation:none;">forum</span><p>Mulai cari doi untuk melihat riwayat chat pribadi di sini.</p></div>`;
          }

          finalChatList.forEach(chat => {
            const div = document.createElement("div");
            div.className = `tg-chat-item ${chat.unread > 0 ? 'unread' : ''}`;
            div.onclick = () => { window.location.href = chat.type === 'global' ? `/chat` : `/chat?from=${chat.id}`; };

            let avatarHtml = '';
            if (chat.type === 'global') avatarHtml = `<div class="tg-avatar global-avatar"><span class="material-icons">public</span></div>`;
            else if (chat.type === 'group') avatarHtml = chat.avatar ? `<img src="${chat.avatar}" class="tg-avatar">` : `<div class="tg-avatar group-avatar"><span class="material-icons">groups</span></div>`;
            else avatarHtml = `<img src="${chat.avatar}" class="tg-avatar" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(chat.name)}'">`;

            let roleBadge = '';
            if (chat.role === 'admin') roleBadge = `<span class="badge" style="background:#ef4444; color:white; font-size:9px; padding:2px 6px; border-radius:4px; margin-left:6px; font-weight:800;">ADMIN</span>`;
            if (chat.role === 'verified') roleBadge = `<span class="verified-badge"><span class="material-icons">verified</span></span>`;

            div.innerHTML = `
              ${avatarHtml}
              <div class="tg-chat-info">
                <div class="tg-chat-top">
                  <h4 class="tg-name">${escapeHtml(chat.name)} ${roleBadge}</h4>
                  <span class="tg-time">${chat.time}</span>
                </div>
                <div class="tg-chat-bottom">
                  <p class="tg-preview">${chat.preview}</p>
                  ${chat.unread > 0 ? `<span class="tg-unread-badge">${chat.unread > 99 ? '99+' : chat.unread}</span>` : ''}
                </div>
              </div>
            `;
            chatList.appendChild(div);
          });

          if (searchInput) {
            searchInput.addEventListener("input", (e) => {
              const query = e.target.value.toLowerCase();
              const items = document.querySelectorAll(".tg-chat-item");
              items.forEach(item => {
                const name = item.querySelector(".tg-name").textContent.toLowerCase();
                item.style.display = name.includes(query) ? "flex" : "none";
              });
            });
          }

        } catch (err) {
          console.error(err);
          chatList.innerHTML = '<div class="loading-state"><span class="material-icons" style="color:#ef4444; animation:none;">error_outline</span><p>Gagal memuat history chat.</p></div>';
        }
      }

      function escapeHtml(str = "") { return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); }
      loadAllChats();
    });
  </script>
</body>
</html>
