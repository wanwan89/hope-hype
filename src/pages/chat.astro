---
import Layout from '../layouts/Layout.astro';

// Perhatiin jalurnya bro, harus lewat folder /chat/ dulu
import ChatHeader from '../components/chat/ChatHeader.astro';
import Sidebar from '../components/chat/Sidebar.astro';
import ChatArea from '../components/chat/ChatArea.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';

import '../styles/chat.css';
---

<Layout title="HopeTalk globe">
  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <ChatHeader />
    <Sidebar />
    <ChatArea />
    <ChatInput />
    <ChatModals />
  </div>

<script is:inline type="module">
  import { createClient } from "https://esm.sh/@supabase/supabase-js";

  // ===== Supabase config =====
  const SUPABASE_URL = "https://hqetnqnvmdxdgfnnluew.supabase.co";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZXRucW52bWR4ZGdmbm5sdWV3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3MzUyODIsImV4cCI6MjA4NzMxMTI4Mn0.Cr9lDBZMqfeONi1dfyFzHpBtawBzZTQLBEWKmPJVAOA";

  window.supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // ===== Global State =====
  window.currentUser = null;
  window.myUsername = "Guest";
  window.myRole = "user";

  const profileCache = new Map();

  // ===== Get Profile (FIXED) =====
  window.getCachedProfile = async function(userId) {
    try {
      if (!userId) return null;

      if (profileCache.has(userId)) return profileCache.get(userId);

      const { data, error } = await window.supabase
        .from("profiles")
        .select("username, avatar_url, role, short_id, gender")
        .eq("id", userId)
        .single();

      if (error) {
        console.error("PROFILE ERROR:", error);
        return null;
      }

      if (data) {
        profileCache.set(userId, data);
      }

      return data;
    } catch (err) {
      console.error("GET PROFILE CRASH:", err);
      return null;
    }
  };

  // ===== LOGIN CHECK (FIXED) =====
  window.requireLogin = async function() {
    try {
      const { data: { session }, error } = await window.supabase.auth.getSession();

      if (error || !session || !session.user) {
        console.warn("Belum login, redirect...");
        window.location.href = "/login";
        return false;
      }

      window.currentUser = { id: session.user.id };
      return true;

    } catch (err) {
      console.error("LOGIN ERROR:", err);
      return false;
    }
  };

window.loadProfile = async function() {
  try {
    const userId = window.currentUser?.id;
    if (!userId) return;

    const profile = await window.getCachedProfile(userId);

    if (!profile) {
      console.warn("Profile kosong");
      return;
    }

    window.myUsername = profile.username || "Guest";
    window.myRole = profile.role || "user";

    // ⏳ biar nunggu Astro render
    setTimeout(() => {
      const usernameEl = document.getElementById("my-username");
      const idEl = document.getElementById("my-id");

      if (usernameEl) usernameEl.textContent = window.myUsername;
      if (idEl) idEl.textContent = `#${profile.short_id || "0000"}`;

      console.log("UI UPDATED");
    }, 200);

    console.log("PROFILE LOADED:", profile);

  } catch (err) {
    console.error("LOAD PROFILE ERROR:", err);
  }
};
  // ===== INIT APP (FIXED FLOW) =====
  async function init() {
    try {
      console.log("INIT START");

      const ok = await window.requireLogin();
      if (!ok) return;

      await window.loadProfile();

      // ===== OPTIONAL (biar gak error kalau belum ada) =====
      if (typeof initPresence === "function") await initPresence();
      if (typeof refreshSidebar === "function") await refreshSidebar();
      if (typeof initRealtimeMessages === "function") initRealtimeMessages();
      if (typeof loadMessages === "function") await loadMessages();
      if (typeof updateHeaderStatus === "function") updateHeaderStatus();
      if (typeof fetchStickers === "function") fetchStickers();
      if (typeof scrollToBottom === "function") scrollToBottom();

      console.log("INIT DONE");

    } catch (err) {
      console.error("INIT ERROR:", err);
    }
  }

  init();
</script>
</Layout>
