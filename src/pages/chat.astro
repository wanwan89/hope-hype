---
import Layout from '../layouts/Layout.astro';
import ChatHeader from '../components/chat/ChatHeader.astro';
import ChatSidebar from '../components/chat/ChatSidebar.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    (function() {
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') applyTheme();
      });
    })();
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <ChatHeader />
    <ChatSidebar />
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-input-wrapper">
        <ChatInput />
    </div>
  </div>

  <ChatModals />

  <script is:inline src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
  <script src="../scripts/chatLogic.js"></script>
</Layout>

<style is:global>
/* --- 🎨 THEME VARIABLES --- */
:root {
  --bg-chat-solid: #e5ddd5;
  --bg-sidebar: #ffffff;
  --bg-header: #3a7bd5;
  --bg-input-bar: #ffffff;
  --bg-input-field: #f4f5f7;
  --bg-bubble-self: #dcf8c6;
  --bg-bubble-other: #ffffff;
  --text-main: #333333;
  --text-msg: #111b21;
  --text-muted: #666666;
  --border-color: #eaeaea;
}

:root.dark {
  --bg-chat-solid: #0b141a;
  --bg-sidebar: #111b21;
  --bg-header: #202c33;
  --bg-input-bar: #202c33;
  --bg-input-field: #2a3942;
  --bg-bubble-self: #005c4b;
  --bg-bubble-other: #202c33;
  --text-main: #e9edef;
  --text-msg: #e9edef;
  --text-muted: #8696a0;
  --border-color: #313d45;
}

/* --- 🛠️ LAYOUT FIX (HEADER & INPUT DIEM) --- */
html, body {
  margin: 0; padding: 0; 
  height: 100vh; height: 100dvh; 
  font-family: "Poppins", sans-serif;
  background-color: var(--bg-chat-solid) !important;
  color: var(--text-main);
  overflow: hidden; 
}

.telegram-chat {
  display: flex; 
  flex-direction: column; 
  height: 100%; 
  width: 100%;
  overflow: hidden; 
  background-color: var(--bg-chat-solid) !important;
  background-image: url("/asets/png/chat.png");
  background-blend-mode: overlay;
  background-size: 400px;
  position: relative; 
  z-index: 1;
}

:root.dark .telegram-chat {
  background-image: linear-gradient(rgba(11,20,26,0.95), rgba(11,20,26,0.95)), url("/asets/png/chat.png") !important;
  background-blend-mode: normal;
}

.chat-header { flex-shrink: 0; position: relative; z-index: 1000; }
.chat-messages { flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; -webkit-overflow-scrolling: touch; }
.chat-input-wrapper { flex-shrink: 0; position: relative; z-index: 1000; background: var(--bg-input-bar) !important; padding-bottom: env(safe-area-inset-bottom, 12px); }

/* ========================================================= */
/* 🔥 FIX TOTAL BUBBLE CHAT (FOTO DI DALAM BUBBLE) 🔥        */
/* ========================================================= */
.chat-message {
  display: flex;
  align-items: flex-start; /* Sejajarkan foto dan teks di atas */
  width: fit-content;
  max-width: 85%; 
  position: relative;
  margin-bottom: 4px;
  padding: 8px 10px; /* Padding ditaruh di bungkus luar */
  border-radius: 15px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  gap: 8px; /* Jarak antara foto profil dan teks */
}

/* Pengaturan Pesan Sendiri (Self) */
.chat-message.self { 
  align-self: flex-end; 
  flex-direction: row-reverse; /* Foto di kanan, teks di kiri */
  background: var(--bg-bubble-self) !important;
  border-bottom-right-radius: 4px;
}

/* Pengaturan Pesan Orang Lain (Other) */
.chat-message.other { 
  align-self: flex-start; 
  flex-direction: row; /* Foto di kiri, teks di kanan */
  background: var(--bg-bubble-other) !important;
  border-bottom-left-radius: 4px;
}

/* Reset Background Content (Karena Background pindah ke luar) */
.chat-message .content {
  display: flex;
  flex-direction: column;
  max-width: 100%; 
  overflow: hidden; 
  background: transparent !important; /* Wajib transparan */
  box-shadow: none !important;
  padding: 0 !important;
  border-radius: 0 !important;
}

/* Foto Profil Masuk ke Dalam Bubble */
.chat-message .avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  flex-shrink: 0; /* Biar gak gepeng */
  object-fit: cover;
  display: block !important;
  margin: 0 !important; 
  margin-top: 2px !important; /* Sejajarkan dengan nama */
}

/* Teks & Nama */
.chat-message .text { color: var(--text-msg); line-height: 1.4; word-break: break-word; font-size: 14px; }
.chat-message .username { color: var(--bg-header); font-weight: 700; font-size: 12px; margin-bottom: 2px; }
:root.dark .chat-message .username { color: #00a884; }

/* Fix Gambar & Stiker di Dalam Chat */
.chat-message .text img {
  width: 100% !important; 
  max-width: 220px !important; 
  height: auto !important;
  border-radius: 8px;
  margin: 5px 0;
  display: block;
}
.chat-message .text img[src*="sticker"] { max-width: 120px !important; }
/* ========================================================= */


/* --- 💀 ADAPTIVE SKELETON LOADING --- */
.chat-loading-screen { display: flex; flex-direction: column; gap: 20px; padding: 20px 15px; animation: fadeInChatLoading 0.25s ease; }
.skeleton-msg { display: flex; align-items: flex-end; gap: 8px; max-width: 80%; }
.skeleton-msg.left { align-self: flex-start; }
.skeleton-msg.right { align-self: flex-end; flex-direction: row-reverse; }
.skeleton-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--border-color); flex-shrink: 0; opacity: 0.6; }
.skeleton-bubble { background: var(--bg-bubble-other); border-radius: 15px; padding: 12px; min-width: 140px; opacity: 0.6; position: relative; overflow: hidden; }
.skeleton-bubble.me { background: var(--bg-bubble-self); min-width: 100px; }

.shimmer { position: relative; overflow: hidden; background-color: rgba(0,0,0,0.05) !important; }
:root.dark .shimmer { background-color: rgba(255,255,255,0.05) !important; }
.shimmer::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); animation: shimmerMove 1.5s infinite; transform: translateX(-100%); }

.skeleton-line { height: 10px; border-radius: 5px; margin-bottom: 8px; }
.skeleton-line:last-child { margin-bottom: 0; }
.w1 { width: 150px; } .w2 { width: 120px; } .w3 { width: 80px; } .w4 { width: 100px; } .w5 { width: 60px; }

/* Typing Bubble */
.typing-bubble { display: flex; gap: 4px; padding: 12px 15px; align-items: center; width: fit-content; }
.typing-bubble span { width: 6px; height: 6px; background: var(--text-muted); border-radius: 50%; opacity: 0.4; animation: typingBounce 1.4s infinite; }
.typing-bubble span:nth-child(2) { animation-delay: 0.2s; }
.typing-bubble span:nth-child(3) { animation-delay: 0.4s; }
.loading-chat-hint { text-align: center; font-size: 11px; color: var(--text-muted); margin-top: 20px; font-style: italic; }

/* Sidebar UI Fix */
.sidebar { background: var(--bg-sidebar) !important; border-right: 1px solid var(--border-color); height: 100%; position: fixed; z-index: 2000; }
:root.dark :global(#private-chat-list), :root.dark :global(.sidebar-chat-item) { background-color: var(--bg-sidebar) !important; }

/* Scrollbar */
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(128, 128, 128, 0.3); border-radius: 10px; }

/* Animations */
@keyframes shimmerMove { 100% { transform: translateX(100%); } }
@keyframes typingBounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-5px); } }
@keyframes fadeInChatLoading { from { opacity: 0; } to { opacity: 1; } }

@media (max-width: 480px) {
  .chat-message { max-width: 88%; }
  .chat-message .text img { max-width: 200px !important; }
}
</style>
