---
import Layout from '../layouts/Layout.astro';
import ChatHeader from '../components/chat/ChatHeader.astro';
import ChatSidebar from '../components/chat/ChatSidebar.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    (function() {
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') applyTheme();
      });
    })();
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>
  <audio id="ringtone" src="/asets/sound/ringtone.mp3" preload="auto" loop></audio>

  <div id="toast-container" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999999; display: flex; flex-direction: column; gap: 10px; width: 90%; max-width: 400px; pointer-events: none;"></div>

  <div class="telegram-chat">
    <ChatHeader />
    <ChatSidebar />
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-input-wrapper">
      <ChatInput />
    </div>
  </div>

  <ChatModals />

  <script is:inline src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
  <script src="../scripts/chatLogic.js"></script>
</Layout>

<style is:global>
/* --- 🎨 THEME VARIABLES --- */
:root {
  --bg-chat-solid: #e5ddd5;
  --bg-sidebar: #ffffff;
  --bg-header: #3a7bd5;
  --bg-input-bar: #ffffff;
  --bg-input-field: #f4f5f7;
  --bg-bubble-self: #dcf8c6;
  --bg-bubble-other: #ffffff;
  --text-main: #333333;
  --text-msg: #111b21;
  --text-muted: #666666;
  --border-color: #eaeaea;
}

:root.dark {
  --bg-chat-solid: #0b141a;
  --bg-sidebar: #111b21;
  --bg-header: #202c33;
  --bg-input-bar: #202c33;
  --bg-input-field: #2a3942;
  --bg-bubble-self: #005c4b;
  --bg-bubble-other: #202c33;
  --text-main: #e9edef;
  --text-msg: #e9edef;
  --text-muted: #8696a0;
  --border-color: #313d45;
}

/* --- 🛠️ LAYOUT DASAR --- */
html, body {
  margin: 0; padding: 0; 
  height: 100%; min-height: -webkit-fill-available;
  font-family: "Poppins", sans-serif;
  background-color: var(--bg-chat-solid) !important;
  color: var(--text-main);
  overflow: hidden; 
}

.telegram-chat {
  display: flex; flex-direction: column; 
  height: 100vh; height: 100dvh; height: -webkit-fill-available; 
  width: 100%; overflow: hidden; 
  background-color: var(--bg-chat-solid) !important;
  background-image: url("/asets/png/chat.png");
  background-blend-mode: overlay; background-size: 400px;
  position: relative; z-index: 1;
}

:root.dark .telegram-chat {
  background-image: linear-gradient(rgba(11,20,26,0.95), rgba(11,20,26,0.95)), url("/asets/png/chat.png") !important;
  background-blend-mode: normal;
}

.chat-header { flex-shrink: 0; position: relative; z-index: 1000; }
.chat-messages { flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; -webkit-overflow-scrolling: touch; }

/* ========================================================= */
/* 🔥 BUG FIX 1: INPUT TEMBUS STIKER 🔥                      */
/* ========================================================= */
.chat-input-wrapper { 
  flex-shrink: 0; 
  position: relative; 
  z-index: 2000; 
  background-color: var(--bg-input-bar) !important; 
  /* Kunci area bawah layar HP (Poni/Nav Bar) dengan warna solid */
  padding-bottom: env(safe-area-inset-bottom, 0px); 
}

.chat-input-container-main, #sticker-menu {
  background-color: var(--bg-input-bar) !important;
}

/* ========================================================= */
/* 🔥 BUG FIX 2: SIDEBAR MASIH PUTIH DI DARK MODE 🔥         */
/* ========================================================= */
/* Paksa hajar semua inline style warna putih di dalam sidebar */
:root.dark .sidebar,
:root.dark #sidebar,
:root.dark .sidebar-section,
:root.dark .sidebar-footer,
:root.dark #private-chat-list,
:root.dark .sidebar div[style*="background: #fff"],
:root.dark .sidebar div[style*="background: white"],
:root.dark .sidebar div[style*="background:#fff"],
:root.dark .sidebar div[style*="background:white"] {
  background: var(--bg-sidebar) !important;
  background-color: var(--bg-sidebar) !important;
  color: var(--text-main) !important;
  border-color: var(--border-color) !important;
}

/* ========================================================= */
/* 🔥 BUG FIX 3: MODAL NELPON (CALL UI) GAK MUNCUL 🔥        */
/* ========================================================= */
/* Paksa z-index modal dari ChatModals.astro ke level dewa */
#call-overlay, 
#incoming-call-overlay,
.modal-overlay,
.delete-overlay {
  z-index: 9999999 !important;
}

/* ========================================================= */
/* 🔥 BUG FIX 4: BUBBLE CHAT RAPI (TEKS & NAMA GAK NUMPUK) 🔥*/
/* ========================================================= */
.chat-message {
  display: flex;
  align-items: flex-start; 
  gap: 8px; 
  width: fit-content;
  max-width: 85%; 
  padding: 8px 10px; 
  border-radius: 15px;
  position: relative;
  box-shadow: 0 1px 2px rgba(0,0,0,0.15);
  margin-bottom: 2px;
}

.chat-message.self { 
  align-self: flex-end; 
  flex-direction: row-reverse; 
  background: var(--bg-bubble-self) !important;
  border-bottom-right-radius: 4px;
}

.chat-message.other { 
  align-self: flex-start; 
  flex-direction: row; 
  background: var(--bg-bubble-other) !important;
  border-bottom-left-radius: 4px;
}

.chat-message .avatar {
  width: 28px; height: 28px;
  border-radius: 50%;
  flex-shrink: 0; 
  object-fit: cover;
  margin: 0 !important;
  margin-top: 2px !important; 
  display: block !important;
}

/* Paksa Teks dan Nama berbaris ke bawah (Column) biar gak numpuk */
.chat-message > div:not(.avatar), .chat-message .text {
  display: flex;
  flex-direction: column;
  min-width: 0; 
  background: transparent !important; 
  box-shadow: none !important;
  padding: 0 !important;
  border-radius: 0 !important;
}

.chat-message .username { 
  font-weight: 700; 
  font-size: 12px; 
  margin-bottom: 4px; 
  display: block;
}
/* Warna Nama ngikutin pengirimnya */
.chat-message.self .username { color: #00a884; align-self: flex-end; }
.chat-message.other .username { color: var(--bg-header); align-self: flex-start; }
:root.dark .chat-message.other .username { color: #00a884; }

.chat-message .text { color: var(--text-msg); line-height: 1.4; word-break: break-word; font-size: 14px; }

/* Jam & Tanda Centang */
.message-info {
  display: flex; justify-content: flex-end; align-items: center;
  gap: 4px; margin-top: 4px; font-size: 10px; color: var(--text-muted);
  align-self: flex-end; /* Paksa jam selalu di pojok kanan bawah */
}
.status-icon.read { color: #53bdeb; }

/* Fix Gambar & Stiker di Dalam Chat */
.chat-message .text img {
  width: 100% !important; max-width: 220px !important; height: auto !important;
  border-radius: 8px; margin: 5px 0; display: block;
}
.chat-message .text img[src*="sticker"] { max-width: 120px !important; }

/* --- 💀 ADAPTIVE SKELETON LOADING --- */
.chat-loading-screen { display: flex; flex-direction: column; gap: 20px; padding: 20px 15px; animation: fadeInChatLoading 0.25s ease; }
.skeleton-msg { display: flex; align-items: flex-start; gap: 8px; max-width: 80%; padding: 10px; border-radius: 15px; }
.skeleton-msg.left { align-self: flex-start; background: var(--bg-bubble-other); border-bottom-left-radius: 4px; }
.skeleton-msg.right { align-self: flex-end; flex-direction: row-reverse; background: var(--bg-bubble-self); border-bottom-right-radius: 4px;}
.skeleton-avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--border-color); flex-shrink: 0; opacity: 0.6; }
.skeleton-bubble { display: flex; flex-direction: column; gap: 8px; flex: 1; }
.shimmer { position: relative; overflow: hidden; background-color: rgba(0,0,0,0.05) !important; }
:root.dark .shimmer { background-color: rgba(255,255,255,0.05) !important; }
.shimmer::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); animation: shimmerMove 1.5s infinite; transform: translateX(-100%); }
.skeleton-line { height: 10px; border-radius: 5px; }
.w1 { width: 140px; } .w2 { width: 100px; } .w3 { width: 80px; } 

/* Typing Bubble */
.typing-bubble { display: flex; gap: 4px; padding: 12px 15px; align-items: center; width: fit-content; }
.typing-bubble span { width: 6px; height: 6px; background: var(--text-muted); border-radius: 50%; opacity: 0.4; animation: typingBounce 1.4s infinite; }
.typing-bubble span:nth-child(2) { animation-delay: 0.2s; }
.typing-bubble span:nth-child(3) { animation-delay: 0.4s; }
.loading-chat-hint { text-align: center; font-size: 11px; color: var(--text-muted); margin-top: 20px; font-style: italic; }

/* Sidebar UI Fix */
.sidebar { background: var(--bg-sidebar) !important; border-right: 1px solid var(--border-color); height: 100%; position: fixed; z-index: 2000; }
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(128, 128, 128, 0.3); border-radius: 10px; }

/* Toast Style */
.toast-msg { background: var(--bg-sidebar); color: var(--text-main); padding: 12px 16px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.2); border-left: 4px solid #3a7bd5; font-size: 13px; font-weight: 600; pointer-events: auto; animation: slideDown 0.3s ease; }

/* Animations */
@keyframes shimmerMove { 100% { transform: translateX(100%); } }
@keyframes typingBounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-5px); } }
@keyframes fadeInChatLoading { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }

@media (max-width: 480px) {
  .chat-message { max-width: 90%; }
  .chat-message .text img { max-width: 200px !important; }
}
</style>
