---
import Layout from '../layouts/Layout.astro';
import ChatHeader from '../components/chat/ChatHeader.astro';
import ChatSidebar from '../components/chat/ChatSidebar.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    (function() {
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') applyTheme();
      });
    })();
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>
  <audio id="ringtone" src="/asets/sound/call.wav" preload="auto" loop></audio>

  <div id="toast-container" style="position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 9999999; display: flex; flex-direction: column; gap: 10px; width: 90%; max-width: 400px; pointer-events: none;"></div>

  <div class="telegram-chat">
    <ChatHeader />
    <ChatSidebar />
    <div class="chat-messages" id="chat-messages"></div>
    <div class="chat-input-wrapper">
      <ChatInput />
    </div>
  </div>

  <ChatModals />

  <script is:inline src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
  
  <script is:inline>
  // =======================
  // 1. CORE & GLOBAL STATE
  // =======================
  window.SUPABASE_URL = "https://hqetnqnvmdxdgfnnluew.supabase.co";
  window.SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZXRucW52bWR4ZGdmbm5sdWV3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3MzUyODIsImV4cCI6MjA4NzMxMTI4Mn0.Cr9lDBZMqfeONi1dfyFzHpBtawBzZTQLBEWKmPJVAOA";
  // Gunakan Client Supabase dari App (Pastikan sudah terpasang global)
  window.supabase = window.supabaseClient || window.supabase.createClient(window.SUPABASE_URL, window.SUPABASE_ANON_KEY);

  window.currentRoomId = "room-1";
  window.currentUser = null;
  window.myUsername = "Guest";
  window.myRole = "user";
  window.profileCache = new Map();
  window.isFirstMessageLoad = true;
  window.currentChatMode = null;
  window.activeGroupId = null;
  window.totalOnlineUsers = 0;
  window.waveSurfers = {};

  window.sendSound = document.getElementById('send-sound');
  window.receiveSound = document.getElementById('receive-sound');
  window.ringtoneSound = document.getElementById('ringtone');

  // =======================
  // 2. GLOBAL HELPERS
  // =======================
  window.showToast = function(message) {
    let container = document.getElementById("toast-container");
    if (!container) return;
    const toast = document.createElement("div");
    toast.className = `toast-msg`; toast.innerHTML = message;
    container.appendChild(toast);
    setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 300); }, 3000);
  };

  window.escapeHtml = function(str = "") { return String(str).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;"); };
  window.formatTime = function(dateString) { const d = new Date(dateString); return `${d.getHours().toString().padStart(2, "0")}:${d.getMinutes().toString().padStart(2, "0")}`; };
  window.scrollToBottom = function() { const msgEl = document.getElementById("chat-messages"); if (msgEl) msgEl.scrollTo({ top: msgEl.scrollHeight, behavior: "smooth" }); };

  window.showChatLoading = function() {
    const msgEl = document.getElementById("chat-messages");
    if (!msgEl) return;
    msgEl.innerHTML = `
      <div class="chat-loading-screen">
        <div class="skeleton-msg left"><div class="skeleton-avatar shimmer"></div><div class="skeleton-bubble"><div class="shimmer skeleton-line w1"></div><div class="shimmer skeleton-line w2"></div></div></div>
        <div class="skeleton-msg right"><div class="skeleton-bubble me"><div class="shimmer skeleton-line w4"></div></div></div>
        <div class="skeleton-msg left"><div class="skeleton-bubble typing-bubble"><span></span><span></span><span></span></div></div>
        <div class="loading-chat-hint">Menyambungkan percakapan...</div>
      </div>`;
  };

  window.getCachedProfile = async function(userId) {
    if (window.profileCache.has(userId)) return window.profileCache.get(userId);
    const { data } = await window.supabase.from('profiles').select('username, avatar_url, role, short_id, gender').eq('id', userId).single();
    if (data) window.profileCache.set(userId, data);
    return data;
  };

  // =======================
  // 3. RENDER & LOGIC
  // =======================
  window.renderMessage = function(msg) {
    const messagesEl = document.getElementById("chat-messages");
    if (!messagesEl || document.getElementById(`msg-${msg.id}`)) return;

    if (msg.is_system) {
      messagesEl.insertAdjacentHTML('beforeend', `<div id="msg-${msg.id}" style="display:flex; justify-content:center; margin:12px 0; width:100%;"><div style="background:rgba(0,0,0,0.06); color:#555; font-size:11px; padding:5px 14px; border-radius:20px;">${window.escapeHtml(msg.message)}</div></div>`);
      return; 
    }

    const isMe = msg.user_id === window.currentUser.id;
    const currentUsername = msg.profiles?.username || msg.username || "User";
    const avatarUrl = msg.profiles?.avatar_url || msg.avatar || "/asets/png/profile.webp";
    let contentHtml = msg.sticker_url ? `<img src="${msg.sticker_url}" style="width:100px;border-radius:12px;">` : (msg.audio_url ? `🎤 Voice Note` : window.escapeHtml(msg.message || ""));

    const msgHtml = `
      <div id="msg-${msg.id}" class="chat-message ${isMe ? 'self' : 'other'}">
        <img class="avatar" src="${avatarUrl}">
        <div class="content">
          <span class="username">${window.escapeHtml(currentUsername)}</span>
          <div class="text">${contentHtml}</div>
          <div class="message-info"><span class="timestamp">${window.formatTime(msg.created_at)}</span></div>
        </div>
      </div>`;
    messagesEl.insertAdjacentHTML('beforeend', msgHtml);
  };

  window.loadMessages = async function() {
    const messagesEl = document.getElementById("chat-messages");
    if (!messagesEl || !window.currentUser) return;
    if (window.isFirstMessageLoad) window.showChatLoading();
    
    const { data } = await window.supabase.from("messages").select(`*, profiles:profiles!messages_user_id_fkey(username, avatar_url, role)`).eq("room_id", window.currentRoomId).order("created_at", { ascending: false }).limit(30); 
    
    messagesEl.innerHTML = "";
    window.isFirstMessageLoad = false;
    if (data) data.reverse().forEach(msg => window.renderMessage(msg));
    window.scrollToBottom();
  };

  window.initRealtimeMessages = function() {
    window.supabase.channel(`messages-${window.currentRoomId}`).on("postgres_changes", { event: "INSERT", schema: "public", table: "messages" }, async (payload) => {
        const newMsg = payload.new;
        if (newMsg.room_id === window.currentRoomId) {
          const senderProfile = await window.getCachedProfile(newMsg.user_id);
          newMsg.profiles = { username: senderProfile?.username, avatar_url: senderProfile?.avatar_url, role: senderProfile?.role };
          window.renderMessage(newMsg);
          if (newMsg.user_id !== window.currentUser.id && !newMsg.is_system) window.receiveSound.play().catch(()=>{});
          window.scrollToBottom();
        }
    }).subscribe();
  };

  async function initApp() {
    const { data: { session } } = await window.supabase.auth.getSession();
    if (!session) return window.location.href = "/login";
    window.currentUser = { id: session.user.id };
    
    const prof = await window.getCachedProfile(session.user.id);
    if(prof) { window.myUsername = prof.username; window.myRole = prof.role; }
    
    window.initRealtimeMessages();
    await window.loadMessages();
    if (typeof window.refreshSidebar === "function") window.refreshSidebar();
  }
  
  document.addEventListener("DOMContentLoaded", initApp);
  </script>
</Layout>

<style is:global>
/* --- Tetap gunakan style global lu yang tadi --- */
:root {
  --bg-chat-solid: #e5ddd5;
  --bg-sidebar: #ffffff;
  --bg-header: #3a7bd5;
  --bg-input-bar: #ffffff;
  --bg-input-field: #f4f5f7;
  --bg-bubble-self: #dcf8c6;
  --bg-bubble-other: #ffffff;
  --text-main: #333333;
  --text-msg: #111b21;
  --text-muted: #666666;
  --border-color: #eaeaea;
}

:root.dark {
  --bg-chat-solid: #0b141a;
  --bg-sidebar: #111b21;
  --bg-header: #202c33;
  --bg-input-bar: #202c33;
  --bg-input-field: #2a3942;
  --bg-bubble-self: #005c4b;
  --bg-bubble-other: #202c33;
  --text-main: #e9edef;
  --text-msg: #e9edef;
  --text-muted: #8696a0;
  --border-color: #313d45;
}

html, body {
  margin: 0; padding: 0; 
  height: 100vh; height: 100dvh; 
  font-family: "Poppins", sans-serif;
  background-color: var(--bg-chat-solid) !important;
  color: var(--text-main);
  overflow: hidden; 
}

.telegram-chat {
  display: flex; flex-direction: column; 
  height: 100%; width: 100%; overflow: hidden; 
  background-color: var(--bg-chat-solid) !important;
  background-image: url("/asets/png/chat.png");
  background-blend-mode: overlay; background-size: 400px;
  position: relative; z-index: 1;
}

:root.dark .telegram-chat {
  background-image: linear-gradient(rgba(11,20,26,0.95), rgba(11,20,26,0.95)), url("/asets/png/chat.png") !important;
}

.chat-header { flex-shrink: 0; position: relative; z-index: 1000; }
.chat-messages { flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; -webkit-overflow-scrolling: touch; }

.chat-input-wrapper { 
  flex-shrink: 0; position: relative; z-index: 2000; 
  background-color: var(--bg-input-bar) !important; 
  padding-bottom: env(safe-area-inset-bottom, 0px); 
}

.chat-message {
  display: flex; align-items: flex-start; gap: 8px; 
  width: fit-content; max-width: 85%; padding: 8px 10px; 
  border-radius: 15px; position: relative;
  box-shadow: 0 1px 2px rgba(0,0,0,0.15); margin-bottom: 2px;
}

.chat-message.self { align-self: flex-end; flex-direction: row-reverse; background: var(--bg-bubble-self) !important; border-bottom-right-radius: 4px; }
.chat-message.other { align-self: flex-start; flex-direction: row; background: var(--bg-bubble-other) !important; border-bottom-left-radius: 4px; }

.chat-message .avatar { width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0; object-fit: cover; }
.chat-message .username { font-weight: 700; font-size: 12px; margin-bottom: 4px; display: block; }
.chat-message.self .username { color: #00a884; }
.chat-message .text { color: var(--text-msg); line-height: 1.4; word-break: break-word; font-size: 14px; }

.message-info { display: flex; justify-content: flex-end; font-size: 10px; color: var(--text-muted); margin-top: 4px; }

/* Skeleton */
.chat-loading-screen { display: flex; flex-direction: column; gap: 20px; padding: 20px 15px; }
.skeleton-msg { display: flex; align-items: flex-start; gap: 8px; opacity: 0.6; }
.skeleton-bubble { background: var(--bg-bubble-other); border-radius: 12px; padding: 15px; min-width: 140px; }
.shimmer { position: relative; overflow: hidden; background: var(--border-color); }
.shimmer::after { content: ""; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); animation: shimmerMove 1.5s infinite; }
@keyframes shimmerMove { 100% { transform: translateX(100%); } }

@media (max-width: 480px) {
  .chat-message { max-width: 90%; }
}
</style>
