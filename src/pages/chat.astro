  // Animasi warna Pink/Merah khas "Cari Doi"
  overlay.innerHTML = `
    <div style="text-align: center; width: 100%; padding: 20px;">
      <div style="display: flex; justify-content: center; align-items: flex-end; gap: 6px; height: 40px; margin-bottom: 25px;">
        <div style="width: 8px; background: #ff4757; border-radius:3px; animation: barUp 0.5s infinite alternate;"></div>
        <div style="width: 8px; background: #ff6b81; border-radius:3px; animation: barUp 0.8s infinite alternate-reverse;"></div>
        <div style="width: 8px; background: #ff4757; border-radius:3px; animation: barUp 0.6s infinite alternate;"></div>
      </div>
      <h3 style="color: #fff; font-size: 18px; font-weight: 700; margin-bottom: 5px;">MENGISI ULANG KUOTA...</h3>
      <p style="color: #888; font-size: 12px; margin-bottom: 30px;">Jangan tutup tab iklan sampai proses selesai!</p>
      
      <div style="position: relative; width: 80px; height: 80px; margin: 0 auto;">
        <svg width="80" height="80" style="transform: rotate(-90deg);">
          <circle cx="40" cy="40" r="35" stroke="rgba(255,255,255,0.05)" stroke-width="6" fill="none" />
          <circle id="timer-line-doi" cx="40" cy="40" r="35" stroke="#ff4757" stroke-width="6" fill="none" 
            stroke-dasharray="220" stroke-dashoffset="0" style="transition: stroke-dashoffset 1s linear;" />
        </svg>
        <div id="ad-timer-doi" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; font-size: 22px; font-weight: 900;">15s</div>
      </div>
    </div>
    <style> @keyframes barUp { from { height: 10px; } to { height: 40px; } } </style>
  `;
  
  document.body.appendChild(overlay);
  setTimeout(() => { overlay.style.opacity = "1"; }, 10);

  // BUKA IKLAN (Direct Link Monetag Lu)
  setTimeout(() => {
    window.open("https://omg10.com/4/10901295", "_blank");
  }, 1200);

  // LOGIKA TIMER 15 DETIK
  let sec = 15;
  const totalSec = 15;
  const timerLine = document.getElementById('timer-line-doi');

  const countdown = setInterval(() => {
    sec--;
    const timerEl = document.getElementById('ad-timer-doi');
    if (timerEl) timerEl.innerText = sec + "s";
    
    if (timerLine) {
      const offset = 220 - (sec / totalSec) * 220;
