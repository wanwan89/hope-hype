  justify-content: center;
  backdrop-filter: blur(2px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  transform: translate(-50%, -50%) scale(0);
  animation: profilePopFade 1.5s ease-out forwards;
}

@keyframes profilePopFade {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  30% { transform: translate(-50%, -50%) scale(1); opacity: 0.7; }
  100% { transform: translate(-50%, -100%) scale(1.1); opacity: 0; } /* Melayang naik & hilang */
}

.search-title-glow {
  color: white;
  font-size: 18px;
  letter-spacing: 1px;
  font-weight: 600;
  margin: 0;
  text-transform: uppercase;
}

.search-subtitle-glow {
  color: rgba(255, 255, 255, 0.5);
  font-size: 13px;
  margin-top: 8px;
}

@keyframes overlayFadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes subtleRipple { 
  0% { transform: scale(0.2); opacity: 0; }
  50% { opacity: 0.5; }
  100% { transform: scale(1.5); opacity: 0; }
}
@keyframes pulsePoint { from { transform: scale(0.8); } to { transform: scale(1.2); } }

/* =========================
   TOAST COMPACT MOBILE FIX
========================= */
#toast {
  position: fixed;
  top: 14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 99999;
  width: calc(100% - 24px);
  max-width: 420px;
  pointer-events: none;
}

.toast-card {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255, 255, 255, 0.96);
  color: #1f2937;
  border-radius: 20px;
  padding: 12px 14px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  opacity: 0;
  transform: translateY(-20px) scale(0.96);
  transition: all 0.28s ease;
  pointer-events: auto;
  min-height: 64px;
  border: 1px solid rgba(255, 255, 255, 0.6);
}

.toast-card.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.toast-icon-wrap {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.toast-icon-wrap.success {
  background: linear-gradient(135deg, #22c55e, #16a34a);
}

.toast-icon-wrap.warning {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}

.toast-icon-wrap.error {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.toast-icon-wrap.info {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
}

.toast-icon {
  font-size: 22px;
  font-weight: 800;
  line-height: 1;
}

.toast-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.toast-title {
  font-size: 14px;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 2px;
  color: #111827;
}

.toast-subtitle {
  font-size: 12px;
  line-height: 1.3;
  color: #6b7280;
  word-break: break-word;
}

.toast-close {
  background: transparent;
  border: none;
  color: #9ca3af;
  font-size: 22px;
  cursor: pointer;
  padding: 0;
  margin-left: 4px;
  line-height: 1;
  flex-shrink: 0;
  width: 24px;
  height: 24px;
}

/* Mobile super compact */
@media (max-width: 480px) {
  #toast {
    top: 10px;
    width: calc(100% - 16px);
  }

  .toast-card {
    border-radius: 18px;
    padding: 10px 12px;
    gap: 8px;
    min-height: 56px;
  }

  .toast-icon-wrap {
    width: 38px;
    height: 38px;
  }

  .toast-icon {
    font-size: 18px;
  }

  .toast-title {
    font-size: 13px;
    margin-bottom: 1px;
  }

  .toast-subtitle {
    font-size: 11px;
    line-height: 1.25;
  }

  .toast-close {
    font-size: 18px;
    width: 20px;
    height: 20px;
  }
}
.empty-chat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 60px 20px;
  margin-top: 20px;
  text-align: center;
  opacity: 0.9;
}

.empty-icon {
  font-size: 40px;
  opacity: 0.6;
  filter: grayscale(0.2);
}

.empty-title {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-color);
}

.empty-subtitle {
  font-size: 13px;
  color: var(--text-muted);
}

/* sedikit animasi biar hidup */
.empty-chat {
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 0.9;
    transform: translateY(0);
  }
}
