---
// 1. IMPORT COMPONENTS
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import BioModal from '../components/modals/BioModal.astro';
import GroupModal from '../components/modals/GroupModal.astro';
import GroupSettingsModal from '../components/modals/GroupSettingsModal.astro';
import InviteModal from '../components/modals/InviteModal.astro';
import StickerMenu from '../components/chat/StickerMenu.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import DeleteModal from '../components/modals/DeleteModal.astro';
import DoiCardModal from '../components/modals/DoiCardModal.astro';
import ReactionMenu from '../components/chat/ReactionMenu.astro';
import CallOverlays from '../components/modals/CallOverlays.astro';

// 2. IMPORT CSS GLOBAL CHAT
import '../styles/chat.css';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
  
  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <Header />
    <Sidebar />
    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <BioModal />
    <GroupModal />
    <GroupSettingsModal />
    <InviteModal />

    <div id="modal-limit-doi" class="custom-modal-overlay" style="display: none;">
      <div class="custom-modal-card">
        <div class="modal-icon-love">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="#FF3366">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
        </div>
        <h3>Kuota Cari Doi Habis!</h3>
        <p>Mau nonton iklan sponsor 15 detik buat isi ulang <b>+10 kuota</b> biar bisa lanjut cari jodoh?</p>
        <div class="modal-actions">
          <button onclick="document.getElementById('modal-limit-doi').style.display='none'" class="btn-modal-cancel">Batal</button>
          <button onclick="window.jalankanIklanIsiUlangDoi(); document.getElementById('modal-limit-doi').style.display='none'" class="btn-modal-confirm">Nonton Iklan</button>
        </div>
      </div>
    </div>

    <div class="chat-messages" id="chat-messages"></div>

    <StickerMenu />
    <div id="reply-preview-box" style="display:none; width:100%; position: relative;"></div>
    <ChatInput />
  </div>

  <DeleteModal />
  <DoiCardModal />
  <ReactionMenu />
  <CallOverlays />

  <script src="../scripts/chat.js"></script>
</Layout>
