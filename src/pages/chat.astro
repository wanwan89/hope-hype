---
import Layout from '../layouts/Layout.astro';
import ChatHeader from '../components/chat/ChatHeader.astro';
import ChatSidebar from '../components/chat/ChatSidebar.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    (function() {
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') applyTheme();
      });
    })();
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <ChatHeader />
    <ChatSidebar />
    <div class="chat-messages" id="chat-messages"></div>
    <ChatInput />
  </div>

  <ChatModals />

  <script is:inline src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
  <script src="../scripts/chatLogic.js"></script>
</Layout>

<style is:global>
/* --- 🎨 THEME VARIABLES --- */
:root {
  --bg-chat-solid: #e5ddd5;
  --bg-sidebar: #ffffff;
  --bg-header: #3a7bd5;
  --bg-input-bar: #ffffff;
  --bg-input-field: #f4f5f7;
  --bg-bubble-self: #dcf8c6;
  --bg-bubble-other: #ffffff;
  --text-main: #333333;
  --text-msg: #111b21;
  --text-muted: #666666;
  --border-color: #eaeaea;
}

/* --- 🌙 DARK MODE COLORS (SOLID NO LEAK) --- */
:root.dark {
  --bg-chat-solid: #0b141a; /* Hitam Padat WA */
  --bg-sidebar: #111b21;
  --bg-header: #202c33;
  --bg-input-bar: #202c33;
  --bg-input-field: #2a3942;
  --bg-bubble-self: #005c4b;
  --bg-bubble-other: #202c33;
  --text-main: #e9edef;
  --text-msg: #e9edef;
  --text-muted: #8696a0;
  --border-color: #313d45;
}

/* --- Base Styles --- */
html, body {
  margin: 0; padding: 0; height: 100%;
  font-family: "Poppins", sans-serif;
  background-color: var(--bg-chat-solid) !important;
  color: var(--text-main);
  transition: background 0.3s ease;
}

.telegram-chat {
  flex: 1; display: flex; flex-direction: column; overflow: hidden;
  background-color: var(--bg-chat-solid) !important;
  background-image: url("/asets/png/chat.png");
  background-blend-mode: overlay;
  background-size: 400px;
  position: relative; z-index: 1;
}

:root.dark .telegram-chat {
  background-image: linear-gradient(rgba(11,20,26,0.95), rgba(11,20,26,0.95)), url("/asets/png/chat.png") !important;
  background-blend-mode: normal;
}

/* --- Area Pesan --- */
.chat-messages {
  flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; height: 100%;
  background-color: var(--bg-chat-solid);
}

/* --- 🖼️ FIX UKURAN GAMBAR/FOTO DI CHAT --- */
.chat-message .text img {
  max-width: 200px !important; /* Batasi lebar foto agar tidak raksasa */
  max-height: 250px !important;
  border-radius: 10px;
  object-fit: cover;
  margin: 5px 0;
  display: block;
  box-shadow: 0 1px 2px rgba(0,0,0,0.2);
}

/* Khusus Sticker */
.chat-message .text img[src*="sticker"] {
  width: 120px !important;
  height: 120px !important;
  max-width: 120px !important;
  background: transparent !important;
  box-shadow: none;
}

/* --- Chat Bubbles --- */
.chat-message {
  display: flex; max-width: 85%; padding: 6px 10px; border-radius: 12px; font-size: 14px;
  position: relative; transition: transform 0.2s ease;
}

.chat-message.self {
  background: var(--bg-bubble-self) !important;
  align-self: flex-end; border-bottom-right-radius: 2px;
  box-shadow: 0 1px 1px rgba(0, 0, 0, 0.1);
}

.chat-message.other {
  background: var(--bg-bubble-other) !important;
  align-self: flex-start; border-bottom-left-radius: 2px;
  box-shadow: 0 1px 1px rgba(0, 0, 0, 0.15);
}

.chat-message .text { color: var(--text-msg); line-height: 1.4; }
.chat-message .username { color: var(--bg-header); font-weight: 700; margin-bottom: 2px; }
:root.dark .chat-message .username { color: #00a884; }

/* --- Sidebar & UI --- */
.sidebar { 
  background: var(--bg-sidebar) !important; 
  border-right: 1px solid var(--border-color); 
}

:root.dark :global(#private-chat-list),
:root.dark :global(.sidebar-chat-item) {
  background-color: var(--bg-sidebar) !important;
}

.chat-header { background: var(--bg-header) !important; }
.chat-input-container { background: var(--bg-input-bar) !important; border-top: 1px solid var(--border-color) !important; }
.input-group-wrapper { background: var(--bg-input-field) !important; border: 1px solid var(--border-color) !important; }
#chat-input { color: var(--text-main) !important; }

/* Scrollbar */
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(128, 128, 128, 0.3); border-radius: 10px; }
:root.dark .chat-messages::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); }

/* Toast Notification Adaptive */
.toast-card {
  background: var(--bg-sidebar) !important;
  color: var(--text-main) !important;
  border: 1px solid var(--border-color);
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}

@keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
@keyframes badgePop { 0% { transform: scale(0); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

@media (max-width: 480px) {
  #toast { top: 10px; width: calc(100% - 16px); }
  .toast-card { border-radius: 18px; padding: 10px 12px; min-height: 56px; }
  .chat-message { max-width: 90%; }
}
</style>
