---
import Layout from '../layouts/Layout.astro';

// Perhatiin jalurnya bro, harus lewat folder /chat/ dulu
import ChatHeader from '../components/chat/ChatHeader.astro';
import Sidebar from '../components/chat/Sidebar.astro';
import ChatArea from '../components/chat/ChatArea.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';

import '../styles/chat.css';
---

<Layout title="HopeTalk globe">
  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <ChatHeader />
    <Sidebar />
    <ChatArea />
    <ChatInput />
    <ChatModals />
  </div>

  <script is:inline type="module">
    import { createClient } from "https://esm.sh/@supabase/supabase-js";

    // ===== Supabase config =====
    const SUPABASE_URL = "https://hqetnqnvmdxdgfnnluew.supabase.co";
    const SUPABASE_ANON_KEY =
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZXRucW52bWR4ZGdmbm5sdWV3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3MzUyODIsImV4cCI6MjA4NzMxMTI4Mn0.Cr9lDBZMqfeONi1dfyFzHpBtawBzZTQLBEWKmPJVAOA";
    window.supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    // ===== Audio Config =====
    window.sendSound = new Audio("/asets/sound/send.mp3");
    window.receiveSound = new Audio("/asets/sound/receive.mp3");
    window.ringtoneSound = new Audio("/asets/sound/call.wav");
    window.ringtoneSound.loop = true;

    // ===== Global State =====
    window.currentRoomId = "room-1";
    window.currentReplyId = null;
    window.currentUser = null;
    window.myUsername = "Guest";
    window.myRole = "user";
    window.presenceChannel = null;
    window.globalPresenceChannel = null; 
    window.messageChannel = null;
    window.typingTimeout = null;
    window.isCurrentlyTyping = false;
    window.selectedMessageId = null;
    window.isFirstMessageLoad = true; 
    window.totalOnlineUsers = 0; 
    window.isSidebarLoading = false; 
    window.selectedGroupFile = null;
    window.callRoom = null;

    const profileCache = new Map();

    window.getCachedProfile = async function(userId) {
      if (profileCache.has(userId)) return profileCache.get(userId);
      const localKey = `hh_profile_${userId}`;
      const cacheTimeKey = `hh_profile_time_${userId}`;
      const cached = localStorage.getItem(localKey);
      const cacheTime = localStorage.getItem(cacheTimeKey);
      if (cached && cacheTime && (Date.now() - parseInt(cacheTime) < 3600000)) {
        const data = JSON.parse(cached);
        profileCache.set(userId, data); 
        return data;
      }
      const { data, error } = await supabase.from('profiles').select('username, avatar_url, role, short_id, gender').eq('id', userId).single();
      if (data) {
        localStorage.setItem(localKey, JSON.stringify(data));
        localStorage.setItem(cacheTimeKey, Date.now().toString());
        profileCache.set(userId, data);
      }
      return data;
    }

    window.requireLogin = async function() {
      const { data: { session }, error } = await supabase.auth.getSession();
      if (error || !session || !session.user) {
        window.location.href = "/login";
        return false;
      }
      window.currentUser = { id: session.user.id };
      const myProfile = await getCachedProfile(session.user.id);
      window.myUsername = myProfile?.username || "Guest";
      window.myRole = myProfile?.role || "user";
      return true;
    }

    async function init() {
      try {
        const ok = await requireLogin(); 
        if (!ok) return;
        await loadProfile(); 
        await initPresence(); 
        await refreshSidebar(); 
        initRealtimeMessages(); 
        await loadMessages(); 
        updateHeaderStatus(); 
        fetchStickers(); 
        scrollToBottom();
      } catch (err) { console.error("Gagal memulai aplikasi:", err); }
    }

    init();
  </script>
</Layout>
