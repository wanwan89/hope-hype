---
import Layout from '../layouts/Layout.astro';
import ChatHeader from '../components/chat/ChatHeader.astro';
import ChatSidebar from '../components/chat/ChatSidebar.astro';
import ChatInput from '../components/chat/ChatInput.astro';
import ChatModals from '../components/chat/ChatModals.astro';
---

<Layout title="HopeTalk Globe">
  <script is:inline>
    (function() {
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') applyTheme();
      });
    })();
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/livekit-client/dist/livekit-client.umd.min.js"></script>

  <audio id="send-sound" src="/asets/sound/send.mp3" preload="auto"></audio>
  <audio id="receive-sound" src="/asets/sound/receive.mp3" preload="auto"></audio>

  <div class="telegram-chat">
    <ChatHeader />
    <ChatSidebar />
    <div class="chat-messages" id="chat-messages"></div>
    <ChatInput />
  </div>

  <ChatModals />

  <script is:inline src="https://unpkg.com/wavesurfer.js@7/dist/wavesurfer.min.js"></script>
  <script src="../scripts/chatLogic.js"></script>
</Layout>

<style is:global>
/* --- 🎨 THEME VARIABLES --- */
:root {
  --bg-chat-solid: #e5ddd5;
  --bg-sidebar: #ffffff;
  --bg-header: #3a7bd5;
  --bg-input-bar: #ffffff;
  --bg-input-field: #f4f5f7;
  --bg-bubble-self: #dcf8c6;
  --bg-bubble-other: #ffffff;
  --text-main: #333333;
  --text-msg: #111b21;
  --text-muted: #666666;
  --border-color: #eaeaea;
}

:root.dark {
  --bg-chat-solid: #0b141a;
  --bg-sidebar: #111b21;
  --bg-header: #202c33;
  --bg-input-bar: #202c33;
  --bg-input-field: #2a3942;
  --bg-bubble-self: #005c4b;
  --bg-bubble-other: #202c33;
  --text-main: #e9edef;
  --text-msg: #e9edef;
  --text-muted: #8696a0;
  --border-color: #313d45;
}

/* --- Base Styles --- */
html, body {
  margin: 0; padding: 0; height: 100%;
  font-family: "Poppins", sans-serif;
  background-color: var(--bg-chat-solid) !important;
  color: var(--text-main);
}

.telegram-chat {
  flex: 1; display: flex; flex-direction: column; overflow: hidden;
  background-color: var(--bg-chat-solid) !important;
  background-image: url("/asets/png/chat.png");
  background-blend-mode: overlay;
  background-size: 400px;
  position: relative; z-index: 1;
}

:root.dark .telegram-chat {
  background-image: linear-gradient(rgba(11,20,26,0.95), rgba(11,20,26,0.95)), url("/asets/png/chat.png") !important;
  background-blend-mode: normal;
}

.chat-messages {
  flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; height: 100%;
}

/* --- 🔥 FIX BUBBLE CHAT & GAMBAR (ANTI-MELEDAK) 🔥 --- */
.chat-message {
  display: flex;
  align-items: flex-end;
  width: fit-content;
  max-width: 75%; /* Kunci lebar bubble maksimal 75% layar */
  position: relative;
  transition: transform 0.2s ease;
}

/* Kontainer isi di dalam bubble */
.chat-message .content {
  display: flex;
  flex-direction: column;
  padding: 6px 10px;
  border-radius: 12px;
  max-width: 100%; /* Supaya gak keluar dari 75% parent-nya */
  overflow: hidden; /* Kunci gambar di dalam */
}

/* Posisi Bubble */
.chat-message.self {
  align-self: flex-end;
  flex-direction: row-reverse; /* Avatar di kanan */
}

.chat-message.other {
  align-self: flex-start;
  flex-direction: row; /* Avatar di kiri */
}

/* Warna Bubble */
.chat-message.self .content {
  background: var(--bg-bubble-self) !important;
  border-bottom-right-radius: 2px;
}

.chat-message.other .content {
  background: var(--bg-bubble-other) !important;
  border-bottom-left-radius: 2px;
  box-shadow: 0 1px 1px rgba(0, 0, 0, 0.15);
}

/* Avatar */
.chat-message .avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  flex-shrink: 0; /* Anti-gepeng */
  margin: 0 8px;
  object-fit: cover;
}

/* --- 🖼️ FIX TOTAL GAMBAR RAKSASA --- */
.chat-message .text img {
  width: 100% !important; /* Paksa lebar ngikut bubble */
  max-width: 250px !important; /* Tapi jangan lebih dari 250px */
  height: auto !important;
  border-radius: 8px;
  margin: 5px 0;
  display: block;
  object-fit: contain;
}

/* Sticker Mode */
.chat-message .text img[src*="sticker"] {
  max-width: 120px !important;
}

/* Teks & Username */
.chat-message .text { color: var(--text-msg); line-height: 1.4; word-break: break-word; }
.chat-message .username { color: var(--bg-header); font-weight: 700; font-size: 12px; margin-bottom: 2px; }
:root.dark .chat-message .username { color: #00a884; }

/* --- Sidebar & UI --- */
.sidebar { background: var(--bg-sidebar) !important; border-right: 1px solid var(--border-color); }
:root.dark :global(#private-chat-list), :root.dark :global(.sidebar-chat-item) { background-color: var(--bg-sidebar) !important; }
.chat-header { background: var(--bg-header) !important; }
.chat-input-container { background: var(--bg-input-bar) !important; border-top: 1px solid var(--border-color) !important; }
.input-group-wrapper { background: var(--bg-input-field) !important; border: 1px solid var(--border-color) !important; }
#chat-input { color: var(--text-main) !important; }

/* Scrollbar */
.chat-messages::-webkit-scrollbar { width: 5px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(128, 128, 128, 0.3); border-radius: 10px; }

@keyframes slideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

@media (max-width: 480px) {
  .chat-message { max-width: 85%; }
  .chat-message .text img { max-width: 200px !important; }
}
</style>
