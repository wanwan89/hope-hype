.status-icon svg { display: block; }

.status-icon.sending { gap: 1px; color: #9aa0a6; font-size: 11px; font-weight: 600; min-width: 14px; }
.sending-dot { display: inline-block; animation: sendingBlink 1.2s infinite; opacity: 0.35; }
.sending-dot:nth-child(2) { animation-delay: 0.2s; }
.sending-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes sendingBlink {
