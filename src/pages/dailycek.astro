---
// 1. IMPORT LAYOUT UTAMA
import Layout from '../layouts/Layout.astro';

// 2. IMPORT CSS KHUSUS DAILY CEK
import '../styles/dailycek.css';
---

<Layout title="Pusat Misi - Hope Hype">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
  <script src="https://openfpcdn.io/fingerprintjs/v4" is:inline></script>

  <div class="mission-wrapper">
    <div id="securityOverlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.95); z-index:99999; color:white; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:30px; font-family:'Inter',sans-serif;">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ff4757" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
      <h2 style="margin-top:20px;">Akses Dibatasi</h2>
      <p style="color:#94a3b8; margin-top:10px;">Perangkat ini sudah terhubung dengan akun lain. Sesuai kebijakan, 1 perangkat hanya untuk 1 akun misi.</p>
    </div>

    <div class="mission-container">
      
      <div class="mission-header">
        <button class="back-btn" onclick="window.history.back()">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <h1 class="header-title">Pusat Misi</h1>
        <div class="header-coin" id="topCoinDisplay">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" stroke="#f59e0b" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 8v8M8 12h8" stroke="#fff"/></svg>
          <span id="missionCoinText" style="color: #f59e0b; font-weight: 800;">0</span>
        </div>
      </div>

      <div class="mission-list" style="margin-top: 1rem;">
        <div class="mission-item" style="background: linear-gradient(135deg, #1e293b, #0f172a); border-radius: 1rem; border: none;">
          <div class="m-icon-box" style="background: #38bdf8;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 1l4 4-4 4"></path><path d="M3 11V9a4 4 0 0 1 4-4h14"></path><path d="M7 23l-4-4 4-4"></path><path d="M21 13v2a4 4 0 0 1-4 4H3"></path></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title" style="color: white;">Tukar Koin Misi</h4>
            <div class="m-reward" style="color: #94a3b8; display: flex; align-items: center; gap: 6px;">
              1000 Misi 
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              10 Hope
            </div>
            <span class="progress-text" style="color: #cbd5e1;">Saldo Hope: <b id="hopeCoinText" style="color: #38bdf8;">0</b></span>
          </div>
          <button class="m-btn" id="btnExchange" style="background: #38bdf8; color: white; border: none;">Tukar</button>
        </div>
      </div>

      <div class="mission-card streak-card">
        <div class="streak-header">
          <h2 class="streak-title">Check-in 7 Hari</h2>
          <p class="streak-desc">Klaim koin gratis tiap hari untuk hadiah lebih besar!</p>
        </div>
        <div class="streak-days-container" id="streakDaysContainer">
          </div>
        <button id="btnClaimCheckin" class="claim-main-btn">
          Memuat data...
        </button>
      </div>

      <h3 class="section-title">Misi Pemula</h3>
      <div class="mission-list">
        <div class="mission-item" id="apkContainer">
          <div class="m-icon-box" style="background: #10b981;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line><path d="M12 7v6"></path><path d="M9 10h6"></path></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Instal Aplikasi HopeHype</h4>
            <div class="m-reward"><span class="coin-dot"></span> +300 Koin</div>
            <span class="progress-text">Akses lebih cepat via Home Screen</span>
          </div>
          <button id="btnInstallPWA" class="m-btn" style="background: #10b981; color: white; border: none; display:none;">Instal</button>
          <span id="pwaStatus" style="font-size: 11px; color: #94a3b8; display:none;">Selesai</span>
        </div>

        <div class="mission-item" id="inviteCodeContainer">
          <div class="m-icon-box" style="background: #f97316;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Masukkan Kode Undangan</h4>
            <div class="m-reward"><span class="coin-dot"></span> +200 Koin</div>
            <input type="text" id="inviteInputCode" placeholder="Kode teman..." class="invite-input" />
          </div>
          <button id="btnInviteCode" class="m-btn">Klaim</button>
        </div>
      </div>

      <h3 class="section-title" style="margin-top: 1.25rem;">Misi Harian</h3>
      <div class="mission-list">
        <div class="mission-item">
          <div class="m-icon-box bg-blue">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Dengar 3 Lagu</h4>
            <div class="m-reward"><span class="coin-dot"></span> +30 Koin</div>
            <div class="progress-bar"><div id="progFillListen" class="progress-fill" style="width: 0%;"></div></div>
            <span id="progTextListen" class="progress-text">0/3</span>
          </div>
          <button id="btnListen" class="m-btn" onclick="window.location.href='/'">Mulai</button>
        </div>

        <div class="mission-item">
          <div class="m-icon-box bg-pink">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Sukai 5 Postingan</h4>
            <div class="m-reward"><span class="coin-dot"></span> +25 Koin</div>
            <div class="progress-bar"><div id="progFillLike" class="progress-fill" style="width: 0%;"></div></div>
            <span id="progTextLike" class="progress-text">0/5</span>
          </div>
          <button id="btnLike" class="m-btn" onclick="window.location.href='/'">Pergi</button>
        </div>

        <div class="mission-item">
          <div class="m-icon-box bg-green">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Komen di 3 Post</h4>
            <div class="m-reward"><span class="coin-dot"></span> +40 Koin</div>
            <div class="progress-bar"><div id="progFillComment" class="progress-fill" style="width: 0%;"></div></div>
            <span id="progTextComment" class="progress-text">0/3</span>
          </div>
          <button id="btnComment" class="m-btn" onclick="window.location.href='/'">Pergi</button>
        </div>
      </div>

      <h3 class="section-title" style="margin-top: 1.25rem;">Misi Kreator</h3>
      <div class="mission-list">
        <div class="mission-item">
          <div class="m-icon-box bg-purple">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
          </div>
          <div class="m-info">
            <h4 class="m-title">Upload 1 Karya</h4>
            <div class="m-reward"><span class="coin-dot"></span> +100 Koin</div>
            <div class="progress-bar"><div id="progFillUpload" class="progress-fill" style="width: 0%;"></div></div>
            <span id="progTextUpload" class="progress-text">0/1</span>
          </div>
          <button id="btnUpload" class="m-btn" onclick="window.location.href='/'">Upload</button>
        </div>
      </div>

      <h3 class="section-title" style="margin-top: 1.25rem;">Program Referral</h3>
      <div class="mission-list" style="margin-bottom: 2rem;">
        <div class="mission-item" style="flex-direction: column; align-items: flex-start;">
          <div style="display: flex; width: 100%; align-items: center;">
            <div class="m-icon-box bg-red">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5c-2.2 0-4 1.8-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><line x1="20" y1="8" x2="20" y2="14"></line><line x1="23" y1="11" x2="17" y2="11"></line></svg>
            </div>
            <div class="m-info">
              <h4 class="m-title">Undang & Dapat Koin</h4>
              <div class="m-reward"><span class="coin-dot"></span> +500 Koin / Teman</div>
              <span class="progress-text">Kode: <b id="myInviteCode" style="color: var(--primary); font-family: monospace;">...</b></span>
            </div>
            <button class="m-btn" id="btnShareLink">Bagikan</button>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script src="../scripts/dailycek.js"></script>
</Layout>
