---
// 1. IMPORT COMPONENTS
import Layout from '../layouts/Layout.astro';
import HiddenPlayer from '../components/ui/HiddenPlayersong.astro';
import Sidebar from '../components/layout/Sidebarsong.astro';
import FloatingUploadBtn from '../components/ui/FloatingUploadBtnsong.astro';
import UploadSheet from '../components/music/UploadSheetsong.astro';
import Header from '../components/layout/Headersong.astro';
import PlaylistGrid from '../components/music/PlaylistGridsong.astro';
import MiniPlayer from '../components/music/MiniPlayersong.astro';
import CommentSheet from '../components/music/CommentSheetsong.astro';
import AudioPlayer from '../components/music/AudioPlayersong.astro';

// 2. IMPORT CSS GLOBAL MUSIC
import '../styles/music.css';
---

<Layout title="Hope SONG - Stream Music">
  
  <script is:inline>
    // Asumsi di index.astro kamu simpan tema pakai nama 'theme' di localStorage.
    function syncThemeInline() {
      const savedTheme = localStorage.getItem('theme'); 
      if (savedTheme === 'light') {
        document.body.classList.add('light-mode');
      } else {
        document.body.classList.remove('light-mode');
      }
    }
    syncThemeInline();
    window.addEventListener('storage', (e) => {
      if (e.key === 'theme') syncThemeInline();
    });
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

  <HiddenPlayer />
  <Sidebar />
  <FloatingUploadBtn />
  <UploadSheet />
  <Header />
  <PlaylistGrid />
  <MiniPlayer />
  <CommentSheet />
  <AudioPlayer />

  <div id="rewardFloatingCard" class="reward-card hidden">
    <div class="reward-content">
      <span class="material-icons reward-icon">redeem</span>
      <div class="reward-text">
        <h3>Misi Koin Tersedia!</h3>
        <p>Nonton iklan sebentar, dapat +5 Misi Koin bro!</p>
      </div>
    </div>
    <div class="reward-actions">
      <button id="rewardDecline" class="btn-decline">Nanti Aja</button>
      <button id="rewardAccept" class="btn-accept">Tonton & Klaim</button>
    </div>
  </div>

  <div class="popup-overlay" id="dataPopup">
    <div class="popup-content">
      <div class="popup-header">
        <h3 id="popupTitle">Data Menu</h3>
        <span class="material-icons" id="closeDataPopup" style="cursor: pointer; color: #333;">close</span>
      </div>
      <div class="popup-body" id="popupBody" style="color: #333;">
      </div>
    </div>
  </div>
  
  <div id="toast"></div>

  <script src="../scripts/music.js"></script>
</Layout>
