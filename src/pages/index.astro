/* =========================
   AD BANNER (IKLAN)
========================= */
.ad-banner-container {
  position: fixed; 
  top: 10px; 
  left: 50%;
  transform: translateX(-50%); 
  width: 380px; 
  max-width: 95%; 
  height: 80px; 
  border: 2px solid #000;
  border-radius: 16px;
  box-shadow: 4px 4px 0px #00000030;
  z-index: 9999;
  background: #fff;
  /* overflow: hidden; kita pindahkan pengaturannya ke ad-slider di bawah */
}

/* Wadah slider yang baru: Mendukung geser manual (Scroll Snap) */
.ad-slider {
  display: flex;
  width: 100%; 
  height: 100%;
  overflow-x: auto; /* Mengizinkan geser ke kanan/kiri */
  scroll-snap-type: x mandatory; /* Bikin efek "nempel" tiap kali digeser */
  scroll-behavior: smooth; /* Efek geser yang mulus */
  border-radius: 14px; /* Menyesuaikan lengkungan luar */
  
  /* Menyembunyikan garis scrollbar agar tetap rapi */
  -ms-overflow-style: none;  /* Untuk IE dan Edge */
  scrollbar-width: none;  /* Untuk Firefox */
}

/* Menyembunyikan garis scrollbar di Chrome/Safari */
.ad-slider::-webkit-scrollbar {
  display: none; 
}

/* Mengatur setiap gambar dan link agar ukurannya pas 1 banner penuh */
.ad-slider > img,
.ad-slider > a {
  flex: 0 0 100%; /* Memaksa tiap elemen memakan 100% lebar layar banner */
  height: 100%;
  scroll-snap-align: center; /* Memastikan gambar nge-pas di tengah saat digeser */
  display: block;
}

.ad-slide {
  width: 100%;
  height: 100%;
  object-fit: cover; 
}

/* Sesuaikan border kalau masuk Dark Mode biar tetep rapi */
body.dark .ad-banner-container {
  border: 2px solid #fff;
}

