  // 5. Logika pintar: Stop otomatis kalau user sedang menyentuh/menggeser, 
  // dan nyalakan lagi kalau jarinya sudah dilepas agar tidak bentrok.
  slider.addEventListener('touchstart', stopAutoSlide); // Jari nempel di HP
