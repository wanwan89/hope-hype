.crown-img {
  width: 30px; /* Sesuaikan ukuran */
  height: 30px;
  object-fit: contain;
  display: block;
}

.product-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40px; /* Memberi ruang yang cukup */
}

/* GAYA AWAL KARTU PRODUK (Tambahkan transisi agar halus) */
.product-card {
  /* ... (gaya yang sudah ada) ... */
  transition: all 0.2s ease; /* Penting untuk transisi halus */
  cursor: pointer; /* Memberitahu user bahwa ini bisa ditekan */
}

/* EFEK KETIKA DITEKAN (:active state) */
.product-card:active {
  /* Opsi 1: Efek Menekan Masuk (Paling umum) */
  transform: translateY(2px) scale(0.98); /* Sedikit turun dan mengecil */
  box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.2); /* Bayangan dalam, efek tertekan */

  /* Opsi 2: Berubah Warna Background (Mirip tombol beli di gambar) */
  background-color: #f7df1e; /* Warna kuning seperti tombol 'Beli' di gambar */
  color: black; /* Agar teks tetap terbaca, ganti warna teks */
  border-color: #f7df1e; /* Jika ada border, samakan warnanya */
}

/* Agar teks di dalam kartu juga berubah warna saat aktif (Opsi 2) */
.product-card:active .p-name,
.product-card:active .p-price,
.product-card:active .product-icon {
  color: black;
}

/* Warna Default (Mode Terang) */
.section-header h3 {
  color: #1a1a1a; /* Warna hitam/gelap */
  transition: color 0.4s ease; /* Agar transisi warnanya halus */
}

/* Warna Saat Mode Gelap aktif */
body.dark .section-header h3 {
  color: #ffffff; /* Warna putih */
}

/* Pastikan warna teks di dalam recent-card ikut bertransisi secara halus */
.recent-card .details h4 {
  transition: color 0.4s ease;
  color: #1a1a1a; /* Warna awal (Mode Terang) */
}

/* Saat mode gelap, ubah warna huruf secara spesifik */
body.dark .recent-card .details h4 {
  color: #ffffff !important;
}

/* Hilangkan transisi 'all' pada recent-card agar tidak membebani render huruf */
.recent-card {
  /* Ganti transition: all ... menjadi lebih spesifik */
  transition: background-color 0.4s ease, transform 0.2s ease, box-shadow 0.4s ease !important;
}

/* Cegah teks berbayang atau berkedip saat animasi */
.details h4,
.details span {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  will-change: color; /* Memberitahu browser untuk fokus pada perubahan warna */
}

/* Efek Denyut saat tombol ditekan */
@keyframes button-push {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

.buy-now-btn:active {
  animation: button-push 0.3s ease;
}

/* Animasi Loading pada tombol */
.btn-loading {
  position: relative;
  color: transparent !important;
  pointer-events: none;
}

.btn-loading::after {
  content: "";
  position: absolute;
  width: 16px;
  height: 16px;
  top: 50%;
  left: 50%;
  margin: -8px 0 0 -8px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border-top-color: #fff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* Efek Partikel */
.particle {
  position: fixed;
  pointer-events: none;
  border-radius: 50%;
  z-index: 10001;
}

/* =========================
   TOAST COMPACT MOBILE FIX
========================= */
#toast {
  position: fixed;
  top: 14px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 99999;
  width: calc(100% - 24px);
  max-width: 420px;
  pointer-events: none;
}

.toast-card {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(255, 255, 255, 0.96);
  color: #1f2937;
  border-radius: 20px;
  padding: 12px 14px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  opacity: 0;
  transform: translateY(-20px) scale(0.96);
  transition: all 0.28s ease;
  pointer-events: auto;
  min-height: 64px;
  border: 1px solid rgba(255, 255, 255, 0.6);
}

.toast-card.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.toast-icon-wrap {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
}

.toast-icon-wrap.success {
  background: linear-gradient(135deg, #22c55e, #16a34a);
}

.toast-icon-wrap.warning {
  background: linear-gradient(135deg, #f59e0b, #d97706);
}

.toast-icon-wrap.error {
  background: linear-gradient(135deg, #ef4444, #dc2626);
}

.toast-icon-wrap.info {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
}

.toast-icon {
  font-size: 22px;
  font-weight: 800;
  line-height: 1;
}

.toast-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.toast-title {
  font-size: 14px;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 2px;
  color: #111827;
}

.toast-subtitle {
  font-size: 12px;
  line-height: 1.3;
  color: #6b7280;
  word-break: break-word;
}

.toast-close {
  background: transparent;
  border: none;
  color: #9ca3af;
  font-size: 22px;
  cursor: pointer;
  padding: 0;
  margin-left: 4px;
  line-height: 1;
  flex-shrink: 0;
  width: 24px;
  height: 24px;
}

/* Mobile super compact */
@media (max-width: 480px) {
  #toast {
    top: 10px;
    width: calc(100% - 16px);
  }

  .toast-card {
    border-radius: 18px;
    padding: 10px 12px;
    gap: 8px;
    min-height: 56px;
  }

  .toast-icon-wrap {
    width: 38px;
    height: 38px;
  }

  .toast-icon {
    font-size: 18px;
  }

  .toast-title {
    font-size: 13px;
    margin-bottom: 1px;
  }

  .toast-subtitle {
    font-size: 11px;
    line-height: 1.25;
  }

  .toast-close {
    font-size: 18px;
    width: 20px;
    height: 20px;
  }
}

/* Pastikan kontainer yang membungkus avatar memiliki position: relative di CSS-mu */
