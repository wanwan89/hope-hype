  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000000;
  backdrop-filter: blur(6px); /* blur background */
  -webkit-backdrop-filter: blur(6px);
  animation: fadeIn 0.4s ease forwards;
  opacity: 0;
  pointer-events: none;
}

.modal.active {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  background: #2a2d31; /* Ganti ke warna gelap solid (tidak tembus pandang) */
