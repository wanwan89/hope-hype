---
import Layout from '../layouts/Layout.astro';
import '../styles/home.css'; 

import SkeletonLoader from '../components/SkeletonLoader.astro';
import AdBanner from '../components/AdBanner.astro';
import Header from '../components/Header.astro';
import MenuCards from '../components/MenuCards.astro';
import Modals from '../components/Modals.astro';
import Contact from '../components/Contact.astro';

import { supabase } from '../lib/supabase.js';

let isMaintenance = false;
let popupServerData = null;

try {
  const [{ data: maintenanceData }, { data: popupData }] = await Promise.all([
    supabase.from('app_settings').select('value').eq('key', 'maintenance_mode').maybeSingle(),
    supabase.from("site_settings").select("popup_active, popup_text, popup_image").eq("id", 1).single()
  ]);

  isMaintenance = maintenanceData && maintenanceData.value === 'true';
  
  if (popupData && popupData.popup_active) {
    popupServerData = {
      text: popupData.popup_text || "",
      image: popupData.popup_image || null
    };
  }
} catch (e) {
  console.error("SSR Supabase Error:", e);
}

const initialDataStr = JSON.stringify({ isMaintenance, popup: popupServerData });
---

<Layout title="HelloHope-web">
  {isMaintenance ? (
    <div id="maintenance-screen" style="height: 100vh; width: 100vw; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 20px; font-family: -apple-system, BlinkMacSystemFont, sans-serif; background: #ffffff; color: #000000; position: fixed; top: 0; left: 0; z-index: 999999;">
      <div style="max-width: 280px; width: 100%;">
        <h1 style="font-size: 24px; font-weight: 800; margin-bottom: 12px; letter-spacing: -1px; text-transform: uppercase;">HopeHype</h1>
        <div style="height: 1px; width: 40px; background: #000; margin: 0 auto 24px;"></div>
        <p style="font-size: 15px; font-weight: 600; margin-bottom: 8px;">Lagi rehat sebentar.</p>
        <p style="color: #666; font-size: 13px; line-height: 1.6; margin-bottom: 40px;">Sistem lagi dirapiin biar makin asik dipake.</p>
        <div style="width: 100%; height: 2px; background: #f0f0f0; position: relative; overflow: hidden;">
          <div style="position: absolute; width: 40%; height: 100%; background: #000; animation: lineMove 1.5s infinite ease-in-out;"></div>
        </div>
      </div>
      <style>@keyframes lineMove { 0% { left: -40%; } 100% { left: 100%; } } body { overflow: hidden !important; }</style>
    </div>
  ) : (
    <main>
      <SkeletonLoader />
      <AdBanner />
      
      <div class="loader"></div>
      <div class="grid-bg"></div>

      <div class="container ready-content">
        <Header />
        <MenuCards />
      </div>

      <Modals />
      <Contact />

      <script id="server-data" type="application/json" set:html={initialDataStr}></script>

      <script>
        // 🔥 DYNAMIC IMPORTS (Performa 100)
        const getDB = () => import('../lib/supabase.js').then(m => m.supabase);
        const getUtils = () => import('../lib/ui-utils.js');

        let db;
        let serverData = { isMaintenance: false, popup: null };
        let currentUserId = null;
        let notificationsPaused = false;
        let notifChannel = null;
        let notifList = document.getElementById("notificationList");

        // A. Baca data Popup Server
        const dataEl = document.getElementById('server-data');
        if (dataEl) {
          try { serverData = JSON.parse(dataEl.textContent); } catch(e){}
        }

        if (serverData.popup) {
          const popupEl = document.getElementById("ad-popup");
          if (popupEl) {
            const desc = document.getElementById("popup-desc");
            const img = document.getElementById("popup-img");
            if (desc) desc.textContent = serverData.popup.text;
            if (img && serverData.popup.image) { 
              img.src = serverData.popup.image; 
              img.style.display = "block"; 
            }
            popupEl.style.display = "flex";
          }
        }

        // =======================
        // FIREBASE PUSH NOTIFIKASI
        // =======================
        async function aktifkanNotifikasi(userId) {
          if (typeof firebase === 'undefined') { setTimeout(() => aktifkanNotifikasi(userId), 1000); return; }
          const firebaseConfig = { apiKey: "AIzaSyCRnwkcydQK2LkdQj7H3WmIKdEyZ9giD9I", authDomain: "hopecreate-b21d8.firebaseapp.com", projectId: "hopecreate-b21d8", storageBucket: "hopecreate-b21d8.firebasestorage.app", messagingSenderId: "313569930727", appId: "1:313569930727:web:afd1e2757cd0fe0867a142" };
          try {
            if (firebase.apps.length === 0) firebase.initializeApp(firebaseConfig);
            const messaging = firebase.messaging();
            const registration = await navigator.serviceWorker.register('/firebase-messaging-sw.js');
            await navigator.serviceWorker.ready;
            const permission = await Notification.requestPermission();
            if (permission !== 'granted') return;
            const token = await messaging.getToken({ serviceWorkerRegistration: registration, vapidKey: 'BJ-fS0SMZxgXvwFL8AGRf4dxL9ijWXAONctGak7-4SGM0UxojMSeWpufhfE_kiIbBBx4iFtWUkYyks-8n36ztYo' });
            if (token) await db.from('user_push_tokens').upsert({ user_id: userId, token: token }, { onConflict: 'user_id' });
          } catch (err) {}
        }

        // =======================
        // CORE LOGIC & USER LOAD
        // =======================
        async function loadUser() {
          db = await getDB();
          const { getUserBadge, showToast } = await getUtils();

          try {
            const { data: { session } } = await db.auth.getSession();
            if (!session) return;

            const user = session.user;
            currentUserId = user.id;

            // Panggil Firebase Notif
            aktifkanNotifikasi(user.id);

            const cacheKey = `hh_profile_${user.id}`;
            let profile = JSON.parse(sessionStorage.getItem(cacheKey));
            
            if (!profile) {
              const { data } = await db.from("profiles").select("username, role, avatar_url, coins").eq("id", user.id).single();
              profile = data;
              if (profile) sessionStorage.setItem(cacheKey, JSON.stringify(profile));
            }

            if (profile) {
              if (profile.role === 'banned') {
                showToast("Akun ditangguhkan!", "", "error");
                await db.auth.signOut(); window.location.href = "/login"; return; 
              }

              window.requestAnimationFrame(() => {
                const usernameEl = document.getElementById("username");
                const avatarEl = document.getElementById("avatar");
                const coinEl = document.getElementById("coinAmount");

                if (usernameEl) usernameEl.innerHTML = `${profile.username || user.email.split("@")[0]} ${getUserBadge(profile.role)}`;
                if (avatarEl && profile.avatar_url) {
                  let avatarSrc = profile.avatar_url;
                  if(avatarSrc.includes('cloudinary.com')) avatarSrc = avatarSrc.replace('/upload/', '/upload/w_100,h_100,c_fill,q_auto,f_auto/');
                  avatarEl.src = avatarSrc;
                }
                if (coinEl) coinEl.textContent = profile.coins ?? 0;
              });
            }
          } catch (err) {}
        }

        // =======================
        // NOTIFIKASI LOGIC
        // =======================
        async function initNotifs() {
          db = await getDB();
          const { showToast } = await getUtils();
          if (!currentUserId) return;

          const { count } = await db.from("notifications").select("*", { count: "exact", head: true }).eq("user_id", currentUserId).eq("is_read", false);
          window.updateNotifBadge(count || 0);

          if (notifChannel) db.removeChannel(notifChannel);
          notifChannel = db.channel("user-notifications").on("postgres_changes", { event: "INSERT", schema: "public", table: "notifications", filter: `user_id=eq.${currentUserId}` },
            async (payload) => { 
              if (!notificationsPaused) {
                const { count: newCount } = await db.from("notifications").select("*", { count: "exact", head: true }).eq("user_id", currentUserId).eq("is_read", false);
                window.updateNotifBadge(newCount || 0);
                const cleanMsg = payload.new.message.replace(/<[^>]*>/g, ""); 
                showToast("Notifikasi Baru", cleanMsg, "info");
              } 
            }
          ).subscribe();
        }

        window.updateNotifBadge = (count) => {
          const el = document.getElementById("notifCount");
          if (!el) return;
          if (count <= 0) { el.style.display = "none"; return; }
          el.style.display = "flex"; el.textContent = count > 99 ? "99+" : count;
        };

        // EVENT KLIK LONCENG NOTIF
        const notifBell = document.getElementById("notifBell");
        if (notifBell) {
          notifBell.onclick = async (e) => {
            e.stopPropagation(); notificationsPaused = true;
            window.updateNotifBadge(0);
            try { await db.from("notifications").update({ is_read: true }).eq("user_id", currentUserId).eq("is_read", false); } catch (err) {}
            
            // Render List Dummy (Karena kode asli lu panjang banget, pastikan fungsi render list lu ditaruh sini atau dialihkan ke halaman /notif)
            showToast("Membuka Notifikasi...", "", "info");
            setTimeout(() => notificationsPaused = false, 2000);
          };
        }

        // =======================
        // INIT APP
        // =======================
        const initApp = () => {
          window.requestAnimationFrame(() => {
            document.body.classList.add('app-loaded');
            loadUser().then(() => {
                setTimeout(initNotifs, 500); 
            });
          });
        };

        if (document.readyState === 'complete') initApp();
        else window.addEventListener('load', initApp);

      </script>

    </main>
  )}
</Layout>

<style is:global>
  /* 🔥 FIX 3: OPTIMAL VISIBILITY (Mencegah Layout Shift) */
  .ready-content { 
    opacity: 0; 
    visibility: hidden; 
    transition: opacity 0.4s ease; 
  }
  
  .app-loaded .ready-content { 
    opacity: 1; 
    visibility: visible; 
  }
  
  .app-loaded #skeleton-screen,
  .app-loaded .loader { 
    display: none !important; 
  }

  /* Perbaikan kecil buat Notif Badge */
  #notifCount {
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
</style>
