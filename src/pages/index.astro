  padding: 24px;
  width: 300px;
  max-width: 90%;
  color: #fff;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.5);
  transform: translateY(-20px);
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.modal.active .modal-content {
  transform: translateY(0);
}

