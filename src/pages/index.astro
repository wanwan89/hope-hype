/* TOGGLE DARK MODE */
.switch {
  --input-focus: #2d8cf0;
  --bg-color: #fff;
  --main-color: #323232;
  position: relative;
  display: inline-block;
  width: 50px;
  height: 20px;
}

.toggle {
  opacity: 0;
  width: 0;
  height: 0;
}

.slider {
  position: absolute;
  cursor: pointer;
  inset: 0;
  border-radius: 5px;
  border: 2px solid var(--main-color);
  background-color: var(--bg-color);
  box-shadow: 4px 4px var(--main-color);
  transition: 0.3s;
}

.slider:before {
  content: "";
  position: absolute;
  height: 20px;
  width: 20px;
  left: -2px;
  bottom: 2px;
  border-radius: 5px;
  border: 2px solid var(--main-color);
  background-color: var(--bg-color);
  box-shadow: 0 3px 0 var(--main-color);
  transition: 0.3s;
}

.toggle:checked + .slider {
  background-color: var(--input-focus);
}

.toggle:checked + .slider:before {
  transform: translateX(30px);
}

body.dark .switch {
  --bg-color: #1e1e1e;
  --main-color: #fff;
}

body.dark .hello-text span {
  color: #fff;
}

body {
  transition: background-color 0.4s ease, color 0.4s ease;
}

