<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Riwayat Transaksi</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap');

    :root {
      --primary: #0b84e3;
      --primary-dark: #096bc0;
      --bg-color: #f4f7fe;
      --card-bg: #ffffff;
      --text-main: #0f172a;
      --text-muted: #64748b;
      --success: #10b981;
      --danger: #f43f5e;
      --gold: #f59e0b;
      --gold-light: #fde68a;
    }

    body {
      margin: 0;
      padding: 0;
      background-color: var(--bg-color);
      font-family: 'Inter', sans-serif;
      color: var(--text-main);
    }

    .app-container {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    /* --- BACKGROUND DECOR --- */
    .bg-circle {
      position: fixed;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(11, 132, 227, 0.08) 0%, rgba(244, 247, 254, 0) 70%);
      border-radius: 50%;
      z-index: -1;
      top: -150px;
      right: -150px;
    }

    /* --- HEADER --- */
    .header {
      padding: 20px;
      display: flex;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(244, 247, 254, 0.85);
      backdrop-filter: blur(12px);
    }

    .back-btn {
      background: white;
      border: none;
      width: 44px;
      height: 44px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.04);
      cursor: pointer;
      color: var(--text-main);
      transition: transform 0.2s;
    }
    
    .back-btn:active {
      transform: scale(0.95);
    }

    .header-title {
      font-family: 'Poppins', sans-serif;
      font-size: 20px;
      font-weight: 700;
      margin-left: 16px;
      letter-spacing: -0.5px;
    }

    /* --- BALANCE CARD --- */
    .balance-card {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      margin: 10px 20px 30px;
      padding: 35px 25px;
      border-radius: 28px;
      box-shadow: 0 20px 40px rgba(37, 99, 235, 0.25);
      color: white;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .balance-card::before {
      content: "";
      position: absolute;
      width: 200px;
      height: 200px;
      background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0));
      border-radius: 50%;
      top: -80px;
      right: -50px;
    }

    .balance-label {
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 2px;
      opacity: 0.85;
      margin-bottom: 8px;
    }

    .balance-amount {
      font-family: 'Poppins', sans-serif;
      font-size: 42px;
      font-weight: 700;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      text-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    /* Custom Premium Coin Icon */
    .premium-coin {
      width: 38px;
      height: 38px;
      background: linear-gradient(135deg, #fcd34d, #f59e0b);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 12px rgba(245, 158, 11, 0.4), inset 0 2px 4px rgba(255, 255, 255, 0.5);
      border: 3px solid #fffbeb;
      font-family: 'Poppins', sans-serif;
      font-weight: 800;
      font-size: 20px;
      color: #78350f;
    }

    /* --- HISTORY LIST --- */
    .section-label {
      padding: 0 25px;
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 17px;
      margin-bottom: 18px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: #1e293b;
    }

    .history-grid {
      padding: 0 20px 40px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .history-item {
      background: white;
      border-radius: 20px;
      padding: 16px;
      display: flex;
      align-items: center;
      box-shadow: 0 10px 25px rgba(0,0,0,0.03);
      border-left: 5px solid transparent;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      opacity: 0;
      animation: slideUp 0.5s forwards ease-out;
    }
    
    .history-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 30px rgba(0,0,0,0.06);
    }

    /* Status Colors */
    .history-item.out { border-left-color: var(--danger); }
    .history-item.in { border-left-color: var(--success); }

    /* Staggered Animation Delay for items */
    .history-item:nth-child(1) { animation-delay: 0.1s; }
    .history-item:nth-child(2) { animation-delay: 0.2s; }
    .history-item:nth-child(3) { animation-delay: 0.3s; }
    .history-item:nth-child(4) { animation-delay: 0.4s; }
    .history-item:nth-child(5) { animation-delay: 0.5s; }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .item-icon {
      width: 52px;
      height: 52px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-right: 16px;
      font-size: 24px;
    }

    .item-icon.out { background: #fff1f2; color: var(--danger); }
    .item-icon.in { background: #f0fdf4; color: var(--success); }

    .item-info {
      flex: 1;
    }

    .item-title {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 2px;
      color: #0f172a;
    }

    .item-desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 6px;
      font-weight: 500;
    }

    .item-date {
      font-size: 11px;
      color: #94a3b8;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .item-date i {
      font-size: 12px;
    }

    /* Badges for Amounts */
    .amount-badge {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 14px;
      padding: 6px 12px;
      border-radius: 12px;
      display: inline-block;
    }

    .amount-badge.minus { 
      background: #fff1f2; 
      color: var(--danger); 
    }
    
    .amount-badge.plus { 
      background: #f0fdf4; 
      color: var(--success); 
    }

    .empty-box {
      text-align: center;
      margin-top: 40px;
      color: var(--text-muted);
      background: white;
      padding: 30px;
      border-radius: 20px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.02);
    }
    
    .empty-icon {
      font-size: 48px;
      color: #cbd5e1;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>
  <div class="bg-circle"></div>
  <div class="app-container">
    <header class="header">
      <button class="back-btn" onclick="window.location.href='/lobby'">
        <i class="material-icons-round">chevron_left</i>
      </button>
      <h1 class="header-title">Riwayat Koin</h1>
    </header>

    <section class="balance-card">
      <div class="balance-label">Saldo Aktif</div>
      <div class="balance-amount" id="balance-amount">
        <div class="premium-coin">$</div>
        0
      </div>
    </section>

    <div class="section-label">
      <span>Aktivitas Terakhir</span>
      <i class="material-icons-round" style="color: var(--primary-dark); font-size: 22px; cursor: pointer;">filter_list</i>
    </div>

    <div class="history-grid" id="history-list">
      <div class="empty-box">
        <i class="material-icons-round empty-icon">history_toggle_off</i>
        <p style="font-weight: 500;">Memuat data transaksi...</p>
      </div>
    </div>
  </div>

  <script>
    // Mock Data untuk preview jika Supabase belum connect
    const mockData = [
      { transaction_type: 'send_gift', description: 'Kirim Daebak x20 ke v', amount: -200, created_at: '2026-04-19T12:16:00' },
      { transaction_type: 'send_gift', description: 'Kirim Fighting x4 ke null', amount: -8000, created_at: '2026-04-19T11:10:00' },
      { transaction_type: 'top_up', description: 'Top Up via BCA', amount: 50000, created_at: '2026-04-18T09:30:00' },
      { transaction_type: 'send_gift', description: 'Kirim Love x22 ke null', amount: -22, created_at: '2026-04-17T11:10:00' }
    ];

    const formatDate = (dateString) => {
      const date = new Date(dateString);
      return date.toLocaleDateString('id-ID', {
        day: 'numeric', month: 'short',
        hour: '2-digit', minute: '2-digit'
      });
    };

    // Simulated Load Data
    async function loadData() {
      try {
        // Simulasi update saldo
        document.getElementById('balance-amount').innerHTML = `
          <div class="premium-coin">$</div>
          22.616
        `;

        const list = document.getElementById('history-list');
        const tx = mockData; // Ganti dengan logika Supabase aslinya nanti
        
        if (!tx || tx.length === 0) {
          list.innerHTML = `
            <div class="empty-box">
              <i class="material-icons-round empty-icon">receipt_long</i>
              <p>Belum ada riwayat transaksi.</p>
            </div>`;
          return;
        }

        list.innerHTML = tx.map(t => {
          const isOut = t.amount < 0;
          const statusClass = isOut ? 'out' : 'in';
          const icon = isOut ? 'card_giftcard' : 'account_balance_wallet';
          const amountSign = isOut ? '' : '+';
          const title = t.transaction_type.replace(/_/g, ' ').toUpperCase();

          return `
            <div class="history-item ${statusClass}">
              <div class="item-icon ${statusClass}">
                <i class="material-icons-round">${icon}</i>
              </div>
              <div class="item-info">
                <div class="item-title">${title}</div>
                <div class="item-desc">${t.description || '-'}</div>
                <div class="item-date">
                  <i class="material-icons-round">schedule</i> ${formatDate(t.created_at)}
                </div>
              </div>
              <div class="item-value">
                <div class="amount-badge ${statusClass}">${amountSign}${t.amount.toLocaleString('id-ID')}</div>
              </div>
            </div>
          `;
        }).join('');
      } catch (e) { console.error(e); }
    }
    
    // Memberikan sedikit delay agar animasi terlihat saat di-load
    setTimeout(loadData, 300);
  </script>
</body>
</html>
