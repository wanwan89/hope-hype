---
// Halaman Riwayat Koin - HypeVoice Clean List Style
---

<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Riwayat Transaksi</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap');

    :root {
      --primary: #0b84e3;
      --bg-color: #ffffff;
      --group-bg: #f5f5f5;
      --text-main: #111;
      --text-muted: #888;
      --divider: #eeeeee;
    }

    body {
      margin: 0;
      padding: 0;
      background-color: var(--bg-color);
      font-family: 'Inter', sans-serif;
      color: var(--text-main);
    }

    .app-container {
      max-width: 480px;
      margin: 0 auto;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* --- HEADER --- */
    .header {
      padding: 15px 20px;
      display: flex;
      align-items: center;
      background: white;
      position: sticky;
      top: 0;
      z-index: 100;
      border-bottom: 1px solid var(--divider);
    }

    .back-btn {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      color: var(--text-main);
      margin-right: 15px;
    }

    .header-title {
      font-size: 18px;
      font-weight: 700;
      margin: 0;
    }

    /* --- GROUP HEADER (Tahun-Bulan) --- */
    .group-header {
      background-color: var(--group-bg);
      padding: 8px 20px;
      font-size: 14px;
      font-weight: 600;
      color: #666;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* --- HISTORY ITEM --- */
    .history-item {
      padding: 15px 20px;
      border-bottom: 1px solid var(--divider);
      background: white;
    }

    .item-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px;
    }

    .item-title {
      font-size: 15px;
      font-weight: 500;
      color: #111;
      flex: 1;
      padding-right: 10px;
    }

    .item-amount {
      font-size: 16px;
      font-weight: 500;
      color: #111;
    }

    .item-user {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 6px;
    }

    .user-avatar {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      object-fit: cover;
      background: #eee;
    }

    .user-name {
      font-size: 13px;
      color: #777;
    }

    .item-time {
      font-size: 12px;
      color: #bbb;
    }

    .empty-box {
      text-align: center;
      padding: 50px 20px;
      color: var(--text-muted);
    }
  </style>
</head>
<body>

  <div class="app-container">
    <header class="header">
      <button class="back-btn" onclick="window.location.href='/lobby'">
        <i class="material-icons-round">arrow_back</i>
      </button>
      <h1 class="header-title">Riwayat Koin</h1>
    </header>

    <div id="history-content">
      <div class="empty-box">Memuat riwayat...</div>
    </div>
  </div>

  <script>
    import { supabase } from '../lib/supabase.js';

    // Helper format waktu (DD/MM/YYYY HH:mm:ss)
    const formatFullTime = (dateString) => {
      const d = new Date(dateString);
      const pad = (n) => n.toString().padStart(2, '0');
      return `${pad(d.getDate())}/${pad(d.getMonth() + 1)}/${d.getFullYear()} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
    };

    // Helper format group key (YYYY-M)
    const getGroupKey = (dateString) => {
      const d = new Date(dateString);
      return `${d.getFullYear()}-${d.getMonth() + 1}`;
    };

    async function loadData() {
      try {
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) return window.location.href = '/login';

        // Ambil riwayat
        const { data: transactions, error } = await supabase
          .from('coin_history')
          .select('*')
          .eq('user_id', user.id)
          .order('created_at', { ascending: false });

        const container = document.getElementById('history-content');

        if (error || !transactions || transactions.length === 0) {
          container.innerHTML = '<div class="empty-box">Belum ada riwayat transaksi.</div>';
          return;
        }

        // --- PROSES GROUPING BERDASARKAN BULAN ---
        const groups = {};
        transactions.forEach(trx => {
          const key = getGroupKey(trx.created_at);
          if (!groups[key]) groups[key] = [];
          groups[key].push(trx);
        });

        // --- RENDER KE HTML ---
        let finalHtml = '';
        
        // Urutkan grup dari yang terbaru
        Object.keys(groups).sort((a, b) => b.localeCompare(a)).forEach(key => {
          finalHtml += `
            <div class="group-header">
              ${key} <i class="material-icons-round" style="font-size: 16px;">arrow_drop_down</i>
            </div>
          `;

          groups[key].forEach(t => {
            const isOut = t.amount < 0;
            const amountText = isOut ? t.amount : `+${t.amount}`;
            
            // Logika judul berdasarkan tipe
            let title = t.transaction_type.replace(/_/g, ' ');
            if(t.transaction_type === 'send_gift') title = "Hadiah Terkirim";
            if(t.transaction_type === 'receive_gift') title = "Hadiah Diterima";

            finalHtml += `
              <div class="history-item">
                <div class="item-top">
                  <span class="item-title">${title}: ${t.description || '-'}</span>
                  <span class="item-amount">${amountText}</span>
                </div>
                <div class="item-user">
                  <img class="user-avatar" src="/asets/png/profile.png" />
                  <span class="user-name">User</span>
                </div>
                <div class="item-time">${formatFullTime(t.created_at)}</div>
              </div>
            `;
          });
        });

        container.innerHTML = finalHtml;

      } catch (e) {
        console.error(e);
      }
    }

    loadData();
  </script>
</body>
</html>
