---
// historycoin.astro
// Halaman ini murni menggunakan client-side fetching
---

<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="hc-wrapper">
  <div class="hc-container">
    <h1 class="hc-title">Riwayat Koin</h1>

    <div id="hc-loading" class="hc-card hc-state-message">
      <div class="hc-spinner"></div>
      <p>Memuat data koinmu...</p>
    </div>

    <div id="hc-auth-warning" class="hc-card hc-state-message" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hc-icon-warning"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <h2>Silakan Login</h2>
      <p>Kamu harus masuk untuk melihat riwayat koinmu.</p>
    </div>

    <div id="hc-error" class="hc-card hc-state-message" style="display: none;">
      <p id="hc-error-text" class="hc-text-danger">Terjadi kesalahan saat memuat data.</p>
    </div>

    <div id="hc-content" style="display: none;">
      <div class="hc-card hc-balance-card">
        <p class="hc-balance-label">TOTAL KOIN SAAT INI</p>
        <h2 class="hc-balance-amount" id="hc-total-coins">0</h2>
      </div>

      <h3 class="hc-subtitle">Riwayat Transaksi</h3>

      <div id="hc-empty-state" class="hc-card hc-state-message" style="display: none;">
        <p>Belum ada transaksi.</p>
      </div>

      <div id="hc-history-list" class="hc-history-list">
        </div>
    </div>
  </div>
</div>

<style is:global>
  /* Reset dasar agar tidak terpengaruh CSS bawaan website */
  .hc-wrapper, .hc-wrapper * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* Variabel CSS untuk Light/Dark Mode */
  .hc-wrapper {
    --hc-bg: #f8fafc;
    --hc-card-bg: #ffffff;
    --hc-text-main: #0f172a;
    --hc-text-muted: #64748b;
    --hc-border: #e2e8f0;
    --hc-primary: #3b82f6;
    --hc-success: #10b981;
    --hc-danger: #ef4444;
    --hc-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px -1px rgba(0, 0, 0, 0.1);
    
    font-family: 'Inter', sans-serif;
    background-color: var(--hc-bg);
    color: var(--hc-text-main);
    min-height: 100vh;
    width: 100%;
    padding: 1.25rem 1rem; /* Jarak pas ke pinggir layar HP */
    touch-action: manipulation; /* Mencegah double-tap zoom */
    overflow-x: hidden;
  }

  /* Support Dark Mode menggunakan class html.dark */
  html.dark .hc-wrapper {
    --hc-bg: #0f172a;
    --hc-card-bg: #1e293b;
    --hc-text-main: #f8fafc;
    --hc-text-muted: #94a3b8;
    --hc-border: #334155;
    --hc-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
  }

  .hc-container {
    width: 100%;
    max-width: 600px; /* Menjaga agar di laptop tidak terlalu lebar */
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .hc-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    text-align: center;
    color: var(--hc-text-main);
  }

  .hc-subtitle {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 1.5rem 0 0.75rem 0;
    color: var(--hc-text-main);
  }

  .hc-card {
    background-color: var(--hc-card-bg);
    border: 1px solid var(--hc-border);
    border-radius: 0.75rem; /* Siku membulat yang modern */
    padding: 1.25rem;
    box-shadow: var(--hc-shadow);
    width: 100%;
  }

  .hc-balance-card {
    text-align: center;
    padding: 1.5rem 1rem;
  }

  .hc-balance-label {
    color: var(--hc-text-muted);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .hc-balance-amount {
    font-size: 2rem;
    font-weight: 700;
    color: var(--hc-primary);
    line-height: 1;
  }

  .hc-history-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem; /* Jarak antar list dibuat lebih rapat sesuai gambar */
    width: 100%;
  }

  .hc-history-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 1rem;
    background-color: var(--hc-card-bg);
    border: 1px solid var(--hc-border);
    border-radius: 0.5rem; /* Border radius list sedikit lebih kecil dari card utama */
    width: 100%;
  }

  .hc-history-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 0;
  }

  .hc-history-desc {
    font-weight: 500;
    font-size: 0.85rem;
    color: var(--hc-text-main);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis; /* Menambahkan titik-titik (...) jika teks terlalu panjang */
  }

  .hc-history-date {
    font-size: 0.7rem;
    color: var(--hc-text-muted);
  }

  .hc-history-amount {
    font-weight: 700;
    font-size: 1rem;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  .hc-text-success { color: var(--hc-success); }
  .hc-text-danger { color: var(--hc-danger); }

  /* Utilities untuk States */
  .hc-state-message {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--hc-text-muted);
  }

  .hc-icon-warning {
    color: var(--hc-text-muted);
    margin-bottom: 1rem;
  }

  .hc-spinner {
    border: 3px solid var(--hc-border);
    border-top: 3px solid var(--hc-primary);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    animation: hc-spin 1s linear infinite;
    margin-bottom: 1rem;
  }

  @keyframes hc-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>

<script>
  import { supabase } from '../lib/supabase.js';

  document.addEventListener('DOMContentLoaded', async () => {
    const elLoading = document.getElementById('hc-loading');
    const elAuthWarning = document.getElementById('hc-auth-warning');
    const elError = document.getElementById('hc-error');
    const elErrorText = document.getElementById('hc-error-text');
    const elContent = document.getElementById('hc-content');
    const elTotalCoins = document.getElementById('hc-total-coins');
    const elEmptyState = document.getElementById('hc-empty-state');
    const elHistoryList = document.getElementById('hc-history-list');

    const showElement = (element) => element.style.display = 'flex'; // Pakai flex agar styling container tetap jalan
    const hideElement = (element) => element.style.display = 'none';

    const formatDate = (dateString) => {
      const options = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' };
      const date = new Date(dateString);
      // Format seperti di gambar: "19 Apr 2026, 11.10"
      return date.toLocaleDateString('id-ID', options).replace('pukul ', '').replace(':', '.'); 
    };

    const renderHistory = (historyData) => {
      if (!historyData || historyData.length === 0) {
        showElement(elEmptyState);
        return;
      }

      historyData.forEach(item => {
        // Mencegah double minus
        const amountValue = Number(item.amount) || 0;
        const displayAmount = Math.abs(amountValue); 
        
        // Logika Uang Masuk/Keluar
        const isIncome = item.type === 'masuk' || (item.type !== 'keluar' && amountValue >= 0);
        const sign = isIncome ? '+' : '-';
        const colorClass = isIncome ? 'hc-text-success' : 'hc-text-danger';

        const historyItem = document.createElement('div');
        historyItem.className = 'hc-history-item';
        
        historyItem.innerHTML = `
          <div class="hc-history-info">
            <span class="hc-history-desc">${escapeHTML(item.description || 'Transaksi')}</span>
            <span class="hc-history-date">${item.created_at ? formatDate(item.created_at) : '-'}</span>
          </div>
          <div class="hc-history-amount ${colorClass}">
            ${sign}${displayAmount}
          </div>
        `;
        
        elHistoryList.appendChild(historyItem);
      });
    };

    const escapeHTML = (str) => {
      if (!str) return '';
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    };

    const fetchCoinData = async () => {
      try {
        const { data: { session }, error: sessionError } = await supabase.auth.getSession();
        
        if (sessionError) throw sessionError;
        
        if (!session || !session.user) {
          hideElement(elLoading);
          showElement(elAuthWarning);
          return;
        }

        const userId = session.user.id;

        const [profileResult, historyResult] = await Promise.all([
          supabase.from('profiles').select('coins').eq('id', userId).single(),
          supabase.from('coin_history').select('*').eq('user_id', userId).order('created_at', { ascending: false })
        ]);

        if (profileResult.error) throw profileResult.error;
        if (historyResult.error) throw historyResult.error;

        elTotalCoins.textContent = profileResult.data.coins || 0;
        renderHistory(historyResult.data);

        hideElement(elLoading);
        showElement(elContent);
        // Reset display ke block/flex sesuai kebutuhan content utama
        elContent.style.display = 'block';

      } catch (error) {
        console.error("Error fetching coin data:", error);
        elErrorText.textContent = `Gagal memuat data: ${error.message || 'Terjadi kesalahan'}`;
        hideElement(elLoading);
        showElement(elError);
      }
    };

    fetchCoinData();
  });
</script>
