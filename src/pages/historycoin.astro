---
// Halaman Riwayat Koin - HypeVoice Ultra Premium UI
---

<html lang="id">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Riwayat Koin</title>

<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap');

:root {
  --primary: #0b84e3;
  --gradient: linear-gradient(135deg, #0b84e3, #1f3cff);
  --bg: #f4f8ff;
  --glass: rgba(255,255,255,0.7);
  --text: #0f172a;
  --muted: #64748b;
  --success: #22c55e;
  --danger: #ef4444;
}

body {
  margin: 0;
  background: var(--bg);
  font-family: 'Inter', sans-serif;
}

/* BACKGROUND GLOW */
body::before {
  content: "";
  position: fixed;
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(11,132,227,0.25), transparent);
  top: -150px;
  right: -150px;
  z-index: -1;
}

/* CONTAINER */
.app {
  max-width: 480px;
  margin: auto;
}

/* HEADER */
.header {
  display: flex;
  align-items: center;
  padding: 20px;
  backdrop-filter: blur(12px);
}

.back {
  width: 45px;
  height: 45px;
  border-radius: 14px;
  background: white;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 6px 14px rgba(0,0,0,0.08);
  cursor: pointer;
}

.title {
  font-weight: 700;
  font-size: 20px;
  margin-left: 14px;
}

/* BALANCE CARD */
.balance {
  margin: 10px 20px 30px;
  padding: 30px;
  border-radius: 28px;
  background: var(--gradient);
  color: white;
  text-align: center;
  box-shadow: 0 20px 40px rgba(11,132,227,0.4);
  position: relative;
  overflow: hidden;
}

.balance::after {
  content: "";
  position: absolute;
  width: 200px;
  height: 200px;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  top: -80px;
  left: -80px;
}

.balance h2 {
  font-size: 13px;
  opacity: 0.8;
  letter-spacing: 1px;
}

.balance-amount {
  font-family: 'Poppins';
  font-size: 40px;
  margin-top: 10px;
  display: flex;
  justify-content: center;
  gap: 10px;
  align-items: center;
}

.coin {
  color: gold;
  filter: drop-shadow(0 0 10px gold);
}

/* SECTION */
.section {
  padding: 0 20px;
  font-weight: 700;
  margin-bottom: 15px;
}

/* LIST */
.list {
  padding: 0 20px 40px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* ITEM */
.item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-radius: 22px;
  background: var(--glass);
  backdrop-filter: blur(14px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  animation: fadeUp .4s ease;
  transition: .2s;
}

.item:hover {
  transform: scale(1.02);
}

/* ICON */
.icon {
  width: 52px;
  height: 52px;
  border-radius: 16px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 14px;
}

.icon.in { background: #dcfce7; color: var(--success); }
.icon.out { background: #fee2e2; color: var(--danger); }

/* TEXT */
.info {
  flex: 1;
}

.title2 {
  font-weight: 600;
  font-size: 14px;
}

.desc {
  font-size: 12px;
  color: var(--muted);
}

.date {
  font-size: 10px;
  margin-top: 4px;
  color: #94a3b8;
}

/* VALUE */
.value {
  font-weight: 700;
  font-family: 'Poppins';
}

.plus { color: var(--success); }
.minus { color: var(--danger); }

/* EMPTY */
.empty {
  text-align: center;
  margin-top: 60px;
  color: var(--muted);
  animation: fadeUp .5s ease;
}

/* ANIMATION */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(15px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
</head>

<body>

<div class="app">

  <div class="header">
    <div class="back" onclick="location.href='/lobby'">
      <i class="material-icons-round">chevron_left</i>
    </div>
    <div class="title">Riwayat Koin</div>
  </div>

  <div class="balance">
    <h2>Saldo Aktif</h2>
    <div class="balance-amount" id="balance">
      <i class="material-icons-round coin">monetization_on</i>
      0
    </div>
  </div>

  <div class="section">Aktivitas Terakhir</div>

  <div class="list" id="list">
    <div class="empty">Loading...</div>
  </div>

</div>

<script type="module">
import { supabase } from '../lib/supabase.js';

const formatDate = (d) => {
  return new Date(d).toLocaleDateString('id-ID', {
    day:'numeric', month:'short',
    hour:'2-digit', minute:'2-digit'
  });
};

async function load() {
  const { data:{ user } } = await supabase.auth.getUser();
  if (!user) return location.href='/login';

  // saldo
  const { data: profile } = await supabase
    .from('profiles')
    .select('coins')
    .eq('id', user.id)
    .single();

  document.getElementById('balance').innerHTML = `
    <i class="material-icons-round coin">monetization_on</i>
    ${(profile?.coins || 0).toLocaleString('id-ID')}
  `;

  // history
  const { data: tx } = await supabase
    .from('coin_history')
    .select('*')
    .eq('user_id', user.id)
    .order('created_at', { ascending:false });

  const list = document.getElementById('list');

  if (!tx || tx.length === 0) {
    list.innerHTML = `<div class="empty">Belum ada transaksi </div>`;
    return;
  }

  list.innerHTML = tx.map(t => {
    const out = t.amount < 0;

    return `
      <div class="item">
        <div class="icon ${out ? 'out':'in'}">
          <i class="material-icons-round">
            ${out ? 'payments':'task_alt'}
          </i>
        </div>

        <div class="info">
          <div class="title2">
            ${t.transaction_type.replace(/_/g,' ')}
          </div>
          <div class="desc">${t.description || '-'}</div>
          <div class="date">${formatDate(t.created_at)}</div>
        </div>

        <div class="value ${out?'minus':'plus'}">
          ${out ? '' : '+'}${t.amount}
        </div>
      </div>
    `;
  }).join('');
}

load();
</script>

</body>
</html>