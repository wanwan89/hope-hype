---
import Layout from '../layouts/Layout.astro';
import Header from '../components/wallet/Headerwallet.astro';
import BalanceSection from '../components/wallet/BalanceSection.astro';
import AssetsGrid from '../components/wallet/AssetsGrid.astro';
import MenuRow from '../components/wallet/MenuRow.astro';
import ServicesArea from '../components/wallet/ServicesArea.astro';
import WithdrawBtn from '../components/wallet/WithdrawBtn.astro';
---

<Layout title="Wallet - HopeHype">
  <div class="wallet-wrapper">
    <Header />
    
    <BalanceSection />
    
    <AssetsGrid />
    
    <MenuRow />
    
    <ServicesArea />
    
    <WithdrawBtn />
  </div>

  <script>
    // Konfigurasi Supabase
    const supabaseUrl = 'https://hqetnqnvmdxdgfnnluew.supabase.co';
    const supabaseKey = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImhxZXRucW52bWR4ZGdmbm5sdWV3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3MzUyODIsImV4cCI6MjA4NzMxMTI4Mn0.Cr9lDBZMqfeONi1dfyFzHpBtawBzZTQLBEWKmPJVAOA';
    
    // Karena lu udah define window.supabase di Layout.astro, kita tinggal panggil
    const supabaseClient = window.supabase.createClient(supabaseUrl, supabaseKey);

    async function loadWalletData() {
      try {
        // 1. Ambil User yang sedang Login
        const { data: { user }, error: authError } = await supabaseClient.auth.getUser();
        
        if (authError || !user) {
          console.log("User belum login");
          return;
        }

        // 2. Ambil data koin ASLI dari tabel profiles
        const { data: profile, error: profileError } = await supabaseClient
          .from('profiles')
          .select('coins')
          .eq('id', user.id)
          .single();

        if (profileError) throw profileError;

        // 3. Update Tampilan
        const realCoins = profile.coins || 0;
        const idrRate = 70; // Kurs Rp 70 sesuai kesepakatan baru
        
        const coinEl = document.getElementById('coinDisplay');
        const idrEl = document.getElementById('idrDisplay');
        
        if (coinEl) coinEl.innerText = realCoins.toLocaleString('id-ID');
        if (idrEl) idrEl.innerText = 'Rp ' + (realCoins * idrRate).toLocaleString('id-ID');

      } catch (err) {
        console.error("Gagal load saldo:", err.message);
      }
    }

    // Jalankan fungsi saat halaman beres dimuat
    document.addEventListener("DOMContentLoaded", loadWalletData);
  </script>
</Layout>

<style is:global>
  :root {
    --bg: #ffffff;          /* Background Putih Bersih */
    --card-bg: #ffffff;     /* Box tetep putih */
    --text-main: #000000;    /* Teks Utama Hitam */
    --text-muted: #8e8e93;   /* Teks abu-abu kalem */
    --border: #f2f2f2;       /* Border abu-abu sangat muda */
    --accent-blue: #007bff;  /* Biru Electric HopeHype */
    --success: #34c759;      /* Hijau Standar iOS/Android */
  }

  * {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  /* * Catatan: Karena kita pake Layout.astro, body-nya nggak perlu di-define 
   * font dan margin lagi di sini kalau di Layout udah ada. 
   * Tapi gw biarin biar nggak merusak struktur desain lu.
   */
  body {
    margin: 0;
    background: var(--bg);
    font-family: 'Inter', 'Poppins', sans-serif;
    color: var(--text-main);
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .wallet-wrapper {
    max-width: 480px;
    margin: 0 auto;
    padding: 40px 24px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
