---
import Layout from '../layouts/Layout.astro';
import Header from '../components/history/Headerhistory.astro'; // Nama variabelnya "Header"
import HistoryList from '../components/history/HistoryList.astro';
---
<Layout title="Withdrawal History - HopeHype">
  <link rel="stylesheet" href="/css/toast.css" />
  <script is:inline src="/js/toast.js"></script>

  <div class="history-container">
    <Header /> 

    <HistoryList />
  </div>
</Layout>

<style is:global>
  :root {
    --bg: #ffffff;
    --card-bg: #f9f9f9;
    --text-main: #000000;
    --text-muted: #8e8e93;
    --border: #f2f2f2;
    --accent-blue: #007bff;
  }

  .history-container * { 
    box-sizing: border-box; 
    -webkit-tap-highlight-color: transparent; 
    outline: none; 
  }

  .history-container { 
    max-width: 480px; 
    margin: 0 auto; 
    padding: 40px 24px;
    height: 100vh; 
    display: flex; 
    flex-direction: column;
    font-family: 'Inter', sans-serif; 
    background: var(--bg); 
    color: var(--text-main); 
  }
</style>
