---
---
<div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<div id="mySidebar" class="sidebar">
  <div class="sidebar-search-container">
    <div class="sidebar-search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8a8b91" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      <input type="text" placeholder="Cari" />
    </div>
  </div>

  <div class="menu-category-label">Aset</div>
  
  <div class="menu-item-tiktok" onclick="window.location.href='/saldo'">
    <div class="icon-wrapper">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>
    </div>
    <div class="menu-text">Saldo</div>
    <div class="arrow-right">›</div>
  </div>

  <div class="menu-item-tiktok" onclick="window.location.href='/historycoin'">
    <div class="icon-wrapper">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="12 8 12 12 14 14"></polyline><circle cx="12" cy="12" r="10"></circle></svg>
    </div>
    <div class="menu-text">Riwayat Transaksi</div>
    <div class="arrow-right">›</div>
  </div>
   
  <div class="menu-category-label">Misi & Hadiah</div>
  <div class="menu-item-tiktok" onclick="window.location.href='/dailycek'">
    <div class="icon-wrapper" style="color: #f59e0b;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
        <path d="M9 16l2 2 4-4"></path>
      </svg>
    </div>
    <div class="menu-text">Pusat Misi</div>
    <div class="arrow-right">›</div>
  </div>



  <hr style="border: 0; border-top: 1px solid #f1f1f2; margin: 10px 16px;" />

  <div class="menu-category-label">Alat pribadi</div>
  <div class="menu-item-tiktok" onclick="shareProfile(); toggleSidebar();">
    <div class="icon-wrapper">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><rect x="7" y="7" width="3" height="3"></rect><rect x="14" y="7" width="3" height="3"></rect><rect x="7" y="14" width="3" height="3"></rect></svg>
    </div>
    <div class="menu-text">Kode QR Anda</div>
    <div class="arrow-right">›</div>
  </div>
</div>

<style is:global>
  .sidebar-overlay {
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.4); z-index: 1999; display: none; opacity: 0;
      transition: opacity 0.3s ease; cursor: pointer;
  }
  .sidebar {
      position: fixed; top: 0; right: -100%; width: 75%; max-width: 300px; height: 100%;
      background: #ffffff; z-index: 2000; transition: right 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
      display: flex; flex-direction: column; overflow-y: auto; box-shadow: -5px 0 20px rgba(0,0,0,0.05);
  }
  .sidebar.open { right: 0; }
  .sidebar-search-container { padding: 20px 16px 10px; }
  .sidebar-search { background: #f1f1f2; border-radius: 8px; padding: 8px 12px; display: flex; align-items: center; gap: 10px; }
  .sidebar-search input { border: none; background: transparent; outline: none; width: 100%; font-size: 15px; color: #1c1e21; }
  .menu-category-label { padding: 20px 16px 8px; font-size: 13px; font-weight: 600; color: #8a8b91; }
  .menu-item-tiktok { display: flex; align-items: center; padding: 12px 16px; cursor: pointer; transition: background 0.2s; }
  .menu-item-tiktok:active { background: #f8f8f8; }
  .menu-item-tiktok .icon-wrapper { width: 28px; display: flex; align-items: center; color: #1c1e21; }
  .menu-item-tiktok .menu-text { flex: 1; font-size: 16px; font-weight: 500; color: #1c1e21; margin-left: 10px; }
  .menu-item-tiktok .arrow-right { color: #bdbebf; font-size: 18px; }
</style>
