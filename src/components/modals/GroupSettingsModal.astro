---
// File: src/components/modals/GroupSettingsModal.astro
---
<div id="group-settings-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px); z-index: 999999; align-items: center; justify-content: center; padding: 20px;">
  
  <div style="width: 100%; max-width: 350px; background: var(--bg-panel, #ffffff); border: 1px solid var(--border-color, #e5e7eb); border-radius: 20px; padding: 25px; text-align: center; box-shadow: 0 15px 35px rgba(0,0,0,0.2); color: var(--text-color, #333); display: flex; flex-direction: column; max-height: 90vh;">
    
    <h2 style="margin: 0 0 15px 0; font-size: 18px; font-weight: 700; color: var(--text-color);">Pengaturan Grup</h2>

    <div style="margin-bottom: 20px; position: relative; align-self: center;">
      <label for="edit-group-photo-input" style="cursor: pointer; display: block; position: relative;">
        <img id="edit-group-photo-preview" src="/asets/png/profile.webp" style="width: 85px; height: 85px; border-radius: 50%; object-fit: cover; border: 3px solid #3a7bd5; background: var(--bg-main);" />
        <div style="position: absolute; bottom: 0; right: 0; background: #3a7bd5; color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid var(--bg-panel); font-size: 13px;">✏️</div>
      </label>
      <input type="file" id="edit-group-photo-input" accept="image/*" style="display: none;" />
    </div>

    <div style="text-align: left; margin-bottom: 15px;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; display: block;">Nama Grup</label>
      <input type="text" id="edit-group-name" placeholder="Nama grup..." style="width: 100%; padding: 12px 14px; border: 1px solid var(--border-color); border-radius: 12px; box-sizing: border-box; background: var(--bg-main); color: var(--text-color); outline: none; font-family: inherit; font-size: 14px;" />
    </div>

    <div style="text-align: left; margin-bottom: 20px; display: flex; flex-direction: column; min-height: 0;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; display: block;">Anggota Grup</label>
      <div id="member-list-container" style="max-height: 150px; overflow-y: auto; background: var(--bg-main); border: 1px solid var(--border-color); border-radius: 12px; padding: 8px 12px;">
        <div style='font-size:12px; color:var(--text-muted); text-align:center; padding: 10px 0;'>Memuat anggota...</div>
      </div>
    </div>

    <div style="display: flex; flex-direction: column; gap: 10px; margin-top: auto;">
      <button id="btn-save-group-info" onclick="window.updateGroupInfo()" style="width: 100%; padding: 12px; border: none; border-radius: 12px; background: #3a7bd5; color: white; font-weight: 600; cursor: pointer;">
        Simpan Perubahan
      </button>
      <div style="display: flex; gap: 10px;">
        <button onclick="window.leaveGroup()" style="flex: 1; padding: 12px; border: none; border-radius: 12px; background: rgba(239, 68, 68, 0.1); color: #ef4444; font-weight: 600; cursor: pointer;">
          Keluar
        </button>
        <button onclick="document.getElementById('group-settings-modal').style.display='none'" style="flex: 1; padding: 12px; border: none; border-radius: 12px; background: var(--label-bg, #f1f5f9); color: var(--text-color); font-weight: 600; cursor: pointer;">
          Tutup
        </button>
      </div>
    </div>

  </div>
</div>
