---
// Ini adalah komponen modal untuk Pengaturan Grup
---
<div id="group-settings-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu" style="width: 90%; max-width: 350px; padding: 25px; text-align: center; background: var(--bg-panel); color: var(--text-color); transition: background-color 0.3s, color 0.3s; position: relative;">
    
    <h2 style="margin: 0 0 15px 0; font-size: 18px; color: var(--text-color);">Pengaturan Grup</h2>

    <div style="margin-bottom: 20px; position: relative; display: inline-block;">
      <label for="edit-group-photo-input" style="cursor: pointer;">
        <img id="edit-group-photo-preview" src="/asets/png/profile.webp" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid #3a7bd5; background: var(--bg-main); transition: background-color 0.3s;" />
        
        <div style="position: absolute; bottom: 0; right: 0; background: #3a7bd5; color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 2px solid var(--bg-panel); font-size: 13px; transition: border-color 0.3s;">
          ✏️
        </div>
      </label>
      <input type="file" id="edit-group-photo-input" accept="image/*" style="display: none;" />
    </div>

    <div style="text-align: left; margin-bottom: 15px;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; display: block;">Nama Grup</label>
      <input type="text" id="edit-group-name" placeholder="Nama grup..." style="width: 100%; padding: 12px 14px; border: 1px solid var(--border-color); border-radius: 12px; box-sizing: border-box; background: var(--bg-main); color: var(--text-color); transition: all 0.2s; outline: none; font-family: inherit;" />
    </div>

    <div style="text-align: left; margin-bottom: 20px;">
      <label style="font-size: 12px; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; display: block;">Anggota Grup</label>
