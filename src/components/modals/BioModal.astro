---
---
<div id="bio-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu" style="width: 90%; max-width: 350px; text-align: left; padding: 25px; background: var(--bg-panel); color: var(--text-color); transition: background-color 0.3s, color 0.3s;">
    <h2 style="margin: 0 0 10px 0; font-size: 18px; color: #3a7bd5; text-align: center;">Lengkapi Profilmu</h2>
    
    <p style="font-size: 11px; color: var(--text-muted); margin-bottom: 20px; text-align: center; transition: color 0.3s;">Data ini membantu kami mencari teman yang paling cocok untukmu.</p>

    <div style="display: flex; gap: 10px; margin-bottom: 15px;">
      <div style="flex: 1;">
        <label style="font-size: 11px; font-weight: 600;">Umur</label>
        <input type="number" id="in-umur" placeholder="20" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-main); color: var(--text-color); box-sizing: border-box; transition: background-color 0.3s, border-color 0.3s, color 0.3s;" />
      </div>
      <div style="flex: 1;">
        <label style="font-size: 11px; font-weight: 600;">Gender</label>
        <select id="in-gender" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-main); color: var(--text-color); box-sizing: border-box; transition: background-color 0.3s, border-color 0.3s, color 0.3s;">
          <option value="Pria">Pria</option>
          <option value="Wanita">Wanita</option>
        </select>
      </div>
    </div>

    <label style="font-size: 11px; font-weight: 600;">Zodiak</label>
    <select id="in-zodiak" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-main); color: var(--text-color); margin-bottom: 15px; box-sizing: border-box; transition: background-color 0.3s, border-color 0.3s, color 0.3s;">
      <option value="Aries">Aries</option>
      <option value="Taurus">Taurus</option>
      <option value="Gemini">Gemini</option>
      <option value="Cancer">Cancer</option>
      <option value="Leo">Leo</option>
      <option value="Virgo">Virgo</option>
      <option value="Libra">Libra</option>
      <option value="Scorpio">Scorpio</option>
      <option value="Sagitarius">Sagitarius</option>
      <option value="Capricorn">Capricorn</option>
      <option value="Aquarius">Aquarius</option>
      <option value="Pisces">Pisces</option>
    </select>

    <label style="font-size: 11px; font-weight: 600;">Hobi</label>
    <input type="text" id="in-hobi" placeholder="Apa kegemaranmu?" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-main); color: var(--text-color); margin-bottom: 15px; box-sizing: border-box; transition: background-color 0.3s, border-color 0.3s, color 0.3s;" />

    <label style="font-size: 11px; font-weight: 600;">Pekerjaan / Kegiatan</label>
    <input type="text" id="in-kerja" placeholder="Contoh: Mahasiswa" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: 8px; background: var(--bg-main); color: var(--text-color); margin-bottom: 20px; box-sizing: border-box; transition: background-color 0.3s, border-color 0.3s, color 0.3s;" />

    <div style="display: flex; gap: 10px;">
      <button class="btn-confirm" id="btn-save-bio" style="flex: 2;">Simpan & Cari</button>
      <button type="button" class="btn-cancel" onclick="window.closeBioModal()" style="flex: 1; padding: 12px; border: none; border-radius: 10px; background: var(--border-color); color: var(--text-color); font-weight: 600; cursor: pointer; transition: background-color 0.3s, color 0.3s;">
        Batal
      </button>
    </div>
  </div>
</div>
