---
---
<div id="doi-card-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div class="doi-card" style="background:var(--bg-panel); width:100%; max-width:340px; border-radius:24px; overflow:hidden; position:relative; transition: background-color 0.3s;">
   
    <div style="position:relative; height:320px; background:#222;">
      <img id="doi-photo" src="" style="width:100%; height:100%; object-fit:cover;" />
      <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding:24px 20px; color:white;">
        <div style="display:flex; align-items:center; gap:8px;">
          <h2 id="doi-name-age" style="margin:0; font-size:24px; font-weight:700;">Nama, 20</h2>
          <span id="doi-gender-icon" style="font-size:18px;"></span>
        </div>
        <p id="doi-zodiac" style="margin:4px 0 0 0; font-size:14px; opacity:0.8; letter-spacing:0.5px;"></p>
      </div>
    </div>

    <div style="padding:20px; background:var(--bg-panel); transition: background-color 0.3s;">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:20px;">
        <div>
          <small style="color:var(--text-muted); text-transform:uppercase; font-size:10px; font-weight:700; transition: color 0.3s;">Pekerjaan</small>
          <div id="doi-job" style="font-size:14px; color:var(--text-color); font-weight:600; transition: color 0.3s;">-</div>
        </div>
        <div>
          <small style="color:var(--text-muted); text-transform:uppercase; font-size:10px; font-weight:700; transition: color 0.3s;">Hobi</small>
          <div id="doi-hobby" style="font-size:14px; color:var(--text-color); font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition: color 0.3s;">-</div>
        </div>
      </div>

      <div style="display:flex; gap:12px;">
        <button onclick="window.tutupDoiCard()" class="btn-lewati" style="flex:1; padding:14px; border:none; border-radius:15px; background:var(--border-color); color:var(--text-color); font-weight:700; cursor:pointer; transition: background-color 0.3s, color 0.3s;">Skip</button>
        
        <button id="btn-gas-chat" class="btn-action" style="flex:2; padding:14px; border:none; border-radius:15px; background:linear-gradient(45deg, #3a7bd5, #00d2ff); color:white; font-weight:700; cursor:pointer; box-shadow: 0 4px 15px rgba(58, 123, 213, 0.3);">Chat Sekarang</button>
      </div>
    </div>
  </div>
</div>
