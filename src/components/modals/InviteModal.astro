<div id="invite-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu" style="width: 90%; max-width: 350px; padding: 25px;">
    <h3 style="margin: 0 0 10px 0; font-size: 16px; color: #3a7bd5; text-align: center;">Undang ke Grup</h3>
    <p style="font-size: 11px; color: #666; margin-bottom: 20px; text-align: center;">Masukkan ID Unik (tanpa #) atau Username temanmu.</p>

    <input type="text" id="in-invite-search" placeholder="Contoh: 08179 atau MELL" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; margin-bottom: 20px; box-sizing: border-box;" />

    <div style="display: flex; gap: 10px;">
      <button class="btn-confirm" id="btn-invite-now" style="flex: 2;">Tambah Member</button>
      <button onclick="document.getElementById('invite-modal').style.display='none'" style="flex: 1; padding: 12px; border: none; border-radius: 10px; background: #ccc; color: #333; font-weight: 600; cursor: pointer;">Batal</button>
    </div>
  </div>
</div>
