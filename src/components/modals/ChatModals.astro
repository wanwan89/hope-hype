---
// src/components/modals/ChatModals.astro
---
<div id="bio-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu" style="width: 90%; max-width: 350px; text-align: left; padding: 25px;">
    <h2 style="margin: 0 0 10px 0; font-size: 18px; color: #3a7bd5; text-align: center;">Lengkapi Profilmu</h2>
    <div style="display: flex; gap: 10px;">
      <button class="btn-confirm" id="btn-save-bio" style="flex: 2;">Simpan & Cari</button>
      <button type="button" class="btn-cancel" onclick="window.closeBioModal()" style="flex: 1; padding: 12px; border: none; border-radius: 10px; background: #ccc; color: #333; font-weight: 600; cursor: pointer;">Batal</button>
    </div>
  </div>
</div>

<div id="group-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">...</div>
<div id="group-settings-modal" class="modal-overlay" style="display:none; z-index:99999;">...</div>
<div id="invite-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">...</div>
<div id="delete-overlay" class="delete-overlay">...</div>
<div id="doi-card-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:9999;">...</div>
<div id="reaction-menu" class="reaction-menu">
  <span class="reaction-emoji" onclick="sendReaction('👍')">👍</span>
  <span class="reaction-emoji" onclick="sendReaction('❤️')">❤️</span>
  <span class="reaction-emoji" onclick="sendReaction('😂')">😂</span>
  <span class="reaction-emoji" onclick="sendReaction('😮')">😮</span>
  <span class="reaction-emoji" onclick="sendReaction('😢')">😢</span>
  <span class="reaction-emoji" onclick="sendReaction('🙏')">🙏</span>
</div>
<div id="call-overlay" style="display:none; position:fixed; inset:0; background:rgba(18, 24, 34, 0.98); z-index:99999; flex-direction:column; align-items:center; justify-content:center; color:white; font-family: 'Poppins', sans-serif;">...</div>
<div id="incoming-call-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:100000; flex-direction:column; align-items:center; justify-content:center; color:white; font-family: 'Poppins', sans-serif;">...</div>

<style is:global>
/* Modals & Overlays CSS */
.delete-overlay, .searching-overlay { position: fixed; inset: 0; display: none; justify-content: center; align-items: center; z-index: 9999; }
.delete-overlay { background: rgba(0, 31, 63, 0.4); backdrop-filter: blur(8px); display: none; align-items: center; justify-content: center; z-index: 10005; padding: 20px; animation: fadeIn 0.2s ease-out; }
.delete-menu { background: #ffffff; width: 100%; max-width: 280px; padding: 25px; border-radius: 24px; text-align: center; box-shadow: 0 15px 35px rgba(58, 123, 213, 0.2) !important; animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
.delete-menu button { flex: 1; padding: 12px; border: none; border-radius: 14px; font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; }
#confirm-delete { background: linear-gradient(135deg, #3a7bd5, #00d2ff) !important; color: white; box-shadow: 0 4px 15px rgba(58, 123, 213, 0.3) !important; }
.reaction-menu { position: absolute; background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(10px); padding: 8px 12px; border-radius: 30px; box-shadow: 0 10px 25px rgba(0,0,0,0.15); display: none; gap: 12px; z-index: 10006; border: 1px solid rgba(255,255,255,0.3); animation: reactionPop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); pointer-events: auto; }
.reaction-emoji { font-size: 24px; cursor: pointer; transition: transform 0.2s; user-select: none; }
.reaction-emoji:hover { transform: scale(1.4) translateY(-5px); }

/* Animation Call & Radar Doi */
.sonar-wave { position: absolute; top: 0; left: 0; right: 0; bottom: 0; border-radius: 50%; background: #3a7bd5; opacity: 0.3; z-index: -1; animation: sonar-effect 2s infinite; }
.doi-search-overlay { position: fixed; inset: 0; background: rgba(15, 20, 30, 0.95); backdrop-filter: blur(8px); z-index: 100000; display: flex; flex-direction: column; align-items: center; justify-content: center; animation: fadeInOverlay 0.3s ease-out; font-family: 'Poppins', sans-serif; }
.radar-container { position: relative; width: 150px; height: 150px; display: flex; align-items: center; justify-content: center; margin-bottom: 30px; }
.radar-wave { position: absolute; width: 100%; height: 100%; border-radius: 50%; border: 2px solid #00d2ff; opacity: 0; animation: rippleWave 2s cubic-bezier(0.21, 0.53, 0.56, 0.8) infinite; box-shadow: 0 0 20px rgba(0, 210, 255, 0.5) inset; }
@keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
@keyframes reactionPop { 0% { transform: scale(0) translateX(-50%); opacity: 0; } 100% { transform: scale(1) translateX(-50%); opacity: 1; } }
@keyframes rippleWave { 0% { transform: scale(0.2); opacity: 1; border-width: 4px; } 100% { transform: scale(2.5); opacity: 0; border-width: 0px; } }
</style>
