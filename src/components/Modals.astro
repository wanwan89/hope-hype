---
// Modals.astro
---
<div id="settingsModal" class="modal">
  <div class="modal-content">
    <span id="closeSettings">X</span>
    <input id="newUsername" placeholder="New username" />
    <div id="avatarOptions">
      <img class="avatar-choice" src="/asets/png/avatar1.png" />
      <img class="avatar-choice" src="/asets/png/avatar2.png" />
      <img class="avatar-choice" src="/asets/png/avatar3.png" />
      <img class="avatar-choice" src="/asets/png/avatar4.png" />
    </div>
    <label for="avatarUpload" style="cursor:pointer; display:block; margin:10px 0; color:#fff;">
      Upload Avatar
    </label>
    <label for="avatarUpload" class="upload-avatar-label">
      <img id="avatarPreview" src="/asets/png/up.png" alt="Avatar" />
    </label>
    <input type="file" id="avatarUpload" accept="image/*" style="display:none;" />
    <button id="saveSettings">Save</button>
  </div>
</div>

<div id="infoModal" class="modal">
  <div class="modal-content info-modal-content">
    <span id="closeInfoModal" class="close-icon">&times;</span>
    <div id="infoModalIconShowcase" class="info-icon-showcase"></div>
    <h3 id="infoModalTitle" class="premium-title">Info Produk</h3>
    <div id="infoModalBenefits" class="premium-benefits-list"></div>
    <button id="closeInfoBtn" class="premium-btn">Mengerti</button>
  </div>
</div>

<div id="vip-bottom-sheet" class="bottom-sheet">
  <div class="sheet-overlay"></div>
  <div class="sheet-content">
    <div class="drag-handle"></div>
    <h3>Pilih Paket Badge VIP</h3>
    <div class="product-list">
      
      <div class="product-card" data-price="30000" data-role="verified">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" style="vertical-align:middle;">
              <circle cx="12" cy="12" r="10" fill="#1DA1F2" />
              <path d="M7 12.5l3 3 7-7" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="product-text">
            <span class="p-name">
              Verified Badge
              <svg class="info-icon" data-title="Verified Badge" data-desc="Dapatkan centang biru eksklusif di sebelah nama kamu. Bikin profil makin terpercaya dan terlihat profesional!" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 30.000/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>
      
      <div class="product-card" data-price="14999" data-role="crown1">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown1.png" alt="Bronze" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Bronze
              <svg class="info-icon" data-title="Crown Bronze" data-desc="Badge mahkota perunggu untuk menunjukkan kamu adalah member VIP pemula. Tampil beda di kolom komentar!" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 14.999/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>

      <div class="product-card" data-price="20000" data-role="crown2">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown2.png" alt="Silver" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Silver
              <svg class="info-icon" data-title="Crown Silver" data-desc="Badge mahkota perak bergengsi. Memberikan highlight khusus pada profil dan ruang obrolan kamu." viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 20.000/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>

      <div class="product-card gold-card" data-price="49999" data-role="crown3">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown3.png" alt="Gold" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Gold
              <svg class="info-icon" data-title="Crown Gold" data-desc="Badge mahkota emas kasta tertinggi! Profil kamu akan bersinar dengan efek khusus dan mendapatkan prioritas utama." viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 49.999/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>
      
    </div>
  </div>
</div>

<div id="coin-bottom-sheet" class="bottom-sheet">
  <div class="sheet-overlay coin-sheet-overlay"></div>
  <div class="sheet-content coin-sheet-content">
    <div class="drag-handle"></div>
    <h3>Top Up Koin</h3>
    <div class="product-list">
      <div class="product-card coin-product-card" data-price="10000" data-coins="100">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">100 Koin</span>
            <span class="p-price">Rp 10.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>

      <div class="product-card coin-product-card" data-price="25000" data-coins="300">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">300 Koin</span>
            <span class="p-price">Rp 25.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>

      <div class="product-card coin-product-card" data-price="50000" data-coins="700">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">700 Koin</span>
            <span class="p-price">Rp 50.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>
    </div>
    <div class="topup-ad-container">
      <img src="/asets/png/topup.webp" alt="Promo Top Up" class="topup-ad-img">
    </div>

    <div class="custom-topup">
      <h4>Custom Top Up</h4>
      <input type="number" id="custom-coins" placeholder="Masukkan jumlah koin" min="1" />
      <button id="buy-custom-coin-btn">Beli</button>
      <p id="custom-price-display"></p>
    </div>
  </div>
</div>

<style is:global>
/* MODAL SETTINGS */
.modal { display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); justify-content: center; align-items: center; z-index: 1000000; animation: fadeIn 0.4s ease forwards; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
.modal.active { display: flex; opacity: 1; pointer-events: auto; }
.modal-content { background: #2a2d31; border-radius: 16px; padding: 24px; width: 300px; max-width: 90%; color: #fff; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.8); transform: translateY(-20px); transition: transform 0.3s ease, opacity 0.3s ease; }
.modal.active .modal-content { transform: translateY(0); }
.modal-content h3 { display: flex; justify-content: space-between; align-items: center; font-size: 18px; margin-bottom: 12px; }
.modal-content h3 span.close { cursor: pointer; font-size: 20px; color: #ff6b6b; transition: transform 0.2s ease; }
.modal-content h3 span.close:hover { transform: rotate(90deg) scale(1.2); }
.modal-content input { width: 100%; padding: 10px 12px; margin-bottom: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.3); background: rgba(255, 255, 255, 0.1); color: #fff; outline: none; transition: all 0.3s ease; }
.modal-content input:focus { border-color: #ffde59; box-shadow: 0 0 10px rgba(255, 222, 89, 0.5); }
.modal-content button { width: 100%; padding: 10px; border-radius: 10px; border: none; background: linear-gradient(135deg, #ff7eb3, #ff758c); color: #fff; font-weight: 600; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; }
.modal-content button:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255, 118, 118, 0.5); }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

#avatarOptions { display: flex; gap: 10px; flex-wrap: wrap; }
.avatar-choice { cursor: pointer; width: 50px; height: 50px; border-radius: 50%; border: 2px solid transparent; object-fit: cover; }
.avatar-choice.selected { border-color: blue; }
.upload-avatar-label { display: inline-block; cursor: pointer; }
#avatarPreview { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid #fff; }

/* BOTTOM SHEETS (PRO & KOIN) */
.bottom-sheet { position: fixed; top: 0; left: 0; width: 100%; height: 100%; display: none; flex-direction: column; justify-content: flex-end; z-index: 10000; }
.bottom-sheet.active { display: flex; }
.sheet-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(4px); }
.sheet-content { position: relative; background: #1a1a1a; width: 100%; padding: 20px; border-top-left-radius: 25px; border-top-right-radius: 25px; transform: translateY(100%); transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1); box-sizing: border-box; }
.bottom-sheet.active .sheet-content { transform: translateY(0); }
.drag-handle { width: 40px; height: 4px; background: #444; border-radius: 10px; margin: 0 auto 20px; }
h3 { color: white; margin-bottom: 20px; font-size: 18px; }
.product-list { display: flex; flex-direction: column; gap: 12px; padding: 10px 5px 15px 5px; }
.product-card { background: #252525; border: 1px solid #333; border-radius: 16px; padding: 15px; display: flex; align-items: center; justify-content: space-between; transition: all 0.2s ease; cursor: pointer; }
.product-info-wrapper { display: flex; align-items: center; gap: 15px; }
.product-icon { font-size: 24px; display: flex; align-items: center; justify-content: center; min-width: 40px; }
.product-text { display: flex; flex-direction: column; }
.p-name { color: white; font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 10px; line-height: 1; }
.p-price { color: #4ade80; font-size: 12px; font-weight: 600; }
.buy-now-btn { background: #3a7bd5; color: white; border: none; padding: 8px 16px; border-radius: 10px; font-weight: bold; font-size: 12px; cursor: pointer; }
.buy-now-btn.btn-loading { opacity: 0.7; pointer-events: none; }
.crown-img { width: 30px; height: 30px; object-fit: contain; display: block; }

/* COIN BOTTOM SHEET */
.coin-sheet-content { background: #1b1b1f; border-top-left-radius: 22px; border-top-right-radius: 22px; padding: 18px 16px 20px; }
.coin-sheet-content h3 { color: #fff; font-size: 16px; font-weight: 600; margin-bottom: 14px; }
.coin-sheet-content .drag-handle { width: 38px; height: 4px; border-radius: 999px; background: rgba(255, 255, 255, 0.18); margin: 0 auto 14px; }
.coin-sheet-overlay { background: rgba(0, 0, 0, 0.4); }
.coin-product-card { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 14px; margin-bottom: 10px; border-radius: 14px; background: #242429; border: 1px solid rgba(255, 255, 255, 0.04); transition: all 0.2s ease; cursor: pointer; }
.coin-product-card .product-info-wrapper { display: flex; align-items: center; gap: 12px; flex: 1; }
.coin-product-card .product-icon { width: 38px; height: 38px; border-radius: 10px; background: #2d2d33; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.coin-product-card .crown-img { width: 18px !important; height: 18px !important; object-fit: contain; }
.coin-product-card .product-text { display: flex; flex-direction: column; gap: 2px; }
.coin-product-card .p-name { color: #fff; font-size: 14px; font-weight: 600; }
.coin-product-card .p-price { color: #bdbdbd; font-size: 12px; font-weight: 500; }
.buy-coin-btn { min-width: 64px; height: 30px; padding: 0 12px; border: none; border-radius: 999px; background: #f7b500; color: #1a1a1a; font-size: 11px; font-weight: 700; cursor: pointer; flex-shrink: 0; }
.buy-coin-btn:hover { opacity: 0.92; }
.buy-coin-btn.btn-loading { opacity: 0.7; pointer-events: none; }
.custom-topup { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
.custom-topup h4 { color: #fff; font-size: 14px; font-weight: 600; }
.custom-topup input { padding: 10px 12px; border-radius: 14px; border: 1px solid rgba(255, 255, 255, 0.1); background: #2d2d33; color: #fff; font-size: 14px; outline: none; }
#buy-custom-coin-btn { min-width: 64px; height: 34px; padding: 0 12px; border: none; border-radius: 999px; background: #f7b500; color: #1a1a1a; font-size: 12px; font-weight: 700; cursor: pointer; align-self: flex-start; transition: opacity 0.2s; }
#custom-price-display { color: #bdbdbd; font-size: 12px; font-weight: 500; }

/* MODAL INFO PREMIUM */
.info-modal-content { text-align: center; padding: 30px 24px 24px; background: linear-gradient(145deg, #2a2d31, #1c1e22); border: 1px solid rgba(255, 255, 255, 0.08); position: relative; width: 320px; border-radius: 16px; }
.close-icon { position: absolute; top: 12px; right: 16px; font-size: 26px; color: #6b7280; cursor: pointer; transition: all 0.2s ease; line-height: 1; }
.close-icon:hover { color: #ff6b6b; transform: scale(1.1) rotate(90deg); }
.info-icon-showcase { width: 70px; height: 70px; margin: 0 auto 12px; background: rgba(255, 255, 255, 0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid rgba(255, 255, 255, 0.1); }
.info-icon-showcase img, .info-icon-showcase svg { width: 40px !important; height: 40px !important; object-fit: contain; }
.premium-title { justify-content: center !important; font-size: 20px !important; font-weight: 800; margin-bottom: 20px !important; background: linear-gradient(to right, #ffffff, #d1d5db); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.premium-benefits-list { text-align: left; display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
.b-item { display: flex; align-items: flex-start; gap: 12px; background: rgba(0, 0, 0, 0.2); padding: 10px 12px; border-radius: 12px; border: 1px solid rgba(255, 255, 255, 0.03); }
.b-icon { font-size: 18px; line-height: 1; margin-top: 1px; flex-shrink: 0; }
.b-text { color: #d1d5db; font-size: 13px; line-height: 1.5; }
.b-text b { color: #fff; display: block; margin-bottom: 2px; }
.b-highlight { background: linear-gradient(135deg, rgba(58, 123, 213, 0.15), rgba(58, 96, 115, 0.1)); border-color: rgba(58, 123, 213, 0.3); }
.b-highlight.b-gold { background: linear-gradient(135deg, rgba(255, 215, 0, 0.15), rgba(255, 165, 0, 0.1)); border-color: rgba(255, 215, 0, 0.3); }
.b-highlight .b-text b { color: #4ade80; }
.b-highlight.b-gold .b-text b { color: #ffd700; }
.premium-btn { background: linear-gradient(135deg, #4b90ff, #2b7af0) !important; font-size: 14px !important; font-weight: 600 !important; padding: 12px !important; color: white !important; border-radius: 8px !important; border: none !important; cursor: pointer !important; width: 100% !important; display: block !important; }
.info-icon { color: #9ca3af; cursor: pointer; transition: all 0.2s ease; flex-shrink: 0; display: block; transform: translateY(-1px); }
.info-icon:hover { color: #4ade80; transform: scale(1.1) translateY(-1px); }
</style>

<script>
  // 🔥 FIX PERFORMA & BUG KLIK
  // Kita bungkus semua logic dalem DOMContentLoaded biar HTML-nya keload sempurna dulu.
  document.addEventListener("DOMContentLoaded", () => {
    
    const getDB = () => import('../lib/supabase.js').then(m => m.supabase);
    const getUtils = () => import('../lib/ui-utils.js');

    // Fungsi pintar buat nampilin Notif (fallback ke window.showNotif atau alert kalau utils gagal)
    const showFallbackNotif = (title, msg, type) => {
      if (window.showNotif) { window.showNotif(`${title}: ${msg}`, type); } 
      else { alert(`${title}\n${msg}`); }
    };

    // ==========================================
    // 1. INFO PRODUK VIP & MODAL LOGIC
    // ==========================================
    const infoIcons = document.querySelectorAll('.info-icon');
    const infoModal = document.getElementById('infoModal');
    const infoModalTitle = document.getElementById('infoModalTitle');
    const infoModalBenefits = document.getElementById('infoModalBenefits');
    const closeInfoModal = document.getElementById('closeInfoModal');
    const closeInfoBtn = document.getElementById('closeInfoBtn');

    const vipBenefitsData = {
      'verified': `<div class="b-item"><div class="b-text"><b>Centang Biru Eksklusif:</b> Tanda resmi akun terverifikasi.</div></div><div class="b-item"><div class="b-text"><b>Prioritas Pencarian:</b> Akun lebih mudah ditemukan.</div></div><div class="b-item"><div class="b-text"><b>Profil Terpercaya:</b> Tampil profesional.</div></div>`,
      'crown1': `<div class="b-item"><div class="b-text"><b>Badge Perunggu:</b> Tampil beda dengan badge VIP.</div></div><div class="b-item"><div class="b-text"><b>Highlight Komentar:</b> Warna khusus di komentar.</div></div><div class="b-item"><div class="b-text"><b>Stiker VIP:</b> Akses stiker eksklusif.</div></div>`,
      'crown2': `<div class="b-item"><div class="b-text"><b>Badge Perak:</b> Badge lebih elegan.</div></div><div class="b-item"><div class="b-text"><b>Efek Masuk:</b> Notifikasi khusus saat masuk room.</div></div><div class="b-item"><div class="b-text"><b>Limit Ekstra:</b> Batas pesan lebih banyak.</div></div><div class="b-item b-highlight"><div class="b-text"><b>Plus:</b> Dapat SEMUA keuntungan Bronze.</div></div>`,
      'crown3': `<div class="b-item"><div class="b-text"><b>Badge Emas:</b> Kasta tertinggi.</div></div><div class="b-item"><div class="b-text"><b>Animasi Mewah:</b> Efek visual super mencolok.</div></div><div class="b-item"><div class="b-text"><b>Bebas Iklan 100%:</b> Aplikasi tanpa iklan.</div></div><div class="b-item b-highlight b-gold"><div class="b-text"><b>Super Plus:</b> Dapat keuntungan Bronze & Silver.</div></div>`
    };

    infoIcons.forEach(icon => {
      icon.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation(); 
        const card = icon.closest('.product-card');
        const role = card.getAttribute('data-role');
        const title = icon.getAttribute('data-title') || card.querySelector('.p-name').childNodes[0].textContent.trim();
        const productIconContainer = card.querySelector('.product-icon');
        const showcase = document.getElementById('infoModalIconShowcase');
        
        if(showcase && productIconContainer) { showcase.innerHTML = productIconContainer.innerHTML; }
        if(infoModalTitle) infoModalTitle.textContent = title;
        if(infoModalBenefits) infoModalBenefits.innerHTML = vipBenefitsData[role] || '<p style="text-align:center;">Belum ada info.</p>';
        if(infoModal) infoModal.classList.add('active');
      });
    });

    const closeInfo = () => { if(infoModal) infoModal.classList.remove('active'); };
    if (closeInfoModal) closeInfoModal.addEventListener('click', closeInfo);
    if (closeInfoBtn) closeInfoBtn.addEventListener('click', closeInfo);

    // ==========================================
    // 2. BOTTOM SHEETS & SETTINGS MODAL TOGGLE
    // ==========================================
    document.querySelectorAll(".sheet-overlay").forEach(overlay => {
      overlay.addEventListener("click", function() {
        const sheet = this.closest(".bottom-sheet");
        if(sheet) {
          sheet.classList.remove("active");
          setTimeout(() => sheet.style.display = "none", 400);
        }
      });
    });

    const settingsBtn = document.getElementById("settingsBtn"); 
    const settingsModal = document.getElementById("settingsModal");
    if (settingsBtn && settingsModal) {
      settingsBtn.addEventListener("click", (e) => {
        e.preventDefault(); e.stopPropagation();
        settingsModal.classList.add("active");
      });
    }
    document.getElementById("closeSettings")?.addEventListener("click", () => settingsModal?.classList.remove("active"));

    // ==========================================
    // 3. UPLOAD AVATAR LOGIC (Dipersingkat)
    // ==========================================
    const saveSettings = document.getElementById("saveSettings");
    if (saveSettings) {
      saveSettings.addEventListener("click", async () => {
        const originalText = saveSettings.innerText;
        saveSettings.innerText = "Menyimpan...";
        saveSettings.disabled = true;
        
        try {
          const db = await getDB();
          const { data: { user }, error: userError } = await db.auth.getUser();
          if (userError || !user) throw new Error("Silakan login dulu");
          
          const newUsername = document.getElementById("newUsername")?.value?.trim();
          if (!newUsername) throw new Error("Isi username terlebih dahulu");

          const { error } = await db.from("profiles").update({ username: newUsername }).eq("id", user.id);
          if (error) throw error;
          
          showFallbackNotif("Berhasil", "Username diupdate!", "success");
          setTimeout(() => location.reload(), 1000);
        } catch(err) {
          showFallbackNotif("Gagal", err.message, "error");
        } finally {
          saveSettings.innerText = originalText;
          saveSettings.disabled = false;
        }
      });
    }

    // ==========================================
    // 4. PAYMENTS (MIDTRANS) LOGIC - FIX TOTAL!
    // ==========================================
    
    // 🔥 Fungsi Pembantu Buat Manggil Supabase & Midtrans
    const processPayment = async (btn, endpoint, payloadBody) => {
      btn.classList.add("btn-loading");
      try {
        const db = await getDB();
        let utils = {};
        try { utils = await getUtils(); } catch(e) {} // Tangkep error kalo utils gagal

        const { data: { session }, error: sessionError } = await db.auth.getSession();
        if (sessionError || !session) throw new Error("Silakan login ulang buat verifikasi.");

        // OTOMATIS TUNGGU MIDTRANS (Anti klik 2 kali!)
        if (!window.snap) {
          if (utils.loadMidtrans) utils.loadMidtrans();
          
          // Nungguin script midtrans nyangkut di html (max 3 detik)
          for(let i=0; i<30; i++) {
             if(window.snap) break;
             await new Promise(r => setTimeout(r, 100)); 
          }
          if (!window.snap) throw new Error("Gagal memuat sistem pembayaran (Midtrans). Coba refresh web-nya ya bro.");
        }

        // Request token ke Supabase Edge Functions
        const response = await fetch(endpoint, {
          method: "POST", 
          headers: { "Content-Type": "application/json", Authorization: `Bearer ${session.access_token}` },
          body: JSON.stringify(payloadBody),
        });

        if (!response.ok) {
           const errText = await response.text();
           throw new Error(errText || "Gagal ngehubungin server pembayaran.");
        }
        
        const result = await response.json(); 
        const token = result?.token;
        if (!token) throw new Error("Waduh, Token pembayaran dari server nggak ada nih.");

        // BUKA POPUP MIDTRANS
        window.snap.pay(token, {
          onSuccess: () => { 
            sessionStorage.removeItem(`hh_profile_${payloadBody.userId}`); 
            showFallbackNotif("Pembayaran Sukses!", "Akun lu udah di-upgrade/ditambahin koin.", "success"); 
            setTimeout(() => location.reload(), 1200); 
          },
          onPending: () => showFallbackNotif("Menunggu Pembayaran", "Selesaikan transaksi lu ya", "warning"),
          onError: () => showFallbackNotif("Pembayaran Gagal", "Ada masalah pas transaksi", "error"),
          onClose: () => showFallbackNotif("Ditutup", "Lu nutup popup sebelum bayar", "info")
        });

      } catch (err) {
        showFallbackNotif("Gagal", err.message, "error");
      } finally {
        btn.classList.remove("btn-loading");
      }
    };

    // A. TOMBOL BELI VIP
    document.querySelectorAll(".buy-now-btn").forEach((button) => {
      button.addEventListener("click", async (e) => {
        const card = e.currentTarget.closest(".product-card");
        if (!card) return;
        
        const db = await getDB();
        const { data: { user } } = await db.auth.getUser();
        if(!user) return showFallbackNotif("Woi!", "Login dulu sebelum beli.", "warning");

        const payload = {
          userId: user.id, 
          email: user.email, 
          amount: parseInt(card.getAttribute("data-price"), 10), 
          item_name: card.querySelector(".p-name")?.innerText || "Premium VIP", 
          role_target: card.getAttribute("data-role")
        };

        processPayment(e.currentTarget, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-premium", payload);
      });
    });

    // B. TOMBOL BELI PAKET KOIN
    document.querySelectorAll(".buy-coin-btn").forEach((button) => {
      button.addEventListener("click", async (e) => {
        const card = e.currentTarget.closest(".coin-product-card");
        if (!card) return;

        const db = await getDB();
        const { data: { user } } = await db.auth.getUser();
        if(!user) return showFallbackNotif("Woi!", "Login dulu sebelum beli.", "warning");

        const payload = {
          userId: user.id, 
          email: user.email, 
          amount: parseInt(card.getAttribute("data-price"), 10), 
          coins: parseInt(card.getAttribute("data-coins"), 10), 
          item_name: card.querySelector(".p-name")?.innerText || "Top Up Koin"
        };

        processPayment(e.currentTarget, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-coins", payload);
      });
    });

    // C. TOMBOL CUSTOM KOIN
    const customInput = document.getElementById("custom-coins");
    const customBtn = document.getElementById("buy-custom-coin-btn");
    const priceDisplay = document.getElementById("custom-price-display");

    if (customInput && customBtn && priceDisplay) {
      customInput.addEventListener("input", () => {
        const coins = parseInt(customInput.value) || 0; 
        const price = coins * 100;
        if (coins > 0) { 
          priceDisplay.textContent = `Total: Rp ${price.toLocaleString("id-ID")}`; 
          priceDisplay.style.color = price < 10000 ? "#ff4757" : "#4ade80"; 
        } else { priceDisplay.textContent = ""; }
      });

      customBtn.addEventListener("click", async (e) => {
        const coins = parseInt(customInput.value); 
        const price = coins * 100;
        if (!coins || coins <= 0) return showFallbackNotif("Gagal", "Masukin koinnya dong", "warning");
        if (price < 10000) return showFallbackNotif("Gagal", "Minimal beli Rp 10.000 (100 Koin)", "warning");
        if (coins > 5000) return showFallbackNotif("Gagal", "Maksimal beli 5000 koin", "warning");

        const db = await getDB();
        const { data: { user } } = await db.auth.getUser();
        if(!user) return showFallbackNotif("Woi!", "Login dulu sebelum beli.", "warning");

        const payload = {
          userId: user.id, 
          email: user.email, 
          amount: price, 
          coins: coins, 
          item_name: `${coins} Koin (Custom)`
        };

        processPayment(e.currentTarget, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-coins", payload);
      });
    }

  });
</script>
