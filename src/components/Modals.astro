---
// Modals.astro
---
<div id="settingsModal" class="modal">
  <div class="modal-content">
    <span id="closeSettings">X</span>
    <input id="newUsername" placeholder="New username" />
    <div id="avatarOptions">
      <img class="avatar-choice" src="/asets/png/avatar1.png" />
      <img class="avatar-choice" src="/asets/png/avatar2.png" />
      <img class="avatar-choice" src="/asets/png/avatar3.png" />
      <img class="avatar-choice" src="/asets/png/avatar4.png" />
    </div>
    <label for="avatarUpload" style="cursor:pointer; display:block; margin:10px 0; color:#fff;">
      Upload Avatar
    </label>
    <label for="avatarUpload" class="upload-avatar-label">
      <img id="avatarPreview" src="/asets/png/up.png" alt="Avatar" />
    </label>
    <input type="file" id="avatarUpload" accept="image/*" style="display:none;" />
    <button id="saveSettings">Save</button>
  </div>
</div>

<div id="infoModal" class="modal">
  <div class="modal-content info-modal-content">
    <span id="closeInfoModal" class="close-icon">&times;</span>
    <div id="infoModalIconShowcase" class="info-icon-showcase"></div>
    <h3 id="infoModalTitle" class="premium-title">Info Produk</h3>
    <div id="infoModalBenefits" class="premium-benefits-list"></div>
    <button id="closeInfoBtn" class="premium-btn">Mengerti</button>
  </div>
</div>

<div id="vip-bottom-sheet" class="bottom-sheet">
  <div class="sheet-overlay"></div>
  <div class="sheet-content">
    <div class="drag-handle"></div>
    <h3>Pilih Paket Badge VIP</h3>
    <div class="product-list">
      
      <div class="product-card" data-price="30000" data-role="verified">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" style="vertical-align:middle;">
              <circle cx="12" cy="12" r="10" fill="#1DA1F2" />
              <path d="M7 12.5l3 3 7-7" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="product-text">
            <span class="p-name">
              Verified Badge
              <svg class="info-icon" data-title="Verified Badge" data-desc="Dapatkan centang biru eksklusif di sebelah nama kamu. Bikin profil makin terpercaya dan terlihat profesional!" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 30.000/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>
      
      <div class="product-card" data-price="14999" data-role="crown1">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown1.png" alt="Bronze" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Bronze
              <svg class="info-icon" data-title="Crown Bronze" data-desc="Badge mahkota perunggu untuk menunjukkan kamu adalah member VIP pemula. Tampil beda di kolom komentar!" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 14.999/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>

      <div class="product-card" data-price="20000" data-role="crown2">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown2.png" alt="Silver" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Silver
              <svg class="info-icon" data-title="Crown Silver" data-desc="Badge mahkota perak bergengsi. Memberikan highlight khusus pada profil dan ruang obrolan kamu." viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 20.000/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>

      <div class="product-card gold-card" data-price="49999" data-role="crown3">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/png/crown3.png" alt="Gold" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">
              Crown Gold
              <svg class="info-icon" data-title="Crown Gold" data-desc="Badge mahkota emas kasta tertinggi! Profil kamu akan bersinar dengan efek khusus dan mendapatkan prioritas utama." viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
            </span>
            <span class="p-price">Rp 49.999/Bulan</span>
          </div>
        </div>
        <button class="buy-now-btn">Beli</button>
      </div>
      
    </div>
  </div>
</div>

<div id="coin-bottom-sheet" class="bottom-sheet">
  <div class="sheet-overlay coin-sheet-overlay"></div>
  <div class="sheet-content coin-sheet-content">
    <div class="drag-handle"></div>
    <h3>Top Up Koin</h3>
    <div class="product-list">
      <div class="product-card coin-product-card" data-price="10000" data-coins="100">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">100 Koin</span>
            <span class="p-price">Rp 10.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>

      <div class="product-card coin-product-card" data-price="25000" data-coins="300">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">300 Koin</span>
            <span class="p-price">Rp 25.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>

      <div class="product-card coin-product-card" data-price="50000" data-coins="700">
        <div class="product-info-wrapper">
          <div class="product-icon">
            <img src="/asets/svg/koin.webp" alt="Koin" class="crown-img" />
          </div>
          <div class="product-text">
            <span class="p-name">700 Koin</span>
            <span class="p-price">Rp 50.000</span>
          </div>
        </div>
        <button class="buy-coin-btn">Beli</button>
      </div>
    </div>
    <div class="topup-ad-container">
      <img src="/asets/png/topup.webp" alt="Promo Top Up" class="topup-ad-img">
    </div>

    <div class="custom-topup">
      <h4>Custom Top Up</h4>
      <input type="number" id="custom-coins" placeholder="Masukkan jumlah koin" min="1" />
      <button id="buy-custom-coin-btn">Beli</button>
      <p id="custom-price-display"></p>
    </div>
  </div>
</div>

<script>
  // 🔥 FUNGSI TOAST GLOBAL ANTI-BUG
  // Dibikin di paling atas biar nggak ada acara "fungsi undefined"
  window.showNotif = function(msg, type = "info") {
    // Pastikan container ada, kalau ga ada BIKIN PAKSA
    let container = document.getElementById("toast");
    if (!container) {
      container = document.createElement("div");
      container.id = "toast";
      document.body.appendChild(container);
    }

    const config = {
      success: { title: "Berhasil", icon: "✓" },
      error: { title: "Gagal", icon: "✕" },
      warning: { title: "Peringatan", icon: "!" },
      info: { title: "Info", icon: "i" }
    };
    const { title, icon } = config[type] || config.info;

    const toastCard = document.createElement("div");
    toastCard.className = "toast-card";
    
    toastCard.innerHTML = `
      <div class="toast-icon-wrap ${type}">
        <span class="toast-icon">${icon}</span>
      </div>
      <div class="toast-content">
        <div class="toast-title">${title}</div>
        <div class="toast-subtitle">${msg}</div>
      </div>
      <button class="toast-close" onclick="this.parentElement.classList.remove('show'); setTimeout(()=>this.parentElement.remove(), 300)">×</button>
    `;

    container.appendChild(toastCard);
    setTimeout(() => toastCard.classList.add("show"), 10);
    
    setTimeout(() => {
      if(toastCard && toastCard.parentElement) {
        toastCard.classList.remove("show");
        setTimeout(() => toastCard.remove(), 300);
      }
    }, 4000);
  };


  document.addEventListener("DOMContentLoaded", () => {
    
    // Dynamic import Supabase & Utils
    const getDB = () => import('../lib/supabase.js').then(m => m.supabase);
    const getUtils = () => import('../lib/ui-utils.js');

    // ==========================================
    // 1. INFO PRODUK VIP & MODAL LOGIC
    // ==========================================
    const infoIcons = document.querySelectorAll('.info-icon');
    const infoModal = document.getElementById('infoModal');
    const infoModalTitle = document.getElementById('infoModalTitle');
    const infoModalBenefits = document.getElementById('infoModalBenefits');
    const closeInfoModal = document.getElementById('closeInfoModal');
    const closeInfoBtn = document.getElementById('closeInfoBtn');

    const vipBenefitsData = {
      'verified': `<div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg></div><div class="b-text"><b>Centang Biru Eksklusif:</b> Tanda resmi akun terverifikasi.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line><line x1="11" y1="8" x2="11" y2="14"></line><line x1="8" y1="11" x2="14" y2="11"></line></svg></div><div class="b-text"><b>Prioritas Pencarian:</b> Akun lebih mudah ditemukan.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="8.5" cy="7" r="4"></circle><polyline points="17 11 19 13 23 9"></polyline></svg></div><div class="b-text"><b>Profil Terpercaya:</b> Tampil profesional.</div></div>`,
      'crown1': `<div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg></div><div class="b-text"><b>Badge Perunggu:</b> Tampil beda dengan badge VIP.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg></div><div class="b-text"><b>Highlight Komentar:</b> Warna khusus di komentar.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg></div><div class="b-text"><b>Stiker VIP:</b> Akses stiker eksklusif.</div></div>`,
      'crown2': `<div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg></div><div class="b-text"><b>Badge Perak:</b> Badge lebih elegan.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg></div><div class="b-text"><b>Efek Masuk:</b> Notifikasi khusus saat masuk room.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg></div><div class="b-text"><b>Limit Ekstra:</b> Batas pesan lebih banyak.</div></div><div class="b-item b-highlight"><div class="b-icon" style="color: #4ade80;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg></div><div class="b-text"><b>Plus:</b> Dapat SEMUA keuntungan Bronze.</div></div>`,
      'crown3': `<div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7zm3 16h14"></path></svg></div><div class="b-text"><b>Badge Emas:</b> Kasta tertinggi.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg></div><div class="b-text"><b>Animasi Mewah:</b> Efek visual super mencolok.</div></div><div class="b-item"><div class="b-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg></div><div class="b-text"><b>Bebas Iklan 100%:</b> Aplikasi tanpa iklan.</div></div><div class="b-item b-highlight b-gold"><div class="b-icon" style="color: #ffd700;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg></div><div class="b-text"><b>Super Plus:</b> Dapat keuntungan Bronze & Silver.</div></div>`
    };

    infoIcons.forEach(icon => {
      icon.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation(); 
        const card = icon.closest('.product-card');
        if (!card) return;
        const role = card.getAttribute('data-role');
        const title = icon.getAttribute('data-title') || card.querySelector('.p-name').childNodes[0].textContent.trim();
        const productIconContainer = card.querySelector('.product-icon');
        const showcase = document.getElementById('infoModalIconShowcase');
        
        if(showcase && productIconContainer) { showcase.innerHTML = productIconContainer.innerHTML; }
        if(infoModalTitle) infoModalTitle.textContent = title;
        if(infoModalBenefits) infoModalBenefits.innerHTML = vipBenefitsData[role] || '<p style="text-align:center;">Belum ada info.</p>';
        if(infoModal) infoModal.classList.add('active');
      });
    });

    const closeInfo = () => { if(infoModal) infoModal.classList.remove('active'); };
    if (closeInfoModal) closeInfoModal.addEventListener('click', closeInfo);
    if (closeInfoBtn) closeInfoBtn.addEventListener('click', closeInfo);

    // ==========================================
    // 2. BOTTOM SHEETS & SETTINGS MODAL TOGGLE
    // ==========================================
    document.querySelectorAll(".sheet-overlay").forEach(overlay => {
      overlay.addEventListener("click", function() {
        const sheet = this.closest(".bottom-sheet");
        if(sheet) {
          sheet.classList.remove("active");
          setTimeout(() => sheet.style.display = "none", 400);
        }
      });
    });

    const settingsBtn = document.getElementById("settingsBtn"); 
    const settingsModal = document.getElementById("settingsModal");
    if (settingsBtn && settingsModal) {
      settingsBtn.addEventListener("click", (e) => {
        e.preventDefault(); e.stopPropagation();
        settingsModal.classList.add("active");
      });
    }
    document.getElementById("closeSettings")?.addEventListener("click", () => settingsModal?.classList.remove("active"));

    // ==========================================
    // 3. UPLOAD AVATAR & SAVE PROFILE LOGIC
    // ==========================================
    const avatarOptions = document.querySelectorAll("#avatarOptions .avatar-choice");
    const avatarPreview = document.getElementById("avatarPreview");
    const avatarUpload = document.getElementById("avatarUpload");
    let selectedAvatar = null; let uploadedAvatarFile = null;

    avatarOptions.forEach((img) => {
      img.addEventListener("click", () => {
        selectedAvatar = img.getAttribute("src"); uploadedAvatarFile = null;
        if (avatarPreview) avatarPreview.src = selectedAvatar;
        avatarOptions.forEach((i) => i.classList.remove("selected"));
        img.classList.add("selected");
      });
    });

    if (avatarUpload && avatarPreview) {
      avatarUpload.addEventListener("change", (e) => {
        const file = e.target.files?.[0]; if (!file) return;
        uploadedAvatarFile = file; selectedAvatar = null;
        avatarPreview.src = URL.createObjectURL(file);
        avatarOptions.forEach((i) => i.classList.remove("selected"));
      });
    }

    const saveSettings = document.getElementById("saveSettings");
    if (saveSettings) {
      saveSettings.addEventListener("click", async () => {
        const originalText = saveSettings.innerText;
        saveSettings.innerText = "Menyimpan..."; saveSettings.disabled = true;
        
        try {
          const db = await getDB();
          const { data: { user }, error: userError } = await db.auth.getUser();
          if (userError || !user) throw new Error("Silakan login dulu");
          
          const newUsername = document.getElementById("newUsername")?.value?.trim();
          if (!newUsername) throw new Error("Isi username terlebih dahulu");

          let finalAvatarUrl = selectedAvatar;
          if (uploadedAvatarFile) {
            window.showNotif("Sedang mengunggah foto...", "info");
            const fd = new FormData(); fd.append("file", uploadedAvatarFile); fd.append("upload_preset", "post_hope"); 
            const res = await fetch("https://api.cloudinary.com/v1_1/dhhmkb8kl/image/upload", { method: "POST", body: fd });
            if (!res.ok) throw new Error("Gagal mengunggah gambar ke server");
            const cData = await res.json(); finalAvatarUrl = cData.secure_url; 
          }

          const updatePayload = { username: newUsername };
          if (finalAvatarUrl) updatePayload.avatar_url = finalAvatarUrl;

          const { error } = await db.from("profiles").update(updatePayload).eq("id", user.id);
          if (error) throw error;
          
          window.showNotif("Profil berhasil diupdate!", "success");
          setTimeout(() => location.reload(), 1000);
        } catch(err) {
          window.showNotif(err.message, "error");
        } finally {
          saveSettings.innerText = originalText; saveSettings.disabled = false;
        }
      });
    }

    // ==========================================
    // 4. PAYMENTS (MIDTRANS) LOGIC - EVENT DELEGATION
    // ==========================================
    const processPayment = async (btn, endpoint, payloadBody) => {
      try {
        const db = await getDB();
        let utils = {};
        try { utils = await getUtils(); } catch(e) {}

        const { data: { session }, error: sessionError } = await db.auth.getSession();
        if (sessionError || !session) throw new Error("Silakan login ulang buat verifikasi.");

        if (!window.snap) {
          if (utils.loadMidtrans) utils.loadMidtrans();
          window.showNotif("Menyiapkan pembayaran...", "info");
          for(let i=0; i<30; i++) {
             if(window.snap) break;
             await new Promise(r => setTimeout(r, 100)); 
          }
          if (!window.snap) throw new Error("Gagal memuat Midtrans. Refresh browser .");
        }

        const response = await fetch(endpoint, {
          method: "POST", 
          headers: { "Content-Type": "application/json", Authorization: `Bearer ${session.access_token}` },
          body: JSON.stringify(payloadBody),
        });

        if (!response.ok) {
           const errText = await response.text();
           throw new Error(errText || "Gagal menghubungi server pembayaran.");
        }
        
        const result = await response.json(); 
        const token = result?.token;
        if (!token) throw new Error("Token dari midtrans nggak muncul bro.");

        window.snap.pay(token, {
          onSuccess: () => { 
            sessionStorage.removeItem(`hh_profile_${payloadBody.userId}`); 
            window.showNotif("Pembayaran Sukses! Akun diupgrade.", "success"); 
            setTimeout(() => location.reload(), 1200); 
          },
            window.showNotif("Selesaikan transaksi dulu", "warning");
            // 🔥 MASUKIN KE DB BIAR LONCENG NYALA MERAH 🔥
            await db.from("notifications").insert({
              user_id: payloadBody.userId,
              type: "payment_pending",
              message: `Transaksi ${payloadBody.item_name} tertunda. Lanjutkan pembayaran?`,
              is_read: false
            });
          },
          onError: () => window.showNotif("Pembayaran gagal", "error"),
          onClose: async () => {
            window.showNotif("Kamu nutup popup sebelum bayar", "info");
            // 🔥 MASUKIN KE DB BIAR LONCENG NYALA MERAH PAS DICANCEL 🔥
            await db.from("notifications").insert({
              user_id: payloadBody.userId,
              type: "payment_pending",
              message: `Transaksi ${payloadBody.item_name} belum diselesaikan.`,
              is_read: false
            });
          }
        });

      } catch (err) {
        window.showNotif(err.message, "error");
      }
    };

    document.body.addEventListener("click", async (e) => {
      
      // A. KLIK TOMBOL BELI VIP
      const buyVipBtn = e.target.closest(".buy-now-btn");
      if (buyVipBtn) {
        e.preventDefault();
        const card = buyVipBtn.closest(".product-card");
        if (!card) return;

        const originalText = buyVipBtn.textContent;
        buyVipBtn.textContent = "Tunggu...";
        buyVipBtn.style.pointerEvents = "none";

        try {
          const db = await getDB();
          const { data: { user } } = await db.auth.getUser();
          if(!user) throw new Error("Login dulu sebelum beli .");

          // 🔥 FIX PENTING: Bersihin spasi dan buang SVG biar nggak eror pas bikin item_name
          const itemName = card.querySelector(".p-name")?.childNodes[0]?.textContent.trim() || "Premium VIP";

          const payload = {
            userId: user.id, 
            email: user.email, 
            amount: parseInt(card.getAttribute("data-price"), 10), 
            item_name: itemName, 
            role_target: card.getAttribute("data-role")
          };

          await processPayment(buyVipBtn, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-premium", payload);
        } catch (err) {
          window.showNotif(err.message, "warning");
        } finally {
          buyVipBtn.textContent = originalText;
          buyVipBtn.style.pointerEvents = "auto";
        }
      }

      // B. KLIK TOMBOL BELI KOIN
      const buyCoinBtn = e.target.closest(".buy-coin-btn");
      if (buyCoinBtn) {
        e.preventDefault();
        const card = buyCoinBtn.closest(".coin-product-card");
        if (!card) return;

        const originalText = buyCoinBtn.textContent;
        buyCoinBtn.textContent = "Tunggu...";
        buyCoinBtn.style.pointerEvents = "none";

        try {
          const db = await getDB();
          const { data: { user } } = await db.auth.getUser();
          if(!user) throw new Error("Login dulu sebelum beli bro.");

          const payload = {
            userId: user.id, 
            email: user.email, 
            amount: parseInt(card.getAttribute("data-price"), 10), 
            coins: parseInt(card.getAttribute("data-coins"), 10), 
            item_name: card.querySelector(".p-name")?.textContent.trim() || "Top Up Koin"
          };

          await processPayment(buyCoinBtn, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-coins", payload);
        } catch (err) {
          window.showNotif(err.message, "warning");
        } finally {
          buyCoinBtn.textContent = originalText;
          buyCoinBtn.style.pointerEvents = "auto";
        }
      }

      // C. KLIK TOMBOL CUSTOM KOIN
      const buyCustomBtn = e.target.closest("#buy-custom-coin-btn");
      if (buyCustomBtn) {
        e.preventDefault();
        const customInput = document.getElementById("custom-coins");
        if (!customInput) return;

        const coins = parseInt(customInput.value); 
        const price = coins * 100;
        
        if (!coins || coins <= 0) return window.showNotif("Masukin jumlah koinnya dong", "warning");
        if (price < 10000) return window.showNotif("Minimal beli Rp 10.000 (100 Koin)", "warning");
        if (coins > 5000) return window.showNotif("Maksimal beli 5000 koin", "warning");

        const originalText = buyCustomBtn.textContent;
        buyCustomBtn.textContent = "Tunggu...";
        buyCustomBtn.style.pointerEvents = "none";

        try {
          const db = await getDB();
          const { data: { user } } = await db.auth.getUser();
          if(!user) throw new Error("Login dulu sebelum beli bro.");

          const payload = {
            userId: user.id, 
            email: user.email, 
            amount: price, 
            coins: coins, 
            item_name: `${coins} Koin (Custom)`
          };

          await processPayment(buyCustomBtn, "https://hqetnqnvmdxdgfnnluew.supabase.co/functions/v1/pay-coins", payload);
        } catch (err) {
          window.showNotif(err.message, "warning");
