---
// Headerpost.astro
---
<header>
  <div class="user-profile">
    <img class="profile-avatar" id="avatar" src="/asets/png/profile.webp" alt="User" />
    <span class="username" id="username">Guest</span>
    <div class="avatar-menu" id="avatarMenu">
      <button id="profileBtn" onclick="window.location.href='/data'">Profil</button>
      <button id="settingsBtn">Settings</button>
      <button id="logoutBtn">Logout</button>
    </div>
  </div>

  <h1 class="logo-wrapper">
    <span class="logo-flip"></span>
  </h1>
  
  <div class="header-actions">
    <div class="notif-wrapper top-notif" id="notifBell">
      <span class="material-icons notification-icon" id="bellIcon">notifications</span>
      <span class="notif-dot" id="notifCount" style="display:none;">0</span>
    </div>
    <label class="switch" for="dark-mode-checkbox">
      <span class="sr-only" style="display:none;">Dark mode</span>
      <input type="checkbox" id="dark-mode-checkbox" class="toggle toggle-dark" aria-label="Beralih Mode Gelap" />
      <span class="slider"></span>
    </label>
  </div>
</header>

<div id="headerNotifPopup" class="notif-list-container">
  <div class="notif-list-header">
    <h3>Notifikasi</h3>
    <button id="closeNotifBtn">&times;</button>
  </div>
  <div id="notifListContent" class="notif-list-content">
    <p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">Memuat notifikasi...</p>
  </div>
</div>

<style is:global>
/* HEADER & SEARCH */
header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.hello-text span { font-size: 14px; color: #444; }
body.dark .hello-text span { color: #fff; }
.hello-text h1 { font-size: 30px; display: flex; align-items: center; gap: 8px; margin-top: 12px; }
.header-actions { position: absolute; top: 20px; right: 20px; display: flex; flex-direction: row; align-items: center; gap: 10px; z-index: 100; }
.icon { border: 2px solid #000; background: #fff; border-radius: 50%; padding: 6px 8px; cursor: pointer; transition: transform 0.2s ease; }
.icon:hover { transform: translateY(-3px); }
.icon span.material-icons { font-size: 22px; color: #1e223d; }
.icon.profile span.material-icons { color: white; }
body.dark .icon.profile { border: 2px solid #000; background: #000; }
.icon.toggle-dark span.material-icons { color: #1e223d; }
.search { display: flex; border: 2px solid #000; border-radius: 14px; overflow: hidden; margin-bottom: 20px; transition: background-color 0.4s ease, color 0.4s ease, box-shadow 0.4s ease; }
body.dark .search { border: 2px solid #000; }
.search-left { background: #cbb7ff; display: flex; justify-content: center; align-items: center; padding: 12px; }
.search-left span.material-icons { font-size: 20px; line-height: 1; color: #1e223d; display: block; }
.search input { flex: 1; border: none; padding: 12px; outline: none; }
.user-profile { display: flex; align-items: center; gap: 10px; cursor: pointer; position: relative; }
.profile-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid white; }
.username { font-size: 15px; font-weight: 600; color: var(--text-main); }
.admin-badge { font-size: 7px; background: #4facfe; color: white; padding: 0px 2px; border-radius: 3px; margin-left: 2px; font-weight: 600; }

/* AVATAR MENU */
#avatarMenu { display: none; flex-direction: column; gap: 8px; padding: 12px; background: #fff; border-radius: 12px; border: 1px solid #e4e6eb; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12); min-width: 160px; position: absolute; top: 65px; left: 20px; z-index: 1000; transform-origin: top left; }
body.dark #avatarMenu { background: #252525; border-color: #333; }
.avatar-menu img { width: 45px; height: 45px; border-radius: 50%; cursor: pointer; }
#avatarMenu button { width: 100%; padding: 10px 14px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-align: left; transition: 0.2s; }
#profileBtn { background: #e7f3ff; color: #007bff; } #profileBtn:hover { background: #dbeafe; }
body.dark #profileBtn { background: #1a2a3a; color: #4facfe; }
#settingsBtn { background: #f0f2f5; color: #1c1e21; } #settingsBtn:hover { background: #e4e6eb; }
body.dark #settingsBtn { background: #333; color: #fff; }
#logoutBtn { background: #fff0f3; color: #fe2c55; } #logoutBtn:hover { background: #ffe4e9; }
body.dark #logoutBtn { background: #3a1a1e; color: #ff6b6b; }

/* DARK MODE SWITCH */
.switch { --input-focus: #2d8cf0; --bg-color: #fff; --main-color: #323232; position: relative !important; display: inline-block; width: 50px; height: 20px; margin: 0 !important; }
body.dark .switch { --bg-color: #1e1e1e; --main-color: #fff; }
.toggle { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; inset: 0; border-radius: 5px; border: 2px solid var(--main-color); background-color: var(--bg-color); box-shadow: 4px 4px var(--main-color); transition: 0.3s; }
body.dark .slider { box-shadow: 4px 4px var(--main-color); border: 2px solid var(--main-color); }
.slider:before { content: ""; position: absolute; height: 20px; width: 20px; left: -2px; bottom: 2px; border-radius: 5px; border: 2px solid var(--main-color); background-color: var(--bg-color); box-shadow: 0 3px 0 var(--main-color); transition: 0.3s; }
.toggle:checked + .slider { background-color: var(--input-focus); }
.toggle:checked + .slider:before { transform: translateX(30px); }

/* NOTIFIKASI BELL */
.top-notif { display: flex; align-items: center; justify-content: center; }
.notif-wrapper { position: relative; display: inline-flex; align-items: center; justify-content: center; }
.notification-icon { font-size: 24px !important; color: var(--text-main); cursor: pointer; transition: color 0.3s ease, transform 0.2s ease; background: none !important; box-shadow: none !important; border-radius: 0 !important; padding: 0 !important; line-height: 1; transform-origin: top center; }
.notification-icon:hover { transform: scale(1.1); color: #1DA1F2; }

/* 🔥 ANIMASI GOYANG LONCENG (RINGING) 🔥 */
@keyframes bellRing {
  0% { transform: rotate(0); }
  20% { transform: rotate(15deg); }
  40% { transform: rotate(-15deg); }
  60% { transform: rotate(10deg); }
  80% { transform: rotate(-10deg); }
  100% { transform: rotate(0); }
}
.bell-ringing { animation: bellRing 0.5s ease-in-out; }

.notif-dot { position: absolute; top: -5px; right: -5px; background: #ff3040; color: white; font-size: 10px; font-weight: 800; min-width: 18px; height: 18px; padding: 0 4px; border-radius: 50%; display: flex; justify-content: center; align-items: center; border: 2px solid var(--bg-main); box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2); }
#notifBell { position: relative !important; z-index: 99999 !important; cursor: pointer !important; pointer-events: auto !important; padding: 10px !important; display: inline-block !important; -webkit-tap-highlight-color: transparent !important; }
#notifCount { pointer-events: none !important; z-index: 100000 !important; }

/* 🔥 DESAIN POPUP NOTIFIKASI (SOLID & PREMIUM) 🔥 */
.notif-list-container {
  display: none; position: absolute; top: 65px; right: 20px; width: 320px; max-height: 420px; 
  background: #ffffff !important; 
  border-radius: 16px; box-shadow: 0 15px 40px rgba(0,0,0,0.15); 
  border: 1px solid #e4e6eb; z-index: 100000; flex-direction: column; overflow: hidden;
  animation: notifSlideDown 0.3s ease forwards;
}
body.dark .notif-list-container { background: #1c1e22 !important; border-color: #333; box-shadow: 0 15px 40px rgba(0,0,0,0.6); }

.notif-list-container.active { display: flex !important; }
@keyframes notifSlideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

.notif-list-header { padding: 14px 16px; border-bottom: 1px solid #e4e6eb; display: flex; justify-content: space-between; align-items: center; background: #f8f9fa; }
body.dark .notif-list-header { background: #252525; border-color: #333; }

.notif-list-header h3 { margin: 0; font-size: 16px; font-weight: 800; color: var(--text-main); }
.notif-list-header button { background: none; border: none; font-size: 24px; color: var(--text-muted); cursor: pointer; line-height: 1; transition: 0.2s; }
.notif-list-header button:hover { color: #ff4757; transform: scale(1.1); }

.notif-list-content { flex: 1; overflow-y: auto; padding: 12px; display: flex; flex-direction: column; gap: 8px; }
.notif-list-content::-webkit-scrollbar { width: 6px; }
.notif-list-content::-webkit-scrollbar-thumb { background: #ccc; border-radius: 10px; }
body.dark .notif-list-content::-webkit-scrollbar-thumb { background: #555; }

.notif-item { padding: 12px; border-radius: 12px; background: #ffffff; display: flex; gap: 12px; align-items: flex-start; text-decoration: none; color: var(--text-main); transition: 0.2s; cursor: pointer; border: 1px solid transparent; }
body.dark .notif-item { background: #1c1e22; }
.notif-item:hover { background: #f3f4f6; }
body.dark .notif-item:hover { background: #2a2d31; }

.notif-item.unread { background: #f0f7ff; border-color: #cce4ff; }
body.dark .notif-item.unread { background: rgba(29, 161, 242, 0.08); border-color: rgba(29, 161, 242, 0.2); }

.notif-item-icon { width: 36px; height: 36px; border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
.notif-item-text { font-size: 13px; line-height: 1.4; }
.notif-item-text b { font-weight: 700; color: var(--text-main); }
.notif-item-date { font-size: 11px; color: var(--text-muted); margin-top: 5px; display: block; font-weight: 500; }
</style>

<script>
  // 🔥 FUNGSI GLOBAL SUNTIK MIDTRANS PAKSA 🔥
  window.loadMidtransForce = function() {
    return new Promise((resolve) => {
      if (window.snap) return resolve(true);
      const script = document.createElement("script");
      script.src = "https://app.sandbox.midtrans.com/snap/snap.js"; // GANTI KE PRODUCTION KALO UDAH LIVE
      script.setAttribute("data-client-key", "SB-Mid-client-0T6dD0H1HkQvBf8G"); // GANTI PAKE CLIENT KEY LU
      script.onload = () => resolve(true);
      script.onerror = () => resolve(false);
      document.head.appendChild(script);
    });
  };

  document.addEventListener("DOMContentLoaded", () => {
    const toggleBtn = document.querySelector(".toggle-dark");
    const karyaCard = document.querySelector(".job-card.karya-card"); 
    const musicCard = document.querySelector(".job-card.music-card");

    function CardImages(isDark) {
      if (!karyaCard || !musicCard) return;
      if (isDark) {
        karyaCard.style.setProperty("background-image", "url('/asets/png/job1-dark.webp')", "important");
        musicCard.style.setProperty("background-image", "url('/asets/png/job-dark.webp')", "important");
      } else {
        karyaCard.style.setProperty("background-image", "url('/asets/png/art.webp')", "important");
        musicCard.style.setProperty("background-image", "url('/asets/png/song.webp')", "important");
      }
    }

    function applyTheme(isDark) {
      if (isDark) {
        document.documentElement.classList.add("dark");
        document.body.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
        document.body.classList.remove("dark");
      }
      CardImages(isDark);
      if (toggleBtn) toggleBtn.checked = isDark;
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    if (toggleBtn) {
      const savedTheme = localStorage.getItem("theme");
      const isAutoDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const isDark = savedTheme ? savedTheme === "dark" : isAutoDark;
      
      applyTheme(isDark);

      toggleBtn.addEventListener("change", () => {
        document.body.classList.add("theme-transition");
        applyTheme(toggleBtn.checked);
        if (navigator.vibrate) navigator.vibrate(20);
        setTimeout(() => { document.body.classList.remove("theme-transition"); }, 400);
      });
    }

    const avatar = document.getElementById("avatar");
    const avatarMenu = document.getElementById("avatarMenu");
    
    if (avatar && avatarMenu) {
      avatar.addEventListener("click", (e) => {
        e.stopPropagation();
        avatarMenu.style.display = avatarMenu.style.display === "flex" ? "none" : "flex";
      });
      
      document.addEventListener("click", (e) => {
        if (!avatarMenu.contains(e.target) && e.target !== avatar) {
          avatarMenu.style.display = "none";
        }
      });
    }

    const notifBell = document.getElementById("notifBell");
    const bellIcon = document.getElementById("bellIcon");
    const notifList = document.getElementById("headerNotifPopup"); 
    const closeNotifBtn = document.getElementById("closeNotifBtn");
    const countEl = document.getElementById("notifCount");
    let currentUser = null;

    if (notifBell && notifList) {
      notifBell.addEventListener("click", async (e) => {
        e.stopPropagation();
        
        bellIcon.classList.remove("bell-ringing");
        void bellIcon.offsetWidth; 
        bellIcon.classList.add("bell-ringing");

        notifList.classList.toggle("active");
        if (notifList.classList.contains("active")) {
          loadNotifications(); 
        }
      });

      closeNotifBtn?.addEventListener("click", () => notifList.classList.remove("active"));

      document.addEventListener("click", (e) => {
        if (!notifList.contains(e.target) && !notifBell.contains(e.target)) {
          notifList.classList.remove("active");
        }
      });
    }

    async function checkInitialUnread() {
      try {
        const { supabase } = await import('../lib/supabase.js');
        if (!currentUser) {
          const { data: { user } } = await supabase.auth.getUser();
          currentUser = user;
        }
        if (!currentUser) return;

        const { count, error } = await supabase
          .from("notifications")
          .select("*", { count: 'exact', head: true })
          .eq("user_id", currentUser.id)
          .eq("is_read", false);
        
        if (!error && count > 0 && countEl) {
          countEl.innerText = count > 9 ? "9+" : count;
          countEl.style.display = "flex";
        } else if (countEl) {
          countEl.style.display = "none";
        }
      } catch (err) {
        console.error("Gagal ngecek unread:", err);
      }
    }

    window.triggerNotifRefresh = () => {
      checkInitialUnread();
      if (notifList && notifList.classList.contains("active")) {
        loadNotifications();
      }
    };

    async function loadNotifications() {
      const content = document.getElementById("notifListContent");
      if (!content) return;

      content.innerHTML = '<p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">Memuat notifikasi...</p>';

      try {
        const { supabase } = await import('../lib/supabase.js');
        
        if (!currentUser) {
          const { data: { user } } = await supabase.auth.getUser();
          currentUser = user;
        }

        if (!currentUser) {
          content.innerHTML = '<p style="text-align: center; color: #ff4757; font-size: 13px; margin-top: 20px;">Silakan login untuk melihat notifikasi.</p>';
          return;
        }

        const { data: notifs, error } = await supabase
          .from("notifications")
          .select("*")
          .eq("user_id", currentUser.id)
          .order("created_at", { ascending: false })
          .limit(15);

        if (error) throw error;

        if (!notifs || notifs.length === 0) {
          content.innerHTML = '<div style="text-align: center; padding: 30px 0;"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--border-card)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:10px;"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg><p style="color: var(--text-muted); font-size: 13px; margin:0;">Belum ada notifikasi.</p></div>';
          if(countEl) countEl.style.display = "none";
          return;
        }

        const unreadCount = notifs.filter(n => !n.is_read).length;
        if (unreadCount > 0 && countEl) {
          countEl.innerText = unreadCount > 9 ? "9+" : unreadCount;
          countEl.style.display = "flex";
        } else if (countEl) {
          countEl.style.display = "none";
        }

        content.innerHTML = ""; 
        
        notifs.forEach(notif => {
          const div = document.createElement("div");
          div.className = `notif-item ${!notif.is_read ? 'unread' : ''}`;
          
          let iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>`; 
          let iconBg = "#3b82f6"; 

          if (notif.type === "like") {
            iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12.1 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3 9.24 3 10.91 3.81 12 5.09 13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5 22 12.28 18.6 15.36 13.55 20.04z"/></svg>`;
            iconBg = "#ff2e63"; 
          } else if (notif.type === "comment") {
            iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/></svg>`;
            iconBg = "#10b981"; 
          } else if (notif.type === "repost") {
            iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M23.77 15.67c-.292-.293-.767-.293-1.06 0l-2.22 2.22V7.65c0-2.068-1.683-3.75-3.75-3.75h-5.85c-.414 0-.75.336-.75.75s.336.75.75.75h5.85c1.24 0 2.25 1.01 2.25 2.25v10.24l-2.22-2.22c-.293-.292-.768-.292-1.06 0s-.294.768 0 1.06l3.5 3.5c.145.147.337.22.53.22s.383-.072.53-.22l3.5-3.5c.294-.292.294-.767 0-1.06zm-10.66 3.28H7.26c-1.24 0-2.25-1.01-2.25-2.25V6.46l2.22 2.22c.148.147.34.22.532.22s.384-.073.53-.22c.293-.293.293-.768 0-1.06l-3.5-3.5c-.293-.294-.768-.294-1.06 0l-3.5 3.5c-.294.292-.294.767 0 1.06s.767.293 1.06 0l2.22-2.22V16.7c0 2.068 1.683 3.75 3.75 3.75h5.85c.414 0 .75-.336.75-.75s-.337-.75-.75-.75z"></path></svg>`;
            iconBg = "#1DA1F2"; 
          } else if (notif.type === "gift") {
            iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20 7h-2.18A3 3 0 0 0 12 3a3 3 0 0 0-5.82 4H4a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h1v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8h1a1 1 0 0 0 1-1V8a1 1 0 0 0-1-1Zm-8-2a1 1 0 0 1 1 1v1h-2V6a1 1 0 0 1 1-1Zm-4 1a1 1 0 0 1 2 0v1H8a1 1 0 0 1 0-2Zm9 13h-4v-7h4Zm-6 0H7v-7h4Zm8-9H5V9h14Z"/></svg>`;
            iconBg = "#f59e0b"; 
          } else if (notif.type === "payment_pending") {
            iconHtml = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"></rect><line x1="2" y1="10" x2="22" y2="10"></line></svg>`;
            iconBg = "#8b5cf6"; 
          }
          
          const dateObj = new Date(notif.created_at);
          const isToday = new Date().toDateString() === dateObj.toDateString();
          const dateStr = isToday ? 
             `Hari ini, ${dateObj.toLocaleTimeString("id-ID", {hour: "2-digit", minute:"2-digit"})}` : 
             dateObj.toLocaleDateString("id-ID", { month: "short", day: "numeric", hour: "2-digit", minute:"2-digit" });

          div.innerHTML = `
            <div class="notif-item-icon" style="background: ${iconBg};">${iconHtml}</div>
            <div style="flex:1;">
              <div class="notif-item-text">${notif.message}</div>
              <span class="notif-item-date">${dateStr}</span>
            </div>
            ${!notif.is_read ? '<div style="width: 8px; height: 8px; background: #1DA1F2; border-radius: 50%; margin-top: 6px;"></div>' : ''}
          `;

          div.onclick = async () => {
            if (!notif.is_read) {
              div.classList.remove('unread');
              const dot = div.querySelector('div[style*="width: 8px"]');
              if (dot) dot.remove();
              
              await supabase.from("notifications").update({ is_read: true }).eq("id", notif.id);
              
              let current = parseInt(countEl.innerText) || 0;
              if (current > 1) {
                countEl.innerText = current - 1;
              } else {
                countEl.style.display = "none";
              }
            }
            
            if (notif.type === "payment_pending" && notif.token) {
              try {
                if(window.showNotif) window.showNotif("Menyiapkan pembayaran...", "info");
                
                const isLoaded = await window.loadMidtransForce();
                
                if (isLoaded && window.snap) {
                  document.getElementById("headerNotifPopup").classList.remove("active");
                  window.snap.pay(notif.token, {
                    onSuccess: () => { if(window.showNotif) window.showNotif("Pembayaran Sukses!", "success"); setTimeout(()=>location.reload(), 1200); },
                    onPending: () => { if(window.showNotif) window.showNotif("Menunggu pembayaran", "warning"); },
                    onError: () => { if(window.showNotif) window.showNotif("Pembayaran gagal", "error"); },
                    onClose: () => { if(window.showNotif) window.showNotif("Popup ditutup", "info"); }
                  });
                } else {
                  if(window.showNotif) window.showNotif("Sistem pembayaran gagal dimuat, silakan refresh web.", "error");
                }
              } catch (err) {
                console.error("Midtrans Resume Error:", err);
              }
            } 
            else if (notif.post_id) {
               window.location.href = `/post?id=${notif.post_id}`;
            }
          };

          content.appendChild(div);
        });

      } catch (err) {
        console.error(err);
        content.innerHTML = '<p style="text-align: center; color: #ff4757; font-size: 13px; margin-top: 20px;">Gagal memuat notifikasi.</p>';
      }
    }

    setTimeout(checkInitialUnread, 1500);

    async function initRealtimeNotif() {
      try {
        const { supabase } = await import('../lib/supabase.js');
        if (!currentUser) {
          const { data: { user } } = await supabase.auth.getUser();
          currentUser = user;
        }
        if (!currentUser) return;

        supabase
          .channel('custom-notif-channel')
          .on(
            'postgres_changes',
            { 
              event: 'INSERT', 
              schema: 'public', 
              table: 'notifications', 
              filter: `user_id=eq.${currentUser.id}` 
            },
            (payload) => {
              if (countEl) {
                let currentCount = parseInt(countEl.innerText) || 0;
                countEl.innerText = currentCount >= 9 ? "9+" : currentCount + 1;
                countEl.style.display = "flex";
              }
              if (window.showNotif) {
                window.showNotif(payload.new.message, "info");
              }
              const notifList = document.getElementById("headerNotifPopup");
              if (notifList && notifList.classList.contains("active")) {
                loadNotifications();
              }
            }
          )
          .subscribe();
      } catch (err) {
        console.error("Realtime init failed:", err);
      }
    }
    
    setTimeout(initRealtimeNotif, 2500);

    window.addEventListener("loadUnreadNotifications", () => {
      setTimeout(() => {
        checkInitialUnread();
        const notifList = document.getElementById("headerNotifPopup");
        if (notifList && notifList.classList.contains("active")) {
          loadNotifications();
        }
      }, 500); 
    });

    // =======================
    // 🔥 DINAMIS LOGIN / LOGOUT LOGIC 🔥
    // =======================
    async function setupAuthMenu() {
      const authBtn = document.getElementById("logoutBtn");
      const profileBtn = document.getElementById("profileBtn");
      const settingsBtn = document.getElementById("settingsBtn");
      
      if (!authBtn) return;

      try {
        const { supabase } = await import('../lib/supabase.js');
        
        // Pastiin kita dapetin status user saat ini
        if (!currentUser) {
          const { data: { user } } = await supabase.auth.getUser();
          currentUser = user;
        }
        
        if (currentUser) {
          // UDAH LOGIN
          authBtn.innerText = "Logout";
          authBtn.style.background = "#fff0f3"; 
          authBtn.style.color = "#fe2c55";
        } else {
          // BELUM LOGIN
          authBtn.innerText = "Login";
          authBtn.style.background = "#e7f3ff"; 
          authBtn.style.color = "#007bff";
          
          // Sembunyiin tombol Profil sama Setting kalo tamu (belum login)
          if (profileBtn) profileBtn.style.display = "none";
          if (settingsBtn) settingsBtn.style.display = "none";
        }

        authBtn.addEventListener("click", async () => {
          if (!currentUser) {
            // Kalo user klik tombol "Login"
            window.location.href = "/login";
            return;
          }
          
          // Kalo user klik tombol "Logout"
          let utils = {};
          try { utils = await import('../lib/ui-utils.js'); } catch(e){}
          const showNotifLocal = utils.showToast || window.showNotif || alert;

          try {
            const { error } = await supabase.auth.signOut();
            if (error && error.message !== "Auth session missing!") throw error;
            localStorage.clear(); 
            sessionStorage.clear(); 
            window.location.href = "/login";
          } catch (err) {
            if (err.message === "Auth session missing!") {
              localStorage.clear(); 
              sessionStorage.clear(); 
              window.location.href = "/login"; 
              return;
            }
            showNotifLocal("Gagal logout", err.message, "error");
          }
        });
      } catch (e) {
        console.error("Auth menu setup error:", e);
      }
    }
    
    // Panggil fungsi buat nge-set tombol auth-nya
    setupAuthMenu();

  });
</script>
