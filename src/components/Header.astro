---
// Headerpost.astro
---
<header>
  <div class="user-profile">
    <img class="profile-avatar" id="avatar" src="/asets/png/profile.webp" alt="User" />
    <span class="username" id="username">Guest</span>
    <div class="avatar-menu" id="avatarMenu">
      <button id="profileBtn" onclick="window.location.href='/data'">Profil</button>
      <button id="settingsBtn">Settings</button>
      <button id="logoutBtn">Logout</button>
    </div>
  </div>

  <h1 class="logo-wrapper">
    <span class="logo-flip"></span>
  </h1>
  
  <div class="header-actions">
    <div class="notif-wrapper top-notif" id="notifBell">
      <span class="material-icons notification-icon">notifications</span>
      <span class="notif-dot" id="notifCount" style="display:none;">0</span>
    </div>
    <label class="switch" for="dark-mode-checkbox">
      <span class="sr-only" style="display:none;">Dark mode</span>
      <input type="checkbox" id="dark-mode-checkbox" class="toggle toggle-dark" aria-label="Beralih Mode Gelap" />
      <span class="slider"></span>
    </label>
  </div>
</header>

<div id="notificationList" class="notif-list-container">
  <div class="notif-list-header">
    <h3>Notifikasi</h3>
    <button id="closeNotifBtn">&times;</button>
  </div>
  <div id="notifListContent" class="notif-list-content">
    <p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">Memuat notifikasi...</p>
  </div>
</div>

<style is:global>
/* HEADER & SEARCH */
header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
.hello-text span { font-size: 14px; color: #444; }
body.dark .hello-text span { color: #fff; }
.hello-text h1 { font-size: 30px; display: flex; align-items: center; gap: 8px; margin-top: 12px; }
.header-actions { position: absolute; top: 20px; right: 20px; display: flex; flex-direction: row; align-items: center; gap: 10px; z-index: 100; }
.icon { border: 2px solid #000; background: #fff; border-radius: 50%; padding: 6px 8px; cursor: pointer; transition: transform 0.2s ease; }
.icon:hover { transform: translateY(-3px); }
.icon span.material-icons { font-size: 22px; color: #1e223d; }
.icon.profile span.material-icons { color: white; }
body.dark .icon.profile { border: 2px solid #000; background: #000; }
.icon.toggle-dark span.material-icons { color: #1e223d; }
.search { display: flex; border: 2px solid #000; border-radius: 14px; overflow: hidden; margin-bottom: 20px; transition: background-color 0.4s ease, color 0.4s ease, box-shadow 0.4s ease; }
body.dark .search { border: 2px solid #000; }
.search-left { background: #cbb7ff; display: flex; justify-content: center; align-items: center; padding: 12px; }
.search-left span.material-icons { font-size: 20px; line-height: 1; color: #1e223d; display: block; }
.search input { flex: 1; border: none; padding: 12px; outline: none; }
.user-profile { display: flex; align-items: center; gap: 10px; cursor: pointer; position: relative; }
.profile-avatar { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid white; }
.username { font-size: 15px; font-weight: 600; color: var(--text-main); }
.admin-badge { font-size: 7px; background: #4facfe; color: white; padding: 0px 2px; border-radius: 3px; margin-left: 2px; font-weight: 600; }

/* AVATAR MENU */
#avatarMenu { display: none; flex-direction: column; gap: 8px; padding: 12px; background: #fff; border-radius: 12px; border: 1px solid #e4e6eb; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12); min-width: 160px; position: absolute; top: 65px; left: 20px; z-index: 1000; transform-origin: top left; }
body.dark #avatarMenu { background: #252525; border-color: #333; }
.avatar-menu img { width: 45px; height: 45px; border-radius: 50%; cursor: pointer; }
#avatarMenu button { width: 100%; padding: 10px 14px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; text-align: left; transition: 0.2s; }
#profileBtn { background: #e7f3ff; color: #007bff; } #profileBtn:hover { background: #dbeafe; }
body.dark #profileBtn { background: #1a2a3a; color: #4facfe; }
#settingsBtn { background: #f0f2f5; color: #1c1e21; } #settingsBtn:hover { background: #e4e6eb; }
body.dark #settingsBtn { background: #333; color: #fff; }
#logoutBtn { background: #fff0f3; color: #fe2c55; } #logoutBtn:hover { background: #ffe4e9; }
body.dark #logoutBtn { background: #3a1a1e; color: #ff6b6b; }

/* DARK MODE SWITCH */
.switch { --input-focus: #2d8cf0; --bg-color: #fff; --main-color: #323232; position: relative !important; display: inline-block; width: 50px; height: 20px; margin: 0 !important; }
body.dark .switch { --bg-color: #1e1e1e; --main-color: #fff; }
.toggle { opacity: 0; width: 0; height: 0; }
.slider { position: absolute; cursor: pointer; inset: 0; border-radius: 5px; border: 2px solid var(--main-color); background-color: var(--bg-color); box-shadow: 4px 4px var(--main-color); transition: 0.3s; }
body.dark .slider { box-shadow: 4px 4px var(--main-color); border: 2px solid var(--main-color); }
.slider:before { content: ""; position: absolute; height: 20px; width: 20px; left: -2px; bottom: 2px; border-radius: 5px; border: 2px solid var(--main-color); background-color: var(--bg-color); box-shadow: 0 3px 0 var(--main-color); transition: 0.3s; }
.toggle:checked + .slider { background-color: var(--input-focus); }
.toggle:checked + .slider:before { transform: translateX(30px); }

/* NOTIFIKASI BELL */
.top-notif { display: flex; align-items: center; justify-content: center; }
.notif-wrapper { position: relative; display: inline-flex; align-items: center; justify-content: center; }
.notification-icon { font-size: 24px !important; color: var(--text-main); cursor: pointer; transition: color 0.3s ease, transform 0.2s ease; background: none !important; box-shadow: none !important; border-radius: 0 !important; padding: 0 !important; line-height: 1; }
.notification-icon:hover { transform: scale(1.1); color: #1DA1F2; }
.notif-dot { position: absolute; top: -5px; right: -5px; background: #ff3040; color: white; font-size: 10px; font-weight: 800; min-width: 18px; height: 18px; padding: 0 4px; border-radius: 50%; display: flex; justify-content: center; align-items: center; border: 2px solid var(--bg-main); box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2); }
#notifBell { position: relative !important; z-index: 99999 !important; cursor: pointer !important; pointer-events: auto !important; padding: 10px !important; display: inline-block !important; -webkit-tap-highlight-color: transparent !important; }
#notifCount { pointer-events: none !important; z-index: 100000 !important; }

/* 🔥 DESAIN POPUP NOTIFIKASI 🔥 */
.notif-list-container {
  display: none; position: absolute; top: 65px; right: 20px; width: 300px; max-height: 400px; 
  background: var(--bg-card); border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); 
  border: 1px solid var(--border-card); z-index: 100000; flex-direction: column; overflow: hidden;
  animation: notifSlideDown 0.3s ease forwards;
}
.notif-list-container.active { display: flex; }
@keyframes notifSlideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }

.notif-list-header {
  padding: 12px 16px; border-bottom: 1px solid var(--border-card);
  display: flex; justify-content: space-between; align-items: center; background: var(--bg-card);
}
.notif-list-header h3 { margin: 0; font-size: 16px; font-weight: 700; color: var(--text-main); }
.notif-list-header button { background: none; border: none; font-size: 24px; color: var(--text-muted); cursor: pointer; line-height: 1; }

.notif-list-content {
  flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 8px;
}
.notif-item {
  padding: 12px; border-radius: 10px; background: var(--bg-input); 
  display: flex; gap: 10px; align-items: flex-start; text-decoration: none; color: var(--text-main); transition: 0.2s; cursor: pointer;
}
.notif-item:hover { background: var(--border-card); }
.notif-item.unread { border-left: 4px solid #1DA1F2; background: rgba(29, 161, 242, 0.05); }
.notif-item-icon { width: 32px; height: 32px; border-radius: 50%; background: #1DA1F2; color: white; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
.notif-item-text { font-size: 13px; line-height: 1.4; }
.notif-item-text b { font-weight: 700; }
.notif-item-date { font-size: 10px; color: var(--text-muted); margin-top: 4px; display: block; }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {

    // =======================
    // CARDS & THEME (DARK MODE)
    // =======================
    const toggleBtn = document.querySelector(".toggle-dark");
    const karyaCard = document.querySelector(".job-card.karya-card"); 
    const musicCard = document.querySelector(".job-card.music-card");

    function CardImages(isDark) {
      if (!karyaCard || !musicCard) return;
      if (isDark) {
        karyaCard.style.setProperty("background-image", "url('/asets/png/job1-dark.webp')", "important");
        musicCard.style.setProperty("background-image", "url('/asets/png/job-dark.webp')", "important");
      } else {
        karyaCard.style.setProperty("background-image", "url('/asets/png/art.webp')", "important");
        musicCard.style.setProperty("background-image", "url('/asets/png/song.webp')", "important");
      }
    }

    function applyTheme(isDark) {
      if (isDark) {
        document.documentElement.classList.add("dark");
        document.body.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
        document.body.classList.remove("dark");
      }
      CardImages(isDark);
      if (toggleBtn) toggleBtn.checked = isDark;
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    if (toggleBtn) {
      const savedTheme = localStorage.getItem("theme");
      const isAutoDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const isDark = savedTheme ? savedTheme === "dark" : isAutoDark;
      
      applyTheme(isDark);

      toggleBtn.addEventListener("change", () => {
        document.body.classList.add("theme-transition");
        applyTheme(toggleBtn.checked);
        if (navigator.vibrate) navigator.vibrate(20);
        setTimeout(() => { document.body.classList.remove("theme-transition"); }, 400);
      });
    }

    // =======================
    // PROFILE & AVATAR MENU TOGGLE
    // =======================
    const avatar = document.getElementById("avatar");
    const avatarMenu = document.getElementById("avatarMenu");
    
    if (avatar && avatarMenu) {
      avatar.addEventListener("click", (e) => {
        e.stopPropagation();
        avatarMenu.style.display = avatarMenu.style.display === "flex" ? "none" : "flex";
      });
      
      document.addEventListener("click", (e) => {
        if (!avatarMenu.contains(e.target) && e.target !== avatar) {
          avatarMenu.style.display = "none";
        }
      });
    }

    // =======================
    // 🔥 LOGIKA POPUP NOTIFIKASI 🔥
    // =======================
    const notifBell = document.getElementById("notifBell");
    const notifList = document.getElementById("notificationList");
    const closeNotifBtn = document.getElementById("closeNotifBtn");
    let currentUser = null;

    if (notifBell && notifList) {
      notifBell.addEventListener("click", async (e) => {
        e.stopPropagation();
        notifList.classList.toggle("active");
        if (notifList.classList.contains("active")) {
          loadNotifications();
        }
      });

      closeNotifBtn?.addEventListener("click", () => notifList.classList.remove("active"));

      document.addEventListener("click", (e) => {
        if (!notifList.contains(e.target) && !notifBell.contains(e.target)) {
          notifList.classList.remove("active");
        }
      });
    }

    // =======================
    // 🔥 FETCH DATA NOTIFIKASI DARI SUPABASE 🔥
    // =======================
    async function loadNotifications() {
      const content = document.getElementById("notifListContent");
      const countEl = document.getElementById("notifCount");
      if (!content) return;

      content.innerHTML = '<p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">Memuat notifikasi...</p>';

      try {
        const { supabase } = await import('../lib/supabase.js');
        
        // Ambil User ID kalo belum
        if (!currentUser) {
          const { data: { user } } = await supabase.auth.getUser();
          currentUser = user;
        }

        if (!currentUser) {
          content.innerHTML = '<p style="text-align: center; color: #ff4757; font-size: 13px; margin-top: 20px;">Silakan login untuk melihat notifikasi.</p>';
          return;
        }

        // Ambil 10 notifikasi terbaru buat user ini
        const { data: notifs, error } = await supabase
          .from("notifications")
          .select("*")
          .eq("user_id", currentUser.id)
          .order("created_at", { ascending: false })
          .limit(10);

        if (error) throw error;

        if (!notifs || notifs.length === 0) {
          content.innerHTML = '<p style="text-align: center; color: var(--text-muted); font-size: 13px; margin-top: 20px;">Belum ada notifikasi.</p>';
          countEl.style.display = "none";
          return;
        }

        // Hitung yang belum dibaca
        const unreadCount = notifs.filter(n => !n.is_read).length;
        if (unreadCount > 0 && countEl) {
          countEl.innerText = unreadCount > 9 ? "9+" : unreadCount;
          countEl.style.display = "flex";
        } else if (countEl) {
          countEl.style.display = "none";
        }

        content.innerHTML = ""; // Bersihin loading
        
        notifs.forEach(notif => {
          const div = document.createElement("div");
          div.className = `notif-item ${!notif.is_read ? 'unread' : ''}`;
          
          let icon = "🔔";
          if (notif.type === "like") icon = "❤️";
          if (notif.type === "comment") icon = "💬";
          if (notif.type === "repost") icon = "♻️";
          if (notif.type === "gift") icon = "🎁";
          
          const date = new Date(notif.created_at).toLocaleDateString("id-ID", { month: "short", day: "numeric", hour: "2-digit", minute:"2-digit" });

          div.innerHTML = `
            <div class="notif-item-icon">${icon}</div>
            <div>
              <div class="notif-item-text">${notif.message}</div>
              <span class="notif-item-date">${date}</span>
            </div>
          `;

          // Pas diklik, tandain dibaca
          div.onclick = async () => {
            if (!notif.is_read) {
              div.classList.remove('unread');
              await supabase.from("notifications").update({ is_read: true }).eq("id", notif.id);
              
              // Kurangin count merah
              let current = parseInt(countEl.innerText) || 0;
              if (current > 1) {
                countEl.innerText = current - 1;
              } else {
                countEl.style.display = "none";
              }
            }
            
            // Kalo ada post_id, lompat ke postingan
            if (notif.post_id) {
               window.location.href = `/post?id=${notif.post_id}`;
            }
          };

          content.appendChild(div);
        });

      } catch (err) {
        console.error(err);
        content.innerHTML = '<p style="text-align: center; color: #ff4757; font-size: 13px; margin-top: 20px;">Gagal memuat notifikasi.</p>';
      }
    }

    // Panggil diam-diam di background pas halaman beres diload biar badge merahnya muncul
    setTimeout(loadNotifications, 2000);


    // =======================
    // LOGOUT LOGIC (LAZY LOAD DB)
    // =======================
    document.getElementById("logoutBtn")?.addEventListener("click", async () => {
      const { supabase: db } = await import('../lib/supabase.js');
      let utils = {};
      try { utils = await import('../lib/ui-utils.js'); } catch(e){}

      const showNotifLocal = utils.showToast || window.showNotif || alert;

      try {
        const { data: { session } } = await db.auth.getSession();
        if (session) {
          const { error } = await db.auth.signOut();
          if (error && error.message !== "Auth session missing!") throw error;
        }
        localStorage.clear(); 
        sessionStorage.clear(); 
        window.location.href = "/login";
      } catch (err) {
        if (err.message === "Auth session missing!") {
          localStorage.clear(); 
          sessionStorage.clear(); 
          window.location.href = "/login"; 
          return;
        }
        showNotifLocal("Gagal logout", err.message, "error");
      }
    });

  });
</script>
