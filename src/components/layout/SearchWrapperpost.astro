---
---
<div class="search-wrapper" style="display: flex; align-items: center; gap: 10px; width: 100%; padding: 10px;">
  <div class="menu-toggle" id="mobileMenuBtn">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="brutal-input-container" style="flex: 1;">
    <input
      type="text"
      id="searchCreator"
      placeholder="Cari kreator..."
      class="brutal-input"
      style="width: 100%; padding: 8px 16px; border-radius: 20px; font-size: 13px; height: 38px; box-sizing: border-box; outline: none; border: none; background: #ececec;"
      required
    />
  </div>

  <button id="openPostModalBtn" class="add-post-btn">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="12" y1="5" x2="12" y2="19"></line>
      <line x1="5" y1="12" x2="19" y2="12"></line>
    </svg>
  </button>
</div>
