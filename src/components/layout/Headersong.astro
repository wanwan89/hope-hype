---
---
<div class="header-container">
  <header class="music-header">
    <div style="display: flex; align-items: center; gap: 15px;">
      <span class="material-icons" id="openSidebar" style="cursor: pointer;">menu</span>
      <h1>Stream song</h1>
    </div>
    <div class="profile-image">
      <img src="/asets/png/music.png" alt="Profile" /> 
    </div>
  </header>
  
  <div class="search-box">
    <span class="material-icons">search</span>
    <input type="text" id="search-input" placeholder="Search songs..." />
  </div>
  
  <div class="category-tabs" id="categoryTabs">
    <button class="active" data-cat="all">All</button>
    <button data-cat="music">Music</button>
    <button data-cat="hopers">Hopers</button>
    <button data-cat="playlist">Playlist</button>
    <button data-cat="trending">Trending</button>
    <button data-cat="trend">Trend</button>
    <button data-cat="viral">Viral</button>
  </div>
</div>
