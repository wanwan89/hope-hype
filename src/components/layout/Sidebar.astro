<div id="sidebar" class="sidebar" style="background: var(--bg-sidebar) !important; transition: background-color 0.3s;">
  
  <div style="padding: 30px 20px; background: #3a7bd5; color: white; display: flex; flex-direction: column; align-items: center; gap: 8px;">
    <img id="side-avatar" src="/asets/png/profile.webp" style="width: 75px; height: 75px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.3); object-fit: cover;" />
    <div style="text-align: center;">
      <div id="side-username" style="font-weight: 600; font-size: 16px; margin-bottom: 2px;">Loading...</div>
      <div onclick="window.copyMyID(document.getElementById('my-unique-id').innerText)" style="font-size: 10px; background: rgba(0,0,0,0.2); padding: 2px 10px; border-radius: 12px; cursor: pointer; display: inline-block; margin-bottom: 5px;">
        ID UNIK: <span id="my-unique-id" style="font-weight: 700;">#-----</span>
      </div>
      <div onclick="window.openEditProfile()" style="font-size: 11px; color: #fff; cursor: pointer; margin-top: 5px; background: rgba(255,255,255,0.2); padding: 5px 15px; border-radius: 20px; display: flex; align-items: center; gap: 5px; justify-content: center; border: 1px solid rgba(255,255,255,0.3); font-weight: 600;">
        Edit Biodata
      </div>
    </div>
  </div>

  <div style="padding: 15px; border-bottom: 1px solid var(--border-color);">
    <div style="display: flex; background: var(--bg-main) !important; border-radius: 20px; padding: 8px 15px; align-items: center; border: 1px solid var(--border-color);">
      <span style="color: #3a7bd5; font-weight: bold; margin-right: 5px;">@</span>
      <input type="text" id="input-search-id" placeholder="Cari ID teman..." 
             style="border: none; background: transparent !important; outline: none; font-size: 13px; width: 100%; color: var(--text-color);" />
    </div>
    <button id="btn-search-id" style="width: 100%; margin-top: 8px; border: none; background: #3a7bd5; color: white; border-radius: 12px; padding: 8px; font-size: 11px; font-weight: 600; cursor: pointer;">
      CARI & CHAT
    </button>
  </div>

  <div style="padding: 10px 15px; border-bottom: 1px solid var(--border-color);">
    <button id="btn-open-group-modal" style="width: 100%; border: 2px dashed #3a7bd5; background: var(--bg-main); color: #3a7bd5; border-radius: 12px; padding: 10px; font-size: 12px; font-weight: 700; cursor: pointer;">
      BUAT GRUP BARU
    </button>
  </div>

  <div style="flex: 1; overflow-y: auto;">
    <div id="private-chat-list"></div>
  </div>

<div class="sidebar-doi-container">
    <button id="btn-sidebar-search" onclick="window.mulaiCariDoiDenganLimit()" class="btn-cari-doi">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      <span>Cari Doi Sekarang</span>
    </button>
    
    <div style="text-align: center; font-size: 11px; color: var(--text-muted); margin-top: 8px;">
      Sisa Kuota Cari: <span id="limit-doi-text" style="font-weight: bold; color: #1f3cff;">--</span>/10
    </div>
</div>

<script is:inline>
  (function() {
    const textLimit = document.getElementById('limit-doi-text');
    // Ambil angka mentah saja dari storage
    const currentLimit = localStorage.getItem('doi_limit') || '10';
    if (textLimit) {
      // HANYA MASUKKAN ANGKA (Misal: 10)
      textLimit.innerText = currentLimit; 
      textLimit.style.color = parseInt(currentLimit) > 0 ? "#1f3cff" : "#ff4757";
    }
  })();
</script>
