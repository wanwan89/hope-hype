---
// Jika ada script atau import bawaan di Header.astro milikmu sebelumnya, 
// letakkan di bagian atas ini. Jika tidak ada, biarkan kosong.
---
<div class="chat-header">
  
  <div class="header-left">
    
    <div class="menu-btn back-btn" id="back-btn" onclick="window.location.href='/hypetalk'" style="cursor: pointer; display: flex; align-items: center; justify-content: center;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
    </div>

    <div class="header-info">
      <h3>HopeTalk Globe</h3>
      <div id="status-container" class="status-container">
        <span id="status-header" class="status-online">Online</span>
        <span id="typing-header" class="status-typing" style="display: none;">Sedang mengetik...</span>
      </div>
    </div>

    <button id="btn-open-invite" class="btn-invite" style="display: none;">
      UNDANG
    </button>
  </div>

  <div class="header-right">
    <div id="btn-start-call" class="btn-call" style="display: none; cursor: pointer;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.19-2.19a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </div>
  </div>

</div>
