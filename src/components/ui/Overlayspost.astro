---
// GiftSheetpost.astro
---
<div id="giftSheet" class="gift-sheet">
  <div class="gift-sheet-overlay" id="giftOverlay"></div>
  
  <div class="gift-sheet-content">
    <div class="sheet-handle"></div>

    <div class="gift-header">
      <span>Kirim hadiah untuk mendukung kreator</span>
      <span class="gift-close-x" id="giftCloseBtn">&times;</span>
    </div>

    <div class="gift-grid">
      <div class="gift-item" data-amount="10" data-img="/asets/png/gift1.png">
        <div class="gift-img-container">
          <img src="/asets/png/gift1.png" class="img-gift" alt="Gift 1" />
        </div>
        <span class="gift-name">Troi</span>
        <span class="gift-price">
          <img src="/asets/svg/koin.webp" class="img-coin-inline" /> 10
        </span>
      </div>

      <div class="gift-item" data-amount="20" data-img="/asets/png/gift2.png">
        <div class="gift-img-container">
          <img src="/asets/png/gift2.png" class="img-gift" alt="Gift 2" />
        </div>
        <span class="gift-name">Fox</span>
        <span class="gift-price">
          <img src="/asets/svg/koin.webp" class="img-coin-inline" /> 20
        </span>
      </div>

      <div class="gift-item" data-amount="20" data-img="/asets/png/gift3.png">
        <div class="gift-img-container">
          <img src="/asets/png/gift3.png" class="img-gift" alt="Gift 3" />
        </div>
        <span class="gift-name">Panda</span>
        <span class="gift-price">
          <img src="/asets/svg/koin.webp" class="img-coin-inline" /> 20
        </span>
      </div>

      <div class="gift-item" data-amount="25" data-img="/asets/png/gift4.png">
        <div class="gift-img-container">
          <img src="/asets/png/gift4.png" class="img-gift" alt="Gift 4" />
        </div>
        <span class="gift-name">Rabbit</span>
        <span class="gift-price">
          <img src="/asets/svg/koin.webp" class="img-coin-inline" /> 25
        </span>
      </div>

      <div class="gift-item" data-amount="100" data-img="/asets/png/gift5.png">
        <div class="gift-img-container">
          <img src="/asets/png/gift5.png" class="img-gift" alt="Gift 5" />
        </div>
        <span class="gift-name">Catglow</span>
        <span class="gift-price">
          <img src="/asets/svg/koin.webp" class="img-coin-inline" /> 100
        </span>
      </div>
    </div>
    
    <div class="gift-footer">
      <div class="user-coins-info" onclick="window.location.href='/topup'">
        <img src="/asets/svg/koin.webp" class="img-coin-footer" />
        <span id="giftUserCoins">0</span>
        <span style="color: rgba(255,255,255,0.3); margin-left: 5px;">&rsaquo;</span>
      </div>
      <button id="sendGiftBtn" class="btn-send-gift" disabled>
        Kirim
      </button>
    </div>
  </div>
</div>

<style>
  /* =========================================
     CSS SCOPED: KHUSUS GIFT SHEET
     ========================================= */
  .gift-sheet {
    position: fixed; inset: 0; z-index: 100000;
    display: none; align-items: flex-end;
  }
  .gift-sheet.active { display: flex; }

  .gift-sheet-overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.55);
    backdrop-filter: blur(2px); cursor: pointer;
  }

  .gift-sheet-content {
    position: relative; width: 100%; background: var(--bg-modal);
    color: var(--text-main); border-radius: 24px 24px 0 0;
    padding: 15px 20px 30px; transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 -10px 40px rgba(0,0,0,0.4); z-index: 100001;
  }
  .gift-sheet.active .gift-sheet-content { transform: translateY(0); }

  .sheet-handle {
    width: 40px; height: 5px; background: var(--border-card);
    border-radius: 10px; margin: 0 auto 15px;
  }

  .gift-header {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 13px; font-weight: 600; color: var(--text-muted); margin-bottom: 20px;
  }
  .gift-close-x { font-size: 22px; cursor: pointer; color: var(--text-main); }

  .gift-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
  }

  .gift-item {
    display: flex; flex-direction: column; align-items: center;
    padding: 12px 5px; border-radius: 14px; border: 2px solid transparent;
    background: var(--bg-input); transition: 0.2s ease; cursor: pointer;
  }
  .gift-item:hover { transform: translateY(-3px); }
  
  .gift-item.selected-gift {
    background: rgba(255, 45, 85, 0.1); border-color: #ff2d55;
    transform: scale(1.05); box-shadow: 0 0 15px rgba(255, 45, 85, 0.2);
  }
  .gift-item.selected-gift img { animation: bounceMini 0.4s ease; }
  @keyframes bounceMini { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }

  .gift-img-container { width: 50px; height: 50px; margin-bottom: 5px; }
  .img-gift { width: 100%; height: 100%; object-fit: contain; }
  
  .gift-name { font-size: 11px; font-weight: 700; color: var(--text-main); }
  .gift-price { font-size: 12px; color: #ffd700; display: flex; align-items: center; gap: 3px; font-weight: 800; }
  .img-coin-inline { width: 12px; height: 12px; }

  .gift-footer {
    margin-top: 25px; display: flex; justify-content: space-between; align-items: center;
    padding-top: 15px; border-top: 1px solid var(--border-card);
  }

  .user-coins-info {
    display: flex; align-items: center; gap: 6px; color: var(--text-main);
    font-weight: 700; cursor: pointer;
  }
  .img-coin-footer { width: 22px; height: 22px; }
  #giftUserCoins { font-size: 16px; }

  .btn-send-gift {
    background: #ff2d55; color: white; border: none; padding: 12px 30px;
    border-radius: 25px; font-weight: 800; font-size: 14px; cursor: pointer; transition: 0.2s;
  }
  .btn-send-gift:disabled { background: var(--bg-input); color: var(--text-muted); cursor: not-allowed; }
  
  @media (max-width: 400px) {
    .gift-grid { grid-template-columns: repeat(3, 1fr); } /* Responsif buat HP kecil */
  }
</style>

<script>
  const getDB = () => import('../../lib/supabase.js').then(m => m.supabase);

  // State
  let giftState = { 
    postId: null, 
    creatorId: null, 
    creatorName: "", 
    userCoins: 0, 
    selectedAmount: 0, 
    selectedImg: "" 
  };

  document.addEventListener("DOMContentLoaded", () => {
    const sheet = document.getElementById("giftSheet");
    const overlay = document.getElementById("giftOverlay");
    const closeBtn = document.getElementById("giftCloseBtn");
    const sendBtn = document.getElementById("sendGiftBtn");
    const coinDisplay = document.getElementById("giftUserCoins");
    const giftItems = document.querySelectorAll(".gift-item");

    // 1. GLOBAL LISTENER BUKA GIFT SHEET (Dari Gallery)
    document.body.addEventListener("click", async (e) => {
      const btn = e.target.closest(".gift-btn");
      if (btn) {
        const db = await getDB();
        const { data: { session } } = await db.auth.getSession();
        
        if (!session) return window.dispatchEvent(new CustomEvent('openLogin'));
        
        if (session.user.id === btn.dataset.creator) {
            if (window.showNotif) window.showNotif("Masa ngirim gift ke diri sendiri bro? 😂", "warning");
            return;
        }

        // Set state
        giftState.postId = btn.dataset.post;
        giftState.creatorId = btn.dataset.creator;
        giftState.creatorName = btn.dataset.name;

        // Fetch koin user
        const { data: prof } = await db.from("profiles").select("coins").eq("id", session.user.id).single();
        giftState.userCoins = prof?.coins || 0;
        coinDisplay.innerText = giftState.userCoins;

        // Munculin Sheet
        sheet.classList.add("active");
        document.body.style.overflow = "hidden"; // Kunci scroll layar
      }
    });

    // 2. LOGIKA TUTUP SHEET
    const closeSheet = () => {
      sheet.classList.remove("active");
      document.body.style.overflow = "";
      // Reset Pilihan
      giftItems.forEach(i => i.classList.remove("selected-gift"));
      sendBtn.disabled = true;
      sendBtn.innerText = "Kirim";
      giftState.selectedAmount = 0;
    };

    overlay.onclick = closeSheet;
    closeBtn.onclick = closeSheet;

    // 3. LOGIKA PILIH GIFT
    giftItems.forEach(item => {
      item.onclick = () => {
        // Hapus border aktif di tempat lain
        giftItems.forEach(i => i.classList.remove("selected-gift"));
        // Tambahin border aktif ke item yang diklik
        item.classList.add("selected-gift");
        
        // Simpan data
        giftState.selectedAmount = parseInt(item.dataset.amount);
        giftState.selectedImg = item.dataset.img;
        
        // Aktifin tombol
        sendBtn.disabled = false;
        sendBtn.innerText = `Kirim (${giftState.selectedAmount} Koin)`;
      };
    });

    // 4. LOGIKA KIRIM GIFT (TRANSAKSI SUPABASE)
    sendBtn.onclick = async () => {
      if (giftState.selectedAmount <= 0) return;
      if (giftState.selectedAmount > giftState.userCoins) {
        if (window.showNotif) window.showNotif("Koin kamu gak cukup bro! Top up dulu.", "error");
        return;
      }

      sendBtn.disabled = true;
      sendBtn.innerText = "Mengirim...";

      try {
        const db = await getDB();
        const { data: { session } } = await db.auth.getSession();

        // 1. Panggil RPC Database (Prosedur Supabase)
        const { error: rpcErr } = await db.rpc("transfer_coins", { 
          sender_id: session.user.id, 
          receiver_id: giftState.creatorId, 
          amount: giftState.selectedAmount 
        });
        if (rpcErr) throw rpcErr;

        // 2. Catat Transaksi
        await db.from("gift_transactions").insert({ 
          sender_id: session.user.id, 
          receiver_id: giftState.creatorId, 
          post_id: parseInt(giftState.postId), 
          amount: giftState.selectedAmount 
        });

        // 3. Ambil data pengirim & Catat Histori
        const { data: sProf } = await db.from("profiles").select("username").eq("id", session.user.id).single();
        
        await db.from("coin_history").insert({ user_id: session.user.id, type: "keluar", transaction_type: "keluar", amount: giftState.selectedAmount, description: `Kirim gift ke ${giftState.creatorName}` });
        await db.from("coin_history").insert({ user_id: giftState.creatorId, type: "masuk", transaction_type: "masuk", amount: giftState.selectedAmount, description: `Terima gift dari ${sProf?.username || 'Seseorang'}` });

        // 4. Kirim Notifikasi
        await db.from("notifications").insert({ 
          user_id: giftState.creatorId, 
          actor_id: session.user.id, 
          post_id: parseInt(giftState.postId), 
          type: "gift", 
          message: `<b>${sProf?.username}</b> mengirim ${giftState.selectedAmount} koin ke karyamu.` 
        });

        // 5. Update UI Koin Lokal (Biar gak usah refresh halaman)
        giftState.userCoins -= giftState.selectedAmount;
        coinDisplay.innerText = giftState.userCoins;

        // 6. ANIMASI TIKTOK MERIAH & CONFETTI LAZY LOAD!
        if (window.showBigImage) window.showBigImage(giftState.selectedImg);
        
        import('https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/+esm').then((confettiModule) => {
            const confetti = confettiModule.default;
            confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
        });

        closeSheet();
        if (window.showNotif) window.showNotif("Berhasil nyawer kreator!", "success");

      } catch (err) {
        if (window.showNotif) window.showNotif("Gagal mengirim gift: " + err.message, "error");
        sendBtn.disabled = false;
        sendBtn.innerText = `Kirim (${giftState.selectedAmount} Koin)`;
      }
    };
  });
</script>
