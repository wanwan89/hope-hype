---
// Overlayspost.astro
---
<div id="toast"></div>

<div id="bigImageContainer" class="overlay-container">
  <div class="overlay-bg" id="bigImageOverlay"></div>
  <img id="bigImage" src="" class="preview-img" />
</div>

<div id="giftAnimationContainer"></div>

<div id="postOptionsSheet" class="action-sheet-overlay">
  <div class="action-sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-content" id="sheetOptionsContent">
      </div>
    <button class="sheet-cancel" id="closeOptionsBtn">Batal</button>
  </div>
</div>

<style>
  /* =========================================
     CSS SCOPED: SEMUA OVERLAYS
     ========================================= */
  
  /* =========================
     TOAST COMPACT MOBILE FIX
  ========================= */
  #toast {
    position: fixed;
    top: 14px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000000;
    width: calc(100% - 24px);
    max-width: 420px;
    pointer-events: none;
  }

  :global(.toast-card) {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.96);
    color: #1f2937;
    border-radius: 20px;
    padding: 12px 14px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    opacity: 0;
    transform: translateY(-20px) scale(0.96);
    transition: all 0.28s ease;
    pointer-events: auto;
    min-height: 64px;
    border: 1px solid rgba(255, 255, 255, 0.6);
  }
  
  /* Support Dark Mode Biar Ga Silau */
  html.dark :global(.toast-card) { background: rgba(30, 30, 30, 0.96); color: #fff; border-color: rgba(255, 255, 255, 0.1); }
  html.dark :global(.toast-title) { color: #f9fafb; }
  html.dark :global(.toast-subtitle) { color: #d1d5db; }

  :global(.toast-card.show) {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  :global(.toast-icon-wrap) {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  :global(.toast-icon-wrap.success) { background: linear-gradient(135deg, #22c55e, #16a34a); }
  :global(.toast-icon-wrap.warning) { background: linear-gradient(135deg, #f59e0b, #d97706); }
  :global(.toast-icon-wrap.error) { background: linear-gradient(135deg, #ef4444, #dc2626); }
  :global(.toast-icon-wrap.info) { background: linear-gradient(135deg, #3b82f6, #2563eb); }

  :global(.toast-icon) {
    font-size: 22px;
    font-weight: 800;
    line-height: 1;
  }

  :global(.toast-content) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  :global(.toast-title) {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 2px;
    color: #111827;
  }

  :global(.toast-subtitle) {
    font-size: 12px;
    line-height: 1.3;
    color: #6b7280;
    word-break: break-word;
  }

  :global(.toast-close) {
    background: transparent;
    border: none;
    color: #9ca3af;
    font-size: 22px;
    cursor: pointer;
    padding: 0;
    margin-left: 4px;
    line-height: 1;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
  }

  /* Mobile super compact */
  @media (max-width: 480px) {
    #toast { top: 10px; width: calc(100% - 16px); }
    :global(.toast-card) { border-radius: 18px; padding: 10px 12px; gap: 8px; min-height: 56px; }
    :global(.toast-icon-wrap) { width: 38px; height: 38px; }
    :global(.toast-icon) { font-size: 18px; }
    :global(.toast-title) { font-size: 13px; margin-bottom: 1px; }
    :global(.toast-subtitle) { font-size: 11px; line-height: 1.25; }
    :global(.toast-close) { font-size: 18px; width: 20px; height: 20px; }
  }

  /* --- BIG IMAGE --- */
  .overlay-container {
    position: fixed; inset: 0; z-index: 999999; display: none; align-items: center; justify-content: center; padding: 20px;
  }
  .overlay-bg { position: absolute; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(5px); }
  .preview-img { position: relative; max-width: 100%; max-height: 90vh; border-radius: 16px; box-shadow: 0 0 30px rgba(0,0,0,0.5); z-index: 2; transform: scale(0.9); transition: transform 0.3s ease; }

  /* --- ACTION SHEET (TITIK TIGA) --- */
  .action-sheet-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 999999;
    display: flex; flex-direction: column; justify-content: flex-end;
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .action-sheet-overlay.active { opacity: 1; pointer-events: auto; }
  
  .action-sheet {
    background: var(--bg-card); width: 100%; max-width: 500px; margin: 0 auto;
    border-radius: 20px 20px 0 0; padding: 20px;
    transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .action-sheet-overlay.active .action-sheet { transform: translateY(0); }
  
  .sheet-handle { width: 40px; height: 5px; background: var(--border-card); border-radius: 10px; margin: 0 auto 20px; }
  
  :global(.sheet-btn) {
    display: flex; align-items: center; gap: 14px; width: 100%; padding: 16px 12px;
    background: none; border: none; font-size: 15px; font-weight: 600;
    color: var(--text-main); text-align: left; cursor: pointer; border-radius: 12px; transition: 0.2s; font-family: inherit;
  }
  :global(.sheet-btn:hover) { background: var(--bg-input); }
  :global(.sheet-btn.danger) { color: #ef4444; }
  :global(.sheet-btn.danger:hover) { background: rgba(239, 68, 68, 0.1); }
  
  .sheet-cancel {
    width: 100%; padding: 16px; margin-top: 10px; border: none; border-radius: 12px;
    background: var(--bg-input); font-weight: 700; cursor: pointer; font-size: 15px; color: var(--text-muted); font-family: inherit;
  }

  /* --- GIFT ANIMATION --- */
  #giftAnimationContainer { position: fixed; inset: 0; pointer-events: none; z-index: 1000001; display: flex; justify-content: center; align-items: center; }
  :global(.gift-main-img) { width: 280px; filter: drop-shadow(0 0 30px rgba(255,215,0,0.6)); animation: tiktokPopIn 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
  @keyframes tiktokPopIn { 0% { opacity: 0; transform: scale(0.5) rotate(-15deg); } 40% { opacity: 1; transform: scale(1.1) rotate(5deg); } 100% { opacity: 0; transform: scale(1.5) rotate(0deg); } }
</style>

<script>
  // ==========================================
  // JAVASCRIPT GLOBAL (Bisa dipanggil komponen lain)
  // ==========================================

  // 1. FUNGSI TOAST NOTIF (Dengan tombol close baru)
  window.showNotif = function(msg, type = "info") {
    const container = document.getElementById("toast");
    if (!container) return;

    const config = {
      success: { title: "Berhasil", icon: "✓" },
      error: { title: "Gagal", icon: "✕" },
      warning: { title: "Peringatan", icon: "!" },
      info: { title: "Info", icon: "i" }
    };
    const { title, icon } = config[type] || config.info;

    const toastCard = document.createElement("div");
    toastCard.className = "toast-card";
    
    // HTML diperbarui biar tombol x (close) jalan sesuai CSS baru lu
    toastCard.innerHTML = `
      <div class="toast-icon-wrap ${type}">
        <span class="toast-icon">${icon}</span>
      </div>
      <div class="toast-content">
        <div class="toast-title">${title}</div>
        <div class="toast-subtitle">${msg}</div>
      </div>
      <button class="toast-close" onclick="this.parentElement.classList.remove('show'); setTimeout(()=>this.parentElement.remove(), 300)">×</button>
    `;

    container.appendChild(toastCard);
    
    setTimeout(() => toastCard.classList.add("show"), 10);
    
    // Auto-hapus setelah 4 detik
    setTimeout(() => {
      if(toastCard && toastCard.parentElement) {
        toastCard.classList.remove("show");
        setTimeout(() => toastCard.remove(), 300);
      }
    }, 4000);
  };

  // 2. FUNGSI BIG IMAGE
  window.openBigImage = function(src) {
    const container = document.getElementById("bigImageContainer");
    const img = document.getElementById("bigImage");
    img.src = src;
    container.style.display = "flex";
    setTimeout(() => { img.style.transform = "scale(1)"; }, 10);
  };

  document.getElementById("bigImageOverlay")?.addEventListener("click", () => {
    document.getElementById("bigImage").style.transform = "scale(0.9)";
    setTimeout(() => { document.getElementById("bigImageContainer").style.display = "none"; }, 300);
  });

  // 3. FUNGSI ANIMASI GIFT
  window.showBigImage = function(imagePath) {
    const container = document.getElementById("giftAnimationContainer");
    container.innerHTML = `<img src="${imagePath}" class="gift-main-img">`;
    setTimeout(() => { container.innerHTML = ""; }, 2000);
  };

  // 4. FUNGSI ACTION SHEET (TITIK TIGA)
  window.openPostOptions = function(postId, isOwner, creatorId) {
    const sheet = document.getElementById('postOptionsSheet');
    const content = document.getElementById('sheetOptionsContent');
    
    content.innerHTML = `
        <button class="sheet-btn" onclick="window.sharePost('${postId}')">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path><polyline points="16 6 12 2 8 6"></polyline><line x1="12" y1="2" x2="12" y2="15"></line></svg>
            Bagikan Karya
        </button>
        <button class="sheet-btn" onclick="window.location.href='/data?id=${creatorId}'">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="7" r="4"></circle><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path></svg>
            Lihat Profil
        </button>
        ${isOwner ? `
        <button class="sheet-btn danger" onclick="window.confirmDeletePost('${postId}')">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 6h18"></path><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            Hapus Karya
        </button>
        ` : `
        <button class="sheet-btn" onclick="window.showNotif('Karya ini telah dilaporkan ke Admin.', 'info'); window.closePostOptions();">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
            Laporkan
        </button>
        `}
    `;
    
    sheet.classList.add('active');
  };

  window.closePostOptions = function() {
    document.getElementById('postOptionsSheet').classList.remove('active');
  };

  document.getElementById("closeOptionsBtn")?.addEventListener("click", window.closePostOptions);
  document.getElementById("postOptionsSheet")?.addEventListener("click", (e) => {
    if (e.target.id === "postOptionsSheet") window.closePostOptions();
  });

  window.sharePost = function(postId) {
    const url = window.location.origin + '/post?id=' + postId;
    if (navigator.share) {
        navigator.share({ title: 'Hope Hype', text: 'Cek karya keren ini di Hope Hype!', url: url });
    } else {
        navigator.clipboard.writeText(url);
        window.showNotif('Link disalin ke clipboard!', 'success');
    }
    window.closePostOptions();
  };

  window.confirmDeletePost = function(postId) {
    window.closePostOptions();
    setTimeout(async () => {
      if (!confirm("Yakin ingin menghapus karya ini secara permanen?")) return;
      window.showNotif("Sedang menghapus karya...", "info");
      try {
        const { supabase } = await import('../../lib/supabase.js');
        const { error } = await supabase.from("posts").delete().eq("id", postId);
        if (error) throw error;
        window.showNotif("Karya berhasil dihapus!", "success");
        setTimeout(() => location.reload(), 1000);
      } catch (err) {
        window.showNotif("Gagal menghapus: " + err.message, "error");
      }
    }, 300); 
  };
</script>
