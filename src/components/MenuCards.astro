---
---
<div class="job-types">
  <div class="job-card karya-card">
    <div class="job-card-text">
      <a href="/post" class="button" id="artButton">
        <div class="bgContainer">
          <span>Hope</span>
          <span>POST</span>
        </div>
        <div class="arrowContainer">
          <svg width="25" height="25" viewBox="0 0 45 38" fill="none">
            <path d="M43.7678 20.7678C44.7441 19.7915 44.7441 18.2085 43.7678 17.2322L27.8579 1.32233C26.8816 0.34602 25.2986 0.34602 24.3223 1.32233C23.346 2.29864 23.346 3.88155 24.3223 4.85786L38.4645 19L24.3223 33.1421C23.346 34.1184 23.346 35.7014 24.3223 36.6777C25.2986 37.654 26.8816 37.654 27.8579 36.6777L43.7678 20.7678ZM0 21.5L42 21.5V16.5L0 16.5L0 21.5Z" fill="black" />
          </svg>
        </div>
      </a>
    </div>
  </div>

  <div class="job-card music-card">
    <div class="job-card-text">
      <a href="/music" class="button">
        <div class="bgContainer">
          <span>Hope</span>
          <span>SONG</span>
        </div>
        <div class="arrowContainer">
          <svg width="25" height="25" viewBox="0 0 45 38" fill="none">
            <path d="M43.7678 20.7678C44.7441 19.7915 44.7441 18.2085 43.7678 17.2322L27.8579 1.32233C26.8816 0.34602 25.2986 0.34602 24.3223 1.32233C23.346 2.29864 23.346 3.88155 24.3223 4.85786L38.4645 19L24.3223 33.1421C23.346 34.1184 23.346 35.7014 24.3223 36.6777C25.2986 37.654 26.8816 37.654 27.8579 36.6777L43.7678 20.7678ZM0 21.5L42 21.5V16.5L0 16.5L0 21.5Z" fill="black" />
          </svg>
        </div>
      </a>
    </div>
  </div>
</div>

<div class="section-header pro-section-header">
  <button class="coin-mini-header-btn" id="topupKoinBtn">
    <div class="coin-mini-header-left">
      <img src="/asets/svg/koin.svg" alt="Koin" class="coin-mini-header-icon" />
      <span class="coin-mini-header-amount" id="coinAmount">0</span>
    </div>
    <span class="coin-mini-header-plus">+</span>
  </button>

  <button class="button-pro section-pro-btn" id="buyVerified">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24" style="width: 20px; fill: #f09f33;">
      <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
    </svg>
    <span style="color: white; font-weight: bold; font-size: 12px;">PRO</span>
  </button>
</div>

<a href="/chat" class="recent-card zodiac-card" id="hopeTalkBox">
  <div class="logo zodiac-logo" style="display: flex; align-items: center; justify-content: center;">
    <img src="/asets/png/zodiac.png" alt="Zodiac Logo" style="width: 42px; height: 42px; border-radius: 10px; object-fit: cover; display: block;">
  </div>
  <div class="details">
    <h4>hypetalk</h4>
  </div>
  <span id="hopeTalkBadge" class="chat-badge" style="display:none;">0</span>
</a>

<a href="/lobby" class="recent-card sawer-link">
  <div class="logo saweria-logo" style="display: flex; align-items: center; justify-content: center;">
    <img src="/asets/png/saweria.png" alt="Saweria" style="width: 42px; height: 42px; border-radius: 10px; object-fit: cover; display: block;">
  </div>
  <div class="details">
    <h4>Voicehype</h4>
  </div>
</a>

<script>
  // 1. LOGIKA 3D HOVER TILT
  document.querySelectorAll(".job-card, .recent-card").forEach((card) => {
    card.addEventListener("mousemove", (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const rotateX = -(y - rect.height / 2) / 12;
      const rotateY = (x - rect.width / 2) / 12;
      card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    card.addEventListener("mouseleave", () => {
      card.style.transform = "rotateX(0) rotateY(0)";
    });
  });

  // 2. LOGIKA EFEK KLIK TOMBOL KARTU
  const artButton = document.getElementById("artButton");
  const karyaCard = document.querySelector(".job-card.karya-card");
  if (artButton && karyaCard) {
    artButton.addEventListener("click", (e) => {
      e.preventDefault();
      karyaCard.style.setProperty("background-image", "url('/asets/png/art.png')", "important");
      setTimeout(() => (window.location.href = "/post"), 100);
    });
  }

  const songButton = document.querySelector(".music-card .button");
  const musicCard = document.querySelector(".job-card.music-card");
  if (songButton && musicCard) {
    songButton.addEventListener("click", (e) => {
      e.preventDefault();
      musicCard.style.setProperty("background-image", "url('/asets/png/song.png')", "important");
      setTimeout(() => (window.location.href = "/music"), 100);
    });
  }

  // 3. LOGIKA BUKA BOTTOM SHEET (PRO & KOIN)
  const buyProBtn = document.getElementById("buyVerified");
  const vipSheet = document.getElementById("vip-bottom-sheet");
  if (buyProBtn) {
    buyProBtn.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      if (vipSheet) {
        vipSheet.style.display = "flex";
        setTimeout(() => vipSheet.classList.add("active"), 10);
      }
    });
  }

  const koinBtn = document.getElementById("topupKoinBtn");
  const coinSheet = document.getElementById("coin-bottom-sheet");
  if (koinBtn) {
    koinBtn.addEventListener("click", (e) => {
      e.preventDefault(); e.stopPropagation();
      if (coinSheet) {
        coinSheet.style.display = "flex";
        setTimeout(() => coinSheet.classList.add("active"), 10);
      }
    });
  }
</script>
