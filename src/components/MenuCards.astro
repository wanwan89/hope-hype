---
---
<div class="job-types">
  <div class="job-card karya-card">
    <div class="job-card-text">
      <a href="/post" class="button" id="artButton" aria-label="Buka halaman Hope Post">
        <div class="bgContainer">
          <span>Hope</span>
          <span>POST</span>
        </div>
        <div class="arrowContainer">
          <svg width="25" height="25" viewBox="0 0 45 38" fill="none">
            <path d="M43.7678 20.7678C44.7441 19.7915 44.7441 18.2085 43.7678 17.2322L27.8579 1.32233C26.8816 0.34602 25.2986 0.34602 24.3223 1.32233C23.346 2.29864 23.346 3.88155 24.3223 4.85786L38.4645 19L24.3223 33.1421C23.346 34.1184 23.346 35.7014 24.3223 36.6777C25.2986 37.654 26.8816 37.654 27.8579 36.6777L43.7678 20.7678ZM0 21.5L42 21.5V16.5L0 16.5L0 21.5Z" fill="black" />
          </svg>
        </div>
      </a>
    </div>
  </div>

  <div class="job-card music-card">
    <div class="job-card-text">
      <a href="/music" class="button" aria-label="Buka halaman Hope Song">
        <div class="bgContainer">
          <span>Hope</span>
          <span>SONG</span>
        </div>
        <div class="arrowContainer">
          <svg width="25" height="25" viewBox="0 0 45 38" fill="none">
            <path d="M43.7678 20.7678C44.7441 19.7915 44.7441 18.2085 43.7678 17.2322L27.8579 1.32233C26.8816 0.34602 25.2986 0.34602 24.3223 1.32233C23.346 2.29864 23.346 3.88155 24.3223 4.85786L38.4645 19L24.3223 33.1421C23.346 34.1184 23.346 35.7014 24.3223 36.6777C25.2986 37.654 26.8816 37.654 27.8579 36.6777L43.7678 20.7678ZM0 21.5L42 21.5V16.5L0 16.5L0 21.5Z" fill="black" />
          </svg>
        </div>
      </a>
    </div>
  </div>
</div>

<div class="section-header pro-section-header">
  <button class="coin-mini-header-btn" id="topupKoinBtn" aria-label="Buka menu Topup Koin">
    <div class="coin-mini-header-left">
      <img src="/asets/svg/koin.webp" alt="Ikon Koin" class="coin-mini-header-icon" loading="eager" width="16" height="16" />
      <span class="coin-mini-header-amount" id="coinAmount">0</span>
    </div>
    <span class="coin-mini-header-plus">+</span>
  </button>

  <button class="button-pro section-pro-btn" id="buyVerified" aria-label="Buka menu aktivasi akun PRO">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 36 24" style="width: 20px; fill: #f09f33;" aria-hidden="true">
      <path d="m18 0 8 12 10-8-4 20H4L0 4l10 8 8-12z"></path>
    </svg>
    <span style="color: white; font-weight: bold; font-size: 12px;">PRO</span>
  </button>
</div>

<a href="/hypetalk" class="recent-card zodiac-card" id="hopeTalkBox">
  <div class="logo zodiac-logo" style="display: flex; align-items: center; justify-content: center;">
    <img src="/asets/png/zodiac.webp" alt="Zodiac Logo" loading="lazy" decoding="async" style="width: 42px; height: 42px; border-radius: 10px; object-fit: cover; display: block;">
  </div>
  <div class="details">
    <h2>Talkhype</h2>
  </div>
  <span id="hopeTalkBadge" class="chat-badge" style="display:none;">0</span>
</a>

<a href="/lobby" class="recent-card sawer-link">
  <div class="logo saweria-logo" style="display: flex; align-items: center; justify-content: center;">
    <img src="/asets/png/saweria.webp" alt="Saweria" loading="lazy" decoding="async" style="width: 42px; height: 42px; border-radius: 10px; object-fit: cover; display: block;">
  </div>
  <div class="details">
    <h2>Voicehype</h2>
  </div>
</a>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    
    // 1. LOGIKA 3D HOVER TILT
    document.querySelectorAll(".job-card, .recent-card").forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const rotateX = -(y - rect.height / 2) / 12;
        const rotateY = (x - rect.width / 2) / 12;
        card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      });
      card.addEventListener("mouseleave", () => {
        card.style.transform = "rotateX(0) rotateY(0)";
      });
    });

    // 2. LOGIKA EFEK KLIK TOMBOL KARTU
    const artButton = document.getElementById("artButton");
    const karyaCard = document.querySelector(".job-card.karya-card");
    if (artButton && karyaCard) {
      artButton.addEventListener("click", (e) => {
        e.preventDefault();
        karyaCard.style.setProperty("background-image", "url('/asets/png/art.webp')", "important");
        setTimeout(() => (window.location.href = "/post"), 100);
      });
    }

    const songButton = document.querySelector(".music-card .button");
    const musicCard = document.querySelector(".job-card.music-card");
    if (songButton && musicCard) {
      songButton.addEventListener("click", (e) => {
        e.preventDefault();
        musicCard.style.setProperty("background-image", "url('/asets/png/song.webp')", "important");
        setTimeout(() => (window.location.href = "/music"), 100);
      });
    }

    // 3. LOGIKA BUKA BOTTOM SHEET (PRO & KOIN)
    const buyProBtn = document.getElementById("buyVerified");
    if (buyProBtn) {
      buyProBtn.addEventListener("click", (e) => {
        e.preventDefault(); e.stopPropagation();
        const vipSheet = document.getElementById("vip-bottom-sheet");
        if (vipSheet) {
          vipSheet.style.display = "flex";
          setTimeout(() => vipSheet.classList.add("active"), 10);
        }
      });
    }

    const koinBtn = document.getElementById("topupKoinBtn");
    if (koinBtn) {
      koinBtn.addEventListener("click", (e) => {
        e.preventDefault(); e.stopPropagation();
        const coinSheet = document.getElementById("coin-bottom-sheet");
        if (coinSheet) {
          coinSheet.style.display = "flex";
          setTimeout(() => coinSheet.classList.add("active"), 10);
        }
      });
    }

    // 4. LOGIKA BADGE HYPETALK (REAL DATA FETCH)
    function updateChatBadge(unreadCount) {
      const badge = document.getElementById("hopeTalkBadge");
      if (badge) {
        if (unreadCount > 0) {
          badge.textContent = unreadCount > 99 ? '99+' : unreadCount;
          badge.style.display = "flex"; 
        } else {
          badge.style.display = "none"; 
        }
      }
    }

        async function fetchUnreadChats() {
      try {
        // Sesuaikan URL endpoint ini dengan backend kamu
        const response = await fetch('/api/get-unread'); 
        
        if (!response.ok) throw new Error('Gagal menarik data');
        
        const data = await response.json();
        
        // 👇 KITA INTIP DATANYA DI SINI YAAAH SAYANGKUUU 👇
        console.log("💌 Data chat dari backend cintakuuu:", data);
        
        // Sesuaikan key json-nya, di sini aku asumsikan pake "unread_count"
        if (data && typeof data.unread_count === 'number') {
          updateChatBadge(data.unread_count);
        }
      } catch (error) {
        console.error("Gagal load badge chat:", error);
      }
    }

    // Panggil saat halaman pertama kali diload
    fetchUnreadChats();

    // Auto-update badge setiap 10 detik
    setInterval(fetchUnreadChats, 10000); 
});
</script>

<style is:global>
/* ========================================= */
/* KARTU POST & SONG (KARYA & MUSIC)         */
/* ========================================= */
.job-types { 
  display: flex; 
  gap: 16px; 
  margin-bottom: 20px; 
}

.job-card { 
  flex: 1; 
  border-radius: 18px; 
  border: 2px solid #000; 
  box-shadow: 5px 5px 0px #00000030; 
  cursor: pointer; 
  /* 1. Tambahin 'will-change' biar GPU HP fokus nge-render animasinya */
  will-change: transform; 
  transition: transform 0.2s ease, box-shadow 0.4s ease; 
  display: flex; 
  flex-direction: column; 
  align-items: center; 
  justify-content: center; 
  padding: 18px; 
  position: relative; 
  overflow: hidden; 
  height: 220px; 
  min-height: 210px; 
  /* 2. Tambahin background-repeat biar makin aman pas render */
  background-repeat: no-repeat;
  background-size: cover; 
  background-position: center; 
  background-color: transparent !important; 
  /* 3. Ilangin highlight biru pas diklik di HP (UX Fix) */
  -webkit-tap-highlight-color: transparent;
}

.job-card:hover { transform: translateY(-6px); }
.job-card:active { transform: translateY(2px); box-shadow: 2px 2px 0px #00000030; }

.job-card::before, 
.job-card::after,
.karya-card::before, 
.music-card::before { 
  display: none !important;
  content: none !important;
}

/* ========================================= */
/* TOMBOL ANIMASI DALAM KARTU                */
/* ========================================= */
.job-card .button { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); }

.button { display: flex; justify-content: space-between; align-items: center; padding: 6px 8px 6px 10px; margin-top: 8px; background-color: #2d8cf0; border: 2px solid #000; border-radius: 10px; box-shadow: 3px 4px 0px black; cursor: pointer; position: relative; overflow: hidden; z-index: 10; transition: all 0.25s ease; }
.button:hover { transform: translate(2px, 2px) translateX(-50%); box-shadow: 1px 2px 0px black; }
.button:active { filter: saturate(0.8); }
.button::after { content: ""; position: absolute; inset: 0; background-color: white; transform: translateX(-100%); transition: transform 0.3s ease; z-index: -1; }
.button:hover::after { transform: translateX(0); }
.button span { color: black !important; }
.bgContainer { display: flex; align-items: center; overflow: hidden; font-size: 13px; font-weight: 700; max-width: 100%; gap: 5px; }
.bgContainer span { transform: translateX(-100%); transition: transform 0.3s ease; }
.button:hover .bgContainer span { transform: translateX(0); }
.arrowContainer { width: 22px; height: 22px; margin-left: 6px; display: flex; align-items: center; justify-content: center; border: 2px solid #000; border-radius: 50%; background-color: white; position: relative; overflow: hidden; transition: transform 0.25s ease; }
.arrowContainer::after { content: ""; position: absolute; inset: 0; background-color: #2d8cf0; transform: translateX(-100%); transition: transform 0.3s ease; z-index: -1; }
.button:hover .arrowContainer::after { transform: translateX(0); }
.button:hover .arrowContainer { transform: translateX(4px); }
.arrowContainer svg { width: 12px; height: 12px; }

/* ========================================= */
/* KARTU RECENT (TALKHYPE DLL)               */
/* ========================================= */
.section-header { display: flex; justify-content: space-between; margin-bottom: 12px; transition: background-color 0.4s ease, color 0.4s ease, box-shadow 0.4s ease; }
.section-header h3 { color: #1a1a1a; transition: color 0.4s ease; }
body.dark .section-header h3 { color: #ffffff; }

.recent-card { 
  display: flex; 
  align-items: center; 
  gap: 12px; 
  background: #fff; 
  padding: 14px; 
  border-radius: 18px; 
  border: 2px solid #000; 
  box-shadow: 5px 5px 0px #00000030; 
  cursor: pointer; 
  /* 1. Tambahin 'will-change' buat akselerasi GPU saat hover/tilt */
  will-change: transform, background-color; 
  transition: background-color 0.4s ease, transform 0.2s ease, box-shadow 0.4s ease !important; 
  position: relative; 
  overflow: hidden; 
  margin-bottom: 14px; 
  /* 2. Ilangin highlight biru pas diketuk di HP */
  -webkit-tap-highlight-color: transparent;
  /* 3. Mencegah teks terpilih gak sengaja pas lagi asik ngetuk-ngetuk */
  user-select: none;
}

.recent-card:hover { transform: translateY(-4px); }
body.dark .recent-card { background: #3a3f63; border: 2px solid #000; box-shadow: 5px 5px 0px #00000030; }

.logo { width: 42px; height: 42px; border-radius: 10px; }

/* FIX CSS: Ganti target dari h4 ke h2 biar style-nya tetep sama */
.details h2 { font-size: 15px; transition: color 0.4s ease; color: #1a1a1a; margin: 0; }
body.dark .recent-card .details h2 { color: #ffffff !important; }

/* LOGO CUSTOM */
.sawer-link, .zodiac-card { text-decoration: none; color: inherit; display: flex; }
.saweria-logo, .zodiac-logo { display: flex; align-items: center; justify-content: center; border-radius: 12px; overflow: hidden; }
.saweria-logo { background: #ffffff; }
.saweria-logo img, .zodiac-logo img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
.sawer-link:hover .saweria-logo img { transform: scale(1.1); }

/* BADGE */
#hopeTalkBox { position: relative; }
.chat-badge { background-color: #ff3b30; color: white; font-size: 12px; font-weight: bold; min-width: 22px; height: 22px; border-radius: 50%; display: flex; justify-content: center; align-items: center; position: absolute; right: 20px; top: 50%; transform: translateY(-50%); padding: 0 5px; box-sizing: border-box; }

/* ========================================= */
/* MINI HEADER PRO & KOIN                    */
/* ========================================= */
.pro-section-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.coin-mini-header-btn { display: flex; align-items: center; justify-content: space-between; gap: 6px; width: 92px; height: 34px; padding: 0 8px; border: none; border-radius: 12px; background: #1f1f1f; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.16); cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; flex-shrink: 0; }
.coin-mini-header-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 14px rgba(0, 0, 0, 0.22); }
.coin-mini-header-left { display: flex; align-items: center; gap: 4px; }
.coin-mini-header-icon { width: 16px; height: 16px; object-fit: contain; }
.coin-mini-header-amount { font-size: 11px; font-weight: 700; color: #fff; line-height: 1; }
.coin-mini-header-plus { width: 16px; height: 16px; border-radius: 50%; background: #f7b500; color: #111; font-size: 13px; font-weight: 700; line-height: 16px; text-align: center; flex-shrink: 0; }

.button-pro { all: unset; display: flex; align-items: center; padding: 0 12px; gap: 6px; height: 34px; background-color: #1e1e1e; border: 1px solid transparent; border-radius: 8px; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 10px rgba(0, 0, 0, 0.4); }
.button-pro:hover { background-color: #2c2c2c; border-color: #F3A135; transform: translateY(-2px); }
.button-pro span { color: white; font-weight: bold; font-size: 11px; letter-spacing: 0.5px; }
.button-pro svg { width: 18px; fill: #f09f33; }
</style>
