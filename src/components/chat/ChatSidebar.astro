---
// src/components/chat/ChatSidebar.astro
---

<div id="sidebar" class="sidebar">
  <div class="sidebar-profile">
    <img id="side-avatar" src="/asets/png/profile.webp" class="profile-avatar" alt="Avatar" />
    <div class="profile-info">
      <div id="side-username" class="profile-name">Loading...</div>
      
      <div onclick="window.copyMyID()" class="id-badge" title="Klik untuk salin">
        ID: <span id="my-unique-id" class="id-text">#-----</span>
      </div>
      
      <button onclick="window.openEditProfile()" class="edit-bio-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
        Edit Biodata
      </button>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="search-input-wrapper">
      <span class="at-icon">@</span>
      <input type="text" id="input-search-id" placeholder="Cari ID teman..." autocomplete="off" />
    </div>
    <button id="btn-search-id" class="btn-main">
      CARI & CHAT
    </button>
  </div>

  <div class="sidebar-section border-bottom">
    <button id="btn-open-group-modal" class="btn-group">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      BUAT GRUP BARU
    </button>
  </div>

  <div class="history-label">Riwayat Chat</div>
  <div class="chat-list-container custom-scrollbar">
    <div id="private-chat-list">
      <div class="empty-chat-state">Memuat chat...</div>
    </div>
  </div>

  <div class="sidebar-footer">
    <button class="btn-cari-doi" id="btn-sidebar-search" onclick="window.mulaiCariDoi()">
      <div class="inner-content">
        <svg class="heart-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <span>CARI DOI SEKARANG</span>
      </div>
      <div class="glow-effect"></div>
    </button>
  </div>
</div>

<div id="sidebar-overlay" class="sidebar-overlay"></div>

<style>
  .sidebar {
    position: fixed; top: 0; left: -280px;
    width: 280px; height: 100%;
    background: var(--bg-sidebar) !important;
    z-index: 2000;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
    display: flex; flex-direction: column;
  }
  .sidebar.open { left: 0; }

  .sidebar-overlay {
    position: fixed; inset: 0;
    background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(2px);
    display: none; z-index: 1999;
  }
  .sidebar-overlay.show { display: block; }

  /* Header Profile */
  .sidebar-profile {
    padding: 30px 20px; background: var(--bg-header);
    color: white; display: flex; flex-direction: column; align-items: center; text-align: center;
  }
  .profile-avatar {
    width: 80px; height: 80px; border-radius: 50%;
    border: 3px solid rgba(255,255,255,0.2); object-fit: cover; margin-bottom: 12px;
  }
  .profile-name { font-weight: 700; font-size: 17px; }
  .id-badge {
    font-size: 11px; background: rgba(0,0,0,0.2); padding: 4px 12px;
    border-radius: 20px; cursor: pointer; margin: 8px 0;
  }
  .edit-bio-btn {
    font-size: 11px; color: #fff; background: rgba(255,255,255,0.1);
    padding: 6px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.2);
    cursor: pointer; display: flex; align-items: center; gap: 6px;
  }

  /* Search Section */
  .sidebar-section { padding: 15px; }
  .search-input-wrapper {
    display: flex; align-items: center; padding: 10px 15px;
    background: var(--bg-input-field); border-radius: 12px; border: 1px solid var(--border-color);
  }
  .at-icon { color: #3a7bd5; font-weight: 800; margin-right: 10px; }
  .search-input-wrapper input { border: none; background: transparent; outline: none; width: 100%; color: var(--text-main); }
  
  .btn-main {
    width: 100%; margin-top: 8px; padding: 10px; border: none;
    background: #3a7bd5; color: white; border-radius: 10px; font-weight: 700; cursor: pointer;
  }

  .btn-group {
    width: 100%; padding: 12px; background: transparent; color: #3a7bd5;
    border: 2px dashed #3a7bd5; border-radius: 10px; font-weight: 700; cursor: pointer;
  }

  /* History List */
  .history-label { padding: 15px 15px 5px; font-size: 10px; font-weight: 800; color: var(--text-muted); text-transform: uppercase; }
  .chat-list-container { flex: 1; overflow-y: auto; }
  
  :global(.sidebar-chat-item) {
    display: flex; align-items: center; gap: 12px; padding: 12px 15px;
    border-bottom: 1px solid var(--border-color); cursor: pointer; transition: 0.2s;
  }
  :global(.sidebar-chat-item:hover) { background: var(--bg-input-field); }
  :global(.sidebar-chat-item img) { width: 45px; height: 45px; border-radius: 50%; object-fit: cover; }
  :global(.sidebar-chat-item strong) { font-size: 14px; color: var(--text-main); display: block; }
  :global(.sidebar-chat-item p) { font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin: 0; }

  /* Footer */
  .sidebar-footer { padding: 15px; border-top: 1px solid var(--border-color); }
  .btn-cari-doi {
    width: 100%; border: none; border-radius: 50px; padding: 15px;
    background: linear-gradient(135deg, #ff4e50, #f9d423); color: white;
    font-weight: 800; cursor: pointer; position: relative; overflow: hidden;
  }

  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
</style>

<script is:inline>
  // Logika Refresh Sidebar
  window.refreshSidebar = async function() {
    const list = document.getElementById("private-chat-list");
    if (!list || !window.currentUser) return;

    try {
      const { data: messages } = await window.supabase
        .from("messages")
        .select("room_id, message, created_at, user_id, sticker_url")
        .ilike("room_id", "pv_%")
        .ilike("room_id", `%${window.currentUser.id}%`)
        .order("created_at", { ascending: false });
      
      list.innerHTML = ""; // Bersihkan
      
      // Tombol Chat Global selalu ada di atas
      list.insertAdjacentHTML('beforeend', `
        <div class="sidebar-chat-item" onclick="window.bukaChatGlobal()">
          <div style="width:45px; height:45px; border-radius:50%; background:#3a7bd5; display:flex; align-items:center; justify-content:center; color:white; font-size:20px;">🌍</div>
          <div style="flex:1;"><strong>Chat Global</strong><p>Obrolan umum HopeTalk</p></div>
        </div>
      `);

      if (messages && messages.length > 0) {
        const uniqueRooms = [...new Set(messages.map(m => m.room_id))];
        for (const roomId of uniqueRooms) {
          const partnerId = roomId.replace("pv_", "").split("_").find(id => id !== window.currentUser.id);
          const partner = await window.getCachedProfile(partnerId);
          const lastMsg = messages.find(m => m.room_id === roomId);
          const displayMsg = lastMsg.sticker_url ? "🖼 Stiker" : lastMsg.message;

          list.insertAdjacentHTML('beforeend', `
            <div class="sidebar-chat-item" onclick="window.bukaChatPribadi('${partnerId}', '${partner.username}', '${partner.short_id}')">
              <img src="${partner.avatar_url || '/asets/png/profile.webp'}" onerror="this.src='/asets/png/profile.webp'">
              <div style="flex:1; overflow:hidden;">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                  <strong>${partner.username}</strong>
                  <span style="font-size:10px; color:#999;">${window.formatTime(lastMsg.created_at)}</span>
                </div>
                <p>${displayMsg}</p>
              </div>
            </div>
          `);
        }
      } else {
        list.insertAdjacentHTML('beforeend', `<div class="empty-chat-state">Belum ada riwayat chat</div>`);
      }
    } catch (e) { console.error(e); }
  };

  // Salin ID
  window.copyMyID = () => {
    const idText = document.getElementById('my-unique-id').innerText;
    navigator.clipboard.writeText(idText);
    window.showToast("ID disalin ke clipboard!");
  };

  // Tutup Sidebar & Overlay
  const closeSidebarUI = () => {
    document.getElementById("sidebar").classList.remove("open");
    document.getElementById("sidebar-overlay").classList.remove("show");
  };

  // Navigasi PV
  window.bukaChatPribadi = async function(id, name, shortId) {
    const ids = [window.currentUser.id, id].sort();
    window.currentRoomId = `pv_${ids[0]}_${ids[1]}`;
    
    if (window.setChatHeaderTitle) window.setChatHeaderTitle(name, `#${shortId}`);
    
    const btnCall = document.getElementById("btn-start-call");
    if (btnCall) {
      btnCall.style.display = "flex";
      btnCall.dataset.targetId = id;
      btnCall.dataset.targetName = name;
    }
    
    document.getElementById("chat-messages").innerHTML = "";
    window.isFirstMessageLoad = true;
    await window.loadMessages();
    closeSidebarUI();
  };

  // Event pencarian ID manual
  document.getElementById("btn-search-id").onclick = async () => {
    const val = document.getElementById("input-search-id").value.trim().toUpperCase().replace("#", "");
    if (!val) return window.showToast("Masukkan ID!");
    
    const { data: user } = await window.supabase.from("profiles").select("id, username, short_id").eq("short_id", val).single();
    if (user) {
      if (user.id === window.currentUser.id) return window.showToast("Itu ID kamu sendiri!");
      window.bukaChatPribadi(user.id, user.username, user.short_id);
    } else {
      window.showToast("ID tidak ditemukan!");
    }
  };
</script>
