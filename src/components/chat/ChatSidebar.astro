---
// src/components/chat/ChatSidebar.astro
---

<div id="sidebar" class="sidebar">
  <div class="sidebar-profile">
    <img id="side-avatar" src="/asets/png/profile.webp" class="profile-avatar" alt="Avatar" />
    <div class="profile-info">
      <div id="side-username" class="profile-name">Loading...</div>
      
      <div onclick="navigator.clipboard.writeText(document.getElementById('my-unique-id').innerText); alert('ID Unik disalin!')" class="id-badge" title="Klik untuk salin">
        ID UNIK: <span id="my-unique-id" class="id-text">#-----</span>
      </div>
      
      <button onclick="window.openEditProfile()" class="edit-bio-btn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
        Edit Biodata
      </button>
      
      <div class="status-indicator">
        <span class="online-dot"></span> Online
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="search-input-wrapper">
      <span class="at-icon">@</span>
      <input type="text" id="input-search-id" placeholder="Cari ID teman..." autocomplete="off" />
    </div>
    <button id="btn-search-id" class="btn-main">
      CARI & CHAT
    </button>
  </div>

  <div class="sidebar-section border-bottom">
    <button id="btn-open-group-modal" class="btn-group">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
      BUAT GRUP BARU
    </button>
  </div>

  <div class="history-label">
    Riwayat Chat Pribadi
  </div>

  <div class="chat-list-container">
    <div id="private-chat-list">
      <div class="empty-chat-state">Memuat chat...</div>
    </div>
  </div>

  <div class="sidebar-footer">
    <button class="btn-cari-doi" id="btn-sidebar-search" onclick="window.mulaiCariDoi()">
      <div class="inner-content">
        <svg class="heart-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <span>CARI DOI SEKARANG</span>
      </div>
      <div class="glow-effect"></div>
    </button>
  </div>
</div>

<div id="sidebar-overlay" class="sidebar-overlay"></div>

<style>
  /* --- LAYOUT UTAMA --- */
  .sidebar {
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    height: 100%;
    background: var(--bg-sidebar) !important;
    color: var(--text-main);
    z-index: 2000;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Transisi lebih smooth */
    box-shadow: 2px 0 15px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    will-change: left;
  }
  .sidebar.open { left: 0; }

  /* --- OVERLAY --- */
  .sidebar-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(2px);
    display: none; z-index: 1999;
    opacity: 0; transition: opacity 0.3s ease;
  }
  .sidebar-overlay.show { display: block; opacity: 1; }

  /* --- HEADER PROFIL --- */
  .sidebar-profile {
    padding: 30px 20px 20px;
    background: var(--bg-header);
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .profile-avatar {
    width: 75px; height: 75px;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,0.3);
    object-fit: cover;
    background: #eee;
    box-shadow: 0 4px 8px rgba(0,0,0,0.15);
  }
  .profile-info { text-align: center; width: 100%; }
  .profile-name { font-weight: 700; font-size: 16px; margin-bottom: 4px; letter-spacing: 0.3px; }
  
  .id-badge {
    font-size: 10px; background: rgba(0,0,0,0.25);
    padding: 4px 12px; border-radius: 12px;
    cursor: pointer; display: inline-block;
    margin-bottom: 6px; transition: background 0.2s;
  }
  .id-badge:hover { background: rgba(0,0,0,0.4); }
  .id-badge:active { transform: scale(0.95); }
  .id-text { font-weight: 700; letter-spacing: 0.5px; }

  .edit-bio-btn {
    font-size: 11px; color: #fff; background: rgba(255,255,255,0.15);
    padding: 6px 16px; border-radius: 20px;
    display: flex; align-items: center; justify-content: center; gap: 6px;
    border: 1px solid rgba(255,255,255,0.3);
    font-weight: 600; cursor: pointer; margin: 0 auto;
    transition: all 0.2s ease;
  }
  .edit-bio-btn:hover { background: rgba(255,255,255,0.25); }
  .edit-bio-btn:active { transform: scale(0.95); }

  .status-indicator { font-size: 10px; opacity: 0.9; margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 4px; }
  .online-dot { height: 8px; width: 8px; background-color: #2ecc71; border-radius: 50%; box-shadow: 0 0 5px #2ecc71; animation: pulse-dot 1.5s infinite; }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* --- SECTION (SEARCH & GROUP) --- */
  .sidebar-section { padding: 15px; background: var(--bg-sidebar); flex-shrink: 0; }
  .border-bottom { border-bottom: 1px solid var(--border-color); padding-top: 5px; }

  .search-input-wrapper {
    display: flex; align-items: center;
    background: var(--bg-input-field);
    border-radius: 15px; padding: 10px 15px;
    border: 1px solid var(--border-color);
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .search-input-wrapper:focus-within {
    border-color: #3a7bd5;
    box-shadow: 0 0 0 2px rgba(58, 123, 213, 0.2);
  }
  .at-icon { color: #3a7bd5; font-weight: bold; margin-right: 8px; }
  .search-input-wrapper input {
    border: none; background: transparent; outline: none;
    font-size: 13px; width: 100%; color: var(--text-main); font-family: inherit;
  }

  .btn-main {
    width: 100%; margin-top: 10px; border: none;
    background: #3a7bd5; color: white;
    border-radius: 12px; padding: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.5px;
    cursor: pointer; transition: 0.2s ease;
  }
  .btn-main:hover { background: #2f65b0; }
  .btn-main:active { transform: scale(0.97); }

  .btn-group {
    width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;
    border: 2px dashed #3a7bd5; background: transparent;
    color: #3a7bd5; border-radius: 12px; padding: 12px;
    font-size: 12px; font-weight: 700; cursor: pointer; transition: 0.2s ease;
  }
  .btn-group:hover { background: rgba(58, 123, 213, 0.05); }
  .btn-group:active { transform: scale(0.97); }

  /* --- LIST CHAT AREA --- */
  .history-label {
    padding: 12px 15px 8px;
    background: var(--bg-sidebar);
    color: var(--text-muted);
    font-size: 10px; font-weight: 800;
    text-transform: uppercase; letter-spacing: 1px;
  }

  .chat-list-container {
    flex: 1; overflow-y: auto; overflow-x: hidden;
    background: var(--bg-sidebar) !important;
  }
  
  /* Custom Scrollbar */
  .chat-list-container::-webkit-scrollbar { width: 4px; }
  .chat-list-container::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 4px; }

  #private-chat-list { background: var(--bg-sidebar) !important; min-height: 100%; }
  .empty-chat-state { text-align: center; font-size: 12px; color: var(--text-muted); margin-top: 30px; font-style: italic; }

  /* --- FOOTER CARI DOI --- */
  .sidebar-footer {
    padding: 15px; border-top: 1px solid var(--border-color);
    background: var(--bg-sidebar); flex-shrink: 0;
  }

  .btn-cari-doi {
    position: relative; width: 100%; border: none; border-radius: 50px;
    background: linear-gradient(135deg, #ff4e50, #f9d423); color: white;
    padding: 16px 20px; font-weight: 800; font-size: 12px; letter-spacing: 0.5px;
    cursor: pointer; overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s;
    box-shadow: 0 8px 15px rgba(255, 78, 80, 0.25);
  }
  .btn-cari-doi:hover { transform: translateY(-2px); box-shadow: 0 12px 20px rgba(255, 78, 80, 0.35); filter: brightness(1.05); }
  .btn-cari-doi:active { transform: translateY(1px); box-shadow: 0 5px 10px rgba(255, 78, 80, 0.2); }

  .inner-content { display: flex; align-items: center; justify-content: center; gap: 8px; z-index: 2; position: relative; }
  .heart-icon { animation: heartBeat 1.5s infinite; }

  @keyframes heartBeat {
    0%, 20%, 40%, 100% { transform: scale(1); }
    10% { transform: scale(1.25); }
    30% { transform: scale(1.15); }
  }

  .glow-effect {
    position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    z-index: 1; transform: skewX(-20deg);
  }
  .btn-cari-doi:hover .glow-effect { left: 150%; transition: 0.7s; }

  /* --- CHAT ITEMS (Dibuat oleh JS) --- */
  :global(.sidebar-chat-item) { 
    background: var(--bg-sidebar) !important;
    border-bottom: 1px solid var(--border-color) !important; 
    color: var(--text-main) !important;
    padding: 12px 15px !important;
    display: flex; align-items: center; gap: 12px;
    transition: background 0.2s ease;
  }
  :global(.sidebar-chat-item:hover) { background-color: var(--bg-input-field) !important; cursor: pointer; }
  :global(.sidebar-chat-item:active) { background-color: var(--border-color) !important; }
  :global(.sidebar-chat-item strong) { color: var(--text-main) !important; font-size: 14px; font-weight: 600; }
  :global(.sidebar-chat-item span) { color: var(--text-muted) !important; font-size: 12px; }
  
  /* Hilangkan outline saat input difokuskan browser HP */
  input:focus, button:focus { outline: none; }
</style>
