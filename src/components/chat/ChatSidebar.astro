---
// src/components/chat/ChatSidebar.astro
---

<div id="sidebar" class="sidebar">
  <div style="padding: 30px 20px; background: #3a7bd5; color: white; display: flex; flex-direction: column; align-items: center; gap: 8px;">
    <img id="side-avatar" src="/asets/png/profile.png" style="width: 75px; height: 75px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.3); object-fit: cover; background: #eee;" />
    <div style="text-align: center;">
      <div id="side-username" style="font-weight: 600; font-size: 16px; margin-bottom: 2px;">Loading...</div>
      <div onclick="navigator.clipboard.writeText(document.getElementById('my-unique-id').innerText); alert('ID Unik disalin!')" style="font-size: 10px; background: rgba(0,0,0,0.2); padding: 2px 10px; border-radius: 12px; cursor: pointer; display: inline-block; margin-bottom: 5px;">
        ID UNIK: <span id="my-unique-id" style="font-weight: 700;">#-----</span>
      </div>
      <div onclick="window.openEditProfile()" style="font-size: 11px; color: #fff; cursor: pointer; margin-top: 5px; background: rgba(255,255,255,0.2); padding: 5px 15px; border-radius: 20px; display: flex; align-items: center; gap: 5px; justify-content: center; border: 1px solid rgba(255,255,255,0.3); font-weight: 600;">
        Edit Biodata
      </div>
      <div style="font-size: 10px; opacity: 0.8; display: block; margin-top: 8px;">
        <span class="online-dot" style="width:6px; height:6px; margin-right:3px;"></span> Online
      </div>
    </div>
  </div>

  <div style="padding: 15px; border-bottom: 1px solid #eee; background: #fff;">
    <div style="display: flex; background: #f0f2f5; border-radius: 20px; padding: 8px 15px; align-items: center; border: 1px solid #ddd;">
      <span style="color: #3a7bd5; font-weight: bold; margin-right: 5px;">@</span>
      <input type="text" id="input-search-id" placeholder="Cari ID teman..." style="border: none; background: transparent; outline: none; font-size: 13px; width: 100%;" />
    </div>
    <button id="btn-search-id" style="width: 100%; margin-top: 8px; border: none; background: #3a7bd5; color: white; border-radius: 12px; padding: 8px; font-size: 11px; font-weight: 600; cursor: pointer;">
      CARI & CHAT
    </button>
  </div>

  <div style="padding: 10px 15px; border-bottom: 1px solid #eee;">
    <button id="btn-open-group-modal" style="width: 100%; border: 2px dashed #3a7bd5; background: #f0f7ff; color: #3a7bd5; border-radius: 12px; padding: 10px; font-size: 12px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;">
      BUAT GRUP BARU
    </button>
  </div>

  <div style="flex: 1; overflow-y: auto; background: white;">
    <div id="private-chat-list">
      <p style="text-align:center; font-size:11px; color:#ccc; margin-top:30px;">Memuat chat...</p>
    </div>
  </div>

  <div style="padding: 15px 20px; border-top: 1px solid #f0f0f0; background: #fff; text-align: center;">
    <button class="cta" id="btn-sidebar-search" onclick="window.mulaiCariDoi()" style="width: 100%; background: linear-gradient(135deg, #3a7bd5, #00d2ff); color: white; border: none; border-radius: 25px; padding: 14px 20px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 15px rgba(58, 123, 213, 0.35); transition: transform 0.2s; letter-spacing: 0.5px;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      CARI DOI SEKARANG
    </button>
  </div>
</div>

<div id="sidebar-overlay" class="sidebar-overlay"></div>

<style>
  /* --- CSS Khusus Sidebar --- */
  .sidebar {
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    height: 100%;
    background: white;
    z-index: 10001;
    transition: transform 0.3s ease-out, left 0.3s ease-out;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    will-change: left;
  }

  .sidebar.open { left: 0; }

  .sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: none;
    z-index: 10000;
    backdrop-filter: blur(5px);
  }

  .online-dot {
    height: 8px;
    width: 8px;
    background-color: #2ecc71;
    border-radius: 50%;
    display: inline-block;
    margin-right: 5px;
    box-shadow: 0 0 5px #2ecc71;
    animation: pulse-dot 1.5s infinite;
  }

  @keyframes pulse-dot {
    0% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1); }
  }

  .cta {
    display: flex;
    padding: 8px 20px;
    text-decoration: none;
    font-family: "Poppins", sans-serif;
    font-size: 14px;
    color: white;
    background: #3a7bd5 !important;
    transition: 1s;
    box-shadow: 4px 4px 0 black;
    transform: skewX(-15deg);
    border: none;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    width: 80%;
    margin: 10px auto;
  }
  .cta:focus { outline: none; }
  .cta:hover { transition: 0.5s; box-shadow: 7px 7px 0 #869da6; background: #2a5cb8 !important; }

  /* Style untuk item list chat yang di-generate via JavaScript */
  :global(.sidebar-chat-item:hover) { background-color: #f5f9ff !important; cursor: pointer; }
  :global(.sidebar-chat-item.unread) { background-color: #f0faff; }
  :global(#private-chat-list .unread-badge) { animation: bounce 0.5s ease-in-out; }
  
  @keyframes bounce { 
    0%, 100% { transform: scale(1); } 
    50% { transform: scale(1.2); } 
  }
</style>
