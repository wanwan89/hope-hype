---
// src/components/chat/ChatSidebar.astro
---

<div id="sidebar" class="sidebar">
  <div class="sidebar-profile">
    <img id="side-avatar" src="/asets/png/profile.webp" style="width: 75px; height: 75px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.3); object-fit: cover; background: #eee;" />
    <div style="text-align: center;">
      <div id="side-username" style="font-weight: 600; font-size: 16px; margin-bottom: 2px; color: white;">Loading...</div>
      <div onclick="navigator.clipboard.writeText(document.getElementById('my-unique-id').innerText); alert('ID Unik disalin!')" class="id-badge">
        ID UNIK: <span id="my-unique-id" style="font-weight: 700;">#-----</span>
      </div>
      <div onclick="window.openEditProfile()" class="edit-bio-btn">
        Edit Biodata
      </div>
      <div style="font-size: 10px; opacity: 0.8; display: block; margin-top: 8px; color: white;">
        <span class="online-dot"></span> Online
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="search-input-wrapper">
      <span class="at-icon">@</span>
      <input type="text" id="input-search-id" placeholder="Cari ID teman..." />
    </div>
    <button id="btn-search-id" class="btn-main">
      CARI & CHAT
    </button>
  </div>

  <div class="sidebar-section border-bottom">
    <button id="btn-open-group-modal" class="btn-group">
      BUAT GRUP BARU
    </button>
  </div>

  <div class="history-label">
    RIWAYAT CHAT PRIBADI
  </div>

  <div class="chat-list-container">
    <div id="private-chat-list">
      <p style="text-align:center; font-size:11px; color:#ccc; margin-top:30px;">Memuat chat...</p>
    </div>
  </div>

  <div class="sidebar-footer">
    <button class="btn-cari-doi" id="btn-sidebar-search" onclick="window.mulaiCariDoi()">
      <div class="inner-content">
        <svg class="heart-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
        <span>CARI DOI SEKARANG</span>
      </div>
      <div class="glow-effect"></div>
    </button>
  </div>
</div>

<div id="sidebar-overlay" class="sidebar-overlay"></div>

<style>
  .sidebar {
    position: fixed;
    top: 0;
    left: -280px;
    width: 280px;
    height: 100%;
    background: var(--bg-sidebar) !important;
    color: var(--text-main);
    z-index: 10001;
    transition: transform 0.3s ease-out, left 0.3s ease-out, background 0.3s ease;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    will-change: left;
  }

  .sidebar.open { left: 0; }

  .sidebar-profile {
    padding: 30px 20px;
    background: var(--bg-header);
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* Label Riwayat Chat - Fix Adaptive */
  .history-label {
    padding: 10px 15px;
    background: var(--bg-input-field);
    border-bottom: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: background 0.3s ease;
  }

  .id-badge {
    font-size: 10px;
    background: rgba(0,0,0,0.2);
    padding: 2px 10px;
    border-radius: 12px;
    cursor: pointer;
    display: inline-block;
    margin-bottom: 5px;
    color: white;
  }

  .edit-bio-btn {
    font-size: 11px;
    color: #fff;
    cursor: pointer;
    margin-top: 5px;
    background: rgba(255,255,255,0.2);
    padding: 5px 15px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 5px;
    justify-content: center;
    border: 1px solid rgba(255,255,255,0.3);
    font-weight: 600;
  }

  .sidebar-section {
    padding: 15px;
    background: var(--bg-sidebar);
    flex-shrink: 0;
  }

  .border-bottom { border-bottom: 1px solid var(--border-color); }

  .search-input-wrapper {
    display: flex;
    background: var(--bg-input-field);
    border-radius: 20px;
    padding: 8px 15px;
    align-items: center;
    border: 1px solid var(--border-color);
  }

  .at-icon { color: #3a7bd5; font-weight: bold; margin-right: 5px; }

  .search-input-wrapper input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 13px;
    width: 100%;
    color: var(--text-main);
  }

  .btn-main {
    width: 100%;
    margin-top: 8px;
    border: none;
    background: #3a7bd5;
    color: white;
    border-radius: 12px;
    padding: 8px;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-group {
    width: 100%;
    border: 2px dashed #3a7bd5;
    background: transparent;
    color: #3a7bd5;
    border-radius: 12px;
    padding: 10px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
  }

  .chat-list-container {
    flex: 1;
    overflow-y: auto;
    background: var(--bg-sidebar) !important;
  }

  #private-chat-list {
    background: var(--bg-sidebar) !important;
    min-height: 100%;
  }

  .sidebar-footer {
    padding: 15px 20px;
    border-top: 1px solid var(--border-color);
    background: var(--bg-sidebar);
    text-align: center;
    flex-shrink: 0;
  }

  .sidebar-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: none;
    z-index: 10000;
    backdrop-filter: blur(5px);
  }

  .online-dot {
    height: 8px; width: 8px;
    background-color: #2ecc71;
    border-radius: 50%;
    display: inline-block;
    margin-right: 3px;
    box-shadow: 0 0 5px #2ecc71;
    animation: pulse-dot 1.5s infinite;
  }

  @keyframes pulse-dot {
    0% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1); }
  }

  .btn-cari-doi {
    position: relative;
    width: 100%;
    background: linear-gradient(135deg, #ff4e50, #f9d423);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 16px 20px;
    font-weight: 800;
    font-size: 13px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 20px rgba(255, 78, 80, 0.3);
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
    outline: none;
  }

  .inner-content {
    display: flex; align-items: center; gap: 8px; z-index: 2; position: relative;
  }

  .heart-icon { animation: heartBeat 1.2s infinite; }

  .btn-cari-doi:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px rgba(255, 78, 80, 0.4);
    filter: brightness(1.1);
  }

  .glow-effect {
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    z-index: 1;
  }

  .btn-cari-doi:hover .glow-effect { left: 100%; transition: 0.6s; }

  @keyframes heartBeat {
    0%, 30%, 60% { transform: scale(1); }
    15% { transform: scale(1.3); }
    45% { transform: scale(1.15); }
  }

  /* 🔥 STYLE UNTUK ITEM CHAT DINAMIS 🔥 */
  :global(.sidebar-chat-item) { 
    background: var(--bg-sidebar) !important;
    border-bottom: 1px solid var(--border-color) !important; 
    color: var(--text-main) !important;
    padding: 12px 15px !important;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: background 0.2s ease;
  }

  :global(.sidebar-chat-item:hover) { 
    background-color: var(--bg-input-field) !important; 
    cursor: pointer; 
  }

  :global(.sidebar-chat-item strong) { 
    color: var(--text-main) !important; 
    font-size: 14px;
  }

  :global(.sidebar-chat-item span) { 
    color: var(--text-muted) !important; 
    font-size: 12px;
  }
</style>
