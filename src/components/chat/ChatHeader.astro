<div class="chat-header" style="position: relative; display: flex; align-items: center; justify-content: space-between; padding: 0 15px; background: #3a7bd5; color: white; height: 65px; box-shadow: 0 2px 8px rgba(0,0,0,0.15); overflow: visible;">
  
  <div style="display: flex; align-items: center; gap: 12px; flex: 1; overflow: hidden;">
    
    <!-- ☰ MENU -->
    <div class="hamburger-btn" id="menu-btn" style="cursor: pointer;">
      <div class="hamburger-line"></div>
      <div class="hamburger-line"></div>
      <div class="hamburger-line"></div>
    </div>

    <!-- 🧠 INFO HEADER -->
    <div style="display: flex; flex-direction: column; justify-content: center; overflow: hidden;">

      <!-- APP NAME -->
      <h3 style="margin: 0; font-size: 15px; font-weight: 600;">
        HopeTalk Globe
      </h3>

      <!-- STATUS -->
      <div id="status-container" style="font-size: 10px;">
        <span id="status-header">Online</span>
        <span id="typing-header" style="display:none;"></span>
      </div>

      <!-- 🔥 USER DATA (INI YANG PENTING) -->
      <div style="font-size: 11px; margin-top: 2px; display: flex; gap: 6px;">
        <span id="my-username" style="font-weight: 600;">Loading...</span>
        <span id="my-id" style="opacity: 0.7;">#----</span>
      </div>

    </div>
  </div>

  <!-- RIGHT SIDE -->
  <div style="display: flex; align-items: center; gap: 15px;">
    <img src="/asets/png/music.png" style="width: 28px;">
  </div>

</div>