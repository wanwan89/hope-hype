---
// src/components/chat/ChatInput.astro
---

<div id="sticker-menu" class="sticker-menu-adaptive">
  <div style="display:flex; gap:8px; margin-bottom:10px; padding: 5px;">
    <input type="text" id="sticker-search-input" placeholder="Cari stiker lucu..." class="sticker-search-input" />
    <button id="sticker-search-btn" class="btn-search-stiker">Cari</button>
  </div>
  <div id="sticker-list" class="sticker-list-grid"></div>
</div>

<div id="reply-preview-box" class="reply-preview-adaptive">
  </div>

<div class="chat-input-container-main">
  <div class="input-group-wrapper-adaptive">
    
    <button id="sticker-btn" class="icon-btn-chat">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
        <line x1="9" y1="9" x2="9.01" y2="9"></line>
        <line x1="15" y1="9" x2="15.01" y2="9"></line>
      </svg>
    </button>

    <textarea id="chat-input" placeholder="Tulis pesan..." rows="1"></textarea>

    <div id="vn-overlay" class="vn-overlay-adaptive">
      <div style="display: flex; align-items: center; width: 100%; gap: 12px;">
        <div class="record-dot"></div>
        <span id="vn-timer" class="timer-text">00:00</span>
        <span class="cancel-hint">&laquo; Geser batal</span>
      </div>
    </div>
  </div>

  <button id="action-btn" class="btn-action-send">
    <div class="icon-stack">
      <span class="svg-send">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="svg-mic" style="display: none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="2" width="6" height="11" rx="3" fill="white" />
          <path d="M5 10V11C5 14.866 8.13401 18 12 18C15.866 18 19 14.866 19 11V10" stroke="white" stroke-width="2.5" stroke-linecap="round" />
          <line x1="12" y1="18" x2="12" y2="22" stroke="white" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>
    </div>
  </button>
</div>

<style>
 /* --- LAYOUT ADAPTIVE --- */
  .chat-input-container-main {
    display: flex; 
    align-items: flex-end; 
    gap: 10px; 
    padding: 10px 15px;
    background: var(--bg-input-bar) !important;
    width: 100%; 
    box-sizing: border-box;
    border-top: 1px solid var(--border-color);
    transition: background 0.3s ease;
    /* 🔥 TAMBAHKAN INI 🔥 */
    position: relative;
    z-index: 100; 
    padding-bottom: env(safe-area-inset-bottom, 10px); /* Jaga jarak buat HP berponi bawah */
  }
  
  .input-group-wrapper-adaptive {
    flex: 1; display: flex; align-items: center;
    background: var(--bg-input-field) !important;
    border-radius: 30px; padding: 4px 16px; position: relative;
    min-height: 48px; box-sizing: border-box;
    border: 1px solid var(--border-color);
  }

  #chat-input {
    flex: 1; border: none; outline: none;
    background: transparent !important; resize: none;
    max-height: 100px; padding: 12px 0;
    font-family: 'Poppins', sans-serif; font-size: 14px;
    color: var(--text-main) !important; line-height: 1.4;
  }

  /* --- REPLY PREVIEW --- */
  .reply-preview-adaptive {
    display: none; width: 100%; position: relative;
    background: var(--bg-input-bar) !important;
    border-left: 5px solid #3a7bd5; padding: 10px 15px;
    box-sizing: border-box; align-items: center;
    justify-content: space-between; gap: 12px; z-index: 10;
    border-top: 1px solid var(--border-color);
  }

  :global(.reply-content-wrapper) {
    flex: 1; min-width: 0; overflow: hidden;
    display: flex; flex-direction: column;
    border-left: 3px solid var(--border-color);
    padding-left: 10px;
  }

  :global(.reply-title) { font-size: 13px; color: #3a7bd5 !important; font-weight: 700; margin-bottom: 2px; }
  :global(.reply-text-preview) { font-size: 13px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  :global(.close-reply-btn) { font-size: 22px; color: var(--text-muted); cursor: pointer; padding: 5px; }

  /* --- STICKER MENU --- */
  .sticker-menu-adaptive {
    display: none; flex-direction: column; padding: 10px;
    background: var(--bg-sidebar) !important;
    border-top: 1px solid var(--border-color); height: 250px;
  }

  .sticker-search-input {
    flex: 1; padding: 8px 12px; border-radius: 20px;
    border: 1px solid var(--border-color); outline: none;
    background: var(--bg-input-field); color: var(--text-main); font-size: 14px;
  }

  .btn-search-stiker {
    background: #3a7bd5; color: white; border: none;
    border-radius: 20px; padding: 8px 15px; cursor: pointer; font-weight: 600;
  }

  /* --- VN OVERLAY --- */
  .vn-overlay-adaptive {
    position: absolute; inset: 0;
    background: var(--bg-input-field) !important;
    border-radius: 30px; display: none; align-items: center;
    padding: 0 16px; z-index: 10;
  }

  .record-dot { width: 10px; height: 10px; background: #ff4757; border-radius: 50%; animation: pulse 1s infinite; }
  .timer-text { font-weight: 600; font-size: 14px; color: var(--text-main); }
  .cancel-hint { color: var(--text-muted); font-size: 12px; margin-left: auto; font-style: italic; }

  /* --- BUTTONS --- */
  .icon-btn-chat { background: none; border: none; cursor: pointer; padding: 0; margin-right: 10px; color: var(--text-muted); }

  .btn-action-send {
    width: 48px; height: 48px; border-radius: 50%;
    background: #3a7bd5; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 10px rgba(58, 123, 213, 0.3); transition: 0.3s;
  }

  .btn-action-send:active { transform: scale(0.9); }
  .btn-action-send.is-recording { background: #ff4757 !important; transform: scale(1.1); }

  .icon-stack { position: relative; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
  .svg-send, .svg-mic { position: absolute; }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.7; }
  }
</style>
