---
// File: src/components/chat/ChatInput.astro (atau di file tempat input ini berada)
---
<div class="chat-input-container" 
     style="display: flex; align-items: flex-end; gap: 10px; padding: 12px 16px; background: var(--bg-panel) !important; width: 100%; box-sizing: border-box; border-top: 1px solid rgba(0,0,0,0.03); box-shadow: 0 -4px 20px rgba(0,0,0,0.02); transition: all 0.3s; z-index: 10; -webkit-tap-highlight-color: transparent;">
  
  <div class="input-group-wrapper" 
       style="flex: 1; display: flex; align-items: center; background: var(--label-bg, #f0f2f5) !important; border-radius: 24px; padding: 6px 16px; position: relative; min-height: 46px; box-sizing: border-box; border: 1px solid transparent; transition: all 0.3s;">
    
    <button id="sticker-btn" style="background: none; border: none; cursor: pointer; padding: 0; margin-right: 8px; flex-shrink: 0; display: flex; align-items: center; outline: none; transition: transform 0.2s; -webkit-tap-highlight-color: transparent;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted, #888)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
        <line x1="9" y1="9" x2="9.01" y2="9"></line>
        <line x1="15" y1="9" x2="15.01" y2="9"></line>
      </svg>
    </button>

    <textarea id="chat-input" 
              placeholder="Tulis pesan..." 
              rows="1" 
              style="flex: 1; border: none; outline: none; background: transparent !important; resize: none; max-height: 120px; padding: 10px 0; font-family: inherit; font-size: 14.5px; color: var(--text-color); line-height: 1.4; -webkit-appearance: none; box-shadow: none; transition: color 0.3s; overflow-y: auto;">
    </textarea>

    <div id="vn-overlay" 
         style="display: none; position: absolute; left: 0; top: 0; width: 100%; height: 100%; background: var(--label-bg, #f0f2f5) !important; border-radius: 24px; align-items: center; padding: 0 18px; box-sizing: border-box; z-index: 10;">
      <div style="display: flex; align-items: center; width: 100%; gap: 12px;">
        <div style="width: 10px; height: 10px; background: #ef4444; border-radius: 50%; animation: pulse 1.2s infinite; box-shadow: 0 0 8px rgba(239, 68, 68, 0.4);"></div>
        <span id="vn-timer" style="font-weight: 600; font-size: 14.5px; color: var(--text-color); font-variant-numeric: tabular-nums;">00:00</span>
        <span style="color: var(--text-muted); font-size: 12px; margin-left: auto; font-style: italic; opacity: 0.8;">&laquo; Geser batal</span>
      </div>
    </div>
  </div>

  <button id="action-btn" 
          style="width: 46px; height: 46px; border-radius: 50%; background: var(--primary-color, #3a7bd5); border: none; cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 12px rgba(58, 123, 213, 0.25); outline: none; transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), background-color 0.2s; -webkit-tap-highlight-color: transparent;">
    <div class="icon-stack" style="display: flex; align-items: center; justify-content: center; position: relative; width: 24px; height: 24px;">
      <span class="svg-send" style="position: absolute; display: flex; transition: all 0.3s ease;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="svg-mic" style="position: absolute; display: none; transition: all 0.3s ease;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="2" width="6" height="11" rx="3" fill="white" />
          <path d="M5 10V11C5 14.866 8.13401 18 12 18C15.866 18 19 14.866 19 11V10" stroke="white" stroke-width="2.5" stroke-linecap="round" />
          <line x1="12" y1="18" x2="12" y2="22" stroke="white" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>
    </div>
  </button>
</div>
