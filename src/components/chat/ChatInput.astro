---
// src/components/chat/ChatInput.astro
---

<div id="sticker-menu" class="sticker-menu-adaptive">
  <div class="sticker-header">
    <input type="text" id="sticker-search-input" placeholder="Cari stiker lucu..." class="sticker-search-input" autocomplete="off" />
    <button id="sticker-search-btn" class="btn-search-stiker">Cari</button>
  </div>
  <div id="sticker-list" class="sticker-list-grid custom-scrollbar"></div>
</div>

<div id="reply-preview-box" class="reply-preview-adaptive"></div>

<div class="chat-input-container-main">
  <div class="input-group-wrapper-adaptive">
    <button id="sticker-btn" class="icon-btn-chat" title="Buka Stiker">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
        <line x1="9" y1="9" x2="9.01" y2="9"></line>
        <line x1="15" y1="9" x2="15.01" y2="9"></line>
      </svg>
    </button>

    <textarea id="chat-input" placeholder="Tulis pesan..." rows="1"></textarea>

    <div id="vn-overlay" class="vn-overlay-adaptive">
      <div class="vn-content">
        <div class="record-dot"></div>
        <span id="vn-timer" class="timer-text">00:00</span>
        <span class="cancel-hint">&laquo; Geser untuk batal</span>
      </div>
    </div>
  </div>

  <button id="action-btn" class="btn-action-send">
    <div class="icon-stack">
      <span class="svg-send">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <span class="svg-mic" style="display: none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
          <rect x="9" y="2" width="6" height="11" rx="3" fill="white" />
          <path d="M5 10V11C5 14.866 8.13401 18 12 18C15.866 18 19 14.866 19 11V10" stroke="white" stroke-width="2.5" stroke-linecap="round" />
          <line x1="12" y1="18" x2="12" y2="22" stroke="white" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>
    </div>
  </button>
</div>

<style>
  /* --- LAYOUT UTAMA --- */
  .chat-input-container-main {
    display: flex; align-items: flex-end; gap: 12px; padding: 10px 15px;
    background: var(--bg-input-bar) !important; position: relative; z-index: 100;
    border-top: 1px solid var(--border-color);
  }

  .input-group-wrapper-adaptive {
    flex: 1; display: flex; align-items: center; background: var(--bg-input-field) !important;
    border-radius: 24px; padding: 4px 16px; position: relative; min-height: 48px;
    border: 1px solid var(--border-color); transition: 0.3s ease;
  }
  
  .input-group-wrapper-adaptive:focus-within {
    border-color: #3a7bd5; box-shadow: 0 0 0 2px rgba(58, 123, 213, 0.15);
  }

  #chat-input {
    flex: 1; border: none; outline: none; background: transparent !important; resize: none;
    max-height: 120px; padding: 12px 0; font-family: 'Poppins', sans-serif;
    font-size: 14px; color: var(--text-main) !important; line-height: 1.4;
  }

  /* --- TOMBOL --- */
  .icon-btn-chat { background: none; border: none; cursor: pointer; color: var(--text-muted); margin-right: 8px; transition: 0.2s; }
  .icon-btn-chat:hover { color: #3a7bd5; }

  .btn-action-send {
    width: 48px; height: 48px; border-radius: 50%; background: #3a7bd5; border: none;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 10px rgba(58, 123, 213, 0.3); transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .btn-action-send:active { transform: scale(0.9); }
  .btn-action-send.is-recording { background: #ff4757 !important; transform: scale(1.15); }

  .icon-stack { position: relative; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; }
  .svg-send, .svg-mic { position: absolute; transition: 0.2s opacity; }

  /* --- STIKER MENU --- */
  .sticker-menu-adaptive {
    display: none; flex-direction: column; padding: 12px; height: 260px;
    background: var(--bg-input-bar) !important; border-top: 1px solid var(--border-color);
  }
  .sticker-header { display: flex; gap: 8px; margin-bottom: 12px; }
  .sticker-search-input {
    flex: 1; padding: 8px 16px; border-radius: 20px; border: 1px solid var(--border-color);
    background: var(--bg-input-field); color: var(--text-main); outline: none; font-size: 13px;
  }
  .btn-search-stiker { background: #3a7bd5; color: white; border: none; border-radius: 20px; padding: 0 15px; font-weight: 600; cursor: pointer; }
  .sticker-list-grid { flex: 1; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; overflow-y: auto; }

  /* --- VN OVERLAY --- */
  .vn-overlay-adaptive {
    position: absolute; inset: 0; background: var(--bg-input-field) !important;
    border-radius: 24px; display: none; align-items: center; padding: 0 16px; z-index: 10;
  }
  .record-dot { width: 10px; height: 10px; background: #ff4757; border-radius: 50%; animation: vnPulse 1s infinite alternate; }
  .timer-text { font-weight: 700; font-size: 14px; margin-left: 8px; color: var(--text-main); }
  .cancel-hint { color: var(--text-muted); font-size: 12px; margin-left: auto; font-style: italic; }

  @keyframes vnPulse { from { transform: scale(1); opacity: 1; } to { transform: scale(1.3); opacity: 0.6; } }

  /* --- REPLY PREVIEW --- */
  .reply-preview-adaptive {
    display: none; background: var(--bg-input-bar) !important; border-left: 4px solid #3a7bd5;
    padding: 10px 15px; align-items: center; justify-content: space-between; border-top: 1px solid var(--border-color);
  }
  :global(.reply-content-wrapper) { flex: 1; overflow: hidden; display: flex; flex-direction: column; padding-left: 8px; }
  :global(.reply-title) { font-size: 12px; color: #3a7bd5; font-weight: 700; }
  :global(.reply-text-preview) { font-size: 12px; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
</style>

<script is:inline>
  const chatInput = document.getElementById("chat-input");
  const btnAction = document.getElementById("action-btn");
  const svgSend = document.querySelector(".svg-send");
  const svgMic = document.querySelector(".svg-mic");
  const vnOverlay = document.getElementById("vn-overlay");
  const vnTimer = document.getElementById("vn-timer");

  let mediaRecorder;
  let audioChunks = [];
  let isRecording = false;
  let timerInterval;
  let seconds = 0;
  let holdTimer;

  // --- 1. AUTO RESIZE TEXTAREA ---
  chatInput.addEventListener("input", function() {
    this.style.height = "auto";
    this.style.height = (this.scrollHeight) + "px";
    
    // Toggle icon Mic vs Send
    if (this.value.trim() !== "") {
      svgSend.style.display = "block";
      svgMic.style.display = "none";
    } else {
      svgSend.style.display = "none";
      svgMic.style.display = "block";
    }
  });

  // --- 2. KIRIM PESAN TEXT ---
  window.Message = async function() {
    const text = chatInput.value.trim();
    if (!text || !window.currentUser) return;

    chatInput.value = "";
    chatInput.style.height = "auto";
    svgSend.style.display = "none";
    svgMic.style.display = "block";

    if (window.sendSound) window.sendSound.play().catch(()=>{});

    try {
      const payload = { 
        message: text, 
        user_id: window.currentUser.id, 
        username: window.myUsername, 
        room_id: window.currentRoomId, 
        status: "sent" 
      };
      if (window.currentChatMode === 'group') payload.group_id = window.activeGroupId;
      
      await window.supabase.from("messages").insert([payload]);
      window.cancelReply();
    } catch (err) { window.showToast("Gagal mengirim"); }
  };

  // --- 3. VOICE NOTE LOGIC (HOLD TO RECORD) ---
  async function startVN() {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      mediaRecorder = new MediaRecorder(stream);
      audioChunks = [];
      
      mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
      mediaRecorder.onstop = async () => {
        if (audioChunks.length > 0 && seconds > 0) {
          const blob = new Blob(audioChunks, { type: "audio/mpeg" });
          const fd = new FormData();
          fd.append("file", blob);
          fd.append("upload_preset", "hopehype_preset");
          const res = await fetch("https://api.cloudinary.com/v1_1/dhhmkb8kl/upload", { method: "POST", body: fd });
          const d = await res.json();
          await window.supabase.from("messages").insert([{ 
            message: "🎤 Voice Note", 
            audio_url: d.secure_url, 
            user_id: window.currentUser.id, 
            room_id: window.currentRoomId 
          }]);
        }
        stream.getTracks().forEach(t => t.stop());
      };

      isRecording = true;
      seconds = 0;
      vnTimer.innerText = "00:00";
      mediaRecorder.start();
      
      btnAction.classList.add("is-recording");
      vnOverlay.style.display = "flex";
      chatInput.style.opacity = "0";

      timerInterval = setInterval(() => {
        seconds++;
        let m = Math.floor(seconds / 60).toString().padStart(2, "0");
        let s = (seconds % 60).toString().padStart(2, "0");
        vnTimer.innerText = `${m}:${s}`;
      }, 1000);

      if (navigator.vibrate) navigator.vibrate(50);
    } catch (err) { window.showToast("Mic tidak diizinkan"); }
  }

  function stopVN(canceled = false) {
    if (!isRecording) return;
    isRecording = false;
    clearInterval(timerInterval);
    if (mediaRecorder) mediaRecorder.stop();
    
    btnAction.classList.remove("is-recording");
    vnOverlay.style.display = "none";
    chatInput.style.opacity = "1";
    if (canceled) window.showToast("Batal merekam");
  }

  // Event handler buat tombol dinamis
  btnAction.addEventListener("mousedown", (e) => {
    if (chatInput.value.trim() === "") {
      holdTimer = setTimeout(startVN, 300);
    } else {
      window.Message();
    }
  });

  window.addEventListener("mouseup", () => {
    clearTimeout(holdTimer);
    if (isRecording) stopVN();
  });

  // Mobile Touch Support
  btnAction.addEventListener("touchstart", (e) => {
    if (chatInput.value.trim() === "") {
      holdTimer = setTimeout(startVN, 300);
    } else {
      window.Message();
    }
  }, {passive: true});

  window.addEventListener("touchend", () => {
    clearTimeout(holdTimer);
    if (isRecording) stopVN();
  });

  // --- 4. GIPHY STICKER INTEGRATION ---
  const GIPHY_API_KEY = "vPUlBU5Qfz2ZygoEtKXVUqmIEAEcIB08";
  window.fetchStickers = async function(query = "") {
    const list = document.getElementById("sticker-list");
    list.innerHTML = "<p style='grid-column:1/-1;text-align:center;font-size:12px;color:#999;'>Mencari...</p>";
    
    const url = query 
      ? `https://api.giphy.com/v1/stickers/search?api_key=${GIPHY_API_KEY}&q=${query}&limit=20`
      : `https://api.giphy.com/v1/stickers/trending?api_key=${GIPHY_API_KEY}&limit=20`;

    try {
      const res = await fetch(url);
      const { data } = await res.json();
      list.innerHTML = "";
      data.forEach(s => {
        const img = document.createElement("img");
        img.src = s.images.fixed_width_small.url;
        img.style.cursor = "pointer";
        img.onclick = () => window.sendSticker(s.images.fixed_width.url);
        list.appendChild(img);
      });
    } catch (e) { list.innerHTML = "Gagal memuat stiker."; }
  };

  document.getElementById("sticker-search-btn").onclick = () => {
    window.fetchStickers(document.getElementById("sticker-search-input").value);
  };
</script>
