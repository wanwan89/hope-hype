---
// src/components/chat/ChatMessages.astro
---
<div class="chat-messages" id="chat-messages"></div>

<style is:global>
#chat-messages { display: flex; flex-direction: column; overflow-y: auto; padding: 15px; gap: 10px; }
.chat-messages { flex: 1; padding: 12px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; height: 100%; }
.chat-messages::-webkit-scrollbar { width: 6px; }
.chat-messages::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.2); border-radius: 3px; }

.chat-message { display: flex; max-width: 75%; padding: 6px 10px; border-radius: 16px; font-size: 14px; word-wrap: break-word; align-items: flex-end; position: relative; transition: transform 0.2s ease; user-select: none; touch-action: pan-y; }
.chat-message.self { background: rgba(220, 248, 198, 0.9); align-self: flex-end; border-bottom-right-radius: 2px; flex-direction: row-reverse; }
.chat-message.other { background: rgba(255, 255, 255, 0.9); align-self: flex-start; border-bottom-left-radius: 2px; box-shadow: 0 1px 1px rgba(0, 0, 0, 0.1); }
.chat-message .avatar { width: 35px; height: 35px; border-radius: 50%; margin: 0 8px; flex-shrink: 0; object-fit: cover; background: #eee; }
.chat-message .content { position: relative; display: flex; flex-direction: column; padding-bottom: 5px; margin-bottom: 5px; }
.chat-message .username { font-weight: 600; font-size: 12px; color: #555; margin-bottom: 2px; }
.chat-message .text { font-size: 14px; transition: all 0.3s ease; }
.chat-message .timestamp { font-size: 10px; color: #555; align-self: flex-end; margin-top: 2px; }

.status-icon { display: inline-flex; align-items: center; justify-content: center; margin-left: 4px; vertical-align: middle; line-height: 1; transform: translateY(1px); }
.status-icon.sending { gap: 1px; color: #9aa0a6; font-size: 11px; font-weight: 600; min-width: 14px; }
.status-icon.sent, .status-icon.delivered { color: #8e8e93; }
.status-icon.read { color: #4fc3f7; }

/* Skeleton loading */
.chat-loading-screen { display: flex; flex-direction: column; gap: 14px; padding: 18px 14px 24px; animation: fadeInChatLoading 0.25s ease; }
.skeleton-msg { display: flex; align-items: flex-end; gap: 8px; max-width: 82%; }
.skeleton-msg.left { align-self: flex-start; }
.skeleton-msg.right { align-self: flex-end; justify-content: flex-end; margin-left: auto; }
.skeleton-avatar { width: 34px; height: 34px; border-radius: 50%; background: rgba(255, 255, 255, 0.35); flex-shrink: 0; }
.skeleton-bubble { background: rgba(255, 255, 255, 0.55); border-radius: 16px; padding: 10px 12px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04); }
.shimmer { background: linear-gradient(90deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.35)); background-size: 200% 100%; animation: shimmerMove 1.2s linear infinite; }
</style>
