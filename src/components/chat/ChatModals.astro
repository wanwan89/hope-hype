---
// src/components/chat/ChatModals.astro
---

<div id="bio-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu modal-adaptive">
    <h2 class="modal-title">Lengkapi Profilmu</h2>
    <p class="modal-subtitle">Data ini membantu kami mencari teman yang paling cocok untukmu.</p>

    <div class="modal-row">
      <div style="flex: 1;">
        <label class="modal-label">Umur</label>
        <input type="number" id="in-umur" placeholder="20" class="modal-input" />
      </div>
      <div style="flex: 1;">
        <label class="modal-label">Gender</label>
        <select id="in-gender" class="modal-input">
          <option value="Pria">Pria</option>
          <option value="Wanita">Wanita</option>
        </select>
      </div>
    </div>

    <label class="modal-label">Zodiak</label>
    <select id="in-zodiak" class="modal-input" style="margin-bottom: 15px;">
      <option value="Aries">Aries</option>
      <option value="Taurus">Taurus</option>
      <option value="Gemini">Gemini</option>
      <option value="Cancer">Cancer</option>
      <option value="Leo">Leo</option>
      <option value="Virgo">Virgo</option>
      <option value="Libra">Libra</option>
      <option value="Scorpio">Scorpio</option>
      <option value="Sagitarius">Sagitarius</option>
      <option value="Capricorn">Capricorn</option>
      <option value="Aquarius">Aquarius</option>
      <option value="Pisces">Pisces</option>
    </select>

    <label class="modal-label">Hobi</label>
    <input type="text" id="in-hobi" placeholder="Apa kegemaranmu?" class="modal-input" style="margin-bottom: 15px;" />

    <label class="modal-label">Pekerjaan / Kegiatan</label>
    <input type="text" id="in-kerja" placeholder="Contoh: Mahasiswa" class="modal-input" style="margin-bottom: 20px;" />

    <div style="display: flex; gap: 10px;">
      <button class="btn-confirm" id="btn-save-bio" style="flex: 2;">Simpan & Cari</button>
      <button type="button" class="btn-cancel" onclick="window.closeBioModal()" style="flex: 1;">Batal</button>
    </div>
  </div>
</div>

<div id="group-modal" class="delete-overlay" style="display: none; align-items: center; justify-content: center;">
  <div class="delete-menu modal-adaptive">
    <h2 class="modal-title">Buat Grup Baru</h2>

    <div style="margin-bottom: 20px; position: relative; display: inline-block;">
      <label for="group-photo-input" style="cursor: pointer;">
        <img id="group-photo-preview" src="/asets/png/profile.webp" class="modal-avatar-preview" />
        <div class="plus-icon">+</div>
      </label>
      <input type="file" id="group-photo-input" accept="image/*" style="display: none;" />
    </div>

    <div style="text-align: left;">
      <label class="modal-label">Nama Grup</label>
      <input type="text" id="in-group-name" placeholder="Contoh: Gibah Squad" class="modal-input" style="margin-bottom: 20px;" />
    </div>

    <div style="display: flex; gap: 10px;">
      <button class="btn-confirm" id="btn-create-group" style="flex: 2;">Buat Sekarang</button>
      <button class="btn-cancel" onclick="document.getElementById('group-modal').style.display='none'" style="flex: 1;">Batal</button>
    </div>
  </div>
</div>

<div id="group-settings-modal" class="modal-overlay" style="display:none; z-index:99999; position: fixed; inset: 0; background: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
  <div class="modal-content modal-adaptive" style="padding: 20px;">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border-color); padding-bottom:10px; margin-bottom:15px;">
      <h3 class="modal-title" style="font-size:16px;">Pengaturan Grup</h3>
      <span onclick="document.getElementById('group-settings-modal').style.display='none'" style="cursor:pointer; font-size:20px; color:var(--text-muted);">&times;</span>
    </div>

    <div style="text-align: center; margin-bottom: 20px;">
      <label for="edit-group-photo-input" style="cursor: pointer; display: inline-block; position: relative;">
        <img id="edit-group-photo-preview" src="/asets/png/profile.webp" class="modal-avatar-preview" />
        <div class="plus-icon">+</div>
      </label>
      <input type="file" id="edit-group-photo-input" accept="image/*" style="display: none;" />
    </div>

    <div style="margin-bottom:20px;">
      <label class="modal-label">Nama Grup</label>
      <input type="text" id="edit-group-name" class="modal-input" style="margin-bottom:10px;" />
      <button id="btn-save-group-info" onclick="window.updateGroupInfo()" class="btn-confirm" style="width:100%;">Simpan Perubahan</button>
    </div>

    <div>
      <label class="modal-label">Daftar Anggota</label>
      <div id="member-list-container" class="member-list"></div>
    </div>

    <button onclick="window.leaveGroup()" class="btn-leave">Keluar dari Grup</button>
  </div>
</div>

<div id="doi-card-modal" class="modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div class="doi-card modal-adaptive">
    <div style="position:relative; height:320px; background:#222;">
      <img id="doi-photo" src="" style="width:100%; height:100%; object-fit:cover;" />
      <div class="doi-info-overlay">
        <div style="display:flex; align-items:center; gap:8px;">
          <h2 id="doi-name-age" style="margin:0; font-size:24px; font-weight:700; color:white;">Nama, 20</h2>
          <span id="doi-gender-icon"></span>
        </div>
        <p id="doi-zodiac" style="margin:4px 0 0 0; font-size:14px; opacity:0.8; color:white;"></p>
      </div>
    </div>

    <div style="padding:20px;">
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:20px;">
        <div>
          <small class="modal-label-small">Pekerjaan</small>
          <div id="doi-job" class="doi-text-val">-</div>
        </div>
        <div>
          <small class="modal-label-small">Hobi</small>
          <div id="doi-hobby" class="doi-text-val">-</div>
        </div>
      </div>

      <div style="display:flex; gap:12px;">
        <button onclick="window.tutupDoiCard()" class="btn-cancel" style="flex:1;">Skip</button>
        <button id="btn-gas-chat" class="btn-confirm" style="flex:2;">Chat Sekarang</button>
      </div>
    </div>
  </div>
</div>

<div id="delete-overlay" class="delete-overlay">
  <div class="delete-menu modal-adaptive">
    <p class="modal-title" style="margin-bottom: 20px;">Hapus pesan ini?</p>
    <div class="delete-menu-btns">
      <button id="confirm-delete" class="btn-confirm">Hapus</button>
      <button class="btn-cancel" onclick="document.getElementById('delete-overlay').style.display='none'">Batal</button>
    </div>
  </div>
</div>

<style>
  /* --- ADAPTIVE MODAL SYSTEM --- */
  .modal-adaptive {
    background: var(--bg-sidebar) !important;
    color: var(--text-main);
    transition: background 0.3s ease;
  }

  .modal-title { color: var(--text-main) !important; font-weight: 700; }
  .modal-subtitle { color: var(--text-muted) !important; }
  .modal-label { font-size: 11px; font-weight: 600; color: var(--text-main); display: block; margin-bottom: 5px; }
  .modal-label-small { color: var(--text-muted); text-transform: uppercase; font-size: 10px; font-weight: 700; }
  
  .modal-input {
    width: 100%; padding: 10px; 
    border: 1px solid var(--border-color); 
    border-radius: 8px; 
    background: var(--bg-input-field); 
    color: var(--text-main);
    box-sizing: border-box;
  }

  .modal-row { display: flex; gap: 10px; margin-bottom: 15px; text-align: left; }
  
  .modal-avatar-preview {
    width: 80px; height: 80px; border-radius: 50%; object-fit: cover; 
    border: 2px solid #3a7bd5; background: var(--bg-input-field);
  }

  .plus-icon {
    position: absolute; bottom: 0; right: 0; background: #3a7bd5; color: white; 
    width: 25px; height: 25px; border-radius: 50%; display: flex; 
    align-items: center; justify-content: center; border: 2px solid var(--bg-sidebar); 
    font-weight: bold; font-size: 14px;
  }

  .btn-confirm {
    background: linear-gradient(135deg, #3a7bd5, #00d2ff) !important;
    color: white; border: none; border-radius: 12px; padding: 12px;
    font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(58, 123, 213, 0.3);
  }

  .btn-cancel {
    padding: 12px; border: none; border-radius: 12px; 
    background: var(--bg-input-field); color: var(--text-muted); 
    font-weight: 600; cursor: pointer;
  }

  .btn-leave {
    width: 100%; background: transparent; color: #ff4757; 
    border: 1px solid #ff4757; padding: 10px; border-radius: 8px; 
    font-weight: bold; cursor: pointer; margin-top: 20px;
  }

  .doi-card { width: 100%; max-width: 340px; border-radius: 24px; overflow: hidden; position: relative; }
  .doi-info-overlay { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); padding: 24px 20px; }
  .doi-text-val { font-size: 14px; color: var(--text-main); font-weight: 600; }

  .member-list { max-height: 200px; overflow-y: auto; border: 1px solid var(--border-color); border-radius: 8px; padding: 5px 10px; }

  /* --- EXISTING STYLES --- */
  .delete-overlay, .searching-overlay {
    position: fixed; inset: 0; display: none; justify-content: center; align-items: center; z-index: 9999;
  }
  .delete-overlay { background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(8px); }
  .delete-menu { width: 90%; max-width: 300px; padding: 25px; border-radius: 24px; animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }

  @keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

  /* --- 🔥 RADAR MODAL (SAMA SEPERTI SEBELUMNYA) --- */
  :global(.searching-overlay) {
    position: fixed; inset: 0; background: rgba(10, 15, 25, 0.98);
    backdrop-filter: blur(10px); z-index: 100000;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  :global(.radar-pencari-ghaib) { width: 250px; height: 250px; position: relative; }
  :global(.radar-inner) {
    width: 100%; height: 100%; border-radius: 50%;
    border: 4px solid rgba(255, 78, 80, 0.2); position: relative;
    overflow: hidden; box-shadow: 0 0 50px rgba(255, 78, 80, 0.2) inset;
  }
  :global(.radar-scan) {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: conic-gradient(from 0deg, transparent, #ff4e50, transparent 90deg);
    animation: radarScanRotate 2s linear infinite; border-radius: 50%;
    filter: blur(5px); opacity: 0.8;
  }
  :global(.radar-center-avatar) {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 65px; height: 65px; border-radius: 50%; border: 3px solid white;
    object-fit: cover; box-shadow: 0 0 30px rgba(255, 78, 80, 0.6); z-index: 10;
  }
  :global(.search-title-romantic) {
    margin: 0; font-size: 24px; font-weight: 800; letter-spacing: 3px;
    background: linear-gradient(135deg, #ff4e50, #f9d423);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  @keyframes radarScanRotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
