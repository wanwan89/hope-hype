---
// Jika ada logic Astro ditaruh di sini
---
<div id="postModal" class="post-modal">
  <div class="post-modal-content">
    <button class="post-close-btn" id="closePostModalBtn">×</button>

    <h2 class="post-modal-title">Upload Post</h2>
    <p class="post-modal-subtitle">Karya kamu akan dikirim untuk direview dulu ya</p>

    <form id="postForm" class="post-form">
      
      <div class="post-type-toggle" style="display: flex; gap: 10px; margin-bottom: 20px; background: var(--bg-secondary, #f1f5f9); padding: 5px; border-radius: 12px;">
        <button type="button" id="btnTypeImage" class="type-btn active" style="flex: 1; padding: 10px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.3s; background: #1DA1F2; color: white;">
          Foto
        </button>
        <button type="button" id="btnTypeText" class="type-btn" style="flex: 1; padding: 10px; border-radius: 8px; border: none; font-weight: 600; font-size: 14px; cursor: pointer; transition: 0.3s; background: transparent; color: var(--text-muted, #64748b);">
          Teks Saja
        </button>
      </div>

      <div class="post-upload-area" id="postUploadArea" style="cursor: pointer;">
        <input type="file" id="postImageInput" accept="image/*" hidden />
        
        <div class="post-upload-placeholder" id="postUploadPlaceholder">
          <span class="post-upload-text">Pilih foto karya</span>
          <small>JPG, PNG, WEBP • Max 5MB</small>
        </div>

        <img id="postPreviewImage" class="post-preview-image" style="display:none; width: 100%; border-radius: 12px; object-fit: cover;" alt="Preview karya" />
      </div>

      <textarea
        id="postCaption"
        class="post-textarea"
        placeholder="Tulis caption menarik di sini...."
        maxlength="300"
        style="margin-top: 15px;"
      ></textarea>

      <div class="category-dropdown" id="categoryDropdown" style="margin-top: 10px;">
        <div class="select-trigger">
          <span id="selectedCategoryText">Pilih kategori</span>
          <i class="arrow-icon">▼</i>
        <div class="options-container">
          <div class="option-item" data-value="Karya">Karya</div>
          <div class="option-item" data-value="Prestasi">Prestasi</div>
          <div class="option-item" data-value="Photography">Photography</div>
          <div class="option-item" data-value="Mountain">Mountain</div>
          <div class="option-item" data-value="Thread">Thread</div>
        </div>

        <input type="hidden" id="postCategory" name="category" value="Karya" />
      </div>

      <div class="music-picker-section" style="margin-top: 20px; border-top: 1px solid var(--border-card); padding-top: 15px;">
        <div style="font-size: 13px; font-weight: 700; margin-bottom: 10px; color: var(--text-main);">Pilih Musik (Opsional)</div>
        
        <input 
          type="text" 
          id="searchMusicInput" 
          placeholder="Cari lagu di iTunes (Contoh: Hindia)..." 
          style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid var(--border-card); background: var(--bg-input); color: var(--text-main); margin-bottom: 12px; font-size: 13px; outline: none;"
        >
        
        <div id="predefinedMusicList" style="max-height: 160px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; padding-right: 5px;">
          <div style="font-size:12px; color:gray; text-align:center; padding: 10px;">Ketik judul lagu untuk mencari musik...</div>
        </div>
        
        <div id="selectedMusicBox" style="display: none; align-items: center; justify-content: space-between; background: rgba(29, 161, 242, 0.1); padding: 10px 12px; border-radius: 10px; margin-top: 10px; border: 1px solid #1DA1F2;">
          <div style="display: flex; align-items: center; gap: 10px; overflow: hidden;">
            <span style="font-size: 9px; font-weight: 900; background: #1DA1F2; color: white; padding: 3px 7px; border-radius: 4px; letter-spacing: 1px;">AUDIO</span>
            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 13px; font-weight: 700; color: #1DA1F2;" id="selectedMusicTitle">Judul Lagu</div>
          </div>
          <button type="button" id="removeMusicBtn" style="background: none; border: none; color: #ef4444; font-weight: 800; cursor: pointer; font-size: 11px;">HAPUS</button>
        </div>
      </div>

      <button type="submit" id="submitPostBtn" class="post-submit-btn" style="width: 100%; padding: 15px; border-radius: 12px; border: none; background: #1f3cff; color: white; font-weight: 700; margin-top: 10px; cursor: pointer;">
        Kirim ke Review
      </button>
    </form>
  </div>
</div>
