---
---
<div id="postModal" class="post-modal">
  <div class="post-modal-content">
    <button class="post-close-btn" id="closePostModalBtn">×</button>

    <h2 class="post-modal-title">Upload Post</h2>
    <p class="post-modal-subtitle">Karya kamu akan dikirim untuk direview dulu ya</p>

    <form id="postForm" class="post-form">
      <div class="post-upload-area" id="postUploadArea">
        <input type="file" id="postImageInput" accept="image/*" hidden />
        
        <div class="post-upload-placeholder" id="postUploadPlaceholder">
          <span class="post-upload-text">Pilih foto karya</span>
          <small>JPG, PNG, WEBP • Max 5MB</small>
        </div>

        <img id="postPreviewImage" class="post-preview-image" style="display:none;" alt="Preview karya" />
      </div>

      <textarea
        id="postCaption"
        class="post-textarea"
        placeholder="Tulis caption...."
        maxlength="300"
      ></textarea>

      <div class="category-dropdown" id="categoryDropdown">
        <div class="select-trigger">
          <span id="selectedCategoryText">Pilih kategori</span>
          <i class="arrow-icon">▼</i>
        </div>
        
        <div class="options-container">
          <div class="option-item" data-value="Karya">Karya</div>
          <div class="option-item" data-value="Prestasi">Prestasi</div>
          <div class="option-item" data-value="Photography">Photography</div>
          <div class="option-item" data-value="Mountain">Mountain</div>
        </div>
        
        <input type="hidden" id="postCategory" name="category" />
      </div>

      <div class="music-picker-section" style="margin-top: 15px; border-top: 1px solid var(--border-color); padding-top: 15px; margin-bottom: 15px;">
        <div style="font-size: 13px; font-weight: 600; margin-bottom: 8px; color: var(--text-dark);">Tambahkan Musik (Opsional)</div>
        <input type="text" id="musicSearchInput" placeholder="Cari judul lagu / artis..." style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border-color); margin-bottom: 10px; font-family: inherit; font-size: 13px;">
        <div id="musicSearchResults" style="max-height: 150px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px;"></div>
        
        <div id="selectedMusicBox" style="display: none; align-items: center; justify-content: space-between; background: var(--light-blue-bg, #e7f3ff); padding: 10px; border-radius: 8px; margin-top: 10px; border: 1px solid var(--primary-blue, #007bff);">
          <div style="display: flex; align-items: center; gap: 10px; overflow: hidden;">
            <div style="background: var(--primary-blue, #007bff); color: white; min-width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
            <div style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 13px; font-weight: 600; color: var(--primary-blue, #007bff);" id="selectedMusicTitle">Judul Lagu</div>
          </div>
          <button type="button" id="removeMusicBtn" style="background: none; border: none; color: #ef4444; font-weight: bold; cursor: pointer; padding: 5px; font-size: 16px;">×</button>
        </div>
      </div>
      <button type="submit" id="submitPostBtn" class="post-submit-btn">
        Kirim ke Review
      </button>
    </form>
  </div>
</div>
