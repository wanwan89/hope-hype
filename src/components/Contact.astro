---
// src/components/Contact.astro
---
<div class="contact-wrapper">
  <input type="checkbox" id="contact-toggle" style="display: none;">
  <label for="contact-toggle" class="contact-text" aria-label="Buka Hubungi Kami">Contact us</label>

  <div class="social-icons-container">
    <a href="https://www.tiktok.com/@hopehypeoffcial" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
      <img 
        src="/asets/png/tiktok.webp" 
        width="24" 
        height="24" 
        class="social-icon" 
        alt="TikTok" 
        decoding="async" 
        loading="lazy"
      >
    </a>
    <a href="https://www.instagram.com/hopehypeofficial" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
      <img 
        src="/asets/png/instagram.webp" 
        width="24" 
        height="24" 
        alt="Instagram" 
        class="social-icon" 
        decoding="async" 
        loading="lazy"
      >
    </a>
    <a href="mailto:hopeofficial2811@gmail.com" aria-label="Email">
      <img 
        src="/asets/png/mail.webp" 
        width="24" 
        height="24" 
        alt="Email" 
        class="social-icon" 
        decoding="async" 
        loading="lazy"
      >
    </a>
  </div>
</div>

<style is:global>
/* ========================================= */
/* CONTACT US & SOSIAL MEDIA                 */
/* ========================================= */
.contact-wrapper { 
  position: fixed; 
  bottom: 20px; 
  left: 20px; 
  z-index: 999; 
  display: flex; 
  align-items: center; 
  gap: 12px; 
}

.contact-text { 
  background-color: var(--bg-container); 
  color: #004bb5; /* FIX: Birunya digelapin dikit biar kontrasnya lulus 100% */
  padding: 6px 14px; 
  border-radius: 20px; 
  font-size: 13px; 
  font-weight: 700; 
  cursor: pointer; 
  box-shadow: 2px 4px 6px var(--shadow-color); 
  transition: all 0.3s ease; 
  /* Tambahan dikit biar UX mobile mantap */
  -webkit-tap-highlight-color: transparent;
}

:root.dark .contact-text { 
  color: #ffffff; 
  background-color: #3f445e; 
}

.social-icons-container { 
  display: flex; 
  flex-direction: row; 
  gap: 10px; 
  opacity: 0; 
  transform: translateX(-20px); 
  pointer-events: none; 
  transition: all 0.4s ease-out; 
}

.social-icon {
  transition: transform 0.2s ease;
  /* Tambahan biar rendering gambar kecil tetep tajem */
  image-rendering: -webkit-optimize-contrast;
}

.social-icon:hover {
  transform: scale(1.1);
}

#contact-toggle:checked ~ .social-icons-container { 
  opacity: 1; 
  transform: translateX(0); 
  pointer-events: auto; 
}

#contact-toggle:checked ~ .contact-text { 
  background-color: #007BFF; 
  color: #ffffff; 
}
</style>
