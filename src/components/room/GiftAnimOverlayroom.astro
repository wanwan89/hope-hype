<div id="gift-anim-overlay">
  <img id="gift-anim-img" src="" alt="Gift Animation" />
</div>

<style is:global>
/* ==================================================
   1. VARIABEL OVERLAY GIFT (DINAMIS)
================================================== */
:root, [data-theme="light"] {
    --overlay-bg: rgba(255, 255, 255, 0.4); /* Transparan terang */
}

[data-theme="dark"] {
    --overlay-bg: rgba(15, 23, 42, 0.6); /* Transparan gelap pekat */
}

/* ==================================================
   2. OVERLAY UTAMA (GLASSMORPHISM EFFECT)
================================================== */
#gift-anim-overlay { 
    position: fixed !important; 
    inset: 0; 
    display: none; /* Disembunyikan secara default oleh JS */
    justify-content: center; 
    align-items: center; 
    z-index: 1000000 !important; 
    pointer-events: none; /* Agar tidak memblokir sentuhan di belakangnya */
}

#gift-anim-overlay.show { 
    display: flex; 
    background: var(--overlay-bg); 
    /* Efek blur modern layaknya kaca */
    backdrop-filter: blur(6px); 
    -webkit-backdrop-filter: blur(6px); /* Untuk dukungan Safari/iOS */
    animation: fadeInOverlay 0.3s ease-out forwards;
}

/* ==================================================
   3. GAMBAR GIFT & EFEK GLOW
================================================== */
#gift-anim-img { 
    width: 300px; 
    max-width: 80%; 
    opacity: 0; 
    transform: scale(0); 
    /* Efek cahaya/glow di belakang gift */
    filter: drop-shadow(0 20px 40px rgba(245, 158, 11, 0.4)); 
}

#gift-anim-overlay.show #gift-anim-img { 
    /* Menggunakan cubic-bezier agar membal alami */
    animation: giftPopUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; 
}

/* ==================================================
   4. KEYFRAMES (ANIMASI)
================================================== */
@keyframes fadeInOverlay {
    from { 
        background: transparent; 
        backdrop-filter: blur(0px); 
    }
    to { 
        background: var(--overlay-bg); 
        backdrop-filter: blur(6px); 
    }
}

@keyframes giftPopUp {
    0% { 
        opacity: 0; 
        transform: scale(0.3) translateY(50px) rotate(-10deg); 
    }
    50% { 
        opacity: 1; 
        transform: scale(1.1) translateY(-10px) rotate(5deg); 
    }
    100% { 
        opacity: 1; 
        transform: scale(1) translateY(0) rotate(0deg); 
    }
}
</style>
