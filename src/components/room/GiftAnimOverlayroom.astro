<div id="gift-anim-overlay">
  <img id="gift-anim-img" src="" alt="Gift Animation" />
</div>

<style is:global>
/* ==================================================
   1. VARIABEL OVERLAY GIFT (PREMIUM GLOW)
================================================== */
:root, [data-theme="light"] {
    --overlay-bg: rgba(255, 255, 255, 0.3);
    /* Cahaya sorot (spotlight) di tengah layar */
    --gift-spotlight: radial-gradient(circle, rgba(245, 158, 11, 0.15) 0%, rgba(255, 255, 255, 0) 60%);
}

[data-theme="dark"] {
    --overlay-bg: rgba(15, 23, 42, 0.4); 
    --gift-spotlight: radial-gradient(circle, rgba(245, 158, 11, 0.25) 0%, rgba(15, 23, 42, 0) 60%);
}

/* ==================================================
   2. OVERLAY UTAMA (GLASSMORPHISM + SPOTLIGHT)
================================================== */
#gift-anim-overlay { 
    position: fixed !important; 
    inset: 0; 
    display: none; 
    justify-content: center; 
    align-items: center; 
    z-index: 1000000 !important; 
    pointer-events: none !important; /* Wajib anti-nyangkut */
}

#gift-anim-overlay.show,
#gift-anim-overlay[style*="display: flex"] { 
    background: var(--gift-spotlight), var(--overlay-bg); 
    backdrop-filter: blur(8px); 
    -webkit-backdrop-filter: blur(8px); 
    animation: fadeInGiftOverlay 0.4s ease-out forwards;
}

/* ==================================================
   3. GAMBAR GIFT & EFEK GLOW (OVERRIDE JS)
================================================== */
/* Pakai !important untuk memastikan CSS ini mengalahkan style bawaan dari JS */
#gift-anim-img { 
    width: 320px !important; 
    max-width: 85% !important; 
    opacity: 0; 
    transform: scale(0); 
    /* Drop shadow ganda: satu untuk batas, satu untuk pendaran cahaya */
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3)) drop-shadow(0 0 40px rgba(245, 158, 11, 0.6)) !important; 
    animation: giftEpicPopUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards !important; 
}

/* ==================================================
   4. TEKS COMBO (DI-INJECT DARI JS)
================================================== */
#gift-combo-text {
    /* Bikin teks combo (x2, x3) menyala dan berdimensi */
    text-shadow: 
        0 4px 0 #d97706, 
        0 8px 10px rgba(0,0,0,0.4), 
        0 0 30px rgba(255, 215, 0, 0.9) !important;
    animation: comboPulse 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards !important;
}

/* ==================================================
   5. KEYFRAMES (ANIMASI KELAS ATAS)
================================================== */
@keyframes fadeInGiftOverlay {
    from { 
        opacity: 0; 
        backdrop-filter: blur(0px); 
    }
    to { 
        opacity: 1; 
        backdrop-filter: blur(8px); 
    }
}

/* Animasi kado masuk: Melenting, memutar sedikit, lalu menetap */
@keyframes giftEpicPopUp {
    0% { 
        opacity: 0; 
        transform: scale(0.2) translateY(100px) rotate(-15deg); 
    }
    50% { 
        opacity: 1; 
        transform: scale(1.15) translateY(-15px) rotate(8deg); 
    }
    75% { 
        transform: scale(0.95) translateY(5px) rotate(-2deg); 
    }
    100% { 
        opacity: 1; 
        transform: scale(1) translateY(0) rotate(0deg); 
    }
}

/* Animasi teks combo berdenyut */
@keyframes comboPulse {
    0% { transform: rotate(-15deg) scale(0.5); opacity: 0; }
    80% { transform: rotate(-15deg) scale(1.2); opacity: 1; }
    100% { transform: rotate(-15deg) scale(1.1); opacity: 1; }
}
</style>
