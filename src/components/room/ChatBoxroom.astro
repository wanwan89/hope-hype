---
<div id="chat-box" class="chat-display">
  <div class="msg system">
    <span class="user">SISTEM:</span> 
    Jangan gunakan kata kasar, hinaan, atau bullying dalam bentuk apa pun. Selalu jawab dengan sopan, santai, dan tetap menghargai orang lain ya!
  </div>
</div>

<style is:global>
/* ==================================================
   1. VARIABEL TEMA KHUSUS CHAT (PREMIUM LOOK)
================================================== */
:root, [data-theme="light"] {
    --msg-bg: rgba(255, 255, 255, 0.95);
    --msg-border: rgba(0, 0, 0, 0.04);
    --msg-shadow: 0 4px 14px rgba(0, 0, 0, 0.03);
    
    --sys-bg: rgba(245, 158, 11, 0.08);
    --sys-border: rgba(245, 158, 11, 0.2);
    --sys-gift-bg: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(245, 158, 11, 0.05));
    --sys-gift-text: #d97706; 
}

[data-theme="dark"] {
    --msg-bg: rgba(30, 41, 59, 0.85); /* Semi transparan untuk efek glass di mode gelap */
    --msg-border: rgba(255, 255, 255, 0.05);
    --msg-shadow: 0 4px 14px rgba(0, 0, 0, 0.25);
    
    --sys-bg: rgba(245, 158, 11, 0.1);
    --sys-border: rgba(245, 158, 11, 0.15);
    --sys-gift-bg: linear-gradient(135deg, rgba(245, 158, 11, 0.2), rgba(245, 158, 11, 0.05));
    --sys-gift-text: #fbbf24; 
}

/* ==================================================
   2. CHAT DISPLAY CONTAINER
================================================== */
.chat-display {
    flex: 1;
    overflow-y: auto;
    padding: 16px 18px; /* Padding samping dilegakan sedikit */
    display: flex;
    flex-direction: column;
    gap: 12px; /* Jarak antar chat dilegakan agar mata nyaman */
    
    /* 🔥 PADDING BAWAH LEGA AGAR TIDAK TERTUTUP INPUT 🔥 */
    padding-bottom: 140px; 
    scrollbar-width: none; 
    scroll-behavior: smooth;
}
.chat-display::-webkit-scrollbar { display: none; }

/* ==================================================
   3. BUBBLE CHAT UTAMA (CLEAN & MODERN)
================================================== */
.msg {
    background: var(--msg-bg);
    box-shadow: var(--msg-shadow);
    border: 1px solid var(--msg-border); 
    border-radius: 18px 18px 18px 4px; /* Sudut lebih melengkung elegan */
    padding: 10px 16px; 
    max-width: 85%;
    font-size: 13.5px; /* Sedikit dibesarkan agar mudah dibaca */
    line-height: 1.5; /* Jarak antar baris teks lebih lega */
    color: var(--text-main); 
    align-self: flex-start;
    
    /* Efek Blur (Glassmorphism) */
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    
    /* Animasi masuk untuk SEMUA chat */
    animation: chatSlideUp 0.3s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
    transform-origin: bottom left;
    transition: background-color 0.3s ease, border-color 0.3s ease;
}

.msg .user { 
    font-weight: 700; 
    color: var(--primary); 
    margin-right: 6px; 
    letter-spacing: -0.2px; /* Kesan tipografi modern */
}

/* ==================================================
   4. PESAN SISTEM (WARNING / INFO CARD)
================================================== */
.msg.system { 
    background: var(--sys-bg); 
    border: 1px solid var(--sys-border);
    border-left: 4px solid var(--accent); /* Garis kiri lebih tegas */
    border-radius: 8px 16px 16px 8px; /* Bentuk asimetris estetik */
    box-shadow: none;
    font-size: 12.5px;
    padding: 12px 16px;
}
.msg.system .user { 
    color: var(--accent); 
    font-weight: 800;
}

/* ==================================================
   5. PESAN GIFT / DONASI (PREMIUM PILL)
================================================== */
.msg.system-gift {
    background: var(--sys-gift-bg) !important;
    border: 1px solid var(--sys-border) !important;
    border-radius: 24px !important; /* Bentuk pil oval bulat sempurna */
    align-self: center !important; 
    text-align: center;
    padding: 8px 20px;
    margin: 12px 0;
    font-size: 12.5px;
    font-weight: 700;
    color: var(--sys-gift-text); 
    box-shadow: 0 4px 15px rgba(245, 158, 11, 0.1);
    
    /* Animasi membal khusus untuk gift */
    animation: giftPopIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; 
    transform-origin: center center;
}

/* ==================================================
   6. KEYFRAMES ANIMASI CHAT
================================================== */
/* Animasi chat biasa masuk (mulus dari bawah) */
@keyframes chatSlideUp {
    0% { opacity: 0; transform: translateY(12px) scale(0.95); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
}

/* Animasi pesan kado masuk (membal elegan di tengah) */
@keyframes giftPopIn {
    0% { opacity: 0; transform: translateY(15px) scale(0.8); }
    50% { opacity: 1; transform: translateY(-3px) scale(1.05); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
}
</style>
