<div id="sidebar-overlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>

<div id="sidebar" class="sidebar">
  <div class="sidebar-header">
    <button class="close-sidebar-btn" onclick="toggleSidebar()">
      <span class="material-icons">chevron_right</span>
    </button>
    <img src="/asets/png/profile.png" id="sidebar-avatar" class="sidebar-profile-img" />
    <span id="sidebar-username">Username</span>
  </div>

  <div class="sidebar-menu">
    <a href="/data">
      <span class="material-icons">person</span> 
      <span>Profil</span>
    </a>
    
<a href="#" id="menu-mic" onclick="toggleMicSidebar(event)">

      <span class="material-icons" id="mic-icon">mic</span> 
      <span id="mic-text">Matikan Mic</span>
    </a>
    
    <a href="#" id="menu-setting" style="display: none;" onclick="openRoomSetting()">
      <span class="material-icons">settings</span> 
      <span>Room Settings</span>
    </a>
    
    <a href="#" onclick="keluarRoom()" class="logout-item">
      <span class="material-icons">logout</span> 
      <span>Keluar</span>
    </a>
  </div>
</div> 

<style is:global>
/* ==================================================
   1. SIDEBAR OVERLAY (GLASSMORPHISM)
================================================== */
.sidebar-overlay { 
    position: fixed; 
    inset: 0; 
    background: rgba(0, 0, 0, 0.4); /* Warna gelap semi-transparan */
    backdrop-filter: blur(4px);     /* Efek blur kaca */
    -webkit-backdrop-filter: blur(4px);
    z-index: 1999; 
    display: none; 
    opacity: 0;
    transition: opacity 0.3s ease;
}

.sidebar-overlay.active { 
    display: block; 
    animation: fadeInOverlay 0.3s ease forwards;
}

/* ==================================================
   2. PANEL SIDEBAR UTAMA
================================================== */
.sidebar {
    position: fixed; 
    top: 0; 
    right: -280px; 
    width: 280px; 
    height: 100%;
    background: var(--panel-bg); /* Menggunakan panel-bg agar sedikit beda dengan background utama */
    z-index: 2000;
    /* Transisi cubic-bezier untuk slide yang ngebut di awal tapi mulus di akhir */
    transition: right 0.4s cubic-bezier(0.25, 0.8, 0.25, 1); 
    padding: 24px 20px;
    display: flex; 
    flex-direction: column; 
    border-left: 1px solid var(--border); /* Dinamis mengikuti tema */
    box-shadow: -5px 0 25px rgba(0, 0, 0, 0.05); /* Bayangan super halus */
}

.sidebar.active { 
    right: 0; 
}

/* ==================================================
   3. HEADER SIDEBAR & PROFIL
================================================== */
.sidebar-header { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    padding-bottom: 24px; 
    border-bottom: 1px solid var(--border); 
    position: relative; 
}

.close-sidebar-btn { 
    position: absolute; 
    left: 0; 
    top: 0; 
    background: transparent; 
    border: none; 
    color: var(--text-muted); 
    cursor: pointer; 
    font-size: 24px; 
    padding: 4px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s, transform 0.15s, color 0.2s;
}

.close-sidebar-btn:active {
    background-color: var(--empty-slot);
    color: var(--danger); /* Merah saat mau ditutup */
    transform: scale(0.85);
}

.sidebar-profile-img { 
    width: 76px; 
    height: 76px; 
    border-radius: 50%; 
    object-fit: cover; 
    margin-bottom: 12px; 
    /* Efek Ring Premium ala Story */
    border: 2px solid var(--primary); 
    padding: 2px; 
}

#sidebar-username { 
    font-weight: 700; 
    font-size: 16px; 
    color: var(--text-main);
    letter-spacing: -0.3px;
}

/* ==================================================
   4. MENU NAVIGASI
================================================== */
.sidebar-menu { 
    margin-top: 24px; 
    display: flex;
    flex-direction: column;
    gap: 4px; /* Jarak rapi antar menu */
}

.sidebar-menu a { 
    display: flex; 
    align-items: center; 
    gap: 12px; 
    color: var(--text-main); 
    text-decoration: none; 
    padding: 14px 16px; 
    border-radius: 12px; 
    font-size: 14px; 
    font-weight: 600; 
    transition: background-color 0.2s ease, transform 0.15s ease; 
}

/* Efek saat menu ditekan */
.sidebar-menu a:active {
    background-color: var(--empty-slot);
    transform: scale(0.97);
}

/* ==================================================
   5. MENU LOGOUT KHUSUS
================================================== */
.sidebar-menu a.logout-item { 
    color: var(--danger); 
    margin-top: 20px; 
    background: rgba(239, 68, 68, 0.08); /* Background merah transparan */
    border: 1px solid rgba(239, 68, 68, 0.15);
}

.sidebar-menu a.logout-item:active { 
    background: rgba(239, 68, 68, 0.15); 
    transform: scale(0.97);
}
</style>

