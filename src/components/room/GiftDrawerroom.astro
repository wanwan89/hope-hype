<style is:global>
/* ==================================================
   0. OVERLAY LACI KADO (ANTI-NYANGKUT)
================================================== */
.drawer-overlay {
    position: fixed; 
    inset: 0; 
    background: rgba(0, 0, 0, 0.5); /* Layar agak gelap */
    z-index: 5000; 
    display: none; 
    opacity: 0;
    transition: opacity 0.3s ease;
    
    /* 🔥 JURUS ANTI-NYANGKUT 🔥 */
    /* Pastikan kalau laci tertutup, layar bisa di-tap */
    pointer-events: none !important; 
}

.drawer-overlay.show {
    display: block;
    opacity: 1;
    /* 🔥 JURUS ANTI-NYANGKUT 🔥 */
    /* Saat laci dibuka, overlay bisa diklik buat nutup laci */
    pointer-events: auto !important; 
    animation: fadeInOverlay 0.3s ease forwards;
}

@keyframes fadeInOverlay {
    from { opacity: 0; }
    to { opacity: 1; }
}

/* ==================================================
   1. DRAWER KADO (BOTTOM SHEET)
================================================== */
.gift-drawer {
    position: fixed; 
    bottom: -100%; 
    left: 0; right: 0;
    background: var(--bg-base); 
    border-top-left-radius: 32px; 
    border-top-right-radius: 32px;
    z-index: 5001; 
    padding: 24px 20px; 
    padding-top: 32px; 
    padding-bottom: calc(30px + env(safe-area-inset-bottom)); 
    transition: bottom 0.4s cubic-bezier(0.32, 0.72, 0, 1); 
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.08); 
    border-top: 1px solid var(--border); 
}

[data-theme="dark"] .gift-drawer {
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.4);
}

.gift-drawer.open { 
    bottom: 0 !important; 
}

.handle { 
    width: 48px; 
    height: 5px; 
    background: var(--border); 
    border-radius: 10px; 
    position: absolute; 
    top: 12px; 
    left: 50%; 
    transform: translateX(-50%); 
}

/* ==================================================
   2. HEADER & PANEL KOIN
================================================== */
.drawer-header { 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
    margin-bottom: 24px; 
}

.drawer-title { 
    font-weight: 800; 
    font-size: 16px; 
    color: var(--text-main);
    letter-spacing: -0.3px;
}

.coin-panel { 
    background: rgba(245, 158, 11, 0.12); 
    padding: 6px 14px; 
    border-radius: 20px; 
    display: flex; 
    align-items: center; 
    gap: 6px; 
    border: 1px solid rgba(245, 158, 11, 0.2); 
}

#user-coins { 
    color: var(--accent); 
    font-weight: 800; 
    font-size: 14px; 
}

/* ==================================================
   3. PEMILIHAN TARGET (SIAPA YANG DIKIRIM KADO)
================================================== */
.target-selection-container { 
    margin-bottom: 24px; 
}

.target-label { 
    font-size: 12px; 
    color: var(--text-muted); 
    font-weight: 700; 
    margin-bottom: 12px; 
    display: block; 
}

.target-list { 
    display: flex; 
    gap: 14px; 
    overflow-x: auto; 
    padding-bottom: 10px; 
    scrollbar-width: none; 
}

.target-user { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    gap: 8px; 
    opacity: 0.4; 
    transition: opacity 0.3s ease, transform 0.2s ease;
    cursor: pointer;
}

.target-user.selected { 
    opacity: 1; 
    transform: translateY(-2px); 
}

.target-avatar { 
    width: 50px; 
    height: 50px; 
    border-radius: 50%; 
    object-fit: cover; 
    border: 2px solid transparent;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.target-user.selected .target-avatar { 
    border-color: var(--primary); 
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2); 
}

.target-name { 
    font-size: 11px; 
    font-weight: 600; 
    color: var(--text-main);
}

/* ==================================================
   4. LIST KADO (GRID ITEM)
================================================== */
.gift-list { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 12px; 
    max-height: 280px; 
    overflow-y: auto;  
    padding-right: 4px; 
    padding-bottom: 10px; 
    scrollbar-width: none; 
}

.gift-item { 
    background: var(--panel-bg); 
    padding: 16px 8px; 
    border-radius: 20px; 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    border: 1px solid var(--border); 
    transition: transform 0.15s ease, background-color 0.2s ease, border-color 0.2s;
    cursor: pointer;
}

.gift-item:active {
    transform: scale(0.92);
    background-color: var(--empty-slot);
    border-color: var(--primary); 
}

.gift-img { 
    width: 50px; 
    height: 50px; 
    object-fit: contain; 
    margin-bottom: 10px; 
    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));
}

.gift-label { 
    font-size: 11px; 
    font-weight: 700; 
    color: var(--text-main); 
}

.gift-price { 
    font-size: 12px; 
    color: var(--accent); 
    font-weight: 800; 
    margin-top: 4px; 
    display: flex;
    align-items: center;
    gap: 2px;
}
</style>
