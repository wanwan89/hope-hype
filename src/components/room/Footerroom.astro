---
---
<footer class="footer-controls">
  <button class="btn-gift-main" onclick="toggleGiftDrawer()">
    <span class="material-icons">redeem</span>
  </button>
  <div class="input-wrapper">
    <input type="text" id="chat-input" placeholder="Ketik komentar..." autocomplete="off" onkeydown="if(event.key === 'Enter') kirimKomentar()" />
    <button class="btn-send" onclick="kirimKomentar()">
      <span class="material-icons" style="font-size: 18px; margin-left: 3px;">send</span>
    </button>
  </div>
</footer>

<style is:global>
/* ==================================================
   1. VARIABEL TAMBAHAN KHUSUS FOOTER
================================================== */
:root, [data-theme="light"] {
    --input-bg: #f1f5f9; /* Abu-abu terang agar kontras dengan panel putih */
}

[data-theme="dark"] {
    --input-bg: rgba(0, 0, 0, 0.25); /* Gelap transparan menyatu dengan panel gelap */
}

/* ==================================================
   2. FOOTER CHAT AREA
================================================== */
.footer-controls {
    position: fixed; 
    bottom: 0; left: 0; right: 0;
    padding: 10px 15px;
    /* Konsolidasi safe-area agar tidak bertumpuk / error di iOS */
    padding-bottom: calc(10px + env(safe-area-inset-bottom));
    background: var(--panel-bg); 
    border-top: 1px solid var(--border); /* Otomatis mengikuti tema */
    display: flex; 
    gap: 10px; 
    align-items: center; 
    z-index: 900; 
    transition: background-color 0.3s ease, border-top-color 0.3s ease;
}

/* ==================================================
   3. TOMBOL GIFT (AKSEN)
================================================== */
.btn-gift-main {
    width: 44px; height: 44px; 
    border-radius: 50%; 
    background: var(--accent); 
    border: none; 
    display: flex; 
    align-items: center; justify-content: center;
    color: #ffffff; 
    cursor: pointer; 
    flex-shrink: 0; 
    box-shadow: 0 4px 10px rgba(245, 158, 11, 0.3); /* Bayangan tipis estetik */
    transition: transform 0.15s ease, box-shadow 0.15s ease;
}

/* Efek tombol saat ditekan */
.btn-gift-main:active {
    transform: scale(0.92);
}

/* ==================================================
   4. WRAPPER INPUT CHAT
================================================== */
.input-wrapper {
    flex: 1; 
    display: flex; 
    align-items: center;
    background: var(--input-bg); /* Dinamis mengikuti mode */
    border: 1px solid var(--border); /* Menambah batas halus agar form tegas */
    border-radius: 24px; 
    padding: 4px 6px 4px 16px; 
    height: 44px; 
    transition: background-color 0.3s ease, border-color 0.3s ease;
}

#chat-input { 
    flex: 1; 
    background: transparent; 
    border: none; 
    color: var(--text-main); 
    font-size: 13px; 
}
#chat-input::placeholder { 
    color: var(--text-muted); 
}

/* ==================================================
   5. TOMBOL KIRIM
================================================== */
.btn-send {
    width: 34px; height: 34px; 
    border-radius: 50%; 
    background: var(--primary); 
    border: none; 
    display: flex; 
    align-items: center; justify-content: center;
    color: white; 
    cursor: pointer;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
    transition: transform 0.15s ease;
}

/* Efek tombol saat ditekan */
.btn-send:active {
    transform: scale(0.9);
}
</style>

