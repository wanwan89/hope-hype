<section id="stage-grid" class="stage-container">
  <div class="speaker-item empty">
    <div class="avatar" onclick="naikKeStage(0)">
      <span class="material-icons">add</span>
    </div>
    <span class="name-label">KOSONG</span>
  </div>
</section>

<style is:global>
/* ==================================================
   1. STAGE CONTAINER (PREMIUM LOOK)
================================================== */
.stage-container {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px 12px; 
    padding: 24px 16px;
    background: var(--panel-bg);
    /* Lengkungan bawah modern agar transisi ke chat halus */
    border-radius: 0 0 32px 32px;
    border-bottom: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    z-index: 90;
    transition: all 0.3s ease;
}

/* ==================================================
   2. SPEAKER ITEM & AVATAR (UPGRADED)
================================================== */
.speaker-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
}

.avatar {
    width: 72px; /* Sedikit diperbesar biar lebih pas di mata */
    height: 72px;
    border-radius: 50%; 
    background: var(--empty-slot);
    position: relative;
    border: 3px solid var(--panel-bg);
    display: flex; 
    align-items: center; 
    justify-content: center;
    box-shadow: 0 6px 15px rgba(0,0,0,0.08);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: pointer;
}

.avatar img { 
    width: 100%; 
    height: 100%; 
    border-radius: 50%; 
    object-fit: cover; 
}

/* Slot Kosong dengan Efek Inset (Lubang Kursi) */
.speaker-item.empty .avatar { 
    background: var(--empty-slot); 
    border: 2px dashed var(--border);
    box-shadow: inset 0 2px 8px rgba(0,0,0,0.06);
}

.speaker-item.empty .avatar .material-icons { 
    color: var(--text-muted);
    font-size: 32px; 
    opacity: 0.5;
}

/* Efek Bouncy saat Slot di-tap */
.avatar:active { 
    transform: scale(0.9); 
}

/* ==================================================
   3. EFEK SONAR (SPEAKING GLOW PREMIUM)
================================================== */
.avatar.speaking {
    border-color: var(--success) !important;
    animation: sonar-premium 2s infinite ease-out;
}

@keyframes sonar-premium {
    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5), 0 6px 15px rgba(0,0,0,0.08); }
    70% { box-shadow: 0 0 0 15px rgba(16, 185, 129, 0), 0 6px 15px rgba(0,0,0,0.08); }
    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0), 0 6px 15px rgba(0,0,0,0.08); }
}

/* ==================================================
   4. NAMA & LABEL STATUS
================================================== */
.name-label {
    margin-top: 12px;
    font-size: 13px; 
    font-weight: 800;
    color: var(--text-main);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
}

.speaker-item.empty .name-label { 
    color: var(--text-muted); 
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
}
</style>
