---
// FIX: Mengubah ViewTransitions menjadi ClientRouter sesuai standar Astro terbaru
import { ClientRouter } from 'astro:transitions'; 

interface Props {
  title: string;
  description?: string; 
}

const { 
  title, 
  description = "Hope Hype - Platform Komunitas Kreatif, Chat Global, dan Voice Room" 
} = Astro.props;
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="preload" as="image" href="/asets/png/art.webp" fetchpriority="high" />
  
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://hqetnqnvmdxdgfnnluew.supabase.co" crossorigin />

  <link 
    rel="stylesheet" 
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" 
    media="print" 
    onload="this.media='all'" 
  />
  <link 
    rel="stylesheet" 
    href="https://fonts.googleapis.com/icon?family=Material+Icons&display=swap" 
    media="print" 
    onload="this.media='all'" 
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons&display=swap" rel="stylesheet" />
  </noscript>
  
  <meta http-equiv="Content-Security-Policy" content="
    default-src 'self'; 
    script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://app.sandbox.midtrans.com https://www.gstatic.com https://www.youtube.com https://s.ytimg.com; 
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; 
    font-src 'self' data: https://fonts.gstatic.com; 
    img-src 'self' data: blob: https://res.cloudinary.com https://ui-avatars.com https://media.giphy.com https://media0.giphy.com https://media1.giphy.com https://media2.giphy.com https://media3.giphy.com https://media4.giphy.com https://i.ytimg.com https://is1-ssl.mzstatic.com https://*.mzstatic.com; 
    connect-src 'self' https://hqetnqnvmdxdgfnnluew.supabase.co wss://hqetnqnvmdxdgfnnluew.supabase.co wss://voicegrup-zxmeibkn.livekit.cloud https://api.cloudinary.com https://api.giphy.com https://app.sandbox.midtrans.com https://www.googleapis.com https://itunes.apple.com;
    frame-src 'self' https://www.youtube.com https://app.sandbox.midtrans.com;
    media-src 'self' blob: https://res.cloudinary.com https://audio-ssl.itunes.apple.com https://itunes.apple.com;
  ">

  <link rel="manifest" href="/manifest.json" />
  <link rel="apple-touch-icon" href="/asets/png/book.png" />
  <link rel="icon" type="image/png" href="/asets/png/book.png" />
  
  <script is:inline>
    // PWA & Service Worker Logic
    window.pwaPrompt = null;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      window.pwaPrompt = e;
    });
    
    if ('serviceWorker' in navigator) {
      // Pake load biasa gapapa untuk service worker (cuma butuh di awal)
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js').catch(err => console.error(err));
      });
    }

    // Anti-Copas Image UX
    document.addEventListener('contextmenu', function(e) {
      if (e.target.tagName === 'IMG') e.preventDefault();
    });

    // 🔥 FIX 2: UBAH LAZY LOAD FIREBASE KE ASTRO PAGE LOAD BIAR JALAN TIAP PINDAH HALAMAN
    document.addEventListener('astro:page-load', () => {
      // Cek biar nggak ke-load dobel-dobel sayangkuuu
      if (!document.getElementById('fb-app-script')) {
        setTimeout(() => {
          const fbApp = document.createElement('script');
          fbApp.id = 'fb-app-script';
          fbApp.src = "https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js";
          fbApp.defer = true;
          document.head.appendChild(fbApp);
          
          fbApp.onload = () => {
            const fbMsg = document.createElement('script');
            fbMsg.src = "https://www.gstatic.com/firebasejs/8.10.1/firebase-messaging.js";
            fbMsg.defer = true;
            document.head.appendChild(fbMsg);
          };
        }, 1500); // Waktunya dicepetin dikit biar gak terlalu nunggu lamaaa
      }
    });
  </script>
  
  <script>
    import { supabase } from '../lib/supabase.js';

    // 1. Bersihkan channel saat mau pindah halaman agar tidak 'nyangkut'
    document.addEventListener('astro:before-preparation', () => {
      if (supabase) {
        supabase.removeAllChannels();
        console.log("🧹 Supabase channels cleaned before navigation.");
      }
    });

    // 2. Tangani masalah Auth Lock saat halaman dimuat ulang oleh ClientRouter
    document.addEventListener('astro:page-load', async () => {
      try {
        const { data, error } = await supabase.auth.getSession();
        if (error && error.message.includes('lock')) {
          console.warn("🔐 Auth lock detected, recovering session...");
          await supabase.auth.getUser();
        }
      } catch (e) {
        console.error("Auth initialization error:", e);
      }
    });
  </script>

  <ClientRouter /> 
</head>

<body class="theme-transition">
  <main transition:animate="fade">
    <slot/>
  </main>
</body>
</html>

<style is:global>
  /* Menghilangkan kedip putih dan bikin transisi body smooth */
  body {
    background-color: #050510; /* Pastiin warna body sama kayak tema gelapnyaaa */
    margin: 0;
    padding: 0;
  }
  
  .theme-transition {
    transition: background-color 0.4s ease-in-out;
  }

  /* Ini rahasia biar efek transisi Astro makin smooth sayanggg */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.4s;
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
